te("to,from\\n")\n    for u, v in intervened_edges:\n        f.write(f"{v},{u}\\n")\n\n# 2. Sample 10k points from the intervened BN.\n# Intervention on Y: Y is set to 0.0.\n# We sample in topological order.\n\n# Topological order:\n# U is root.\n# Y, R, D, M are children of U.\n# D is child of Y.\n# M is child of R.\n# Order: U, Y, R, D, M (or similar)\n# Let\'s find a valid topological order.\ntopo_order = []\nvisited = set()\ndef get_topo(u):\n    if u in visited: return\n    for _, v in edges:\n        if v == u:\n            get_topo(_)\n    visited.add(u)\n    topo_order.append(u)\n\n# Since it\'s a small DAG, we can just manually define it or use a simple sort.\n# U -> Y, R, D, M; Y -> D; R -> M.\n# Order: U, Y, R, D, M.\ntopo_order = [\'U\', \'Y\', \'R\', \'D\', \'M\']\n\nsamples = pd.DataFrame(index=range(10000))\n\nfor node in topo_order:\n    if node == \'Y\':\n        # Intervention: Y = 0.0\n        samples[node] = 0.0\n    else:\n        params = model_params[node]\n        if params[\'type\'] == \'root\':\n            # For root nodes (except Y), we sample from the original distribution\n            # But wait, U is the only root.\n            samples[node] = np.random.normal(params[\'mean\'], params[\'std\'], 10000)\n        else:\n            # Child node: sample based on parents\n            p_vals = params[\'parents\']\n            # Y = intercept + sum(slope_i * parent_i) + noise\n            # We need the noise variance.\n            # Noise variance = Var(y - predicted_y)\n            X = df[p_vals]\n            X_with_intercept = np.column_stack([np.ones(len(X)), X])\n            coeffs, residuals, rank, s = np.linalg.lstsq(X_with_intercept, df[node], rcond=None)\n            \n            # Calculate noise std\n            predicted = X_with_intercept @ coeffs\n            noise = df[node] - predicted\n            noise_std = np.std(noise)\n            \n            # Now sample\n            parent_data = pd.DataFrame(index=range(10000))\n            for p in p_vals:\n                parent_data[p] = samples[p]\n            \n            X_new = np.column_stack([np.ones(10000), parent_data[p_vals].values])\n            new_vals = X_new @ coeffs + np.random.normal(0, noise_std, 10000)\n            samples[node] = new_vals\n\nsamples.to_csv("/app/final_bn_sample.csv", index=False)\nprint("Done sampling.")\n\nEOF\npython3 learn_and_intervene.py'})
