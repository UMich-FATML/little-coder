>> ShellSession({'command': 'cat << \'EOF\' > analyze_data.py\nimport csv\n\ndef calculate_correlation(x, y):\n    n = len(x)\n    if n == 0: return 0\n    mu_x = sum(x) / n\n    mu_y = sum(y) / n\n    num = sum((xi - mu_x) * (yi - mu_y) for xi, yi in zip(x, y))\n    den_x = sum((xi - mu_x)**2 for xi in x)\n    den_y = sum((yi - mu_y)**2 for yi in y)\n    if den_x == 0 or den_y == 0: return 0\n    return num / (den_x * den_y)**0.5\n\nwith open("/app/bn_sample_10k.csv", "r") as f:\n    reader = csv.reader(f)\n    header = next(reader)\n    data = []\n    for row in reader:\n        data.append([float(val) for val in row])\n\nn_cols = len(header)\ncorrelations = [[0.0] * n_cols for _ in range(n_cols)]\n\nfor i in range(n_cols):\n    for j in range(i + 1, n_cols):\n        col_i = [row[i] for row in data]\n        col_j = [row[j] for row in data]\n        corr = calculate_correlation(col_i, col_j)\n        correlations[i][j] = correlations[j][i] = corr\n\nprint("Correlation Matrix:")\nfor i in range(n_cols):\n    row_str = ""\n    for j in range(n_cols):\n        row_str += f"{header[j]}:{correlations[i][j]:.4f} "\n    print(row_str)\n\n# Let\'s check partial correlations (simple version: correlation of residuals)\n# To do this properly we\'d need linear regression.\n# Let\'s try a very simple linear regression to see if we can find dependencies.\n\ndef linear_regression(x, y):\n    n = len(x)\n    if n == 0: return 0, 0\n    mu_x = sum(x) / n\n    mu_y = sum(y) / n\n    num = sum((xi - mu_x) * (yi - mu_y) for xi, yi in zip(x, y))\n    den = sum((xi - mu_x)**2 for xi in x)\n    if den == 0: return 0, 0\n    slope = num / den\n    intercept = mu_y - slope * mu_x\n    return slope, intercept\n\ndef get_residuals(x, y):\n    slope, intercept = linear_regression(x, y)\n    return [yi - (slope * xi + intercept) for xi, yi in zip(x, y)]\n\nprint("\\nPartial Correlations (approximate via residuals):")\nfor i in range(n_cols):\n    for j in range(i + 1, n_cols):\n        for k in range(n_cols):\n            if k == i or k == j: continue\n            \n            col_i = [row[i] for row in data]\n            col_j = [row[j] for row in data]\n            col_k = [row[k] for row in data]\n            \n            res_i = get_residuals(col_k, col_i)\n            res_j = get_residuals(col_k, col_j)\n            \n            p_corr = calculate_correlation(res_i, res_j)\n            print(f"{header[i]} - {header[j]} | given {header[k]}: {p_corr:.4f}")\n\nEOF\npython3 analyze_data.py'})
