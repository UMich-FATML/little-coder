 to)\n        # learned_dag.csv is to,from\n        # so row[0] is to, row[1] is from\n        parents[row[0]].append(row[1])\n\n# 1. Save the edges of the intervened BN.\nintervened_edges = []\nwith open("/app/learned_dag.csv", "r") as f:\n    reader = csv.reader(f)\n    next(reader)\n    for row in reader:\n        if row[0] != \'Y\':\n            intervened_edges.append((row[1], row[0])) # (from, to)\n\nwith open("/app/intervened_dag.csv", "w") as f:\n    f.write("to,from\\n")\n    for u, v in intervened_edges:\n        f.write(f"{v},{u}\\n")\n\n# 2. Learn the BN\nmodel_params = {}\nfor i, node in enumerate(header):\n    node_parents = parents[node]\n    if not node_parents:\n        col_data = [row[i] for row in data]\n        mean = calculate_mean(col_data)\n        std = calculate_std(col_data, mean)\n        model_params[node] = {\'type\': \'root\', \'mean\': mean, \'std\': std}\n    else:\n        parent_indices = [header.index(p) for p in node_parents]\n        X = []\n        y = []\n        for row in data:\n            X_row = [1.0] + [row[idx] for idx in parent_indices]\n            X.append(X_row)\n            y.append(row[i])\n        \n        beta = linear_regression_multiple(X, y)\n        \n        # Calculate noise std\n        # predicted = X * beta\n        sum_sq_err = 0.0\n        for r in range(n_rows):\n            pred = 0.0\n            for j in range(len(beta)):\n                pred += X[r][j] * beta[j]\n            sum_sq_err += (y[r] - pred)**2\n        noise_std = math.sqrt(sum_sq_err / n_rows)\n        \n        model_params[node] = {\n            \'type\': \'child\',\n            \'parents\': node_parents,\n            \'intercept\': beta[0],\n            \'slopes\': {node_parents[j]: beta[j+1] for j in range(len(node_parents))},\n            \'noise_std\': noise_std\n        }\n\n# 3. Sample 10k points\ntopo_order = [\'U\', \'Y\', \'R\', \'D\', \'M\']\nsamples = {node: [] for node in header}\n\nfor node in topo_order:\n    if node == \'Y\':\n        samples[node] = [0.0] * 10000\n    else:\n        params = model_params[node]\n        if params[\'type\'] == \'root\':\n            samples[node] = [random.normalvariate(params[\'mean\'], params[\'std\']) for _ in range(10000)]\n        else:\n            p_names = params[\'parents\']\n            intercept = params[\'intercept\']\n            slopes = params[\'slopes\']\n            noise_std = params[\'noise_std\']\n            \n            node_samples = []\n            for _ in range(10000):\n                val = intercept\n                for p in p_names:\n                    val += slopes[p] * samples[p][_]\n                val += random.normalvariate(0, noise_std)\n                node_samples.append(val)\n            samples[node] = node_samples\n\n# Save result\nwith open("/app/final_bn_sample.csv", "w") as f:\n    f.write(",".join(header) + "\\n")\n    for i in range(10000):\n        row_vals = [samples[node][i] for node in header]\n        f.write(",".join([f"{v:.6f}" for v in row_vals]) + "\\n")\n\nprint("Done sampling.")\nEOF\npython3 learn_and_intervene.py'})
