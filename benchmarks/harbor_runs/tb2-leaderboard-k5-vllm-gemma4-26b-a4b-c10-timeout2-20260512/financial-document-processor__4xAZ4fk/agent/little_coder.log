>> ShellSession({'command': 'cat << \'EOF\' > /app/process_documents.py\nimport os\nimport shutil\nimport re\nimport csv\nimport subprocess\n\n# Note: Since we are in a terminal environment, we might not have OCR tools like Tesseract installed.\n# However, for PDF files, we can try to extract text using pdftotext if available.\n# For JPG files, we would normally need OCR. \n# Let\'s check what tools are available.\n\ndef get_text(file_path):\n    ext = os.path.splitext(file_path)[1].lower()\n    text = ""\n    if ext == \'.pdf\':\n        try:\n            # Try pdftotext\n            result = subprocess.run([\'pdftotext\', file_path, \'-\'], capture_output=True, text=True)\n            if result.returncode == 0:\n                text = result.stdout\n            else:\n                # Fallback to something else if pdftotext fails?\n                pass\n        except FileNotFoundError:\n            pass\n    elif ext == \'.jpg\' or ext == \'.jpeg\':\n        # For JPG, we\'d need OCR. Let\'s see if tesseract is available.\n        try:\n            # tesseract <input> <stdout>\n            result = subprocess.run([\'tesseract\', file_path, \'stdout\'], capture_output=True, text=True)\n            if result.returncode == 0:\n                text = result.stdout\n        except FileNotFoundError:\n            pass\n    return text\n\ndef classify_and_extract(file_path):\n    text = get_text(file_path)\n    # If text is empty, we might need to try harder or it\'s not an invoice\n    # But for this task, let\'s assume the text contains the info if it\'s an invoice.\n    \n    # Simple classification: look for invoice-like keywords\n    invoice_keywords = [\'invoice\', \'bill\', \'receipt\', \'amount due\', \'total\']\n    is_invoice = any(kw in text.lower() for kw in invoice_keywords)\n    \n    if not is_invoice:\n        return \'other\', None, None\n\n    # Extraction\n    # Total amount\n    # Look for "Total", "Amount Due", "Grand Total"\n    # Special case: If both "Total" and "Amount Due" are present with different values, use only the "Total" amount\n    \n    total_val = None\n    amount_due_val = None\n    \n    # Regex for amounts: e.g., $1,234.56 or 1234.56\n    amount_pattern = r\'(?:Total|Amount Due|Grand Total|Total:?|Amount Due:?)\\s*[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\'\n    \n    # We need to be careful with the "Total" vs "Amount Due" rule.\n    # Let\'s find all matches for Total and Amount Due.\n    \n    # Find Total\n    total_matches = re.findall(r\'(?:Total|Grand Total)\\s*[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    # Find Amount Due\n    amount_due_matches = re.findall(r\'Amount Due\\s*[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    \n    if total_matches:\n        total_val = float(total_matches[0].replace(\',\', \'\'))\n    \n    if amount_due_matches:\n        amount_due_val = float(amount_due_matches[0].replace(\',\', \'\'))\n        \n    if total_val is not None and amount_due_val is not None and total_val != amount_due_val:\n        # Use only the "Total" amount as per instructions\n        final_total = total_val\n    elif total_val is not None:\n        final_total = total_val\n    elif amount_due_val is not None:\n        final_total = amount_due_val\n    else:\n        # If we can\'t find it, maybe it\'s not an invoice or we failed to extract\n        # But if it passed classification, we try to find any amount if possible\n        # For now, let\'s assume if it\'s an invoice it must have a total.\n        final_total = 0.0\n\n    # VAT amount\n    # Look for "VAT", "Tax", "GST"\n    vat_val = 0.0\n    vat_matches = re.findall(r\'(?:VAT|Tax|GST)\\s*[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    if vat_matches:\n        vat_val = float(vat_matches[0].replace(\',\', \'\'))\n        \n    return \'invoice\', final_total, vat_val\n\ndef main():\n    docs_dir = \'/app/documents/\'\n    invoices_dir = \'/app/invoices/\'\n    other_dir = \'/app/other/\'\n    \n    files = os.listdir(docs_dir)\n    invoice_data = []\n    \n    for filename in files:\n        file_path = os.path.join(docs_dir, filename)\n        if os.path.isdir(file_path):\n            continue\n            \n        category, total, vat = classify_and_extract(file_path)\n        \n        if category == \'invoice\':\n            dest = os.path.join(invoices_dir, filename)\n            shutil.move(file_path, dest)\n            invoice_data.append({\n                \'filename\': filename,\n                \'total_amount\': total,\n                \'vat_amount\': vat\n            })\n        else:\n            dest = os.path.join(other_dir, filename)\n            shutil.move(file_path, dest)\n            \n    # Create summary.csv\n    summary_path = os.path.join(invoices_dir, \'summary.csv\')\n    \n    total_sum_amount = 0.0\n    total_sum_vat = 0.0\n    \n    with open(summary_path, \'w\', newline=\'\') as csvfile:\n        fieldnames = [\'filename\', \'total_amount\', \'vat_amount\']\n        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)\n        writer.writeheader()\n        \n        for data in invoice_data:\n            writer.writerow(data)\n            total_sum_amount += data[\'total_amount\']\n            total_sum_vat += data[\'vat_amount\']\n            \n        writer.writerow({\n            \'filename\': \'total\',\n            \'total_amount\': total_sum_amount,\n            \'vat_amount\': total_sum_vat\n        })\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/process_documents.py\n'})
