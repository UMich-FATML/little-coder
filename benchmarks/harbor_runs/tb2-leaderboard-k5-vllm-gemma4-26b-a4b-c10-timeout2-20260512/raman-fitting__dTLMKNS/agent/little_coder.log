 * (two_d_gamma**2 / ((x - two_d_x0)**2 + two_d_gamma**2)) +\n                offset)\n\n    # Initial guess\n    p0 = [g_x0_init, 20, g_amp_init - offset_init, \n          two_d_x0_init, 30, two_d_amp_init - offset_init, \n          offset_init]\n\n    # Bounds to prevent crazy values\n    # x0: [1400, 1600], [2600, 2800]\n    # gamma: [5, 100]\n    # amp: [0, max_y]\n    # offset: [min_y, max_y]\n    bounds = (\n        [1500, 5, 0, 2600, 5, 0, -np.inf],\n        [1600, 100, np.inf, 2800, 100, np.inf, np.inf]\n    )\n\n    try:\n        popt, _ = curve_fit(model, x_data, y_data, p0=p0, bounds=bounds)\n        \n        results = {\n            "G": {\n                "x0": popt[0],\n                "gamma": popt[1],\n                "amplitude": popt[2],\n                "offset": popt[6]\n            },\n            "2D": {\n                "x0": popt[3],\n                "gamma": popt[4],\n                "amplitude": popt[5],\n                "offset": popt[6]\n            }\n        }\n        \n        # Note: The task asks for offset of the peaks. \n        # Usually, in a sum of Lorentzians, they share the same offset.\n        # The prompt says "return the x0, gamma, amplitude and offset of the peaks".\n        # If they share an offset, I\'ll use the same one for both.\n        \n        with open(\'/app/results.json\', \'w\') as f:\n            json.dump(results, f, indent=2)\n        print("Success")\n    except Exception as e:\n        print(f"Error: {e}")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/fit_peaks.py'})
