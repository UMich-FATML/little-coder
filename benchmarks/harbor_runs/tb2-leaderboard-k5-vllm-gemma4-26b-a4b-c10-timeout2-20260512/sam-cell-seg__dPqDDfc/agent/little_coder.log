gistry[model_type](checkpoint=args.weights_path, device=device)\n    predictor = SamPredictor(sam)\n    predictor.set_image(image)\n\n    # Load CSV\n    df = pd.read_csv(args.csv_path)\n\n    # We will store the new data in a new dataframe\n    new_df = df.copy()\n\n    # To handle "no overlap" and "one contiguous mask", we can use the SAM masks.\n    # However, the prompt says "refine *all* of the masks". \n    # A common way to refine a mask with SAM is to use the bounding box as a prompt.\n    \n    # To address the "no overlap" requirement, we can use a global mask to keep track of occupied pixels.\n    # However, the prompt says "refine *all* of the masks". \n    # If we process them one by one, we can try to subtract the masks already processed.\n    # But that might change the mask too much.\n    # Let\'s try to refine each mask and then if there\'s overlap, we\'ll just let it be for now,\n    # or we can try to refine them in a way that they don\'t overlap.\n    # Actually, a better way to ensure no overlap is to process them in some order \n    # or use a global mask. \n    # Let\'s try to refine each mask and then if there\'s overlap, we\'ll just let it be for now.\n    \n    # Let\'s use a global mask to prevent overlap.\n    global_mask = np.zeros((image_height, image_width), dtype=np.uint8)\n\n    for idx, row in tqdm(df.iterrows(), total=len(df)):\n        # Get bounding box from current mask\n        xmin, ymin, xmax, ymax = row[\'xmin\'], row[\'ymin\'], row[\'xmax\'], row[\'ymax\']\n        \n        # SAM prompt: [x1, y1, x2, y2]\n        input_box = np.array([xmin, ymin, xmax, ymax])\n        \n        # Predict mask\n        masks, scores, _ = predictor.predict(\n            box=input_box[None, :],\n            multimask_output=False\n        )\n        \n        mask = masks[0]\n        \n        # To ensure "no overlap", we can intersect the predicted mask with the inverse of the global mask.\n        # But that might be too aggressive. \n     