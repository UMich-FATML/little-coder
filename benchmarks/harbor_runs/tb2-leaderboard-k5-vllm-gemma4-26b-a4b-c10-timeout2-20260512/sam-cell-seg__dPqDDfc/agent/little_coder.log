gistry[model_type](checkpoint=args.weights_path, device=device)\n    predictor = SamPredictor(sam)\n    predictor.set_image(image)\n\n    # Load CSV\n    df = pd.read_csv(args.csv_path)\n\n    # We will store the new data in a new dataframe\n    new_df = df.copy()\n\n    # To address the "no overlap" requirement, we can use a global mask to keep track of occupied pixels.\n    global_mask = np.zeros((image_height, image_width), dtype=np.uint8)\n\n    for idx, row in tqdm(df.iterrows(), total=len(df)):\n        # Get bounding box from current mask\n        xmin, ymin, xmax, ymax = row[\'xmin\'], row[\'ymin\'], row[\'xmax\'], row[\'ymax\']\n        \n        # SAM prompt: [x1, y1, x2, y2]\n        input_box = np.array([xmin, ymin, xmax, ymax])\n        \n        # Predict mask\n        masks, scores, _ = predictor.predict(\n            box=input_box[None, :],\n            multimask_output=False\n        )\n        \n        mask = masks[0]\n        \n        # To ensure "no overlap", we can intersect the predicted mask with the inverse of the global mask.\n        mask = mask & (global_mask == 0)\n        \n        # Update global mask\n        global_mask[mask > 0] = 1\n        \n        # Get polyline\n        coords_x_str, coords_y_str = get_polyline_from_mask(mask)\n        \n        # Update the dataframe\n        if coords_x_str and coords_y_str:\n            cx = np.array([float(x) for x in coords_x_str.split(\',\')])\n            cy = np.array([float(y) for y in coords_y_str.split(\',\')])\n            \n            new_df.at[idx, \'xmin\'] = cx.min()\n            new_df.at[idx, \'ymin\'] = cy.min()\n            new_df.at[idx, \'xmax\'] = cx.max()\n            new_df.at[idx, \'ymax\'] = cy.max()\n            new_df.at[idx, \'coords_x\'] = coords_x_str\n            new_df.at[idx, \'coords_y\'] = coords_y_str\n            new_df.at[idx, \'type\'] = \'polyline\'\n        else:\n            # If no contour found, keep original or handle error\n            pass\n\n 