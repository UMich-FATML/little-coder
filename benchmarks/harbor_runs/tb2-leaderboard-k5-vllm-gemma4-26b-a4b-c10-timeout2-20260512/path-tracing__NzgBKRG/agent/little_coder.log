>> ShellSession({'command': 'cat << \'EOF\' > analyze_ppm.py\nimport sys\n\ndef analyze_ppm(filename):\n    with open(filename, \'r\') as f:\n        header = f.readline().strip()\n        if header != \'P3\':\n            print("Not P3")\n            return\n        dims = f.readline().split()\n        w, h = int(dims[0]), int(dims[1])\n        max_val = int(f.readline().strip())\n        \n        # Read all numbers\n        data = []\n        for line in f:\n            data.extend(map(int, line.split()))\n            \n    print(f"W: {w}, H: {h}, Max: {max_val}")\n    print(f"Total numbers: {len(data)}")\n    \n    # Check if it\'s a simple gradient or pattern\n    # Sample some pixels\n    pixels = []\n    for i in range(0, len(data), 3):\n        pixels.append((data[i], data[i+1], data[i+2]))\n    \n    # Print first 10 pixels\n    print("First 10 pixels:")\n    for p in pixels[:10]:\n        print(p)\n        \n    # Print some pixels from the middle\n    mid = len(pixels) // 2\n    print("Middle 10 pixels:")\n    for p in pixels[mid:mid+10]:\n        print(p)\n\n    # Check for patterns\n    # Calculate variance of R, G, B separately\n    r = [p[0] for p in pixels]\n    g = [p[1] for p in pixels]\n    b = [p[2] for p in pixels]\n    \n    def var(arr):\n        if not arr: return 0\n        m = sum(arr)/len(arr)\n        return sum((x-m)**2 for x in arr)/len(arr)\n\n    print(f"Var R: {var(r)}, Var G: {var(g)}, Var B: {var(b)}")\n\nanalyze_ppm(\'/app/image.ppm\')\nEOF\npython3 analyze_ppm.py\n'})
