e output sequence at that site.\n                        # The output sequence at that site is: anneal_after + mut_seq + (something)\n                        # No, the rev primer should be the reverse complement of (anneal_after + mut_seq).\n                        # Let\'s check.\n                        # If we use Fwd: anneal_before + mut_seq\n                        # and Rev: rev_comp(anneal_after + mut_seq)\n                        # The primers will overlap at the mutation.\n                        \n                        fwd_primer = anneal_before + mut_seq\n                        rev_primer = rev_comp(anneal_after + mut_seq)\n                        \n                        best_fwd = fwd_primer\n                        best_rev = rev_primer\n                        break\n            if best_fwd:\n                break\n                \n    if best_fwd and best_rev:\n        with open(\'primers.fasta\', \'w\') as f:\n            f.write(">primer_pair_1\\n")\n            f.write(f"{best_fwd}\\n")\n            f.write(f"{best_rev}\\n")\n        print("Success")\n    else:\n        print("Failed to find primers")\n\nsolve()\nEOF\npython3 solution.py\n'})
