>> ShellSession({'command': 'cat <<EOF > cli_tool.py\nimport sys\nimport json\nimport torch\nimport torch.nn as nn\nfrom PIL import Image\nimport numpy as np\n\nclass MnistModel(nn.Module):\n    def __init__(\n        self,\n        input_dim: int,\n        hidden_dim: int,\n        num_classes: int,\n    ) -> torch.nn.Module:\n        super().__init__()\n        self.input_layer = nn.Linear(input_dim, hidden_dim)\n        self.hidden_layer = nn.Linear(hidden_dim, hidden_dim)\n        self.output_layer = nn.Linear(hidden_dim, num_classes)\n        self.activation = nn.ReLU()\n\n    def forward(self, x):\n        x = self.input_layer(x)\n        x = self.activation(x)\n        x = self.hidden_layer(x)\n        x = self.activation(x)\n        x = self.output_layer(x)\n        return x\n\ndef main():\n    if len(sys.argv) != 3:\n        sys.exit(1)\n\n    weights_path = sys.argv[1]\n    image_path = sys.argv[2]\n\n    # Load weights\n    with open(weights_path, \'r\') as f:\n        weights_dict = json.load(f)\n\n    # Initialize model\n    input_dim = 784\n    hidden_dim = 128\n    num_classes = 10\n    model = MnistModel(input_dim, hidden_dim, num_classes)\n\n    # Load weights into model\n    # The weights in JSON are lists, convert them to torch tensors\n    new_state_dict = {}\n    for name, value in weights_dict.items():\n        new_state_dict[name] = torch.tensor(value)\n    \n    model.load_state_dict(new_state_dict)\n    model.eval()\n\n    # Load image\n    img = Image.open(image_path).convert(\'L\')\n    img = img.resize((28, 28))\n    img_array = np.array(img).astype(np.float32) / 255.0\n    img_tensor = torch.from_numpy(img_array).view(1, 1, 28, 28).flatten().view(1, 784)\n\n    # Inference\n    with torch.no_grad():\n        output = model(img_tensor)\n        prediction = torch.argmax(output, dim=1).item()\n\n    print(prediction)\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 cli_tool.py weights.json image.png > prediction.txt\ncat prediction.txt'})
