ints) - 1\n    if (n_segments == 0) {\n      stop("Not enough points to form an envelope.")\n    }\n    \n    segment_probs <- numeric(n_segments)\n    \n    integrate_segment <- function(x1, x2, y1, y2) {\n      if (abs(y1 - y2) < 1e-12) {\n        return(exp(y1) * (x2 - x1))\n      } else {\n        m <- (y2 - y1) / (x2 - x1)\n        return(exp(y1) * (exp(y2 - y1) - 1) / (y2 - y1))\n      }\n    }\n\n    for (j in 1:n_segments) {\n      segment_probs[j] <- integrate_segment(x_points[j], x_points[j+1], y_points[j], y_points[j+1])\n    }\n    \n    cum_probs <- c(0, cumsum(segment_probs))\n    total_prob <- cum_probs[length(cum_probs)]\n    \n    if (is.na(total_prob) || total_prob <= 0) {\n       stop("Envelope integration failed. Target density might be too low or non-log-concave.")\n    }\n    \n    u <- runif(1) * total_prob\n    seg_idx <- which(cum_probs >= u)[1] - 1\n    if (seg_idx <= 0) seg_idx <- 1\n    if (seg_idx > n_segments) seg_idx <- n_segments\n    \n    x_j <- x_points[seg_idx]\n    x_next <- x_points[seg_idx+1]\n    y_j <- y_points[seg_idx]\n    y_next <- y_points[seg_idx+1]\n    \n    u_seg <- runif(1)\n    if (abs(y_j - y_next) < 1e-12) {\n      val <- x_j + u_seg * (x_next - x_j)\n    } else {\n      m <- (y_next - y_j) / (x_next - x_j)\n      val <- x_j + log(u_seg * (exp(y_next - y_j) - 1) + 1) / m\n    }\n    \n    if (val < lower_bound || val > upper_bound) {\n       i <- i - 1\n       next\n    }\n    \n    if (abs(y_j - y_next) < 1e-12) {\n      L_val <- y_j\n    } else {\n      m <- (y_next - y_j) / (x_next - x_j)\n      L_val <- y_j + m * (val - x_j)\n    }\n    \n    log_dens_val <- target_log_density(val)\n    \n    if (log_dens_val > L_val + 1e-9) {\n      stop("Non-log-concave density detected during sampling.")\n    }\n    \n    if (runif(1) <= exp(log_dens_val - L_val)) {\n      samples[i] <- val\n      x_points <- c(x_points, val)\n      x_points <- unique(sort(x_points))\n    } else {\n      i <- i - 1\n    }\n  }\n  \n  return(samples)\n}\n\n#\' Test function for ARS\n#\'\n#\' @return Prints test results.\ntest <- function() {\n  cat("Starting ARS tests...\\n")\n  \n  # Test 1: Normal Distribution\n  cat("TEST_NORMAL: Running...\\n")\n  target_norm <- function(x) { -0.5 * x^2 } \n  n <- 1000\n  set.seed(123)\n  samples_norm <- ars(target_norm, n_samples = n)\n  \n  mean_norm <- mean(samples_norm)\n  sd_norm <- sd(samples_norm)\n  \n  if (abs(mean_norm - 0) < 0.15 && abs(sd_norm - 1) < 0.15) {\n    cat(sprintf("TEST_NORMAL: PASS (mean=%.4f, sd=%.4f)\\n", mean_norm, sd_norm))\n  } else {\n    cat(sprintf("TEST_NORMAL: FAIL (mean=%.4f, sd=%.4f)\\n", mean_norm, sd_norm))\n  }\n  write.table(samples_norm, "/app/normal_samples.txt", row.names=FALSE, col.names=FALSE)\n\n  # Test 2: Exponential Distribution\n  cat("TEST_EXPONENTIAL: Running...\\n")\n  target_exp <- function(x) { -x }\n  n <- 1000\n  set.seed(123)\n  samples_exp <- ars(target_exp, n_samples = n, lower_bound = 0)\n  \n  mean_exp <- mean(samples_exp)\n  sd_exp <- sd(samples_exp)\n  \n  if (abs(mean_exp - 1) < 0.15 && abs(sd_exp - 1) < 0.15) {\n    cat(sprintf("TEST_EXPONENTIAL: PASS (mean=%.4f, sd=%.4f)\\n", mean_exp, sd_exp))\n  } else {\n    cat(sprintf("TEST_EXPONENTIAL: FAIL (mean=%.4f, sd=%.4f)\\n", mean_exp, sd_exp))\n  }\n  write.table(samples_exp, "/app/exponential_samples.txt", row.names=FALSE, col.names=FALSE)\n\n  # Test 3: Input Validation\n  cat("TEST_VALIDATION: Running...\\n")\n  passed_val <- FALSE\n  tryCatch({\n    ars(target_norm, n_samples = -1)\n    cat("TEST_VALIDATION: FAIL (did not catch negative n_samples)\\n")\n  }, error = function(e) {\n    cat("TEST_VALIDATION: PASS (caught negative n_samples)\\n")\n    passed_val <<- TRUE\n  })\n  \n  # Test 4: Non-log-concave detection\n  cat("TEST_NON_LOG_CONCAVE: Running...\\n")\n  target_bimodal <- function(x) { - (x^2 - 5)^2 }\n  passed_non_log <- FALSE\n  tryCatch({\n    ars(target_bimodal, n_samples = 100)\n    cat("TEST_NON_LOG_CONCAVE: FAIL (did not catch non-log-concave)\\n")\n  }, error = function(e) {\n    if (grepl("Non-log-concave", e$message)) {\n      cat("TEST_NON_LOG_CONCAVE: PASS (caught non-log-concave)\\n")\n      passed_non_log <<- TRUE\n    } else {\n      cat(sprintf("TEST_NON_LOG_CONCAVE: FAIL (wrong error: %s)\\n", e$message))\n    }\n  })\n}\n\nif (!interactive()) {\n  test()\n}\nEOF\n'})
