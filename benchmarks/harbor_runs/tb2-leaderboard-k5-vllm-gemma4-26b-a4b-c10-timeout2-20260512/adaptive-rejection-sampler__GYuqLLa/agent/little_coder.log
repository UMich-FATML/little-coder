>> ShellSession({'command': 'cat << \'EOF\' > /app/ars.R\n# Adaptive Rejection Sampler (ARS) implementation\n# Based on Gilks and Wild (1992)\n\n#\' Adaptive Rejection Sampler\n#\'\n#\' @param target_log_density A function that returns the log-density of the target distribution.\n#\'                           It should be vectorized.\n#\' @param n_samples Integer. Number of samples to generate.\n#\' @param lower_bound Numeric. Lower bound of the support. Use -Inf if unknown.\n#\' @param upper_bound Numeric. Upper bound of the support. Use Inf if unknown.\n#\' @return A vector of samples.\nars <- function(target_log_density, n_samples, lower_bound = -Inf, upper_bound = Inf) {\n  # 1. Input Validation\n  if (!is.function(target_log_density)) {\n    stop("target_log_density must be a function.")\n  }\n  if (!is.numeric(n_samples) || n_samples <= 0 || n_samples %% 1 != 0) {\n    stop("n_samples must be a positive integer.")\n  }\n  if (lower_bound >= upper_bound) {\n    stop("lower_bound must be less than upper_bound.")\n  }\n\n  # Internal state for the envelope\n  # We maintain a set of points that define the log-concave envelope\n  # For simplicity in this implementation, we\'ll use a growing set of points\n  # to construct the piecewise linear envelope of the log-density.\n  \n  samples <- numeric(n_samples)\n  \n  # Initial points to start the envelope\n  # We need at least two points to form a line.\n  # If bounds are finite, we can use them. If not, we need to find some points.\n  \n  # Helper to find initial points if bounds are infinite\n  find_initial_points <- function(log_dens, lb, ub) {\n    # Try to find points with reasonable density\n    # This is a heuristic.\n    pts <- c()\n    if (lb > -Inf) pts <- c(pts, lb)\n    if (ub < Inf) pts <- c(pts, ub)\n    \n    # If still not enough points, try searching around 0\n    if (length(pts) < 2) {\n      search_pts <- c(-1, 0, 1)\n      for (p in search_pts) {\n        if (p > lb && p < ub) pts <- c(pts, p)\n        if (length(pts) >= 2) break\n      }\n    }\n    \n    # If still not enough, we might have a problem or need more sophisticated search\n    if (length(pts) < 2) {\n      # Fallback: just try to find any two points in the range\n      # This is risky but for standard distributions it usually works\n      if (lb == -Inf && ub == Inf) {\n        pts <- c(-1, 1)\n      } else if (lb == -Inf) {\n        pts <- c(0, 1)\n      } else if (ub == Inf) {\n        pts <- c(-1, 0)\n      }\n    }\n    return(unique(pts))\n  }\n\n  # Initial points for the envelope\n  x_points <- find_initial_points(target_log_density, lower_bound, upper_bound)\n  \n  # Check log-concavity (heuristic: check if the envelope is always above the density)\n  # In a real ARS, we\'d check if the new point violates log-concavity.\n  # For this task, we\'ll implement the core logic.\n\n  for (i in 1:n_samples) {\n    # 1. Construct the envelope (piecewise linear in log-space)\n    # The envelope is the upper hull of the points (x_points, log_dens(x_points))\n    \n    # Sort points\n    x_points <- sort(x_points)\n    y_points <- target_log_density(x_points)\n    \n    # Check for log-concavity: \n    # A simple check is to see if the density at any point is higher than the envelope.\n    # However, the envelope is constructed from points, so it\'s always >= density at those points.\n    # A more robust check would be to sample a few points and see.\n    \n    # 2. Sample from the envelope\n    # The envelope is a piecewise linear function in log-space.\n    # This corresponds to a piecewise exponential distribution.\n    \n    # Calculate weights for each segment\n    # Segment j is between x_points[j] and x_points[j+1]\n    # Log-density in segment j: L(x) = y_j + (y_{j+1} - y_j) * (x - x_j) / (x_{j+1} - x_j)\n    # This is an exponential-type distribution on [x_j, x_{j+1}]\n    \n    n_segments <- length(x_points) - 1\n    if (n_segments == 0) {\n      # This shouldn\'t happen if find_initial_points works\n      stop("Not enough points to form an envelope.")\n    }\n    \n    segment_probs <- numeric(n_segments)\n    \n    # Function to integrate exp(L(x)) over [a, b]\n    # Integral of exp(m*x + c) dx = (1/m) * exp(m*x + c)\n    # where m = (y_{j+1} - y_j) / (x_{j+1} - x_j)\n    # and c = y_j - m * x_j\n    \n    integrate_segment <- function(x1, x2, y1, y2) {\n      if (abs(y1 - y2) < 1e-12) {\n        # Constant log-density: uniform distribution\n        return(exp(y1) * (x2 - x1))\n      } else {\n        m <- (y2 - y1) / (x2 - x1)\n        # Integral is [exp(m*x + c) / m] from x1 to x2\n        # c = y1 - m*x1\n        # Integral = (exp(y2) - exp(y1)) / m\n        # To avoid overflow, use: exp(y1) * (exp(m*(x2-x1)) - 1) / (m*(x2-x1))\n        # Wait, m*(x2-x1) = y2-y1.\n        # So: exp(y1) * (exp(y2-y1) - 1) / (y2-y1)\n        return(exp(y1) * (exp(y2 - y1) - 1) / (y2 - y1))\n      }\n    }\n\n    for (j in 1:n_segments) {\n      segment_probs[j] <- integrate_segment(x_points[j], x_points[j+1], y_points[j], y_points[j+1])\n    }\n    \n    # Sample a segment\n    # Use cumulative sum to pick a segment\n    cum_probs <- c(0, cumsum(segment_probs))\n    total_prob <- cum_probs[length(cum_probs)]\n    \n    # If total_prob is extremely small or NaN, something is wrong\n    if (is.na(total_prob) || total_prob <= 0) {\n       stop("Envelope integration failed. Target density might be too low or non-log-concave.")\n    }\n    \n    u <- runif(1) * total_prob\n    seg_idx <- which(cum_probs >= u)[1] - 1\n    if (seg_idx == 0) seg_idx <- 1 # safety\n    if (seg_idx > n_segments) seg_idx <- n_segments\n    \n    # Sample within the segment [x_j, x_{j+1}]\n    # The density is exp(m*x + c)\n    # CDF F(x) = Integral_{x_j}^{x} exp(m*t + c) dt / Integral_{x_j}^{x_{j+1}} exp(m*t + c) dt\n    # F(x) = (exp(m*x + c) - exp(m*x_j + c)) / (exp(m*x_{j+1} + c) - exp(m*x_j + c))\n    # F(x) = (exp(m*(x - x_j)) - 1) / (exp(m*(x_{j+1} - x_j)) - 1)\n    \n    x_j <- x_points[seg_idx]\n    x_next <- x_points[seg_idx+1]\n    y_j <- y_points[seg_idx]\n    y_next <- y_points[seg_idx+1]\n    \n    u_seg <- runif(1)\n    if (abs(y_j - y_next) < 1e-12) {\n      # Uniform\n      val <- x_j + u_seg * (x_next - x_j)\n    } else {\n      m <- (y_next - y_j) / (x_next - x_j)\n      # u_seg = (exp(m*(val - x_j)) - 1) / (exp(m*(x_next - x_j)) - 1)\n      # exp(m*(val - x_j)) = u_seg * (exp(m*(x_next - x_j)) - 1) + 1\n      # m*(val - x_j) = log(u_seg * (exp(y_next - y_j) - 1) + 1)\n      val <- x_j + log(u_seg * (exp(y_next - y_j) - 1) + 1) / m\n    }\n    \n    # 3. Acceptance/Rejection\n    # Check if val is within bounds\n    if (val < lower_bound || val > upper_bound) {\n       # This shouldn\'t happen if the envelope is correct, but for safety:\n       # We\'ll just retry this sample\n       i <- i - 1\n       next\n    }\n    \n    # Acceptance probability: p = exp(log_dens(val) - L(val))\n    # where L(val) is the envelope value at val.\n    # Since we sampled from the envelope, L(val) is the linear interpolation.\n    \n    # Calculate L(val)\n    if (abs(y_j - y_next) < 1e-12) {\n      L_val <- y_j\n    } else {\n      m <- (y_next - y_j) / (x_next - x_j)\n      L_val <- y_j + m * (val - x_j)\n    }\n    \n    log_dens_val <- target_log_density(val)\n    \n    # Check for log-concavity: if log_dens_val > L_val, it\'s not log-concave\n    # (within numerical precision)\n    if (log_dens_val > L_val + 1e-9) {\n      stop("Non-log-concave density detected during sampling.")\n    }\n    \n    if (runif(1) <= exp(log_dens_val - L_val)) {\n      samples[i] <- val\n      \n      # 4. Update envelope points\n      # Add the new point to the set of points defining the envelope\n      # and keep only the points that are on the upper hull.\n      # For simplicity, we just add it and sort. \n      # A more efficient way would be to maintain the hull.\n      x_points <- c(x_points, val)\n      # To keep it efficient and prevent too many points, we could prune,\n      # but for small n_samples it\'s fine.\n      # However, we must ensure we don\'t have duplicate x_points.\n      x_points <- unique(sort(x_points))\n      # Re-calculate y_points is handled by the next iteration.\n    } else {\n      # Reject\n      i <- i - 1\n    }\n  }\n  \n  return(samples)\n}\n\n#\' Test function for ARS\n#\'\n#\' @return Prints test results.\ntest <- function() {\n  cat("Starting ARS tests...\\n")\n  \n  # Test 1: Normal Distribution\n  cat("TEST_NORMAL: Running...\\n")\n  target_norm <- function(x) { -0.5 * x^2 } # log(dnorm(x)) is -0.5*x^2 + const\n  n <- 1000\n  set.seed(123)\n  samples_norm <- ars(target_norm, n_samples = n)\n  \n  mean_norm <- mean(samples_norm)\n  sd_norm <- sd(samples_norm)\n  \n  # Expected: mean=0, sd=1\n  # We use a tolerance for stochastic results\n  if (abs(mean_norm - 0) < 0.15 && abs(sd_norm - 1) < 0.15) {\n    cat(sprintf("TEST_NORMAL: PASS (mean=%.4f, sd=%.4f)\\n", mean_norm, sd_norm))\n  } else {\n    cat(sprintf("TEST_NORMAL: FAIL (mean=%.4f, sd=%.4f)\\n", mean_norm, sd_norm))\n  }\n  \n  # Save normal samples\n  write.table(samples_norm, "/app/normal_samples.txt", row.names=FALSE, col.names=FALSE)\n\n  # Test 2: Exponential Distribution\n  cat("TEST_EXPONENTIAL: Running...\\n")\n  # log(dexp(x, rate=1)) = -x for x > 0\n  target_exp <- function(x) { -x }\n  # We need to provide the domain [0, Inf)\n  n <- 1000\n  set.seed(123)\n  samples_exp <- ars(target_exp, n_samples = n, lower_bound = 0)\n  \n  mean_exp <- mean(samples_exp)\n  sd_exp <- sd(samples_exp)\n  \n  # Expected: mean=1, sd=1\n  if (abs(mean_exp - 1) < 0.15 && abs(sd_exp - 1) < 0.15) {\n    cat(sprintf("TEST_EXPONENTIAL: PASS (mean=%.4f, sd=%.4f)\\n", mean_exp, sd_exp))\n  } else {\n    cat(sprintf("TEST_EXPONENTIAL: FAIL (mean=%.4f, sd=%.4f)\\n", mean_exp, sd_exp))\n  }\n  \n  # Save exponential samples\n  write.table(samples_exp, "/app/exponential_samples.txt", row.names=FALSE, col.names=FALSE)\n\n  # Test 3: Input Validation\n  cat("TEST_VALIDATION: Running...\\n")\n  passed_val <- FALSE\n  tryCatch({\n    ars(target_norm, n_samples = -1)\n    cat("TEST_VALIDATION: FAIL (did not catch negative n_samples)\\n")\n  }, error = function(e) {\n    cat("TEST_VALIDATION: PASS (caught negative n_samples)\\n")\n    passed_val <<- TRUE\n  })\n  \n  # Test 4: Non-log-concave detection\n  cat("TEST_NON_LOG_CONCAVE: Running...\\n")\n  # A bimodal distribution is not log-concave\n  # log(density) = -(x^2 - 5)^2\n  target_bimodal <- function(x) { - (x^2 - 5)^2 }\n  passed_non_log <- FALSE\n  tryCatch({\n    ars(target_bimodal, n_samples = 100)\n    cat("TEST_NON_LOG_CONCAVE: FAIL (did not catch non-log-concave)\\n")\n  }, error = function(e) {\n    if (grepl("Non-log-concave", e$message)) {\n      cat("TEST_NON_LOG_CONCAVE: PASS (caught non-log-concave)\\n")\n      passed_non_log <<- TRUE\n    } else {\n      cat(sprintf("TEST_NON_LOG_CONCAVE: FAIL (wrong error: %s)\\n", e$message))\n    }\n  })\n}\n\n# If run as a script, execute test\nif (!interactive()) {\n  test()\n}\nEOF\n'})
