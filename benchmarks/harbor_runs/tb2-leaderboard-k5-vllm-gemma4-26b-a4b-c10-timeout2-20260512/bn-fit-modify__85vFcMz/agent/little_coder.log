>> ShellSession({'command': 'python3 -c \'\nimport csv\nimport numpy as np\n\nwith open("/app/bn_sample_10k.csv", "r") as f:\n    lines = f.readlines()\n\nheader = [h.strip("\\"") for h in lines[0].strip().split(",")]\ndata = []\nfor line in lines[1:]:\n    data.append([float(val) for val in line.strip().split(",")])\n\ndef get_corr(x, y):\n    n = len(x)\n    mu_x = sum(x) / n\n    mu_y = sum(y) / n\n    num = sum((xi - mu_x) * (yi - mu_y) for xi, yi in zip(x, y))\n    den = (sum((xi - mu_x)**2 for xi in x) * sum((yi - mu_y)**2 for yi in y))**0.5\n    return num / den if den != 0 else 0\n\n# Check partial correlations to find structure\n# For a DAG, if X -> Y -> Z, then corr(X,Z | Y) should be 0.\n# We can use the formula for partial correlation:\n# rho(X,Z | Y) = (rho(X,Z) - rho(X,Y)*rho(Z,Y)) / sqrt((1-rho(X,Y)^2)(1-rho(Z,Y)^2))\n\ndef partial_corr(i, j, k, header, data):\n    col_i = [row[i] for row in data]\n    col_j = [row[j] for row in data]\n    col_k = [row[k] for row in data]\n    \n    r_ij = get_corr(col_i, col_j)\n    r_jk = get_corr(col_j, col_k)\n    r_ik = get_corr(col_i, col_k)\n    \n    num = r_ik - r_ij * r_jk\n    den = ((1 - r_ij**2) * (1 - r_jk**2))**0.5\n    return num / den if den != 0 else 0\n\nprint("Partial Correlations:")\nfor i in range(len(header)):\n    for j in range(i + 1, len(header)):\n        for k in range(len(header)):\n            if k == i or k == j: continue\n            p = partial_corr(i, j, k, header, data)\n            print(f"P({header[i]},{header[j]} | {header[k]}): {p:.4f}")\n\''})
