>> ShellSession({'command': 'cat <<EOF > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return None\n\n    num_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    \n    # We will track the vertical position (y-coordinate) of the athlete.\n    # Since the camera is stationary, we can use a simple background subtraction \n    # or frame differencing to find the athlete.\n    \n    # Let\'s use a more robust approach: \n    # 1. Detect motion using frame differencing.\n    # 2. Find the centroid of the motion.\n    # 3. Track the y-coordinate of this centroid.\n    \n    prev_gray = None\n    y_coords = []\n    frame_indices = []\n    \n    for i in range(num_frames):\n        ret, frame = cap.read()\n        if not ret:\n            break\n        \n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        gray = cv2.GaussianBlur(gray, (5, 5), 0)\n        \n        if prev_gray is not None:\n            diff = cv2.absdiff(gray, prev_gray)\n            _, thresh = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)\n            \n            # Clean up noise\n            kernel = np.ones((5, 5), np.uint8)\n            thresh = cv2.dilate(thresh, kernel, iterations=1)\n            \n            M = cv2.moments(thresh)\n            if M["m00"] > 500:\n                cy = int(M["m01"] / M["m00"])\n                y_coords.append(cy)\n                frame_indices.append(i)\n        \n        prev_gray = gray\n    \n    cap.release()\n    \n    if not y_coords:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # The jump is a period where the y-coordinate is significantly lower (higher in frame).\n    # Let\'s find the baseline y-coordinate (running level).\n    # We\'ll use the median of all y-coordinates, but we must exclude the jump itself.\n    # A simple way to exclude the jump is to look at the y-coordinates that are NOT the minimum.\n    \n    # Let\'s find the minimum y (highest point)\n    min_y = min(y_coords)\n    min_idx_in_list = y_coords.index(min_y)\n    \n    # Let\'s estimate the baseline by taking the median of y-coordinates \n    # that are not in the immediate vicinity of the minimum y.\n    # We\'ll take a window of 20 frames around the min_y_frame.\n    \n    # Find the actual frame index of the minimum y\n    min_frame_idx = frame_indices[min_idx_in_list]\n    \n    baseline_samples = []\n    for idx, f_idx in zip(y_coords, frame_indices):\n        if abs(f_idx - min_frame_idx) > 20:\n            baseline_samples.append(idx)\n            \n    if not baseline_samples:\n        baseline_y = np.median(y_coords)\n    else:\n        baseline_y = np.median(baseline_samples)\n\n    # Now, the jump is the period where y < baseline_y - threshold.\n    threshold = h * 0.05\n    jump_indices = [i for i, y in enumerate(y_coords) if y < baseline_y - threshold]\n    \n    if jump_indices:\n        # The takeoff is the first frame of the jump.\n        # The landing is the last frame of the jump.\n        takeoff_frame = frame_indices[jump_indices[0]]\n        land_frame = frame_indices[jump_indices[-1]]\n    else:\n        # Fallback\n        takeoff_frame = max(0, min_frame_idx - 5)\n        land_frame = min(num_frames - 1, min_frame_idx + 5)\n\n    return {\n        "jump_takeoff_frame_number": takeoff_frame,\n        "jump_land_frame_number": land_frame\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    results = analyze_video(video_path)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml'})
