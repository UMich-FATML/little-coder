>> ShellSession({'command': 'cat <<EOF > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return None\n\n    num_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    \n    centroids = []\n    frame_idx = 0\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        \n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        # Use a more robust thresholding or background subtraction\n        # Since the camera is stationary, we can use the first frame as background\n        # But the first frame might have some noise.\n        # Let\'s use a simple threshold first.\n        _, thresh = cv2.threshold(gray, 100, 255, cv2.THRESH_BINARY)\n        \n        M = cv2.moments(thresh)\n        if M["m00"] > 100: # Avoid noise\n            cy = int(M["m01"] / M["m00"])\n            centroids.append((frame_idx, cy))\n        \n        frame_idx += 1\n    \n    cap.release()\n    \n    if not centroids:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # The jump is when the centroid moves UP (lower y).\n    # Let\'s find the baseline y.\n    # We\'ll use the median of the first 15 valid centroids as the baseline.\n    baseline_y_samples = [c[1] for c in centroids[:15]]\n    if not baseline_y_samples:\n        baseline_y = h // 2\n    else:\n        baseline_y = np.median(baseline_y_samples)\n\n    # A jump is a period where cy is significantly less than baseline_y.\n    # Let\'s find the frames where cy < baseline_y - threshold\n    threshold = h * 0.03\n    jump_frames = [idx for idx, cy in centroids if cy < baseline_y - threshold]\n    \n    if jump_frames:\n        takeoff_frame = jump_frames[0]\n        land_frame = jump_frames[-1]\n    else:\n        # If no jump detected, maybe the threshold is too high.\n        # Let\'s try to find the minimum y and its neighbors.\n        min_y_idx = 0\n        min_y_val = float(\'inf\')\n        for i in range(len(centroids)):\n            if centroids[i][1] < min_y_val:\n                min_y_val = centroids[i][1]\n                min_y_idx = i\n        \n        # If we found a minimum, let\'s assume the jump is around it.\n        # This is a very crude fallback.\n        takeoff_frame = max(0, centroids[min_y_idx][0] - 5)\n        land_frame = min(num_frames - 1, centroids[min_y_idx][0] + 5)\n\n    return {\n        "jump_takeoff_frame_number": takeoff_frame,\n        "jump_land_frame_number": land_frame\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    results = analyze_video(video_path)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml'})
