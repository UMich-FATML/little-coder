>> ShellSession({'command': 'cat <<EOF > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return None\n\n    num_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    \n    # We\'ll use a simple background subtraction by taking the first frame \n    # as a reference, but since the first frame has no runner, we\'ll \n    # use a more robust approach: frame differencing between consecutive frames.\n    \n    prev_gray = None\n    centroids = []\n    \n    frame_idx = 0\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        \n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        \n        if prev_gray is not None:\n            # Frame differencing to find motion\n            diff = cv2.absdiff(gray, prev_gray)\n            _, thresh = cv2.threshold(diff, 30, 255, cv2.THRESH_BINARY)\n            \n            # Clean up noise\n            kernel = np.ones((5, 5), np.uint8)\n            thresh = cv2.dilate(thresh, kernel, iterations=1)\n            \n            M = cv2.moments(thresh)\n            if M["m00"] > 200: # Significant motion\n                cy = int(M["m01"] / M["m00"])\n                centroids.append((frame_idx, cy))\n        \n        prev_gray = gray\n        frame_idx += 1\n    \n    cap.release()\n    \n    if not centroids:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # The jump is characterized by the athlete\'s vertical position (cy) \n    # being significantly lower (higher in the frame) than their running position.\n    \n    # Let\'s find the minimum y (highest point in the frame)\n    min_y_val = float(\'inf\')\n    min_y_frame = -1\n    for idx, cy in centroids:\n        if cy < min_y_val:\n            min_y_val = cy\n            min_y_frame = idx\n            \n    if min_y_frame == -1:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # To find takeoff and landing, we look for the window where the athlete \n    # is "high" in the frame.\n    # We\'ll use the median of all centroids as a baseline for "running" height.\n    all_ys = [c[1] for c in centroids]\n    baseline_y = np.median(all_ys)\n    \n    # A jump is when cy < baseline_y - threshold\n    threshold = h * 0.05\n    jump_frames = [idx for idx, cy in centroids if cy < baseline_y - threshold]\n    \n    if jump_frames:\n        takeoff_frame = jump_frames[0]\n        land_frame = jump_frames[-1]\n    else:\n        # Fallback to the frame with the highest point\n        takeoff_frame = max(0, min_y_frame - 5)\n        land_frame = min(num_frames - 1, min_y_frame + 5)\n\n    return {\n        "jump_takeoff_frame_number": takeoff_frame,\n        "jump_land_frame_number": land_frame\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    results = analyze_video(video_path)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml'})
