rn {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # Let\'s find the takeoff and landing by looking at the vertical position.\n    # We\'ll use a window around the min_y_frame.\n    \n    # Takeoff: the frame where the athlete starts moving up significantly.\n    # Landing: the frame where the athlete starts moving down significantly.\n    \n    # Let\'s find the frames where cy is significantly less than the average cy of the whole video.\n    # Or better, the average cy of the frames before and after the jump.\n    \n    # Let\'s find the jump by looking for the period of minimum y.\n    # We\'ll define the jump as the continuous sequence of frames where cy is below a threshold.\n    \n    # First, let\'s find the "running" y level.\n    # We\'ll take the median of all cy values, excluding the ones near the jump.\n    \n    # To exclude the jump, we\'ll use the fact that the jump is around min_y_frame.\n    # Let\'s take all cy values that are NOT within 20 frames of min_y_frame.\n    \n    non_jump_cy = [cy for idx, cy in centroids if abs(idx - min_y_frame) > 20]\n    \n    if not non_jump_cy:\n        # If the jump is too long or the video is too short, fallback.\n        baseline_y = h // 2\n    else:\n        baseline_y = np.median(non_jump_cy)\n\n    threshold = h * 0.05\n    jump_frames = [idx for idx, cy in centroids if cy < baseline_y - threshold]\n    \n    if jump_frames:\n        takeoff_frame = jump_frames[0]\n        land_frame = jump_frames[-1]\n    else:\n        # Fallback\n        takeoff_frame = max(0, min_y_frame - 5)\n        land_frame = min(num_frames - 1, min_y_frame + 5)\n\n    return {\n        "jump_takeoff_frame_number": takeoff_frame,\n        "jump_land_frame_number": land_frame\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    results = analyze_video(video_path)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml'})
