oids:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # The jump is characterized by a deviation in the centroid\'s y-coordinate.\n    # Since the athlete is running, the centroid will move.\n    # But the jump is a sudden upward movement.\n    \n    # Let\'s find the frame where the centroid is highest (lowest y value).\n    # Wait, if the athlete jumps, the centroid moves UP (lower y).\n    # If the athlete is running on the ground, the centroid is at a certain y.\n    \n    # Let\'s find the minimum y (highest point)\n    min_y_val = float(\'inf\')\n    min_y_frame = -1\n    \n    for idx, cy in valid_centroids:\n        if cy < min_y_val:\n            min_y_val = cy\n            min_y_frame = idx\n            \n    # Now, takeoff is likely a few frames before the min_y_frame.\n    # Landing is likely a few frames after.\n    \n    # Let\'s refine: takeoff is when the vertical velocity becomes significantly negative (upward).\n    # Landing is when it becomes positive (downward) and stays stable.\n    \n    # Let\'s use a simpler approach: \n    # The jump happens when the centroid is significantly above its "running" level.\n    # Let\'s estimate the running level by looking at the first few frames.\n    \n    running_y_levels = []\n    for i in range(min(20, len(valid_centroids))):\n        running_y_levels.append(valid_centroids[i][1])\n    \n    if not running_y_levels:\n        avg_running_y = h // 2\n    else:\n        avg_running_y = sum(running_y_levels) / len(running_y_levels)\n\n    takeoff_frame = 0\n    land_frame = 0\n    \n    # Find takeoff: first frame where cy < avg_running_y - threshold\n    threshold = h * 0.05 # 5% of height\n    \n    for idx, cy in valid_centroids:\n        if cy < avg_running_y - threshold:\n            takeoff_frame = idx\n            break\n            \n    # Find landing: last frame where cy < avg_running_y - threshold (or similar)\n    # Actually, landing is when the athlete returns to the running level.\n    # Let\'s look for the last frame where the centroid was "high" and then it returns.\n    \n    # Let\'s try a different way:\n    # The jump is the period where cy is significantly less than avg_running_y.\n    \n    jump_frames = [idx for idx, cy in valid_centroids if cy < avg_running_y - threshold]\n    \n    if jump_frames:\n        takeoff_frame = jump_frames[0]\n        land_frame = jump_frames[-1]\n    else:\n        # Fallback\n        takeoff_frame = 0\n        land_frame = 0\n\n    return {\n        "jump_takeoff_frame_number": takeoff_frame,\n        "jump_land_frame_number": land_frame\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        print("Usage: python jump_analyzer.py <video_path>")\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    results = analyze_video(video_path)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            toml.dump(results, f)\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml'})
