>> ShellSession({'command': 'cat <<EOF > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return None\n\n    num_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    \n    # We will use a background subtraction approach to isolate the moving athlete.\n    # Since the camera is stationary, we can use the first frame as a background model.\n    # However, the first frame might have some noise.\n    # A better way is to use a running average or MOG2, but we\'ll stick to simple \n    # frame differencing or a thresholded centroid.\n    \n    centroids = []\n    frame_idx = 0\n    \n    # Read first frame to initialize background\n    ret, first_frame = cap.read()\n    if not ret:\n        cap.release()\n        return None\n    \n    background = cv2.cvtColor(first_frame, cv2.COLOR_BGR2GRAY)\n    # Apply a slight blur to the background to reduce noise\n    background = cv2.GaussianBlur(background, (5, 5), 0)\n    \n    frame_idx += 1\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        \n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        gray_blur = cv2.GaussianBlur(gray, (5, 5), 0)\n        \n        # Difference between current frame and background\n        diff = cv2.absdiff(gray_blur, background)\n        _, thresh = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)\n        \n        # Dilate to fill holes in the detected object\n        kernel = np.ones((5, 5), np.uint8)\n        thresh = cv2.dilate(thresh, kernel, iterations=1)\n        \n        M = cv2.moments(thresh)\n        if M["m00"] > 500: # Threshold for a significant object\n            cy = int(M["m01"] / M["m00"])\n            centroids.append((frame_idx, cy))\n        \n        # Slowly update background to adapt to lighting changes\n        cv2.accumulateWeighted(gray_blur.astype(np.float32), background.astype(np.float32), 0.01)\n        background = cv2.convertScaleAbs(background)\n        \n        frame_idx += 1\n    \n    cap.release()\n    \n    if not centroids:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # The jump is when the centroid moves UP (lower y).\n    # Let\'s find the baseline y.\n    # We\'ll use the median of the first 15 valid centroids as the baseline.\n    # But wait, the athlete is running, so the baseline might change.\n    # However, the jump is a sudden deviation.\n    \n    # Let\'s find the minimum y (highest point)\n    min_y_val = float(\'inf\')\n    min_y_frame = -1\n    for idx, cy in centroids:\n        if cy < min_y_val:\n            min_y_val = cy\n            min_y_frame = idx\n            \n    if min_y_frame == -1:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # Let\'s find the takeoff and landing by looking at the vertical velocity.\n    # Takeoff: velocity becomes significantly negative (upward).\n    # Landing: velocity becomes positive (downward) and stays stable.\n    \n    # We\'ll use a window of frames to find the jump.\n    # Let\'s look for the frames around the minimum y.\n    \n    # A more robust way:\n    # 1. Calculate the vertical velocity (dy/dt)\n    # 2. Takeoff is when dy/dt is strongly negative.\n    # 3. Landing is when dy/dt is strongly positive.\n    \n    velocities = []\n    for i in range(1, len(centroids)):\n        dy = centroids[i][1] - centroids[i-1][1]\n        dt = centroids[i][0] - centroids[i-1][0]\n        if dt > 0:\n            velocities.append((centroids[i][0], dy / dt))\n            \n    if not velocities:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # Find the frame with the most negative velocity (fastest ascent)\n    max_ascent_frame = -1\n    max_ascent_val = 0\n    for f, v in velocities:\n        if v < max_ascent_val:\n            max_ascent_val = v\n            max_ascent_frame = f\n            \n    if max_ascent_frame == -1:\n        # Fallback to the min_y_frame logic if no clear ascent\n        return {"jump_takeoff_frame_number": max(0, min_y_frame - 5), "jump_land_frame_number": min(num_frames-1, min_y_frame + 5)}\n\n    # Takeoff is a bit before the max ascent.\n    # Landing is when the velocity becomes positive again.\n    \n    takeoff_frame = max_ascent_frame\n    # Search forward from max_ascent_frame for the first significant positive velocity\n    land_frame = max_ascent_frame\n    for f, v in velocities:\n        if f > max_ascent_frame and v > 0:\n            land_frame = f\n            break\n            \n    # Refine takeoff: look backwards from max_ascent_frame for when velocity was near zero\n    for i in range(len(velocities)-1, -1, -1):\n        f, v = velocities[i]\n        if f < max_ascent_frame and abs(v) < 1: # velocity was low before ascent\n            takeoff_frame = f\n            break\n        if f < max_ascent_frame:\n            takeoff_frame = f\n            break\n\n    return {\n        "jump_takeoff_frame_number": takeoff_frame,\n        "jump_land_frame_number": land_frame\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    results = analyze_video(video_path)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml'})
