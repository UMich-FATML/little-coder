>> ShellSession({'command': 'cat <<EOF > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return None\n\n    num_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    \n    # We\'ll use a background subtraction approach to isolate the moving athlete.\n    # Since the camera is stationary, we can use the first frame as a background model.\n    \n    # To avoid issues with the first frame having no runner, we\'ll use a \n    # running average of the background.\n    \n    avg_background = None\n    centroids = []\n    \n    frame_idx = 0\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        \n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        gray = cv2.GaussianBlur(gray, (5, 5), 0)\n        \n        if avg_background is None:\n            avg_background = gray.astype(np.float32)\n            frame_idx += 1\n            continue\n            \n        # Update background\n        cv2.accumulateWeighted(gray.astype(np.float32), avg_background, 0.05)\n        bg_frame = cv2.convertScaleAbs(avg_background)\n        \n        # Difference\n        diff = cv2.absdiff(gray, bg_frame)\n        _, thresh = cv2.threshold(diff, 30, 255, cv2.THRESH_BINARY)\n        \n        # Dilate\n        kernel = np.ones((5, 5), np.uint8)\n        thresh = cv2.dilate(thresh, kernel, iterations=1)\n        \n        M = cv2.moments(thresh)\n        if M["m00"] > 500:\n            cy = int(M["m01"] / M["m00"])\n            centroids.append((frame_idx, cy))\n        \n        frame_idx += 1\n    \n    cap.release()\n    \n    if not centroids:\n        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}\n\n    # The jump is when the centroid moves UP (lower y).\n    # We\'ll find the period where the centroid is significantly above its running level.\n    \n    # Let\'s find the median y of all centroids to get a baseline.\n    all_ys = [c[1] for c in centroids]\n    baseline_y = np.median(all_ys)\n    \n    # A jump is a period where cy is significantly less than baseline_y.\n    # We\'ll look for the continuous block of frames that are "high".\n    threshold = h * 0.05\n    jump_frames = [idx for idx, cy in centroids if cy < baseline_y - threshold]\n    \n    if jump_frames:\n        # We need to find the start and end of the jump.\n        # Since there\'s only one jump, it\'s the first and last frame in the jump_frames list.\n        takeoff_frame = jump_frames[0]\n        land_frame = jump_frames[-1]\n    else:\n        # Fallback: find the minimum y\n        min_y_val = float(\'inf\')\n        min_y_frame = 0\n        for idx, cy in centroids:\n            if cy < min_y_val:\n                min_y_val = cy\n                min_y_frame = idx\n        takeoff_frame = max(0, min_y_frame - 5)\n        land_frame = min(num_frames - 1, min_y_frame + 5)\n\n    return {\n        "jump_takeoff_frame_number": takeoff_frame,\n        "jump_land_frame_number": land_frame\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    results = analyze_video(video_path)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml'})
