>> ShellSession({'command': 'cat <<\'EOF\' > /app/eigen.py\nimport numpy as np\n\ndef find_dominant_eigenvalue_and_eigenvector(A: np.ndarray):\n    """\n    Find the dominant eigenvalue and eigenvector of a general real square matrix.\n\n    Args:\n        A: Real-valued square matrix (accepts numpy arrays) up to size 10x10,\n        dtype np.float64.\n\n    Returns:\n        eigenvalue: Dominant eigenvalue (numpy scalar, potentially complex)\n        eigenvector: Corresponding eigenvector (np.ndarray, potentially complex)\n    """\n    # Power iteration is much faster than full eigendecomposition for small matrices.\n    # To handle complex eigenvalues, we use a complex starting vector.\n    \n    n = A.shape[0]\n    # Use a fixed starting vector to avoid the cost of np.random.\n    x = np.ones(n, dtype=complex)\n    \n    # For 10x10, 100 iterations is very fast and usually sufficient.\n    for _ in range(100):\n        x_next = A @ x\n        norm = np.linalg.norm(x_next)\n        if norm < 1e-25:\n            return 0.0 + 0j, x\n        x = x_next / norm\n        \n    # Rayleigh quotient for the eigenvalue\n    eigenval = np.dot(x.conj().T, A @ x)\n    eigenvec = x\n    \n    # Check if it satisfies the eigenvalue equation.\n    # If it doesn\'t (e.g., due to complex conjugate pairs), fall back to np.linalg.eig.\n    if not np.allclose(A @ eigenvec, eigenval * eigenvec, atol=1e-5):\n        eigenvalues, eigenvectors = np.linalg.eig(A)\n        idx = np.argmax(np.abs(eigenvalues))\n        return eigenvalues[idx], eigenvectors[:, idx]\n\n    return eigenval, eigenvec\nEOF\n'})
