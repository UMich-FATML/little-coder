"Needs 15-min buffer after meetings ending at 4:45 PM or later"\n                if end_time >= datetime.datetime(2024, 1, day, 16, 45, tzinfo=datetime.timezone.utc):\n                    if end_time + datetime.timedelta(minutes=15) > datetime.datetime(2024, 1, day, 17, 0, tzinfo=datetime.timezone.utc):\n                        continue\n\n                # Check for conflicts with existing meetings\n                conflict = False\n                for e_start, e_end in all_events:\n                    if max(start_time, e_start) < min(end_time, e_end):\n                        conflict = True\n                        break\n                if conflict:\n                    continue\n                \n                is_monday = (day == 15)\n                is_alice_morning = (start_time.hour < 12)\n                \n                possible_slots.append({\n                    \'start\': start_time,\n                    \'end\': end_time,\n                    \'is_monday\': is_monday,\n                    \'is_alice_morning\': is_alice_morning\n                })\n\n    if not possible_slots:\n        print("No slot found")\n        return\n\n    # Sort by:\n    # 1. is_monday (False first)\n    # 2. start_time (earliest first)\n    # 3. is_alice_morning (True first)\n    \n    possible_slots.sort(key=lambda x: (x[\'is_monday\'], x[\'start\'], not x[\'is_alice_morning\']))\n    \n    best = possible_slots[0]\n    print(f"Best slot: {best[\'start\']} to {best[\'end\']}")\n    \n    ics_content = [\n        "BEGIN:VCALENDAR",\n        "VERSION:2.0",\n        "PRODID:-//Terminal-Bench//Team Meeting//EN",\n        "CALSCALE:GREGORIAN",\n        "METHOD:PUBLISH",\n        "",\n        "BEGIN:VEVENT",\n        f"UID:team-planning-{best[\'start\'].strftime(\'%Y%m%d%H%M%S\')}@example.com",\n        f"DTSTART:{best[\'start\'].strftime(\'%Y%m%dT%H%M%SZ\')}",\n        f"DTEND:{best[\'end\'].strftime(\'%Y%m%dT%H%M%SZ\')}",\n        "SUMMARY:Team Planning Meeting",\n        "DESCRIPTION:Team planning session",\n        "ATTENDEE;RSVP=TRUE;PARTSTAT=ACCEPTED:mailto:alice@example.com",\n        "ATTENDEE;RSVP=TRUE;PARTSTAT=ACCEPTED:mailto:bob@example.com",\n        "ATTENDEE;RSVP=TRUE;PARTSTAT=ACCEPTED:mailto:carol@example.com",\n        "END:VEVENT",\n        "",\n        "END:VCALENDAR"\n    ]\n    \n    with open(\'/app/meeting_scheduled.ics\', \'w\') as f:\n        f.write(\'\\n\'.join(ics_content))\n\nsolve()\nEOF\npython3 /app/solver.py\n'})
