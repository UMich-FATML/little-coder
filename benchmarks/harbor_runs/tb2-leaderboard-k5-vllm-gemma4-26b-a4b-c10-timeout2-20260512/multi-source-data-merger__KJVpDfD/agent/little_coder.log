il\', \'created_date\', \'status\']]\n    df_b[\'source\'] = \'source_b\'\n\n    # Source C: Parquet\n    df_c = pd.read_parquet(\'/data/source_c/users.parquet\')\n    # Mapping C: userId -> user_id, userName -> name, email -> email, joined -> created_date\n    df_c = df_c.rename(columns={\n        \'userId\': \'user_id\',\n        \'userName\': \'name\',\n        \'email\': \'email\',\n        \'joined\': \'created_date\'\n    })\n    # Handle status for C\n    if \'active\' in df_c.columns:\n        df_c[\'status\'] = df_c[\'active\'].map({True: \'active\', False: \'inactive\'})\n    else:\n        df_c[\'status\'] = None\n\n    df_c[\'user_id\'] = df_c[\'user_id\'].astype(int)\n    df_c = df_c[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\n    df_c[\'source\'] = \'source_c\'\n\n    # 2. Merge and handle conflicts\n    # We need to merge all users and then resolve conflicts by priority.\n    # Priority: source_a > source_b > source_c\n    \n    all_users = pd.concat([df_a, df_b, df_c], ignore_index=True)\n    \n    # Group by user_id to find unique users and conflicts\n    unique_user_ids = all_users[\'user_id\'].unique()\n    \n    merged_data = []\n    conflicts_list = []\n    \n    fields_to_check = [\'name\', \'email\', \'created_date\', \'status\']\n\n    for uid in unique_user_ids:\n        user_rows = all_users[all_users[\'user_id\'] == uid].sort_values(by=\'source\')\n        # Sort order for \'source\' column: source_a, source_b, source_c\n        # Since they are strings, \'source_a\' < \'source_b\' < \'source_c\' is true.\n        # So sort_values(by=\'source\') will put source_a first.\n        \n        # The highest priority is the first row in user_rows\n        best_row = user_rows.iloc[0]\n        \n        # Check for conflicts\n        # A conflict occurs if any field has different values across the sources present for this user.\n        # We need to collect values from all sources for the conflict report.\n        \n        user_conflicts = []\n        \n        # Get all available values for this user across sources\n        source_values = {}\n        for _, row in user_rows.iterrows():\n            src = row[\'source\']\n            if src not in source_values:\n                source_values[src] = {}\n            for field in fields_to_check:\n                val = row[field]\n                # Handle NaN/None\n                if pd.isna(val):\n                    val = None\n                # Convert date to string for comparison if it\'s a timestamp\n                if field == \'created_date\' and isinstance(val, (datetime, pd.Timestamp)):\n                    val = val.strftime(\'%Y-%m-%d\')\n                source_values[src][field] = val\n\n        # Check each field for conflicts\n        for field in fields_to_check:\n            # Get all non-None values for this field from the sources present\n            vals = []\n            for src in [\'source_a\', \'source_b\', \'source_c\']:\n                if src in source_values and source_values[src].get(field) is not None:\n                    vals.append(source_values[src][field])\n            \n            # If there\'s more than one unique value, it\'s a conflict\n            if len(set(vals)) > 1:\n                # Construct conflict entry\n                conflict_entry = {\n                    "user_id": int(uid),\n                    "field": field,\n                    "values": {\n                        "source_a": source_values.get(\'source_a\', {}).get(field),\n                        "source_b": source_values.get(\'source_b\', {}).get(field),\n                        "source_c": source_values.get(\'source_c\', {}).get(field)\n                    },\n                    "selected": best_row[field] if not pd.isna(best_row[field]) else None\n                }\n                # Ensure selected is formatted correctly if it\'s a date\n                if field == \'created_date\' and isinstance(conflict_entry["selected"], (datetime, pd.Timestamp)):\n                    conflict_entry["selected"] = conflict_entry["selected"].strftime(\'%Y-%m-%d\')\n                \n                user_conflicts.append(conflict_entry)\n\n        if user_conflicts:\n            conflicts_list.extend(user_conflicts)\n\n        # Prepare merged row\n        # Ensure created_date is string YYYY-MM-DD\n        row_dict = {\n            \'user_id\': int(uid),\n            \'name\': best_row[\'name\'],\n            \'email\': best_row[\'email\'],\n            \'created_date\': best_row[\'created_date\'],\n            \'status\': best_row[\'status\']\n        }\n        \n        # Format date\n        if isinstance(row_dict[\'created_date\'], (datetime, pd.Timestamp)):\n            row_dict[\'created_date\'] = row_dict[\'created_date\'].strftime(\'%Y-%m-%d\')\n        elif pd.isna(row_dict[\'created_date\']):\n            row_dict[\'created_date\'] = None\n            \n        # Handle status None/NaN\n        if pd.isna(row_dict[\'status\']):\n            row_dict[\'status\'] = None\n\n        merged_data.append(row_dict)\n\n    # 3. Write outputs\n    # Merged Parquet\n    merged_df = pd.DataFrame(merged_data)\n    # Ensure types\n    merged_df[\'user_id\'] = merged_df[\'user_id\'].astype(int)\n    merged_df[\'name\'] = merged_df[\'name\'].astype(str)\n    merged_df[\'email\'] = merged_df[\'email\'].astype(str)\n    merged_df[\'created_date\'] = merged_df[\'created_date\'].astype(str)\n    # status is optional, can be object/string\n    \n    # Replace \'None\' string if it was converted from NaN\n    merged_df.replace(\'None\', None, inplace=True)\n    merged_df.replace(\'nan\', None, inplace=True)\n\n    merged_df.to_parquet(\'/app/merged_users.parquet\', index=False)\n\n    # Conflict report\n    report = {\n        "total_conflicts": len(conflicts_list),\n        "conflicts": conflicts_list\n    }\n    with open(\'/app/conflicts.json\', \'w\') as f:\n        json.dump(report, f, indent=2)\n\nif 