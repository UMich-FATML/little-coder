_features\n        self.out_features = out_features\n        self.bias = bias\n        \n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n        \n        # master_weight shape: (out_features, in_features)\n        # RowParallel splits by rows (input dimension)\n        shard_size = in_features // self.world_size\n        start_idx = self.rank * shard_size\n        end_idx = (self.rank + 1) * shard_size\n        if self.rank == self.world_size - 1:\n            end_idx = in_features\n            \n        self.weight = nn.Parameter(master_weight[:, start_idx:end_idx].clone())\n        \n        if bias:\n            # "the bias remains full on each rank"\n            # "If bias is used, initialize the bias to zero."\n            self.bias_param = nn.Parameter(torch.zeros(out_features))\n            self.has_bias = True\n        else:\n            self.has_bias = False\n\n    def forward(self, input):\n        # In a typical TP setup, the input to RowParallel is already sharded.\n        # However, if ColumnParallel returned the full tensor, input is full.\n        # If input is full, we must slice it to match the weight shard.\n        \n        shard_size = self.in_features // self.world_size\n        start_idx = self.rank * shard_size\n        end_idx = (self.rank + 1) * shard_size\n        if self.rank == self.world_size - 1:\n            end_idx = self.in_features\n            \n        # Slice input to match the weight shard\n        input_shard = input[:, start_idx:end_idx]\n        \n        # output_shard: (batch, out_features)\n        output_shard = torch.matmul(input_shard, self.weight.t())\n        \n        # "the partial outputs should be summed together as if using all_reduce"\n        dist.all_reduce(output_shard)\n        \n        if self.has_bias:\n            output_shard += self.bias_param\n            \n        return output_shard\nEOF\n'})
