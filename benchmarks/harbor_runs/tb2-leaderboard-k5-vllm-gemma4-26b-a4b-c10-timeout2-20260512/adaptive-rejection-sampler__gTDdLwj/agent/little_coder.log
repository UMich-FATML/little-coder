s.finite(grid)]\n      for (p in grid) {\n        val <- target_log_density(p)\n        if (!is.infinite(val) && !is.na(val)) {\n          x_pts <- c(x_pts, p); y_pts <- c(y_pts, val)\n          if (length(x_pts) >= 2) break\n        }\n      }\n    }\n    \n    if (length(x_pts) < 2) stop("Could not find enough points to initialize the envelope.")\n    \n    ord <- order(x_pts)\n    x_pts <- x_pts[ord]; y_pts <- y_pts[ord]\n    if (!check_log_concavity(x_pts, y_pts)) stop("Initial points do not form a log-concave envelope.")\n    \n    accepted <- FALSE\n    while (!accepted) {\n      n_intervals <- length(x_pts) - 1\n      integrals <- numeric(n_intervals)\n      for (j in 1:n_intervals) {\n        x_j <- x_pts[j]; x_next <- x_pts[j+1]\n        y_j <- y_pts[j]; y_next <- y_pts[j+1]\n        s_j <- (y_next - y_j) / (x_next - x_j)\n        if (abs(s_j) < 1e-12) {\n          integrals[j] <- exp(y_j) * (x_next - x_j)\n        } else {\n          integrals[j] <- exp(y_j) * (exp(s_j * (x_next - x_j)) - 1) / s_j\n        }\n      }\n      total_integral <- sum(integrals)\n      if (total_integral <= 0) stop("Total integral of envelope is non-positive.")\n      u <- runif(1) * total_integral\n      cum_integrals <- cumsum(integrals)\n      interval_idx <- which(cum_integrals >= u)[1]\n      x_j <- x_pts[interval_idx]; x_next <- x_pts[interval_idx+1]\n      y_j <- y_pts[interval_idx]; y_next <- y_pts[interval_idx+1]\n      s_j <- (y_next - y_j) / (x_next - x_j)\n      if (abs(s_j) < 1e-12) {\n        sample_x <- x_j + runif(1) * (x_next - x_j)\n      } else {\n        u_prime <- runif(1)\n        delta <- s_j * (x_next - x_j)\n        sample_x <- x_j + (1/s_j) * log(1 + u_prime * (exp(delta) - 1))\n      }\n      target_log_val <- target_log_density(sample_x)\n      envelope_log_val <- y_j + s_j * (sample_x - x_j)\n      if (target_log_val >= envelope_log_val) {\n        samples[i] <- sample_x\n        accepted <- TRUE\n      } else {\n        x_pts <- c(x_pts, sample_x); y_pts <- c(y_pts, target_log_val)\n        ord <- order(x_pts); x_pts <- x_pts[ord]; y_pts <- y_pts[ord]\n        if (!check_log_concavity(x_pts, y_pts)) stop("The target density is not log-concave.")\n      }\n    }\n  }\n  return(samples)\n}\n\ntest <- function() {\n  cat("Starting tests...\\n")\n  cat("TEST_NORMAL: ")\n  target_log_density_norm <- function(x) dnorm(x, mean = 0, sd = 1, log = TRUE)\n  tryCatch({\n    samples <- ars(target_log_density_norm, n_samples = 500, domain = function() c(-10, 10))\n    mean_val <- mean(samples); sd_val <- sd(samples)\n    if (abs(mean_val - 0) < 0.2 && abs(sd_val - 1) < 0.2) {\n      cat(sprintf("PASS (mean=%.3f, sd=%.3f)\\n", mean_val, sd_val))\n      write(samples, file = "/app/normal_samples.txt")\n    } else {\n      cat(sprintf("FAIL (mean=%.3f, sd=%.3f)\\n", mean_val, sd_val))\n    }\n  }, error = function(e) cat(sprintf("FAIL (Error: %s)\\n", e$message)))\n  \n  cat("TEST_EXPONENTIAL: ")\n  target_log_density_exp <- function(x) if (x < 0) -Inf else dexp(x, rate = 1, log = TRUE)\n  tryCatch({\n    samples <- ars(target_log_density_exp, n_samples = 500, domain = function() c(0, 10))\n    mean_val <- mean(samples); sd_val <- sd(samples)\n    if (abs(mean_val - 1) < 0.2 && abs(sd_val - 1) < 0.2) {\n      cat(sprintf("PASS (mean=%.3f, sd=%.3f)\\n", mean_val, sd_val))\n      write(samples, file = "/app/exponential_samples.txt")\n    } else {\n      cat(sprintf("FAIL (mean=%.3f, sd=%.3f)\\n", mean_val, sd_val))\n    }\n  }, error = function(e) cat(sprintf("FAIL (Error: %s)\\n", e$message)))\n  \n  cat("TEST_NON_LOG_CONCAVE: ")\n  target_log_density_bimodal <- function(x) log(0.5 * dnorm(x, 0, 1) + 0.5 * dnorm(x, 5, 1))\n  tryCatch({\n    ars(target_log_density_bimodal, n_samples = 50, domain = function() c(-5, 10))\n    cat("FAIL (Should have failed)\\n")\n  }, error = function(e) {\n    if (grepl("not log-concave", e$message)) cat("PASS (Caught non-log-concavity)\\n")\n    else cat(sprintf("FAIL (Error: %s)\\n", e$message)