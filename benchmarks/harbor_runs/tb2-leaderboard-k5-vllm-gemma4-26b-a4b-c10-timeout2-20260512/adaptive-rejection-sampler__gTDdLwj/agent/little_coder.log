>> ShellSession({'command': 'cat << \'EOF\' > /app/ars.R\n# Adaptive Rejection Sampling (ARS) implementation\n# Based on Gilks and Wild (1992)\n\n#\' Adaptive Rejection Sampler\n#\'\n#\' @param target_log_density A function that returns the log density of the target distribution.\n#\' @param n_samples The number of samples to generate.\n#\' @param domain A function that returns the domain of the distribution (e.g., c(-Inf, Inf)).\n#\' @return A vector of samples.\nars <- function(target_log_density, n_samples, domain = function(x) c(-Inf, Inf)) {\n  # Input validation\n  if (!is.function(target_log_density)) {\n    stop("target_log_density must be a function.")\n  }\n  if (!is.numeric(n_samples) || n_samples <= 0) {\n    stop("n_samples must be a positive integer.")\n  }\n  \n  dom <- domain()\n  if (length(dom) != 2) {\n    stop("domain must return a vector of length 2 (lower, upper).")\n  }\n  \n  # Helper to check log-concavity\n  check_log_concavity <- function(x_points, log_densities) {\n    if (length(x_points) < 3) return(TRUE)\n    # Check if the slopes are decreasing\n    slopes <- diff(log_densities) / diff(x_points)\n    # Using a small tolerance for floating point issues\n    if (any(diff(slopes) > 1e-8)) {\n      return(FALSE)\n    }\n    return(TRUE)\n  }\n\n  samples <- numeric(n_samples)\n  \n  for (i in 1:n_samples) {\n    # For each sample, we build the envelope\n    # We need at least two points to start.\n    # We\'ll use a simple search to find initial points if domain is infinite.\n    \n    # Initial points:\n    # We\'ll try to find points that are not too close and have reasonable density.\n    # For this implementation, we\'ll use a simple approach:\n    # Start with two points that are somewhat spread out.\n    \n    # Let\'s use a more robust way to find initial points.\n    # We\'ll try to find the mode or just use some points.\n    \n    # For simplicity, let\'s assume we can find two points.\n    # If domain is (-Inf, Inf), we\'ll try to find them.\n    \n    x_pts <- c()\n    y_pts <- c()\n    \n    # Initial search for points\n    # We\'ll try to find points by sampling or using the domain.\n    # This is a bit of a heuristic.\n    \n    # Let\'s try to find two points by searching.\n    # We\'ll use a simple grid search or similar.\n    \n    # For the sake of this implementation, let\'s assume we can find them.\n    # We\'ll try to find points with high density.\n    \n    # Let\'s use a simple approach:\n    # If domain is (-Inf, Inf), we\'ll try to find points around 0.\n    # If domain is finite, we\'ll use the boundaries.\n    \n    if (dom[1] == -Inf && dom[2] == Inf) {\n      # Heuristic for infinite domain: find points around 0\n      # We\'ll try to find points where log density is not -Inf\n      search_points <- c(-10, -1, 0, 1, 10)\n      for (p in search_points) {\n        val <- target_log_density(p)\n        if (!is.infinite(val) && !is.na(val)) {\n          x_pts <- c(x_pts, p)\n          y_pts <- c(y_pts, val)\n          if (length(x_pts) >= 2) break\n        }\n      }\n      # If still not enough, keep searching\n      if (length(x_pts) < 2) {\n        # This is a fallback. In a real implementation, we\'d be more robust.\n        # Let\'s try a wider range.\n        search_points <- seq(-100, 100, length.out = 200)\n        for (p in search_points) {\n          val <- target_log_density(p)\n          if (!is.infinite(val) && !is.na(val)) {\n            x_pts <- c(x_pts, p)\n            y_pts <- c(y_pts, val)\n            if (length(x_pts) >= 2) break\n          }\n        }\n      }\n    } else {\n      # Finite domain: use boundaries or points near them\n      # We\'ll try to find points near the boundaries that have finite log density\n      # Or just use the boundaries if they are finite.\n      \n      # Let\'s try to find points near the boundaries.\n      # For simplicity, let\'s just use the boundaries if they are finite.\n      # If they are -Inf/Inf, we\'ll use a large number.\n      \n      # Actually, let\'s just try to find two points in the domain.\n      # We\'ll use a simple grid.\n      grid <- seq(dom[1], dom[2], length.out = 100)\n      # Filter out -Inf/Inf for the grid\n      grid <- grid[is.finite(grid)]\n      \n      for (p in grid) {\n        val <- target_log_density(p)\n        if (!is.infinite(val) && !is.na(val)) {\n          x_pts <- c(x_pts, p)\n          y_pts <- c(y_pts, val)\n          if (length(x_pts) >= 2) break\n        }\n      }\n    }\n    \n    if (length(x_pts) < 2) {\n      stop("Could not find enough points to initialize the envelope.")\n    }\n    \n    # Sort points\n    ord <- order(x_pts)\n    x_pts <- x_pts[ord]\n    y_pts <- y_pts[ord]\n    \n    # Check log-concavity of initial points\n    if (!check_log_concavity(x_pts, y_pts)) {\n      stop("Initial points do not form a log-concave envelope.")\n    }\n    \n    # The core ARS loop\n    accepted <- FALSE\n    while (!accepted) {\n      # 1. Sample from the current envelope\n      # The envelope is a piecewise linear function (in log space).\n      # We can sample from it by:\n      # a. Sampling from the piecewise linear distribution.\n      # b. This is equivalent to sampling from a mixture of truncated exponentials.\n      \n      # For simplicity, let\'s use the property that the envelope is \n      # a piecewise linear function in log-space.\n      # We can sample from it using the following method:\n      # 1. Pick an interval [x_j, x_{j+1}] with probability proportional to \n      #    the integral of the exponential over that interval.\n      # 2. Sample from the truncated exponential in that interval.\n      \n      # Calculate integrals of the exponential over each interval\n      # Integral of exp(a*x + b) dx = (1/a) * exp(a*x + b)\n      # Here, for interval [x_j, x_{j+1}], the log-density is y_j + (y_{j+1}-y_j)/(x_{j+1}-x_j) * (x - x_j)\n      # Let slope s_j = (y_{j+1}-y_j)/(x_{j+1}-x_j)\n      # Log-density: s_j * x + (y_j - s_j * x_j)\n      # Integral: (1/s_j) * [exp(s_j * x_{j+1} + b_j) - exp(s_j * x_j + b_j)]\n      # where b_j = y_j - s_j * x_j\n      \n      n_intervals <- length(x_pts) - 1\n      integrals <- numeric(n_intervals)\n      \n      for (j in 1:n_intervals) {\n        x_j <- x_pts[j]\n        x_next <- x_pts[j+1]\n        y_j <- y_pts[j]\n        y_next <- y_pts[j+1]\n        \n        s_j <- (y_next - y_j) / (x_next - x_j)\n        \n        if (abs(s_j) < 1e-12) {\n          # Nearly constant density: integral is exp(y_j) * (x_next - x_j)\n          integrals[j] <- exp(y_j) * (x_next - x_j)\n        } else {\n          # Integral of exp(s_j * x + b_j)\n          # = (1/s_j) * [exp(s_j * x_next + b_j) - exp(s_j * x_j + b_j)]\n          # = (1/s_j) * [exp(y_next) - exp(y_j)]\n          # Wait, this is only if s_j is not zero.\n          # Let\'s use a more stable way:\n          # (1/s_j) * exp(y_j) * (exp(s_j * (x_next - x_j)) - 1)\n          # No, that\'s not right.\n          # Let\'s use: (exp(y_next) - exp(y_j)) / s_j\n          # But exp(y) can be very small.\n          # Let\'s use: exp(y_j) * (exp(s_j * (x_next - x_j)) - 1) / s_j\n          # This is better.\n          integrals[j] <- exp(y_j) * (exp(s_j * (x_next - x_j)) - 1) / s_j\n        }\n      }\n      \n      # Total integral\n      total_integral <- sum(integrals)\n      \n      # Sample an interval\n      u <- runif(1) * total_integral\n      cum_integrals <- cumsum(integrals)\n      interval_idx <- which(cum_integrals >= u)[1]\n      \n      # Sample from the chosen interval\n      x_j <- x_pts[interval_idx]\n      x_next <- x_pts[interval_idx+1]\n      y_j <- y_pts[interval_idx]\n      y_next <- y_pts[interval_idx+1]\n      s_j <- (y_next - y_j) / (x_next - x_j)\n      \n      if (abs(s_j) < 1e-12) {\n        # Uniform in the interval\n        sample_x <- x_j + runif(1) * (x_next - x_j)\n      } else {\n        # Sample from truncated exponential\n        # Using the inverse CDF method for the truncated exponential\n        # CDF(x) = (exp(s_j * (x - x_j)) - 1) / (exp(s_j * (x_next - x_j)) - 1)\n        # x = x_j + (1/s_j) * log(1 + u\' * (exp(s_j * (x_next - x_j)) - 1))\n        # where u\' is uniform(0,1)\n        u_prime <- runif(1)\n        sample_x <- x_j + (1/s_j) * log(1 + u_prime * (exp(s_j * (x_next - x_j)) - 1))\n      }\n      \n      # 2. Check if accepted\n      # Accept if target_density(sample_x) >= envelope_density(sample_x)\n      # In log space: target_log_density(sample_x) >= envelope_log_density(sample_x)\n      \n      target_log_val <- target_log_density(sample_x)\n      \n      # Calculate envelope log density at sample_x\n      # It\'s the linear interpolation between x_j and x_{j+1}\n      # But we already know it\'s in interval_idx\n      # envelope_log_val = y_j + s_j * (sample_x - x_j)\n      # Wait, we need to find which interval sample_x falls into.\n      # Since we sampled from the envelope, it\'s in interval_idx.\n      \n      envelope_log_val <- y_j + s_j * (sample_x - x_j)\n      \n      if (target_log_val >= envelope_log_val) {\n        samples[i] <- sample_x\n        accepted <- TRUE\n      } else {\n        # Reject and update the envelope\n        # Add sample_x to the points and re-sort\n        x_pts <- c(x_pts, sample_x)\n        y_pts <- c(y_pts, target_log_val)\n        \n        ord <- order(x_pts)\n        x_pts <- x_pts[ord]\n        y_pts <- y_pts[ord]\n        \n        # Check log-concavity again\n        if (!check_log_concavity(x_pts, y_pts)) {\n          stop("The target density is not log-concave.")\n        }\n      }\n    }\n  }\n  \n  return(samples)\n}\n\n#\' Test function for ARS\n#\'\n#\' @return Prints test results.\ntest <- function() {\n  cat("Starting tests...\\n")\n  \n  # Test 1: Normal Distribution\n  cat("TEST_NORMAL: ")\n  target_log_density_norm <- function(x) dnorm(x, mean = 0, sd = 1, log = TRUE)\n  # We need to provide a domain. For normal, it\'s (-Inf, Inf).\n  # But our implementation needs to find initial points.\n  # Let\'s use a large finite domain for testing to be safe, \n  # or rely on the heuristic.\n  \n  # Let\'s try with a large domain first.\n  tryCatch({\n    samples <- ars(target_log_density_norm, n_samples = 1000, domain = function() c(-10, 10))\n    mean_val <- mean(samples)\n    sd_val <- sd(samples)\n    \n    # Check if mean is close to 0 and sd is close to 1\n    if (abs(mean_val - 0) < 0.2 && abs(sd_val - 1) < 0.2) {\n      cat(sprintf("PASS (mean=%.3f, sd=%.3f)\\n", mean_val, sd_val))\n      write(samples, file = "/app/normal_samples.txt")\n    } else {\n      cat(sprintf("FAIL (mean=%.3f, sd=%.3f)\\n", mean_val, sd_val))\n    }\n  }, error = function(e) {\n    cat(sprintf("FAIL (Error: %s)\\n", e$message))\n  })\n  \n  # Test 2: Exponential Distribution\n  cat("TEST_EXPONENTIAL: ")\n  target_log_density_exp <- function(x) {\n    if (x < 0) return(-Inf)\n    return(dexp(x, rate = 1, log = TRUE))\n  }\n  tryCatch({\n    samples <- ars(target_log_density_exp, n_samples = 1000, domain = function() c(0, 10))\n    mean_val <- mean(samples)\n    sd_val <- sd(samples)\n    \n    # For exponential(rate=1), mean=1, sd=1\n    if (abs(mean_val - 1) < 0.2 && abs(sd_val - 1) < 0.2) {\n      cat(sprintf("PASS (mean=%.3f, sd=%.3f)\\n", mean_val, sd_val))\n      write(samples, file = "/app/exponential_samples.txt")\n    } else {\n      cat(sprintf("FAIL (mean=%.3f, sd=%.3f)\\n", mean_val, sd_val))\n    }\n  }, error = function(e) {\n    cat(sprintf("FAIL (Error: %s)\\n", e$message))\n  })\n  \n  # Test 3: Non-log-concave density (should fail)\n  cat("TEST_NON_LOG_CONCAVE: ")\n  # A bimodal distribution is not log-concave\n  target_log_density_bimodal <- function(x) {\n    # Mixture of two normals\n    return(log(0.5 * dnorm(x, 0, 1) + 0.5 * dnorm(x, 5, 1)))\n  }\n  tryCatch({\n    ars(target_log_density_bimodal, n_samples = 100, domain = function() c(-5, 10))\n    cat("FAIL (Should have failed due to non-log-concavity)\\n")\n  }, error = function'})
