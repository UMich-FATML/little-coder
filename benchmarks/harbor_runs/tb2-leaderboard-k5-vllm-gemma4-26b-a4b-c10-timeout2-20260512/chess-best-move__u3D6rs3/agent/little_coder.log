s:\n        print(f"{color}: {to_chess(r, c)}")\n\n    # 3. Print the full brightness map to see if we missed anything\n    print("\\nFull brightness map:")\n    for r in range(8):\n        row_b = []\n        for c in range(8):\n            p = img.getpixel(((c + 0.5) * square_size, (r + 0.5) * square_size))\n            row_b.append(f"{np.mean(p):3.0f}")\n        print(" ".join(row_b))\n\nanalyze()\nEOF\npython3 analyze_chess.py\n'})
