 searching from the bounds.\n  \n  find_initial_points <- function(f, l, u) {\n    # Try bounds first\n    p1 <- l\n    p2 <- u\n    \n    # If bounds are infinite, we need to find some finite points.\n    # This is a bit tricky. Let\'s try a simple search.\n    if (is.infinite(f(p1))) {\n      # Search for a point with finite density\n      # If l is -Inf, we\'ll try to find a point by stepping from 0 or something.\n      # But let\'s assume the user provides reasonable bounds or we can find them.\n      # A better way: if l is -Inf, start from 0 and go down.\n      if (is.infinite(l)) {\n        curr <- 0\n        step <- 1\n        for (i in 1:100) {\n          if (is.finite(f(curr))) {\n            p1 <- curr\n            break\n          }\n          curr <- curr - step\n          step <- step * 2\n        }\n      } else {\n        # Search from l upwards\n        step <- (u - l) / 100\n        for (i in 1:100) {\n          curr <- l + i * step\n          if (is.finite(f(curr))) {\n            p1 <- curr\n            break\n          }\n        }\n      }\n    }\n    \n    if (is.infinite(f(p2))) {\n      if (is.infinite(u)) {\n        curr <- 0\n        step <- 1\n        for (i in 1:100) {\n          if (is.finite(f(curr))) {\n            p2 <- curr\n            break\n          }\n          curr <- curr + step\n          step <- step * 2\n        }\n      } else {\n        # Search from u downwards\n        step <- (u - l) / 100\n        for (i in 1:100) {\n          curr <- u - i * step\n          if (is.finite(f(curr))) {\n            p2 <- curr\n            break\n          }\n        }\n      }\n    }\n    \n    if (is.infinite(f(p1)) || is.infinite(f(p2))) {\n      stop("Could not find initial points with finite density. Check your bounds and density function.")\n    }\n    \n    return(c(p1, p2))\n  }\n\n  # Get initial points\n  init_pts <- find_initial_points(target_log_density, lower, upper)\n  points_x <- sort(init_pts)\n  points_log_y <- target_log_density(points_x)\n\n  samples <- numeric(n_samples)\n  \n  for (i in 1:n_samples) {\n    # 1. Generate a candidate sample from the current envelope\n    # The envelope is a piecewise linear function in log-space.\n    # We sample from the distribution defined by this envelope.\n    \n    # The envelope is defined by points_x and points_log_y.\n    # We can use rejection sampling or direct sampling from the piecewise linear envelope.\n    # For simplicity, let\'s use rejection sampling from a simpler envelope.\n    # But the Gilks paper suggests using the piecewise linear envelope directly.\n    \n    # To sample from the piecewise linear envelope:\n    # 1. Sample a point from the piecewise linear density.\n    # 2. Accept/reject based on the actual density.\n    \n    # Let\'s use a simpler approach: \n    # The envelope is a piecewise linear function in log-space.\n    # We can sample from it by:\n    # a) Picking an interval [x_j, x_{j+1}] with probability proportional to the area under the line.\n    # b) Sampling from the line in that interval.\n    \n    # Calculate areas of trapezoids\n    dx <- diff(points_x)\n    avg_log_y <- (points_log_y[-length(points_log_y)] + points_log_y[-1]) / 2\n    # Area of trapezoid in density space is NOT just avg_log_y * dx.\n    # The density is exp(log_y). The integral of exp(a + b(x-x0)) is...\n    # Let\'s compute the integral of exp(linear_function) over each interval.\n    \n    interval_areas <- sapply(1:length(dx), function(j) {\n      x0 <- points_x[j]\n      x1 <- points_x[j+1]\n      y0 <- points_log_y[j]\n      y1 <- points_log_y[j+1]\n      \n      if (abs(y1 - y0) < 1e-10) {\n        return(exp(y0) * (x1 - x0))\n      } else {\n        # Integral of exp(y0 + (y1-y0)/(x1-x0) * (x-x0)) dx from x0 to x1\n        # Let slope m = (y1-y0)/(x1-x0)\n        # Integral is exp(y0) * [exp(m*(x-x0)) / m] from 0 to (x1-x0)\n        # = exp(y0) * (exp(m*(x1-x0)) - 1) / m\n        # = exp(y0) * (exp(y1-y0) - 1) / (m)\n        # = exp(y0) * (exp(y1-y0) - 1) * (x1-x0) / (y1-y0)\n        m <- (y1 - y0) / (x1 - x0)\n        return(exp(y0) * (exp(y1 - y0) - 1) / m)\n      }\n    })\n    \n    # Sample from the piecewise linear envelope\n    # Step a: Pick interval\n    probs <- interval_areas / sum(interval_areas)\n    interval_idx <- sample(1:length(probs), 1, prob = probs)\n    \n    # Step b: Sample from the line in the interval\n    x_j <- points_x[interval_idx]\n    x_next <- points_x[interval_idx + 1]\n    y_j <- points_log_y[interval_idx]\n    y_next <- points_log_y[interval_idx + 1]\n    \n    # Sample from the line: \n    # The density is f(x) = exp(y_j + m*(x - x_j))\n    # CDF F(x) = (exp(y_j + m*(x - x_j)) - 1) / (m * exp(y_j)) * (area_of_interval / total_area_of_interval_in_density_space?? No)\n    # Let\'s use the rejection method within the interval to sample from the line.\n    # Or more simply, use the inverse transform sampling for the line.\n    # F(x) = (exp(y_j + m*(x - x_j)) - 1) / (exp(y_next) - 1) * (something)\n    # Actually, the CDF of the line in the interval [x_j, x_next] is:\n    # F(x) = (exp(m*(x - x_j)) - 1) / (exp(m*(x_next - x_j)) - 1)\n    \n    u_val <- runif(1)\n    if (abs(y_next - y_j) < 1e-10) {\n      candidate_x <- x_j + u_val * (x_next - x_j)\n    } else {\n      m <- (y_next - y_j) / (x_next - x_j)\n      # u = (exp(m*(x-x_j)) - 1) / (exp(m*(x_next-x_j)) - 1)\n      # exp(m*(x-x_j)) = u * (exp(m*(x_next-x_j)) - 1) + 1\n      # m*(x-x_j) = log(u * (exp(m*(x_next-x_j)) - 1) + 1)\n      candidate_x <- x_j + log(u_val * (exp(y_next - y_j) - 1) + 1) / m\n    }\n    \n    # 2. Accept/reject candidate\n    # The envelope is always below or equal to the target density (due to log-concavity).\n    # So we accept with probability target_density(candidate_x) / envelope_density(candidate_x)\n    # In log space: log(target) - log(envelope)\n    \n    log_target <- target_log_density(candidate_x)\n    # The envelope density at candidate_x is the linear interpolation of log_y\n    # We already have the candidate_x from the line.\n    # The log_envelope at candidate_x is:\n    if (abs(y_next - y_j) < 1e-10) {\n      log_envelope <- y_j\n    } else {\n      m <- (y_next - y_j) / (x_next - x_j)\n      log_envelope <- y_j + m * (candidate_x - x_j)\n    }\n    \n    # Check log-concavity\n    if (!check_log_concavity(candidate_x, log_target, points_x, points_log_y)) {\n      stop("Non-log-concave density detected during sampling.")\n    }\n    \n    # Acceptance probability\n    if (log(runif(1)) < (log_target - log_envelope)) {\n      samples[i] <- candidate_x\n      # Update the envelope with the new point\n      # Find where to insert the new point\n      new_idx <- find(points_x, candidate_x) # This is not a standard R function\n      # Let\'s use order() or similar\n      # We\'ll just append and re-sort\n      points_x <- c(points_x, candidate_x)\n      points_log_y <- c(points_log_y, log_target)\n      # Re-sort points\n      ord <- order(points_x)\n      points_x <- points_x[ord]\n      points_log_y <- points_log_y[ord]\n    } else {\n      # Reject: we need to try again for the same sample index i\n      i <- i - 1\n    }\n  }\n  \n  # The loop above is a bit messy with the i <- i - 1. \n  # Let\'s rewrite it more cleanly.\n  \n  return(samples)\n}\nEOF\n'})
