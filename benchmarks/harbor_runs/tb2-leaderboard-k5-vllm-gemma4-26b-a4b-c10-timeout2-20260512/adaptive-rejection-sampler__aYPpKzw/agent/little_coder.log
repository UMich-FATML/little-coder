n        step <- (u - l) / 100\n        found <- FALSE\n        for (i in 1:100) {\n          curr <- l + i * step\n          if (is.finite(f(curr))) {\n            p1 <- curr\n            found <- TRUE\n            break\n          }\n        }\n        if (!found) stop("Could not find initial point for finite lower bound.")\n      }\n    }\n    \n    if (is.infinite(f(p2))) {\n      if (is.infinite(u)) {\n        curr <- 0\n        step <- 1\n        found <- FALSE\n        for (i in 1:100) {\n          if (is.finite(f(curr))) {\n            p2 <- curr\n            found <- TRUE\n            break\n          }\n          curr <- curr + step\n          step <- step * 2\n        }\n        if (!found) stop("Could not find initial point for Inf upper bound.")\n      } else {\n        step <- (u - l) / 100\n        found <- FALSE\n        for (i in 1:100) {\n          curr <- u - i * step\n          if (is.finite(f(curr))) {\n            p2 <- curr\n            found <- TRUE\n            break\n          }\n        }\n        if (!found) stop("Could not find initial point for finite upper bound.")\n      }\n    }\n    \n    if (is.infinite(f(p1)) || is.infinite(f(p2))) {\n      stop("Could not find initial points with finite density. Check your bounds and density function.")\n    }\n    \n    return(sort(c(p1, p2)))\n  }\n\n  init_pts <- find_initial_points(target_log_density, lower, upper)\n  points_x <- init_pts\n  points_log_y <- target_log_density(points_x)\n\n  samples <- numeric(n_samples)\n  s_idx <- 1\n  \n  while (s_idx <= n_samples) {\n    dx <- diff(points_x)\n    interval_areas <- sapply(1:length(dx), function(j) {\n      x0 <- points_x[j]\n      x1 <- points_x[j+1]\n      y0 <- points_log_y[j]\n      y1 <- points_log_y[j+1]\n      if (abs(y1 - y0) < 1e-12) {\n        return(exp(y0) * (x1 - x0))\n      } else {\n        m <- (y1 - y0) / (x1 - x0)\n        return(exp(y0) * (exp(y1 - y0) - 1) / m)\n      }\n    })\n    \n    probs <- interval_areas / sum(interval_areas)\n    interval_idx <- sample(1:length(probs), 1, prob = probs)\n    \n    x_j <- points_x[interval_idx]\n    x_next <- points_x[interval_idx + 1]\n    y_j <- points_log_y[interval_idx]\n    y_next <- points_log_y[interval_idx + 1]\n    \n    u_val <- runif(1)\n    if (abs(y_next - y_j) < 1e-12) {\n      candidate_x <- x_j + u_val * (x_next - x_j)\n    } else {\n      m <- (y_next - y_j) / (x_next - x_j)\n      candidate_x <- x_j + log(u_val * (exp(y_next - y_j) - 1) + 1) / m\n    }\n    \n    log_target <- target_log_density(candidate_x)\n    if (!check_log_concavity(candidate_x, log_target, points_x, points_log_y)) {\n      stop("Non-log-concave density detected during sampling.")\n    }\n    \n    if (abs(y_next - y_j) < 1e-12) {\n      log_envelope <- y_j\n    } else {\n      m <- (y_next - y_j) / (x_next - x_j)\n      log_envelope <- y_j + m * (candidate_x - x_j)\n    }\n    \n    if (log(runif(1)) < (log_target - log_envelope)) {\n      samples[s_idx] <- candidate_x\n      points_x <- c(points_x, candidate_x)\n      points_log_y <- c(points_log_y, log_target)\n      ord <- order(points_x)\n      points_x <- points_x[ord]\n      points_log_y <- points_log_y[ord]\n      s_idx <- s_idx + 1\n    }\n  }\n  return(samples)\n}\n\ntest <- function() {\n  cat("Starting tests...\\n")\n  results <- list()\n  \n  cat("Running TEST_NORMAL...\\n")\n  target_log_norm <- function(x) dnorm(x, mean = 0, sd = 1, log = TRUE)\n  tryCatch({\n    samples <- ars(target_log_norm, n_samples = 500, lower = -10, upper = 10)\n    m <- mean(samples)\n    s <- sd(samples)\n    if (abs(m - 0) < 0.2 && abs(s - 1) < 0.2) {\n      cat("TEST_NORMAL: PASS (mean =", round(m, 3), ", sd =", round(s, 3), ")\\n")\n      results$normal <- TRUE\n      writeLines(as.character(samples), "/app/normal_samples.txt")\n    } else {\n      cat("TEST_NORMAL: FAIL (mean =", round(m, 3), ", sd =", round(s, 3), ")\\n")\n      results$normal <- FALSE\n    }\n  }, error = function(e) {\n    cat("TEST_NORMAL: FAIL (Error:", e$message, ")\\n")\n    results$normal <- FALSE\n  })\n\n  cat("Running TEST_EXPONENTIAL...\\n")\n  target_log_exp <- function(x) {\n    if (x < 0) return(-Inf)\n    dexp(x, rate = 1, log = TRUE)\n  }\n  tryCatch({\n    samples <- ars(target_log_exp, n_samples = 500, lower = 0, upper = 10)\n    m <- mean(samples)\n    s <- sd(samples)\n    if (abs(m - 1) < 0.2 && abs(s - 1) < 0.2) {\n      cat("TEST_EXPONENTIAL: PASS (mean =", round(m, 3), ", sd =", round(s, 3), ")\\n")\n      results$exponential <- TRUE\n      writeLines(as.character(samples), "/app/exponential_samples.txt")\n    } else {\n      cat("TEST_EXPONENTIAL: FAIL (mean =", round(m, 3), ", sd =", round(s, 3), ")\\n")\n      results$exponential <- FALSE\n    }\n  }, error = function(e) {\n    cat("TEST_EXPONENTIAL: FAIL (Error:", e$message, ")\\n")\n    results$exponential <- FALSE\n  })\n\n  cat("Running TEST_NON_LOG_CONCAVE...\\n")\n  target_log_bimodal <- function(x) {\n    -0.5 * x^4 + 2 * x^2\n  }\n  tryCatch({\n    ars(target_log_bimodal, n_samples = 100, lower = -5, upper = 5)\n    cat("TEST_NON_LOG_CONCAVE: FAIL (Did not catch non-log-concavity)\\n")\n    results$non_log_concave <- FALSE\n  }, error = function(e) {\n    if (grepl("Non-log-concave density detected", e$message)) {\n      cat("TEST_NON_LOG_CONCAVE: PASS (Caught non-log-concavity)\\n")\n      results$non_log_concave <- TRUE\n    } else {\n      cat("TEST_NON_LOG_CONCAVE: FAIL (Caught wrong error:", e$message, ")\\n")\n      results$non_log_concave <- FALSE\n    }\n  })\n\n  cat("Running TEST_INVALID_INPUTS...\\n")\n  tryCatch({\n    ars("not a function", 10)\n    cat("TEST_INVALID_INPUTS: FAIL (Did not catch invalid function)\\n")\n    results$invalid_inputs <- FALSE\n  }, error = function(e) {\n    cat("TEST_INVALID_INPUTS: FAIL (Did not catch invalid function)\\n")\n    results$invalid_inputs <- FALSE\n  })\n\n  cat("Running TEST_INVALID_BOUNDS...\\n")\n  tryCatch({\n    target_log_norm <- function(x) dnorm(x, mean = 0, sd = 1, log = TRUE)\n    ars(target_log_norm, 10, lower = 10, upper = 0)\n    cat("TEST_INVALID_BOUNDS: FAIL (Did not catch invalid bounds)\\n")\n    results$invalid_bounds <- FALSE\n  }, error = function(e) {\n    cat("TEST_INVALID_BOUNDS: FAIL (Caught invalid bounds)\\n")\n    results$invalid_bounds <- FALSE\n  })\n\n  cat("\\nSummary of tests:\\n")\n  for (name in names(results)) {\n    cat(paste0(toupper(name), ": ", if(results[[name]]) "PASS" else "FAIL", "\\n"))\n  }\n}\n\nif (!interactive()) {\n  test()\n}\nEOF\n'})
