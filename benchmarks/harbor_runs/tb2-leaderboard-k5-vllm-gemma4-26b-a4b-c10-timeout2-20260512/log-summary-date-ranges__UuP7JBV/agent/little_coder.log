and log_date <= reference_date:\n                    counts[\'today\'][found_severity] += 1\n                \n                if log_date >= last_7_days_start and log_date <= reference_date:\n                    counts[\'last_7_days\'][found_severity] += 1\n                \n                if log_date >= last_30_days_start and log_date <= reference_date:\n                    counts[\'last_30_days\'][found_severity] += 1\n                \n                if log_date >= month_to_date_start and log_date <= reference_date:\n                    counts[\'month_to_date\'][found_severity] += 1\n\n    # Write to CSV\n    with open(\'/app/summary.csv\', \'w\', newline=\'\') as csvfile:\n        writer = csv.writer(csvfile)\n        writer.writerow([\'period\', \'severity\', \'count\'])\n        \n        # Order of periods as requested\n        order = [\'today\', \'last_7_days\', \'last_30_days\', \'month_to_date\', \'total\']\n        for period in order:\n            for sev in severities:\n                writer.writerow([period, sev, counts[period][sev]])\n\nif __name__ == "__main__":\n    analyze()\nEOF\npython3 /app/analyze_logs.py\n'})
