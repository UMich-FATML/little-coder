>> ShellSession({'command': 'cat << \'EOF\' > /app/analyze_logs.py\nimport os\nimport csv\nfrom datetime import datetime, timedelta\n\ndef analyze():\n    log_dir = \'/app/logs\'\n    reference_date = datetime(2025, 8, 12)\n    \n    # Define periods\n    today_start = reference_date\n    last_7_days_start = reference_date - timedelta(days=6)\n    last_30_days_start = reference_date - timedelta(days=29)\n    month_to_date_start = reference_date.replace(day=1)\n    \n    # Severity levels to count\n    severities = [\'ERROR\', \'WARNING\', \'INFO\']\n    \n    # Initialize counts\n    counts = {\n        \'today\': {s: 0 for s in severities},\n        \'last_7_days\': {s: 0 for s in severities},\n        \'last_30_days\': {s: 0 for s in severities},\n        \'month_to_date\': {s: 0 for s in severities},\n        \'total\': {s: 0 for s in severities}\n    }\n    \n    # Get all log files\n    log_files = [f for f in os.listdir(log_dir) if f.endswith(\'.log\')]\n    \n    for log_file in log_files:\n        # Extract date from filename: YYYY-MM-DD_<source>.log\n        try:\n            date_str = log_file.split(\'_\')[0]\n            log_date = datetime.strptime(date_str, \'%Y-%m-%d\')\n        except Exception:\n            continue\n            \n        file_path = os.path.join(log_dir, log_file)\n        \n        with open(file_path, \'r\') as f:\n            for line in f:\n                # Check for severities\n                found_severity = None\n                for s in severities:\n                    if f\'[{s}]\' in line:\n                        found_severity = s\n                        break\n                \n                if found_severity:\n                    # Update total\n                    counts[\'total\'][found_severity] += 1\n                    \n                    # Update period-specific counts\n                    if log_date == today_start:\n                        counts[\'today\'][found_severity] += 1\n                    \n                    if last_7_days_start <= log_date <= reference_date:\n                        counts[\'last_7_days\'][found_severity] += 1\n                        \n                    if last_30_days_start <= log_date <= reference_date:\n                        counts[\'last_30_days\'][found_severity] += 1\n                        \n                    if month_to_date_start <= log_date <= reference_date:\n                        counts[\'month_to_date\'][found_severity] += 1\n\n    # Write to CSV\n    with open(\'/app/summary.csv\', \'w\', newline=\'\') as csvfile:\n        writer = csv.writer(csvfile)\n        writer.writerow([\'period\', \'severity\', \'count\'])\n        \n        # Order of periods as requested\n        periods = [\'today\', \'last_7_days\', \'last_30_days\', \'month_to_date\', \'total\']\n        for p in periods:\n            for s in severities:\n                writer.writerow([p, s, counts[p][s]])\n\nif __name__ == "__main__":\n    analyze()\nEOF\npython3 /app/analyze_logs.py\n'})
