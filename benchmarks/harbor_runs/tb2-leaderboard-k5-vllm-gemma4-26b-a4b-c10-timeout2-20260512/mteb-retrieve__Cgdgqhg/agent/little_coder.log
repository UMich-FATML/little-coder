>> ShellSession({'command': 'cat <<EOF > /app/solution.py\nimport torch\nfrom sentence_transformers import SentenceTransformer, util\n\ndef main():\n    query = "terminal-bench"\n    model_name = "BAAI/bge-small-zh-v1.5"\n    revision = "7999e1d3359715c523056ef9478215996d62a620"\n    \n    # Load model with specific revision\n    model = SentenceTransformer(model_name, revision=revision)\n    \n    # Read documents\n    with open(\'/app/data.txt\', \'r\', encoding=\'utf-8\') as f:\n        documents = [line.strip() for line in f if line.strip()]\n    \n    if not documents:\n        print("No documents found.")\n        return\n\n    # Encode query and documents\n    query_embedding = model.encode(query, convert_to_tensor=True)\n    doc_embeddings = model.encode(documents, convert_to_tensor=True)\n    \n    # Compute cosine similarities\n    cosine_scores = util.cos_sim(query_embedding, doc_embeddings)[0]\n    \n    # Get indices of top scores in descending order\n    # We want the 5th highest similarity.\n    # Sort scores in descending order\n    sorted_indices = torch.argsort(cosine_scores, descending=True)\n    \n    # The 5th highest is at index 4 (0-indexed)\n    if len(sorted_indices) >= 5:\n        target_idx = sorted_indices[4].item()\n        result_text = documents[target_idx]\n        with open(\'/app/result.txt\', \'w\', encoding=\'utf-8\') as f:\n            f.write(result_text + \'\\n\')\n        print(f"Success: {result_text}")\n    else:\n        print(f"Not enough documents: {len(documents)}")\n\nif __name__ == "__main__":\n    main()\nEOF\n'})
