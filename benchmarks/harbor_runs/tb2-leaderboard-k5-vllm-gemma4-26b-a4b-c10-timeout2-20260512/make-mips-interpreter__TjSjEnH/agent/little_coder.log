>> ShellSession({'command': 'cat <<\'EOF\' > /app/mips_dump.py\nimport sys\nimport struct\n\ndef dump_elf(filename):\n    with open(filename, \'rb\') as f:\n        data = f.read()\n    \n    # Very basic ELF parser for the purpose of this task\n    # We need to find the segments and their contents\n    \n    # ELF Header\n    magic = data[0:4]\n    if magic != b\'\\x7fELF\':\n        print("Not an ELF file")\n        return\n\n    cls = data[4] # 1 = 32-bit, 2 = 64-bit\n    endian = data[5] # 1 = little, 2 = big\n    \n    if cls != 1:\n        print("Only 32-bit ELF supported")\n        return\n\n    if endian == 1:\n        def read_u32(off): return struct.unpack(\'<I\', data[off:off+4])[0]\n        def read_u16(off): return struct.unpack(\'<H\', data[off:off+2])[0]\n    else:\n        def read_u32(off): return struct.unpack(\'>I\', data[off:off+4])[0]\n        def read_u16(off): return struct.unpack(\'>H\', data[off:off+2])[0]\n\n    e_type = read_u16(16)\n    e_machine = read_u16(18)\n    e_version = read_u32(20)\n    e_entry = read_u32(24)\n    e_phoff = read_u32(28)\n    e_phnum = read_u16(32)\n    \n    print(f"Entry: {hex(e_entry)}")\n    print(f"PH Offset: {hex(e_phoff)}")\n    print(f"PH Num: {e_phnum}")\n\n    for i in range(e_phnum):\n        off = e_phoff + i * 32 # Assuming 32-byte program headers\n        p_type = read_u32(off)\n        p_offset = read_u32(off + 4)\n        p_vaddr = read_u32(off + 8)\n        p_paddr = read_u32(off + 12)\n        p_filesz = read_u32(off + 16)\n        p_memsz = read_u32(off + 20)\n        p_flags = read_u32(off + 24)\n        p_align = read_u32(off + 28)\n        \n        print(f"PH {i}: type={hex(p_type)}, offset={hex(p_offset)}, vaddr={hex(p_vaddr)}, filesz={hex(p_filesz)}, memsz={hex(p_memsz)}, flags={hex(p_flags)}")\n\n    return data, e_entry, e_phoff, e_phnum, endian\n\nif __name__ == "__main__":\n    dump_elf(sys.argv[1])\nEOF\npython3 /app/mips_dump.py /app/doomgeneric_mips\n'})
