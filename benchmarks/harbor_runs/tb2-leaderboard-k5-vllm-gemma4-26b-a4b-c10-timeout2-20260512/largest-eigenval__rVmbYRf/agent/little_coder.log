>> ShellSession({'command': 'cat <<\'EOF\' > /app/eigen.py\nimport numpy as np\n\ndef find_dominant_eigenvalue_and_eigenvector(A: np.ndarray):\n    """\n    Find the dominant eigenvalue and eigenvector of a general real square matrix.\n\n    Args:\n        A: Real-valued square matrix (accepts numpy arrays) up to size 10x10,\n        dtype np.float64.\n\n    Returns:\n        eigenvalue: Dominant eigenvalue (numpy scalar, potentially complex)\n        eigenvector: Corresponding eigenvector (np.ndarray, potentially complex)\n    """\n    # For small matrices, np.linalg.eig is very fast.\n    # To beat it, we can try to use a more direct method if possible,\n    # but for 10x10, the overhead is mostly in the Python-to-C call.\n    # Let\'s try to use the fact that for small matrices, we can just use eig\n    # but maybe we can optimize the selection.\n    \n    # Actually, let\'s try to use the power iteration but with a trick to handle\n    # complex conjugate pairs: use a 2D subspace (subspace iteration).\n    \n    n = A.shape[0]\n    # Use a small number of vectors for subspace iteration\n    # For 10x10, 2 or 3 vectors should be enough to catch complex pairs.\n    m = 2\n    Q = np.random.randn(n, m).astype(np.complex128)\n    \n    for _ in range(20):\n        Z = A @ Q\n        Q, _ = np.linalg.qr(Z)\n        \n    # Now Q contains the subspace. We solve the small eigenvalue problem on the subspace.\n    # B = Q^H A Q\n    B = Q.conj().T @ A @ Q\n    eigvals, eigvecs_small = np.linalg.eig(B)\n    \n    idx = np.argmax(np.abs(eigvals))\n    dominant_eigval = eigvals[idx]\n    dominant_eigvec = Q @ eigvecs_small[:, idx]\n    \n    return dominant_eigval, dominant_eigvec\nEOF\n'})
