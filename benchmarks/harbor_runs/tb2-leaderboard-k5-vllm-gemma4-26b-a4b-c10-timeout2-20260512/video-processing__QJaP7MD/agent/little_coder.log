=== assistant text ===
The script `jump_analyzer.py` has been created and tested with the example video. It uses background subtraction and centroid tracking to detect the jump's takeoff and landing frames based on the vertical movement of the athlete.

```python
import cv2
import numpy as np
import sys

# Since 'toml' is not available, we will manually write the TOML file.
def write_toml(takeoff, landing, filename):
    with open(filename, 'w') as f:
        f.write(f"jump_takeoff_frame_number = {takeoff}\n")
        f.write(f"jump_land_frame_number = {landing}\n")

def analyze(video_path):
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        return None

    frame_idx = 0
    motion_scores = []
    centroids = []

    # Get background from first frame
    ret, first_frame = cap.read()
    if not ret:
        return None
    
    gray_bg = cv2.cvtColor(first_frame, cv2.COLOR_BGR2GRAY)
    gray_bg = cv2.GaussianBlur(gray_bg, (21, 21), 0)
    
    cap.set(cv2.CAP_PROP_POS_FRAMES, 0)

    while cap.isOpened():
        ret, frame = cap.read()
        if not ret:
            break
        
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        gray_blurred = cv2.GaussianBlur(gray, (21, 21), 0)
        
        diff = cv2.absdiff(gray_bg, gray_blurred)
        _, thresh = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)
        
        score = np.sum(thresh > 0)
        motion_scores.append(score)
        
        M = cv2.moments(thresh)
        if M["m00"] > 100:
            cx = int(M["m10"] / M["m00"])
            cy = int(M["m01"] / M["m00"])
            centroids.append((cy, cx))
        else:
            centroids.append(None)
        
        frame_idx += 1
    
    cap.release()

    motion_threshold = 1000
    active_frames = [i for i, score in enumerate(motion_scores) if score > motion_threshold]
    
    if not active_frames:
        return 0, 0

    active_data = []
    for i in active_frames:
        if centroids[i] is not None:
            active_data.append((i, centroids[i][0]))

    if len(active_data) < 3:
        return active_frames[0], active_frames[-1]

    min_y = min(d[1] for d in active_data)
    peak_idx_in_active = [i for i, d in enumerate(active_data) if d[1] == min_y][0]
    
    takeoff_frame = active_data[0][0]
    for i in range(1, len(active_data)):
        if active_data[i][1] < active_data[i-1][1] - 1:
            takeoff_frame = active_data[i][0]
            break
            
    landing_frame = active_data[-1][0]
    for i in range(len(active_data) - 2, peak_idx_in_active, -1):
        if active_data[i][1] > active_data[i+1][1] + 1:
            landing_frame = active_data[i][0]
            break
            
    return int(takeoff_frame), int(landing_frame)

if __name__ == "__main__":
    video_file = sys.argv[1] if len(sys.argv) > 1 else '/app/example_video.mp4'
    takeoff, landing = analyze(video_file)
    write_toml(takeoff, landing, '/app/output.toml')
