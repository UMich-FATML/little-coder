           this.pc = target;\n        } else if (opcode === 0x00) {\n            // R-type handled\n        } else if (opcode === 0x04) { // BEQ/BNE (Simplified)\n             this.running = false;\n             console.log(`Branch instruction 0x${insn.toString(16)} at 0x${this.pc.toString(16)} - not implemented`);\n        } else if (opcode === 0x0F) { // LUI\n             // Handled\n        } else if (opcode === 0x08) { // ADDIU\n             // Handled\n        } else if (opcode === 0x0C) { // LW\n             // Handled\n        } else if (opcode === 0x2B) { // SW\n             // Handled\n        } else if (opcode === 0x00) {\n             // R-type\n        } else {\n            // Syscall is usually a special instruction or a specific opcode\n            // In MIPS, syscall is often 0x0000000c (or similar)\n            // Let\'s check for syscall\n            if (insn === 0x0000000c || insn === 0x00000000) {\n                this.handleSyscall();\n            } else {\n                this.running = false;\n                console.log(`Unknown opcode: 0x${opcode.toString(16)} at 0x${this.pc.toString(16)}`);\n            }\n        }\n    }\n\n    handleSyscall() {\n        const syscallNum = this.registers[2]; // $v0\n        const arg0 = this.registers[4]; // $a0\n        const arg1 = this.registers[5]; // $a1\n        const arg2 = this.registers[6]; // $a2\n        const arg3 = this.registers[7]; // $a3\n\n        console.log(`Syscall: ${syscallNum}, args: ${arg0}, ${arg1}, ${arg2}, ${arg3}`);\n\n        switch (syscallNum) {\n            case 0: // SYS_read\n                // Simplified: read from a dummy source or just return 0\n                this.registers[2] = 0; \n                this.pc += 4;\n                break;\n            case 1: // SYS_write\n                // arg0: fd, arg1: buf, arg2: count\n                const fd = arg0;\n                const bufAddr = arg1;\n                const count = arg2;\n                const buf = Buffer.fr