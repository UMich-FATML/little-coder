}: {corr:.4f}")\n\nprint("\\nConditional Correlations (approximate):")\nfor i in range(len(cols)):\n    for j in range(i + 1, len(cols)):\n        for k in range(len(cols)):\n            if k == i or k == j: continue\n            cond_corr = calculate_conditional_correlation(data, i, j, k)\n            print(f"{cols[i]} - {cols[j]} | cond on {cols[k]}: {cond_corr:.4f}")\n\nEOF\npython3 analyze_data_v4.py'})
