>> ShellSession({'command': 'cat <<EOF > /app/run.py\nimport asyncio\nimport signal\nfrom typing import Callable, Awaitable, List\n\nasync def run_tasks(tasks: List[Callable[[], Awaitable[None]]], max_concurrent: int) -> None:\n    """\n    Runs a list of async tasks with a limit on concurrency.\n    Handles KeyboardInterrupt (SIGINT) to allow tasks to perform cleanup.\n    """\n    semaphore = asyncio.Semaphore(max_concurrent)\n    \n    # We use a loop to manage the tasks. \n    # To handle cancellation gracefully, we wrap the execution in a try/finally block.\n    \n    async def worker(task: Callable[[], Awaitable[None]]):\n        async with semaphore:\n            try:\n                await task()\n            except asyncio.CancelledError:\n                # This is where task-specific cleanup happens if the task \n                # itself handles CancelledError or if we want to ensure \n                # something happens here.\n                raise\n            except Exception as e:\n                print(f"Task failed with error: {e}")\n                raise\n\n    # Create task objects\n    running_tasks = []\n    \n    # We need to handle the signal for KeyboardInterrupt\n    loop = asyncio.get_running_loop()\n    \n    # Define a way to stop everything\n    stop_event = asyncio.Event()\n\n    def signal_handler():\n        print("\\nReceived interrupt signal. Cancelling tasks...")\n        stop_event.set()\n\n    # Register signal handlers for SIGINT and SIGTERM\n    # Note: In some environments, signal handlers must be set in the main thread.\n    # Since we are inside an async function, we rely on the loop\'s ability to handle it.\n    try:\n        for sig in (signal.SIGINT, signal.SIGTERM):\n            loop.add_signal_handler(sig, signal_handler)\n    except NotImplementedError:\n        # add_signal_handler is not implemented on Windows or some other platforms\n        # but we are in a Linux container.\n        pass\n\n    try:\n        # Create all tasks\n        task_objects = [asyncio.create_task(worker(t)) for t in tasks]\n        \n        # Wait for all tasks to complete or for the stop event to be set\n        # We use wait with return_when=FIRST_COMPLETED to check the stop_event\n        \n        # However, a simpler way to handle the "wait for all or stop" is to \n        # wrap the gathering in a task that waits for the stop_event.\n        \n        async def wait_for_completion():\n            await asyncio.gather(*task_objects)\n\n        completion_task = asyncio.create_task(wait_for_completion())\n        \n        # Wait for either completion or the stop event\n        done, pending = await asyncio.wait(\n            [completion_task, stop_event.wait()],\n            return_when=asyncio.FIRST_COMPLETED\n        )\n\n        if stop_event.is_set():\n            # Cancel all running tasks\n            for t in task_objects:\n                if not t.done():\n                    t.cancel()\n            \n            # Wait for tasks to finish their cancellation/cleanup\n            await asyncio.gather(*task_objects, return_exceptions=True)\n            print("All tasks cancelled and cleaned up.")\n\n    except Exception as e:\n        print(f"An error occurred in run_tasks: {e}")\n        # Ensure tasks are cancelled if an error occurs in the runner itself\n        for t in task_objects:\n            if not t.done():\n                t.cancel()\n        await asyncio.gather(*task_objects, return_exceptions=True)\n        raise\n    finally:\n        # Clean up signal handlers\n        try:\n            for sig in (signal.SIGINT, signal.SIGTERM):\n                loop.remove_signal_handler(sig)\n        except Exception:\n            pass\n\nEOF\n'})
