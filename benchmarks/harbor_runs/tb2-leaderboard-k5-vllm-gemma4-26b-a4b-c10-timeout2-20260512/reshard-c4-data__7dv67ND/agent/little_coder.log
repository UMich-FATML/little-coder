iles_in_current_shard = 0\n    shard_counter = 0\n\n    for root, dirs, files in os.walk(input_dir):\n        for file in files:\n            full_path = os.path.join(root, file)\n            rel_path = os.path.relpath(full_path, input_dir)\n            \n            file_size = os.path.getsize(full_path)\n            \n            # Check if we need a new shard based on file count\n            if files_in_current_shard >= MAX_FILES_PER_DIR:\n                shard_counter += 1\n                current_shard_dir = os.path.join(output_dir, f"shard_{shard_counter:05d}")\n                os.makedirs(current_shard_dir, exist_ok=True)\n                files_in_current_shard = 0\n\n            if rel_path not in manifest:\n                manifest[rel_path] = []\n\n            # Handle file splitting if > 15MB\n            if file_size > MAX_FILE_SIZE:\n                # Split file\n                with open(full_path, \'rb\') as f:\n                    chunk_idx = 0\n                    while True:\n                        chunk = f.read(MAX_FILE_SIZE)\n                        if not chunk:\n                            break\n                        \n                        chunk_filename = f"{hashlib.md5(rel_path.encode()).hexdigest()}_{chunk_idx}.part"\n                        dest_path = os.path.join(current_shard_dir, chunk_filename)\n                        \n                        with open(dest_path, \'wb\') as df:\n                            df.write(chunk)\n                        \n                        manifest[rel_path].append((f"shard_{shard_counter:05d}", chunk_filename))\n                        files_in_current_shard += 1\n                        \n                        if files_in_current_shard >= MAX_FILES_PER_DIR:\n                            shard_counter += 1\n                            current_shard_dir = os.path.join(output_dir, f"shard_{shard_counter:05d}")\n                            os.makedirs(current_shard_dir, exist_ok=True)\n                            files_in_current_shard = 0\n                        \n                        chunk_idx += 1\n            else:\n                # Single file\n                chunk_filename = f"{hashlib.md5(rel_path.encode()).hexdigest()}_{0}.file"\n                dest_path = os.path.join(current_shard_dir, chunk_filename)\n                shutil.copy2(full_path, dest_path)\n                manifest[rel_path].append((f"shard_{shard_counter:05d}", chunk_filename))\n                files_in_current_shard += 1\n\n    with open(manifest_path, \'w\') as f:\n        json.dump(manifest, f, indent=2)\n\nif __name__ == "__main__":\n    if len(sys.argv) != 3:\n        print("Usage: python compress.py <input_dir> <output_dir>")\n        sys.exit(1)\n    compress(sys.argv[1], sys.argv[2])\nEOF\n'})
