>> ShellSession({'command': 'cat <<EOF > /app/solution.sparql\nPREFIX uni: <http://university.org/ontology/>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n\nSELECT ?professorName (GROUP_CONCAT(DISTINCT ?country; separator=", ") AS ?countries)\nWHERE {\n  # 1. They are full professors.\n  # Based on the data, professors have a role like "Professor of ..."\n  # We\'ll use regex to match "Professor" in the role.\n  ?professor uni:hasName ?professorName ;\n             uni:role ?role ;\n             uni:worksIn ?dept .\n  FILTER(REGEX(?role, "Professor", "i") && !REGEX(?role, "Assistant Professor", "i") && !REGEX(?role, "Associate Professor", "i"))\n\n  # 2. They work in at least one department of a university located in an EU country.\n  ?dept uni:belongsTo ?university .\n  ?university uni:locatedInCountry ?country .\n  \n  # EU Member States as of 2025-08-16 (ISO 3166-1 alpha-2)\n  # AT, BE, BG, CY, CZ, DE, DK, EE, ES, FI, FR, GR, HR, HU, IE, IT, LT, LU, LV, MT, NL, PL, PT, RO, SE, SI, SK\n  FILTER(?country IN ("AT", "BE", "BG", "CY", "CZ", "DE", "DK", "EE", "ES", "FI", "FR", "GR", "HR", "HU", "IE", "IT", "LT", "LU", "LV", "MT", "NL", "PL", "PT", "RO", "SE", "SI", "SK"))\n\n  # 3. Among all departments they work in, at least one has more than 10 students currently enrolled in any classes taught in that department.\n  # We need to check if there exists a department (?dept2) where the professor works,\n  # and that department has > 10 students in its classes.\n  # Note: The requirement says "Among all departments they work in, at least one has..."\n  # This means the professor must satisfy the EU condition (which we did), \n  # AND there must exist a department they work in that meets the student count condition.\n  \n  {\n    SELECT ?professor (COUNT(DISTINCT ?student) AS ?studentCount)\n    WHERE {\n      ?professor uni:worksIn ?dept2 .\n      ?dept2 uni:isTaughtIn ?course .\n      ?student uni:isEnrolledIn ?course .\n      # Check if student is still enrolled (not graduated)\n      OPTIONAL { ?student uni:hasGraduationDate ?gradDate . }\n      FILTER(!BOUND(?gradDate) || ?gradDate > "2025-08-16"^^xsd:date)\n    }\n    GROUP BY ?professor ?dept2\n    HAVING (COUNT(DISTINCT ?student) > 10)\n  }\n  \n  # To ensure the professor meets the "at least one department" condition for the student count:\n  # The subquery above finds (professor, dept2) pairs. \n  # We need to link the professor to the existence of such a dept2.\n  # Since the subquery is in the WHERE clause, it acts as a filter.\n  # However, the subquery returns ?professor. We need to make sure the professor \n  # we are selecting is one of those.\n  \n  # Let\'s refine the structure to be cleaner.\n}\nGROUP BY ?professorName\nEOF\n'})
