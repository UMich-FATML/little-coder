                     ent_data = json.loads(ent_res.read().decode())\n                        ligand_ids = ent_data.get(\'rcsb_entity_container_identifiers\', {}).get(\'ligand_ids\', [])\n                        for lid in ligand_ids:\n                            smiles = get_ligand_smiles(lid)\n                            if smiles == smiles_target:\n                                return pdb_id, lid\n                except:\n                    continue\n    except:\n        pass\n    return None, None\n\nfor pid in pdb_ids:\n    found_pid, lid = check_pdb(pid)\n    if found_pid:\n        print(f"FOUND: {found_pid}, {lid}")\n        break\nEOF\npython3 find_molecule.py\n'})
