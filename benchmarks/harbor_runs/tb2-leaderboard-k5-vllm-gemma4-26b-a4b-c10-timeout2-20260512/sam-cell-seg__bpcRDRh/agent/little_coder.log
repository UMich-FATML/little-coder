ounding box from the new mask to be precise\n        y_indices, x_indices = np.where(mask)\n        if len(x_indices) > 0:\n            new_xmin = int(np.min(x_indices))\n            new_xmax = int(np.max(x_indices))\n            new_ymin = int(np.min(y_indices))\n            new_ymax = int(np.max(y_indices))\n        else:\n            new_xmin, new_xmax, new_ymin, new_ymax = xmin, xmax, ymin, ymax\n\n        # Create new row\n        new_row = row.copy()\n        new_row[\'xmin\'] = new_xmin\n        new_row[\'ymin\'] = new_ymin\n        new_row[\'xmax\'] = new_xmax\n        new_row[\'ymax\'] = new_ymax\n        new_row[\'coords_x\'] = coords_x_str\n        new_row[\'coords_y\'] = coords_y_str\n        new_rows.append(new_row)\n\n    # Create new DataFrame\n    new_df = pd.DataFrame(new_rows)\n    \n    # Save to CSV\n    output_csv_path = os.path.join(args.output_path, os.path.basename(args.csv_path))\n    new_df.to_csv(output_csv_path, index=False)\n    print(f"Saved new masks to {output_csv_path}")\n\nif __name__ == "__main__":\n    main()\nEOF\n'})
