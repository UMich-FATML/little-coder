>> ShellSession({'command': 'cat <<\'EOF\' > /app/eigen.py\nimport numpy as np\n\ndef find_dominant_eigenvalue_and_eigenvector(A: np.ndarray):\n    """\n    Find the dominant eigenvalue and eigenvector of a general real square matrix.\n\n    Args:\n        A: Real-valued square matrix (accepts numpy arrays) up to size 10x10,\n        dtype np.float64.\n\n    Returns:\n        eigenvalue: Dominant eigenvalue (numpy scalar, potentially complex)\n        eigenvector: Corresponding eigenvector (np.ndarray, potentially complex)\n    """\n    # For 10x10, np.linalg.eig is very fast, but we want to beat it.\n    # Power iteration is the standard way to find the dominant eigenvalue.\n    # To handle complex conjugate pairs (where |lambda1| = |lambda2|), \n    # we can use subspace iteration with 2 vectors.\n    \n    n = A.shape[0]\n    if n == 1:\n        return A[0, 0], np.array([1.0])\n\n    # Subspace iteration with 2 vectors to handle complex conjugate pairs\n    # and potentially improve convergence.\n    Q = np.random.randn(n, 2).astype(complex)\n    \n    for _ in range(30):\n        Z = A @ Q\n        # Orthonormalize using QR\n        Q, _ = np.linalg.qr(Z)\n        \n    # After subspace iteration, the dominant eigenvalue/vector should be in the subspace.\n    # We can find it by solving the small 2x2 problem in the subspace.\n    # A @ Q = Q @ R (approx)\n    # R = Q.H @ A @ Q\n    R = Q.conj().T @ A @ Q\n    \n    # Solve the 2x2 eigenvalue problem\n    eigvals_2x2, eigvecs_2x2 = np.linalg.eig(R)\n    \n    idx = np.argmax(np.abs(eigvals_2x2))\n    dominant_eigval = eigvals_2x2[idx]\n    dominant_eigvec_subspace = eigvecs_2x2[:, idx]\n    \n    # Transform back to original space\n    dominant_eigvec = Q @ dominant_eigvec_subspace\n    \n    # Check if it\'s actually valid. If not, fallback to np.linalg.eig.\n    # This fallback is only used if subspace iteration fails.\n    if not np.allclose(A @ dominant_eigvec, dominant_eigval * dominant_eigvec, atol=1e-5):\n        eigenvalues, eigenvectors = np.linalg.eig(A)\n        idx_ref = np.argmax(np.abs(eigenvalues))\n        return eigenvalues[idx_ref], eigenvectors[:, idx_ref]\n        \n    return dominant_eigval, dominant_eigvec\nEOF\n'})
