ose(A @ x, eigval * x, atol=1e-5):\n        eigenvalues, eigenvectors = np.linalg.eig(A)\n        idx = np.argmax(np.abs(eigenvalues))\n        return eigenvalues[idx], eigenvectors[:, idx]\n        \n    return eigval, x\nEOF\n'})
