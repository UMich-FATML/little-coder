                     bounds=([x0_g-50, 0, 0, offset_g-100], [x0_g+50, 100, amp_g*2, offset_g+100]))\n\n    # 2D peak\n    two_d_mask = (x > 2600) & (x < 2800)\n    x_2d = x[two_d_mask]\n    y_2d = y[two_d_mask]\n    \n    if len(x_2d) == 0:\n        # Fallback\n        two_d_idx = np.argmax(y[x > 2500])\n        x0_2d = x[two_d_idx]\n    else:\n        x0_2d = x_2d[np.argmax(y_2d)]\n        \n    amp_2d = np.max(y_2d) if len(y_2d) > 0 else np.max(y)\n    offset_2d = np.min(y)\n    gamma_2d = 30.0\n    \n    popt_2d, _ = curve_fit(lorentzian, x, y, p0=[x0_2d, gamma_2d, amp_2d, offset_2d],\n                          bounds=([x0_2d-100, 0, 0, offset_2d-100], [x0_2d+100, 100, amp_2d*2, offset_2d+100]))\n\n    results = {\n        "G": {\n            "x0": popt_g[0],\n            "gamma": popt_g[1],\n            "amplitude": popt_g[2],\n            "offset": popt_g[3]\n        },\n        "2D": {\n            "x0": popt_2d[0],\n            "gamma": popt_2d[1],\n            "amplitude": popt_2d[2],\n            "offset": popt_2d[3]\n        }\n    }\n\n    with open(\'/app/results.json\', \'w\') as f:\n        json.dump(results, f, indent=2)\n    \n    print("Results written to /app/results.json")\n    print(json.dumps(results, indent=2))\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/fit_peaks.py'})
