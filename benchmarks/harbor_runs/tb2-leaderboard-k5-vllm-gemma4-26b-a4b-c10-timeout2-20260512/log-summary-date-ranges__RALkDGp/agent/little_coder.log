>> ShellSession({'command': 'cat << \'EOF\' > /app/analyze_logs.py\nimport os\nimport csv\nfrom datetime import datetime, timedelta\n\ndef analyze():\n    log_dir = \'/app/logs\'\n    reference_date = datetime(2025, 8, 12)\n    \n    # Define date ranges\n    today_start = reference_date.replace(hour=0, minute=0, second=0, microsecond=0)\n    last_7_days_start = today_start - timedelta(days=6)\n    last_30_days_start = today_start - timedelta(days=29)\n    month_to_date_start = reference_date.replace(day=1, hour=0, minute=0, second=0, microsecond=0)\n\n    # Severity levels to count\n    severities = [\'ERROR\', \'WARNING\', \'INFO\']\n    \n    # Initialize counts\n    counts = {\n        \'today\': {s: 0 for s in severities},\n        \'last_7_days\': {s: 0 for s in severities},\n        \'last_30_days\': {s: 0 for s in severities},\n        \'month_to_date\': {s: 0 for s in severities},\n        \'total\': {s: 0 for s in severities}\n    }\n\n    # Get all log files\n    log_files = [f for f in os.listdir(log_dir) if f.endswith(\'.log\')]\n\n    for log_file in log_files:\n        # Extract date from filename: YYYY-MM-DD_<source>.log\n        try:\n            date_str = log_file.split(\'_\')[0]\n            file_date = datetime.strptime(date_str, \'%Y-%m-%d\')\n        except (ValueError, IndexError):\n            continue\n\n        with open(os.path.join(log_dir, log_file), \'r\') as f:\n            for line in f:\n                # Check for severity in line\n                for sev in severities:\n                    if f\'[{sev}]\' in line:\n                        # Update total\n                        counts[\'total\'][sev] += 1\n                        \n                        # Update period-specific counts\n                        if file_date >= today_start:\n                            counts[\'today\'][sev] += 1\n                        \n                        if file_date >= last_7_days_start:\n                            counts[\'last_7_days\'][sev] += 1\n                            \n                        if file_date >= last_30_days_start:\n                            counts[\'last_30_days\'][sev] += 1\n                            \n                        if file_date >= month_to_date_start:\n                            counts[\'month_to_date\'][sev] += 1\n                        \n                        # Break after finding the severity for this line to avoid double counting if multiple exist (though unlikely)\n                        break\n\n    # Write to CSV\n    with open(\'/app/summary.csv\', \'w\', newline=\'\') as csvfile:\n        writer = csv.writer(csvfile)\n        writer.writerow([\'period\', \'severity\', \'count\'])\n        \n        # Order of output as specified in the task\n        order = [\n            (\'today\', \'ERROR\'), (\'today\', \'WARNING\'), (\'today\', \'INFO\'),\n            (\'last_7_days\', \'ERROR\'), (\'last_7_days\', \'WARNING\'), (\'last_7_days\', \'INFO\'),\n            (\'last_30_days\', \'ERROR\'), (\'last_30_days\', \'WARNING\'), (\'last_30_days\', \'INFO\'),\n            (\'month_to_date\', \'ERROR\'), (\'month_to_date\', \'WARNING\'), (\'month_to_date\', \'INFO\'),\n            (\'total\', \'ERROR\'), (\'total\', \'WARNING\'), (\'total\', \'INFO\')\n        ]\n        \n        for period, sev in order:\n            writer.writerow([period, sev, counts[period][sev]])\n\nif __name__ == "__main__":\n    analyze()\nEOF\npython3 /app/analyze_logs.py'})
