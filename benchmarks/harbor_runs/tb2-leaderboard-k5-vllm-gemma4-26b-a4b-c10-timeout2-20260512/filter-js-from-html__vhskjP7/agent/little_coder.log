>> ShellSession({'command': 'cat << \'EOF\' > /app/filter.py\nimport sys\nimport re\nimport os\n\ndef filter_html(file_path):\n    if not os.path.exists(file_path):\n        print(f"Error: File {file_path} not found.")\n        sys.exit(1)\n\n    with open(file_path, \'r\', encoding=\'utf-8\') as f:\n        content = f.read()\n\n    # 1. Remove <script>...</script> blocks (case-insensitive, including content)\n    # Using DOTALL to match across multiple lines\n    content = re.sub(r\'<script\\b[^>]*>.*?</script>\', \'\', content, flags=re.DOTALL | re.IGNORECASE)\n\n    # 2. Remove inline event handlers (e.g., onclick, onerror, onload, etc.)\n    # These are attributes that start with \'on\' followed by letters/numbers\n    # We look for patterns like: onsomething="..." or onsomething=\'...\' or onsomething=...\n    # This regex targets attributes that start with \'on\' and are followed by alphanumeric characters,\n    # then an equals sign, then a quoted or unquoted value.\n    # Note: This is a heuristic and might catch some non-JS attributes if they exist, \n    # but in HTML \'on*\' attributes are almost exclusively JS event handlers.\n    content = re.sub(r\'\\son[a-zA-Z0-9]+\\s*=\\s*("[^"]*"|\\\'[^\\\']*\\\'|[^\\s>]+)\', \'\', content, flags=re.IGNORECASE)\n\n    # 3. Remove javascript: pseudo-protocol in attributes (e.g., <a href="javascript:alert(1)">)\n    content = re.sub(r\'href\\s*=\\s*["\\\']\\s*javascript:[^"\\\']*["\\\']\', \'href="#"\', content, flags=re.IGNORECASE)\n    content = re.sub(r\'href\\s*=\\s*["\\\']\\s*javascript:[^"\\\']*["\\\']\', \'href="#"\', content, flags=re.IGNORECASE)\n    # More robustly:\n    content = re.sub(r\'(href|src|action|formaction)\\s*=\\s*["\\\']\\s*javascript:[^"\\\']*["\\\']\', r\'\\1="#"\', content, flags=re.IGNORECASE)\n\n    # 4. Remove <svg> onload/onerror etc if they weren\'t caught by the attribute regex\n    # (The attribute regex should have caught them, but being safe)\n\n    with open(file_path, \'w\', encoding=\'utf-8\') as f:\n        f.write(content)\n\nif __name__ == "__main__":\n    if len(sys.argv) != 2:\n        print("Usage: python filter.py <html_file>")\n        sys.exit(1)\n\n    filter_html(sys.argv[1])\nEOF\n'})
