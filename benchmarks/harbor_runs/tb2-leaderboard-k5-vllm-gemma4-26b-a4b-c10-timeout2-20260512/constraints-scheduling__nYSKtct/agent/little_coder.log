nd.hour == 17 and slot_end.minute > 0):\n                continue\n            if (is_tuesday or is_thursday) and slot_end > datetime.datetime(2024, 1, day, 16, 30, 0):\n                continue\n            \n            # 4. Carol\'s hard constraints: 9 AM - 5 PM. Lunch 12:00-12:30.\n            if slot_start.hour < 9 or slot_end.hour > 17 or (slot_end.hour == 17 and slot_end.minute > 0):\n                continue\n            lunch_start = current_day.replace(hour=12, minute=0, second=0)\n            lunch_end = current_day.replace(hour=12, minute=30, second=0)\n            if not (slot_end <= lunch_start or slot_start >= lunch_end):\n                continue\n            \n            # 5. Check existing calendar conflicts\n            conflict = False\n            for s, e in alice_events + bob_events + carol_events:\n                if not (slot_end <= s or slot_start >= e):\n                    conflict = True\n                    break\n            if conflict:\n                continue\n            \n            # 6. Carol\'s buffer constraint for existing meetings\n            for s, e in carol_events:\n                if (e.hour == 16 and e.minute >= 45) or (e.hour >= 17):\n                    if slot_start < e + datetime.timedelta(minutes=15):\n                        conflict = True\n                        break\n            if conflict:\n                continue\n\n            is_alice_morning = (slot_end <= current_day.replace(hour=12, minute=0, second=0))\n            valid_slots.append({\n                \'start\': slot_start,\n                \'end\': slot_end,\n                \'is_monday\': is_monday,\n                \'is_alice_morning\': is_alice_morning\n            })\n\n    if not valid_slots:\n        return None\n\n    # The prompt says: "Find the earliest valid time slot... Among multiple valid options, prefer slots that avoid Carol\'s Monday preference."\n    # This is still slightly ambiguous. Let\'s try to interpret "Among multiple valid options" as \n    # "If there are multiple valid slots, we have a preference order".\n    # But "earliest" is usually the most important.\n    # Let\'s assume the priority is:\n    # 1. Earliest start time.\n    # 2. If there\'s a tie in start time (impossible with minute granularity), use preferences.\n    # Wait, if "multiple valid options" means "all valid options", then "earliest" and "prefer not Monday" \n    # might be in conflict.\n    # Let\'s try this: Find the earliest slot. If that slot is on Monday, check if there\'s a non-Monday slot \n    # that is "close" or if the instruction implies we should skip Monday if possible.\n    # Actually, "Find the earliest valid time slot... Among multiple valid options, prefer slots that avoid Carol\'s Monday preference."\n    # usually means:\n    # Sort by (start_time, is_monday, not_alice_morning)\n    # where is_monday is 1 for Monday and 0 for others (to prefer 0).\n    # and not_alice_morning is 1 for afternoon and 0 for morning.\n    \n    # Let\'s sort and pick the first one.\n    # To prefer NOT Monday, we use (slot[\'start\'], 1 if slot[\'is_monday\'] else 0, 0 if slot[\'is_alice_morning\'] else 1)\n    \n    valid_slots.sort(key=lambda x: (x[\'start\'], 1 if x[\'is_monday\'] else 0, 0 if x[\'is_alice_morning\'] else 1))\n    return valid_slots[0]\n\nresult = solve()\nif result:\n    print(f"START:{result[\'start\'].strftime(\'%Y%m%dT%H%M%SZ\')}")\n    print(f"END:{result[\'end\'].strftime(\'%Y%m%dT%H%M%SZ\')}")\nelse:\n    print("NONE")\nEOF\npython3 /app/solver.py\n'})
