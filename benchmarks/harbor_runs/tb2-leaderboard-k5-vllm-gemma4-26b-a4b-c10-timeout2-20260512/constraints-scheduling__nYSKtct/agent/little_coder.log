          \n                # Check if slot_end is within Alice\'s 2 PM limit\n                if slot_end > current_day.replace(hour=14, minute=0, second=0):\n                    continue\n\n                # Check Carol\'s lunch (12:00-12:30)\n                lunch_start = current_day.replace(hour=12, minute=0, second=0)\n                lunch_end = current_day.replace(hour=12, minute=30, second=0)\n                if not (slot_end <= lunch_start or slot_start >= lunch_end):\n                    continue\n\n                # Check existing calendar conflicts\n                conflict = False\n                for s, e in alice_events + bob_events + carol_events:\n                    if not (slot_end <= s or slot_start >= e):\n                        conflict = True\n                        break\n                if conflict:\n                    continue\n                \n                # Carol\'s buffer constraint\n                for s, e in carol_events:\n                    if (e.hour == 16 and e.minute >= 45) or (e.hour >= 17):\n                        if slot_start < e + datetime.timedelta(minutes=15):\n                            conflict = True\n                            break\n                if conflict:\n                    continue\n\n                is_alice_morning = (slot_end <= current_day.replace(hour=12, minute=0, second=0))\n                valid_slots.append({\n                    \'start\': slot_start,\n                    \'end\': slot_end,\n                    \'is_monday\': is_monday,\n                    \'is_alice_morning\': is_alice_morning\n                })\n\n    if not valid_slots:\n        return None\n\n    # "Find the earliest valid time slot... Among multiple valid options, prefer slots that avoid Carol\'s Monday preference."\n    # This is the tricky part. If "earliest" is the primary key, we just take the first.\n    # If "prefer not Monday" is a tie-breaker for the earliest time, it\'s useless because \n    # there\'s only one earliest time.\n    # If "prefer not Monday" means "If there are valid slots on Monday and Tuesday, \n    # and we want the earliest, but we prefer not Monday", it usually means \n    # we prioritize non-Monday slots if they are "reasonable".\n    # However, in competitive programming/tasks, "earliest" usually means the absolute minimum.\n    # Let\'s try sorting by (is_monday, start_time) to see if that\'s what they mean by "prefer".\n    # Wait, "Among multiple valid options" - if we consider ALL valid options, \n    # then we sort by (is_monday, start_time).\n    # But the instruction says "Find the earliest... Among multiple valid options, prefer...".\n    # This usually means:\n    # 1. Find the earliest time.\n    # 2. If there are multiple slots at that same earliest time (not possible), use preferences.\n    # OR\n    # 1. Find all valid slots.\n    # 2. Sort them by (is_monday, start_time).\n    \n    # Let\'s try the most literal: Earliest first.\n    valid_slots.sort(key=lambda x: x[\'start\'])\n    return valid_slots[0]\n\nresult = solve()\nif result:\n    print(f"START:{result[\'start\'].strftime(\'%Y%m%dT%H%M%SZ\')}")\n    print(f"END:{result[\'end\'].strftime(\'%Y%m%dT%H%M%SZ\')}")\nelse:\n    print("NONE")\nEOF\npython3 /app/solver.py\n'})
