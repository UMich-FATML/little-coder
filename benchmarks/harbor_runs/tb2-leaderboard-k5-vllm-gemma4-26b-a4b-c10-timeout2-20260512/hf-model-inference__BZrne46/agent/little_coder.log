   elif sentiment_label == "negative":\n            final_sentiment = "negative"\n        else:\n            # Fallback if labels are different\n            final_sentiment = sentiment_label\n\n        # Construct confidence object\n        # We need to return both positive and negative scores\n        # Based on SST-2: 0 is negative, 1 is positive\n        # We\'ll assume 0 is negative and 1 is positive for the confidence dict\n        # but we\'ll use the actual scores from the softmax\n        \n        # To be safe, let\'s map based on the actual labels in the model\n        # We\'ll try to find which index corresponds to positive and negative\n        pos_idx = -1\n        neg_idx = -1\n        for idx, label in id2label.items():\n            if "pos" in label.lower():\n                pos_idx = idx\n            elif "neg" in label.lower():\n                neg_idx = idx\n        \n        # If we can\'t find them, default to 0/1\n        if pos_idx == -1: pos_idx = 1\n        if neg_idx == -1: neg_idx = 0\n\n        confidence = {\n            "positive": scores[pos_idx],\n            "negative": scores[neg_idx]\n        }\n\n        return jsonify({\n            "sentiment": final_sentiment,\n            "confidence": confidence\n        })\n\n    except Exception as e:\n        return jsonify({"error": str(e)}), 400\n\nif __name__ == "__main__":\n    app.run(host="0.0.0.0", port=5000)\nEOF\n'})
