>> ShellSession({'command': 'cat << \'EOF\' > /app/filter.py\nimport sys\nimport re\n\ndef filter_html(file_path):\n    try:\n        with open(file_path, \'r\', encoding=\'utf-8\') as f:\n            content = f.read()\n\n        # 1. Remove <script>...</script> tags and their content\n        # Using DOTALL to match across multiple lines\n        content = re.sub(r\'<script\\b[^>]*>.*?</script>\', \'\', content, flags=re.DOTALL | re.IGNORECASE)\n\n        # 2. Remove inline event handlers (e.g., onclick, onload, onerror, etc.)\n        # This regex looks for attributes starting with \'on\' followed by word characters and \'=\'\n        # We target attributes like onclick="...", onclick=\'...\', or onclick=...\n        # A more robust way is to find \'on[a-z]+\' followed by whitespace or \'=\'\n        content = re.sub(r\'\\son[a-z]+\\s*=\\s*("[^"]*"|\\\'[^\\\']*\\\'|[^\\s>]+)\', \'\', content, flags=re.IGNORECASE)\n\n        # 3. Remove javascript: pseudo-protocol in attributes (e.g., href="javascript:alert(1)")\n        content = re.sub(r\'href\\s*=\\s*["\\\']\\s*javascript:[^"\\\']*["\\\']\', \'\', content, flags=re.IGNORECASE)\n        content = re.sub(r\'href\\s*=\\s*["\\\']\\s*javascript:[^"\\\']*["\\\']\', \'\', content, flags=re.IGNORECASE)\n        # Also handle cases without quotes if they exist, though less common in valid HTML\n        content = re.sub(r\'href\\s*=\\s*javascript:[^\\s>]+\', \'\', content, flags=re.IGNORECASE)\n\n        # 4. Remove <svg> with onload or other dangerous attributes if necessary, \n        # but the event handler regex above should catch them.\n\n        with open(file_path, \'w\', encoding=\'utf-8\') as f:\n            f.write(content)\n\n    except Exception as e:\n        print(f"Error: {e}", file=sys.stderr)\n        sys.exit(1)\n\nif __name__ == "__main__":\n    if len(sys.argv) != 2:\n        print("Usage: python filter.py <html_file>")\n        sys.exit(1)\n    \n    filter_html(sys.argv[1])\nEOF\n'})
