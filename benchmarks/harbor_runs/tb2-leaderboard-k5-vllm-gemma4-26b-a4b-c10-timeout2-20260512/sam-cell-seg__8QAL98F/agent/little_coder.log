ask, cv2.bitwise_not(occupied_mask))\n        \n        # Re-check connectivity after subtraction\n        num_labels, labels = cv2.connectedComponents(mask)\n        if num_labels > 1:\n            largest_label = 1 + np.argmax(np.bincount(labels.ravel())[1:])\n            mask = (labels == largest_label).astype(np.uint8)\n        \n        # Update occupied mask\n        occupied_mask = cv2.bitwise_or(occupied_mask, mask)\n\n        # Find contours for the final mask\n        contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n        if not contours:\n            # Fallback to bounding box if no contour found\n            coords_x = [xmin, xmax, xmax, xmin]\n            coords_y = [ymin, ymin, ymax, ymax]\n        else:\n            # Take the largest contour\n            max_contour = max(contours, key=cv2.contourArea)\n            contour_flattened = max_contour.reshape(-1, 2)\n            coords_x = contour_flattened[:, 0].tolist()\n            coords_y = contour_flattened[:, 1].tolist()\n\n        # Update bounding box\n        new_xmin = float(min(coords_x))\n        new_xmax = float(max(coords_x))\n        new_ymin = float(min(coords_y))\n        new_ymax = float(max(coords_y))\n\n        # Create new row\n        new_row = row.copy()\n        new_row[\'xmin\'] = new_xmin\n        new_row[\'ymin\'] = new_ymin\n        new_row[\'xmax\'] = new_xmax\n        new_row[\'ymax\'] = new_ymax\n        new_row[\'coords_x\'] = ",".join(map(str, coords_x))\n        new_row[\'coords_y\'] = ",".join(map(str, coords_y))\n        new_rows.append(new_row)\n\n    # Create output directory if it doesn\'t exist\n    os.makedirs(args.output_path, exist_ok=True)\n    \n    # Save the new CSV\n    output_df = pd.DataFrame(new_rows)\n    base_name = os.path.basename(args.csv_path)\n    output_file = os.path.join(args.output_path, base_name)\n    \n    output_df.to_csv(output_file, index=False)\n    print(f"Saved to {output_file}")\n\nif __name__ == "__main__":\n    main()\nEOF\n'})
