>> ShellSession({'command': 'cat <<EOF > /app/pystan_analysis.py\nimport pandas as pd\nimport numpy as np\nimport json\nimport stan\n\ndef main():\n    # Load data\n    with open(\'/app/meta_public.json\', \'r\') as f:\n        meta_pub = json.load(f)\n    \n    train_X = pd.read_csv(\'/app/train_X.csv\').values\n    test_X = pd.read_csv(\'/app/test_X.csv\').values\n    train_y = pd.read_csv(\'/app/train_y.csv\')[\'y\'].values\n\n    P = int(meta_pub[\'P\'])\n    jitter = float(meta_pub[\'jitter\'])\n\n    N = train_X.shape[0]\n    D = train_X.shape[1]\n    N_new = test_X.shape[0]\n\n    # H = cbind(1, train_X[,1], train_X[,2])\n    # Since train_X has 2 columns (D=2), H will have 3 columns (P=3)\n    H = np.column_stack([np.ones(N), train_X])\n    \n    if N_new > 0:\n        H_new = np.column_stack([np.ones(N_new), test_X])\n    else:\n        H_new = np.zeros((0, P))\n\n    stan_code = """\nfunctions {\n  matrix cov_ard_sqexp(matrix X, vector rho, real alpha, real jitter) {\n    int N = rows(X);\n    int D = cols(X);\n    matrix[N, N] K;\n\n    for (i in 1:N) {\n      K[i, i] = square(alpha) + jitter;\n      for (j in (i + 1):N) {\n        real s = 0;\n        for (d in 1:D) {\n          real t = (X[i, d] - X[j, d]) / rho[d];\n          s += t * t;\n        }\n        K[i, j] = square(alpha) * exp(-0.5 * s);\n        K[j, i] = K[i, j];\n      }\n    }\n    return K;\n  }\n\n  matrix cross_cov_ard(matrix X, matrix X_new, vector rho, real alpha) {\n    int N = rows(X);\n    int M = rows(X_new);\n    int D = cols(X);\n    matrix[N, M] Kx;\n    for (i in 1:N) {\n      for (j in 1:M) {\n        real s = 0;\n        for (d in 1:D) {\n          real t = (X[i, d] - X_new[j, d]) / rho[d];\n          s += t * t;\n        }\n        Kx[i, j] = square(alpha) * exp(-0.5 * s);\n      }\n    }\n    return Kx;\n  }\n}\n\ndata {\n  int<lower=1> N;\n  int<lower=1> D;\n  matrix[N, D] X;\n  int<lower=1> P;\n  matrix[N, P] H;\n  vector[N] y;\n  real<lower=0> jitter;\n\n  int<lower=0> N_new;\n  matrix[N_new, D] X_new;\n  matrix[N_new, P] H_new;\n}\n\nparameters {\n  vector[P] beta;\n  real<lower=0> alpha;\n  vector<lower=0>[D] rho;\n  real<lower=0> sigma;\n}\n\ntransformed parameters {\n  vector[N] mu = H * beta;\n  matrix[N, N] K = cov_ard_sqexp(X, rho, alpha, jitter)\n                   + diag_matrix(rep_vector(square(sigma), N));\n  matrix[N, N] L_K = cholesky_decompose(K);\n}\n\nmodel {\n  beta  ~ normal(0, 1);\n  alpha ~ normal(0, 1.5);\n  rho   ~ lognormal(0, 1);\n  sigma ~ normal(0, 0.5);\n  y ~ multi_normal_cholesky(mu, L_K);\n}\n\ngenerated quantities {\n  vector[N_new] y_new;\n  if (N_new > 0) {\n    matrix[N, N_new] K_x_xnew = cross_cov_ard(X, X_new, rho, alpha);\n    matrix[N_new, N_new] K_new = cov_ard_sqexp(X_new, rho, alpha, jitter);\n    vector[N] resid = y - (H * beta);\n\n    vector[N] alpha_vec = mdivide_left_tri_low(L_K, resid);\n    alpha_vec = mdivide_left_tri_low(L_K\', alpha_vec);\n\n    vector[N_new] f_mean = (K_x_xnew\' * alpha_vec);\n    matrix[N, N_new] v = mdivide_left_tri_low(L_K, K_x_xnew);\n    vector[N_new] f_var = to_vector(diagonal(K_new)) - to_vector(columns_dot_self(v));\n    for (m in 1:N_new) {\n      real m_mean = (H_new[m] * beta) + f_mean[m];\n      real m_sd   = sqrt(f_var[m] + square(sigma));\n      y_new[m] = normal_rng(m_mean, m_sd);\n    }\n  }\n}\n"""\n\n    data_dict = {\n        "N": N,\n        "D": D,\n        "X": train_X,\n        "P": P,\n        "H": H,\n        "y": train_y,\n        "jitter": jitter,\n        "N_new": N_new,\n        "X_new": test_X,\n        "H_new": H_new\n    }\n\n    # Build the model\n    # Note: PyStan 3 uses stan.build()\n    # The requirement says: "When use stan.build, you must set the random_seed to 1"\n    # However, stan.build() in PyStan 3 doesn\'t take random_seed directly in the same way as rstan.\n    # Actually, PyStan 3\'s build process is different. \n    # Let\'s check the documentation or try to use the build method.\n    # In PyStan 3, we use stan.build(stan_code, ...)\n    \n    # Re-reading requirement: "When use stan.build, you must set the random_seed to 1"\n    # In PyStan 3, build() might not have random_seed. \n    # But let\'s try to pass it if possible or just use the standard build.\n    # Actually, the requirement might be referring to the sampling or the build.\n    # Let\'s try:\n    \n    try:\n        # PyStan 3 build\n        model = stan.build(stan_code, data=data_dict, random_seed=1)\n    except TypeError:\n        # If random_seed is not an argument to build\n        model = stan.build(stan_code, data=data_dict)\n\n    # Sampling\n    # R script: chains = 4, iter = 2000, warmup = 1000, thin = 2, seed = 1\n    # control: adapt_delta = 0.93, max_treedepth = 14, adapt_gamma = 0.05, adapt_kappa = 0.75, adapt_t0 = 10, adapt_init_buffer = 100, adapt_term_buffer = 50, adapt_window = 25\n    \n    # In PyStan 3, sampling is done via model.sample()\n    # The control parameters in R (adapt_...) are passed to the sampler.\n    # In PyStan 3, these are often passed via \'sample_args\' or similar.\n    # However, PyStan 3\'s sampling interface is different.\n    # Let\'s use the most common way to pass these.\n    \n    # For PyStan 3, we can pass \'adapt_delta\' etc. in the sample call.\n    # Note: PyStan 3 uses different names for some parameters.\n    \n    fit = model.sample(\n        num_chains=4,\n        iter=2000,\n        warmup=1000,\n        thin=2,\n        seed=1,\n        # PyStan 3 uses \'adapt_delta\' in the sample call or via options\n        # We\'ll try to pass them as keyword arguments.\n        adapt_delta=0.93,\n        max_treedepth=14,\n        # The other adapt_... parameters are more specific to RStan\'s interface.\n        # In PyStan 3, we\'ll try to pass them.\n    )\n\n    # Extract posterior means\n    # fit.summary() or fit.extract()\n    # fit.extract() returns a dictionary of arrays\n    samples = fit.extract()\n    \n    alpha_mean = np.mean(samples[\'alpha\'])\n    sigma_mean = np.mean(samples[\'sigma\'])\n    rho_means = np.mean(samples[\'rho\'], axis=0)\n    beta_means = np.mean(samples[\'beta\'], axis=0)\n\n    # Save results\n    with open(\'/app/alpha_est.csv\', \'w\') as f:\n        f.write(f"{alpha_mean}\\n")\n    with open(\'/app/sigma_est.csv\', \'w\') as f:\n        f.write(f"{sigma_mean}\\n")\n    with open(\'/app/rho_est.csv\', \'w\') as f:\n        f.write(",".join(map(str, rho_means)) + "\\n")\n    with open(\'/app/beta_est.csv\', \'w\') as f:\n        f.write(",".join(map(str, beta_means)) + "\\n")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/pystan_analysis.py\n', 'timeout': 1200})
