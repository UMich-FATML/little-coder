\n    median_board_brightness = np.median(low_std_brightness)\n    \n    # Print the board\n    # W = White piece, B = Black piece, . = Empty\n    # We\'ll use the center pixel and its brightness.\n    # White pieces are bright, Black pieces are dark.\n    \n    # Let\'s try to find the two board colors.\n    # We\'ll use the median of the low-std brightnesses.\n    # But we need to distinguish between the two board colors.\n    # Let\'s use the two most common brightness values in low-std squares.\n    \n    # Actually, let\'s just use a simple threshold.\n    # If brightness is very high, it\'s a white piece.\n    # If brightness is very low, it\'s a black piece.\n    # If brightness is in the middle, it\'s the board.\n    \n    # Let\'s find the range of board brightness.\n    board_brightness_values = sorted(low_std_brightness)\n    min_b = board_brightness_values[0]\n    max_b = board_brightness_values[-1]\n    mid_b = (min_b + max_b) / 2\n    \n    for r in range(8):\n        row_str = ""\n        for c in range(8):\n            b, g, r_val = board[r][c][\'center\']\n            brightness = (float(b) + float(g) + float(r_val)) / 3.0\n            std = board[r][c][\'std\']\n            \n            if std > 100: # Piece detected\n                if brightness > mid_b + 20:\n                    row_str += "W "\n                elif brightness < mid_b - 20:\n                    row_str += "B "\n                else:\n                    row_str += "P "\n            else:\n                row_str += ". "\n        print(row_str)\n\ndetect_pieces(\'chess_board.png\')\nEOF\npython3 detect_pieces_v13.py\n'})
