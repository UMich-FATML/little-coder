fp_seq || !$flag_seq || !$snap_seq || !$output_seq) {\n    die "Error: One or more sequences not found in fasta file.\\n";\n}\n\nmy $j1_idx = length($input_seq);\nmy $j2_idx = length($input_seq) + length($egfp_seq);\nmy $j3_idx = length($input_seq) + length($egfp_seq) + length($flag_seq);\nmy $j4_idx = length($input_seq) + length($egfp_seq) + length($flag_seq) + length($snap_seq);\n\n# The overhang is 4 bp.\n# Let\'s use the 4 bp at the junction.\n# We need to be careful with substr.\nmy $j1_overhang = substr($output_seq, $j1_idx-2, 4);\nmy $j2_overhang = substr($output_seq, $j2_idx-2, 4);\nmy $j3_overhang = substr($output_seq, $j3_idx-2, 4);\nmy $j4_overhang = substr($output_seq, $j4_idx-2, 4);\n\nmy @fragments = (\n    ["input", $input_seq, $j4_overhang, $j1_overhang],\n    ["egfp", $egfp_seq, $j1_overhang, $j2_overhang],\n    ["flag", $flag_seq, $j2_overhang, $j3_overhang],\n    ["snap", $snap_seq, $j3_overhang, $j4_overhang]\n);\n\nmy $leader = "CCCCCC";\nmy $bsai = "GGTCTC";\nmy @all_primers;\n\nforeach my $frag (@fragments) {\n    my ($name, $seq, $fwd_ov, $rev_ov) = @$frag;\n    my $found = 0;\n    \n    my @valid_fwds;\n    for (my $flen = 15; $flen <= 45; $flen++) {\n        my $anneal = substr($seq, 0, $flen);\n        my $tm = get_tm($anneal);\n        if ($tm >= 58 && $tm <= 72) {\n            push @valid_fwds, { len => $flen, tm => $tm, seq => $leader . $bsai . $fwd_ov . $anneal };\n        }\n    }\n    \n    my @valid_revs;\n    for (my $rlen = 15; $rlen <= 45; $rlen++) {\n        my $anneal_rc = reverse_complement(substr($seq, length($seq) - $rlen));\n        my $tm = get_tm($anneal_rc);\n        if ($tm >= 58 && $tm <= 72) {\n            push @valid_revs, { len => $rlen, tm => $tm, seq => $leader . $bsai . $rev_ov . $anneal_rc };\n        }\n    }\n    \n    for my $f (@valid_fwds) {\n        for my $r (@valid_revs) {\n            if (abs($f->{tm} - $r->{tm}) <= 5) {\n                push @all_primers, "> ${name}_fwd\\n" . $f->{seq};\n              