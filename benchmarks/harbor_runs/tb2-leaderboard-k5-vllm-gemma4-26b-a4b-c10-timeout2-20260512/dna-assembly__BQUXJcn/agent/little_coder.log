primer pairs, we just need one pair per fragment.\n        # But wait, the task says "Output the minimum number of primer pairs necessary to complete this task."\n        # This means we need 2 primers for each of the 4 fragments = 8 primers.\n        \n        # Let\'s search for the primers.\n        # For fwd primer:\n        # template is seq\n        # annealing part is seq[0:fwd_len]\n        # primer is leader + bsai + fwd_overhang + seq[0:fwd_len]\n        \n        # For rev primer:\n        # template is seq\n        # annealing part is seq[len(seq)-rev_len : len(seq)]\n        # primer is leader + bsai + rev_overhang + reverse_complement(seq[len(seq)-rev_len : len(seq)])\n        # Wait, the rev primer is the reverse complement of the strand.\n        # The annealing part is the reverse complement of the template\'s end.\n        # So the primer is: 5\' - [Leader] - [BsaI] - [Overhang] - [Template_End_RC] - 3\'\n        # Let\'s check:\n        # Template: 5\' - ...[Template_End] - 3\'\n        # Rev primer: 5\' - [Leader] - [BsaI] - [Overhang] - [Template_End_RC] - 3\'\n        # When it anneals, it binds to the template.\n        \n        # Let\'s try all combinations of lengths.\n        # To be efficient, let\'s find all valid fwd primers first, then all valid rev primers.\n        \n        valid_fwds = []\n        for flen in range(15, 46):\n            anneal_seq = seq[:flen]\n            tm = get_tm(anneal_seq)\n            if 58 <= tm <= 72:\n                primer = leader + bsai + fwd_overhang + anneal_seq\n                valid_fwds.append((flen, tm, primer))\n        \n        valid_revs = []\n        for rlen in range(15, 46):\n            anneal_seq_rc = reverse_complement(seq[len(seq)-rlen:])\n            tm = get_tm(anneal_seq_rc)\n            if 58 <= tm <= 72:\n                primer = leader + bsai + rev_overhang + anneal_seq_rc\n                valid_revs.append((rlen, tm, primer))\n        \n        # Find a pair\n        for f_len, f_tm, f_primer in valid_fwds:\n            for r_len, r_tm, r_primer in valid_revs:\n                if abs(f_tm - r_tm) <= 5:\n                    primers.append(f"> {name}_fwd\\n{f_primer}")\n                    primers.append(f"> {name}_rev\\n{r_primer}")\n                    found_pair = True\n                    break\n            if found_pair:\n                break\n        \n        if not found_pair:\n            print(f"Error: Could not find primer pair for {name}", file=sys.stderr)\n            sys.exit(1)\n\n    with open(\'primers.fasta\', \'w\') as f:\n        for p in primers:\n            f.write(p + "\\n")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 solution.py\n'})
