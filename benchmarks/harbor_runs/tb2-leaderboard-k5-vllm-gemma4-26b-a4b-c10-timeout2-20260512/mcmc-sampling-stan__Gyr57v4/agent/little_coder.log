<< library(rstan)

set.seed(1)

data_df <- read.csv("/app/data.csv")
N <- nrow(data_df)
y <- data_df$y
n <- data_df$n

stan_data <- list(
  N = N,
  y = y,
  n = n
)

fit <- sampling(
  model = "/app/hierarchical_model.stan",
  data = stan_data,
  iter = 100000,
  chains = 4,
  seed = 1
)

posterior_alpha_mean <- mean(extract(fit)$alpha)
posterior_beta_mean <- mean(extract(fit)$beta)

