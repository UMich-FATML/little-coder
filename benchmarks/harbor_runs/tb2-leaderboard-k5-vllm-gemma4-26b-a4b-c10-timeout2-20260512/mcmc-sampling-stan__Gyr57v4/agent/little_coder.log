  int<lower=0> N;
  int<lower=0> y[];
  int<lower=0> n[];
}

parameters {
  real<lower=0> alpha;
  real<lower=0> beta;
  vector<lower=0, upper=1> theta;
}

model {
  target += -2.5 * log(alpha + beta);
  theta ~ beta(alpha, beta);
