ion\n            # Use log(p/u) = log(p * V)\n            # KL(P||U) = sum P_i * log(P_i * V)\n            # KL(U||P) = sum (1/V) * log(1 / (P_i * V))\n            \n            # To avoid precision issues with large V, use the formula:\n            # KL(P||U) = sum P_i * (log(P_i) + log(V))\n            # KL(U||P) = (1/V) * sum (-log(P_i) - log(V))\n            \n            # Actually, let\'s use the direct definition\n            # P is best_dist\n            # U is 1/V\n            # KL(P||U) = np.sum(best_dist * np.log(best_dist / (1.0/V)))\n            # KL(U||P) = np.sum((1.0/V) * np.log((1.0/V) / best_dist))\n            \n            # But best_dist might have zeros if we are not careful.\n            # However, our x_d, y_d are > 0.\n            \n            # Let\'s use a more stable way to calculate KL\n            # KL(P||U) = sum P_i log(P_i) + log(V)\n            # KL(U||P) = -log(V) - (1/V) sum log(P_i)\n            \n            # Let\'s use the actual values\n            p = best_dist\n            u = 1.0/V\n            # Use rel_entr for stability\n            kl_fwd = np.sum(rel_entr(p, u))\n            kl_bwd = np.sum(rel_entr(u, p))\n            \n            print(f"Final k: {best_k}")\n            print(f"KL Fwd: {kl_fwd}")\n            print(f"KL Bwd: {kl_bwd}")\n            \n            if abs(kl_fwd - 10.0) <= tol and abs(kl_bwd - 10.0) <= tol:\n                np.save(\'/app/dist.npy\', p)\n                print("SUCCESS")\n            else:\n                print("FAILED TOLERANCE")\n        else:\n            print("NO DISTRIBUTION FOUND")\n\nsolve()\nEOF\npython3 /app/solve.py\n'})
