      # But k is fixed as int(a*V).\n        \n        # Let\'s solve for x, y given k:\n        # 1) k*x + (V-k)*y = 1  => y = (1 - k*x) / (V-k)\n        # 2) k*log(x) + (V-k)*log(y) = -10*V\n        \n        def solve_discrete(k_val):\n            def func_discrete(x):\n                y = (1 - k_val*x) / (V - k_val)\n                return k_val*np.log(x) + (V - k_val)*np.log(y) + 10*V\n            \n            # x must be in (0, 1/k)\n            res_d = opt.root_scalar(func_discrete, bounds=(1e-15, 1/k_val - 1e-15), method=\'brentq\')\n            x_d = res_d.root\n            y_d = (1 - k_val*x_d) / (V - k_val)\n            return x_d, y_d\n\n        x_final, y_final = solve_discrete(k)\n        \n        # Verify KL\n        kl_fwd = (k/V)*x_final*np.log(x_final*V) + ((V-k)/V)*y_final*np.log(y_final*V)\n        kl_bwd = (k/V)*np.log(1/(x_final*V)) + ((V-k)/V)*np.log(1/(y_final*V))\n        \n        print(f"Discrete: k={k}, x={x_final}, y={y_final}")\n        print(f"KL Fwd: {kl_fwd}, KL Bwd: {kl_bwd}")\n        \n        if abs(kl_fwd - 10.0) <= tol and abs(kl_bwd - 10.0) <= tol:\n            dist = np.zeros(V)\n            dist[:k] = x_final\n            dist[k:] = y_final\n            # Ensure sum is 1\n            dist = dist'})
