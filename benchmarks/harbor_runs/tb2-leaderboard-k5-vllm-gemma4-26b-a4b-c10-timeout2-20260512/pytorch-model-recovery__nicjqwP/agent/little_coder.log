ry)\n        return x\n\nclass RecoveredModel(nn.Module):\n    def __init__(self, vocab_size=64, d_model=128, nhead=8, num_encoder_layers=3, num_decoder_layers=1, dim_feedforward=256, output_dim=64):\n        super().__init__()\n        self.embedding = nn.Embedding(vocab_size, d_model)\n        self.pos_encoder = PositionalEncoding(d_model)\n        \n        encoder_layers = nn.ModuleList([CustomEncoderLayer(d_model, nhead, dim_feedforward) for _ in range(num_encoder_layers)])\n        self.transformer_encoder = EncoderContainer(encoder_layers)\n        \n        decoder_layers = nn.ModuleList([CustomDecoderLayer(d_model, nhead, dim_feedforward) for _ in range(num_decoder_layers)])\n        self.transformer_decoder = DecoderContainer(decoder_layers)\n        self.output_layer = nn.Linear(d_model, output_dim)\n\n    def forward(self, src, tgt):\n        # src: [batch, seq, 64]\n        # tgt: [batch, seq, 64]\n        # Use embedding as linear projection\n        src_emb = F.linear(src, self.embedding.weight, self.embedding.bias)\n        src_emb = self.pos_encoder(src_emb)\n        memory = self.transformer_encoder(src_emb)\n        \n        tgt_emb = F.linear(tgt, self.embedding.weight, self.embedding.bias)\n        tgt_emb = self.pos_encoder(tgt_emb)\n        \n        decoder_out = self.transformer_decoder(tgt_emb, memory)\n        return self.output_layer(decoder_out)\n\n# Main execution\ndef main():\n    device = torch.device(\'cpu\')\n    weights = torch.load(\'/app/weights.pt\', map_location=device)\n    dataset = torch.load(\'/app/dataset.pt\', map_location=device)\n    src_sequences = dataset[\'src_sequences\']\n    tgt_sequences = dataset[\'tgt_sequences\']\n\n    model = RecoveredModel()\n    model.load_state_dict(weights)\n\n    # Original MSE\n    with torch.no_grad():\n        original_output = model(src_sequences, tgt_sequences)\n        original_mse = F.mse_loss(original_output, tgt_sequences)\n    print(f"Original MSE: {original_mse.item()}")\n\n    # Tune output_layer\n    optimizer = optim.Adam(model.output_layer.parameters(), lr=0.01)\n    model.transformer_encoder.requires_grad_(False)\n    model.transformer_decoder.requires_grad_(False)\n    model.embedding.requires_grad_(False)\n    model.pos_encoder.requires_grad_(False)\n    model.output_layer.requires_grad_(True)\n\n    for epoch in range(100):\n        optimizer.zero_grad()\n        output = model(src_sequences, tgt_sequences)\n        loss = F.mse_loss(output, tgt_sequences)\n        loss.backward()\n        optimizer.step()\n        if epoch % 20 == 0:\n            print(f"Epoch {epoch}, Loss: {loss.item()}")\n\n    with torch.no_grad():\n        new_output = model(src_sequences, tgt_sequences)\n        new_mse = F.mse_loss(new_output, tgt_sequences)\n    print(f"New MSE: {new_mse.item()}")\n\n    # Save as TorchScript\n    model.eval()\n    # TorchScript requires a scripted or traced model. Tracing is easier for complex models.\n    # We need to provide dummy inputs.\n    dummy_src = torch.randn(20, 20, 64)\n    dummy_tgt = torch.randn(20, 20, 64)\n    traced_model = torch.jit.trace(model, (dummy_src, dummy_tgt))\n    traced_model.save(\'/app/model.pt\')\n    print("Model saved to /app/model.pt")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 solve.py'})
