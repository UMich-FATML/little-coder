>> ShellSession({'command': 'cat > /app/ars.R <<\'EOF\'\n# Adaptive Rejection Sampler (ARS)\n# Based on Gilks et al. (1992)\n\n#\' @title Adaptive Rejection Sampler\n#\' @description Implements the ARS algorithm for sampling from log-concave densities.\n#\' @param n Integer. Number of samples to generate.\n#\' @param log_density Function. A vectorized function returning the log-density.\n#\' @param lower Numeric. Lower bound of the support.\n#\' @param upper Numeric. Upper bound of the support.\n#\' @return A numeric vector of samples.\nars <- function(n, log_density, lower = -Inf, upper = Inf) {\n  # 1. Input Validation\n  if (!is.function(log_density)) stop("log_density must be a function.")\n  if (n <= 0) stop("n must be a positive integer.")\n  if (is.finite(lower) && is.finite(upper) && lower >= upper) {\n    stop("lower bound must be less than upper bound.")\n  }\n\n  # 2. Internal Helper Functions\n  \n  # Piecewise linear interpolation of log-density\n  get_envelope_val <- function(x, points_x, points_log_y) {\n    if (length(points_x) < 2) return(-Inf)\n    idx <- findInterval(x, points_x)\n    if (idx == 0) return(-Inf)\n    if (idx == length(points_x)) return(-Inf)\n    \n    x0 <- points_x[idx]\n    x1 <- points_x[idx + 1]\n    y0 <- points_log_y[idx]\n    y1 <- points_log_y[idx + 1]\n    \n    return(y0 + (y1 - y0) * (x - x0) / (x1 - x0))\n  }\n\n  # Check for log-concavity\n  check_log_concavity <- function(points_x, points_log_y) {\n    if (length(points_x) < 3) return(TRUE)\n    slopes <- diff(points_log_y) / diff(points_x)\n    if (any(diff(slopes) > 1e-7)) return(FALSE)\n    return(TRUE)\n  }\n\n  # 3. Main Sampling Logic\n  samples <- numeric(n)\n  \n  # Initial points search\n  find_initial_points <- function(log_density, lower, upper) {\n    l <- if(is.infinite(lower)) -100 else lower\n    u <- if(is.infinite(upper)) 100 else upper\n    grid <- seq(l, u, length.out = 200)\n    vals <- log_density(grid)\n    valid <- !is.na(vals) & is.finite(vals)\n    if (sum(valid) < 2) stop("Could not find enough points in the domain.")\n    grid <- grid[valid]\n    vals <- vals[valid]\n    idx <- order(vals, decreasing = TRUE)[1:2]\n    return(list(x = grid[idx], y = vals[idx]))\n  }\n\n  init <- find_initial_points(log_density, lower, upper)\n  points_x <- sort(init$x)\n  points_y <- log_density(points_x)\n\n  for (i in 1:n) {\n    accepted <- FALSE\n    while (!accepted) {\n      # Sample from the envelope\n      areas <- numeric(length(points_x) - 1)\n      for (j in 1:(length(points_x) - 1)) {\n        x0 <- points_x[j]\n        x1 <- points_x[j+1]\n        y0 <- points_y[j]\n        y1 <- points_y[j+1]\n        if (abs(y1 - y0) < 1e-9) {\n          areas[j] <- exp(y0) * (x1 - x0)\n        } else {\n          areas[j] <- exp(y0) * (exp(y1 - y0) - 1) * (x1 - x0) / (y1 - y0)\n        }\n      }\n      \n      prob_intervals <- areas / sum(areas)\n      interval_idx <- sample(1:(length(points_x) - 1), 1, prob = prob_intervals)\n      \n      x0 <- points_x[interval_idx]\n      x1 <- points_x[interval_idx + 1]\n      y0 <- points_y[interval_idx]\n      y1 <- points_y[interval_idx + 1]\n      \n      u <- runif(1)\n      if (abs(y1 - y0) < 1e-9) {\n        candidate_x <- x0 + u * (x1 - x0)\n      } else {\n        k <- (y1 - y0) / (x1 - x0)\n        candidate_x <- x0 + (log(u * (exp(y1 - y0) - 1) + 1)) / k\n      \n      }\n      \n      actual_log_dens <- log_density(candidate_x)\n      envelope_log_dens <- get_envelope_val(candidate_x, points_x, points_y)\n      \n      if (actual_log_dens >= envelope_log_dens) {\n        samples[i] <- candidate_x\n        accepted <- TRUE\n        points_x <- c(points_x, candidate_x)\n        points_y <- c(points_y, actual_log_dens)\n        ord <- order(points_x)\n        points_x <- points_x[ord]\n        points_y <- points_y[ord]\n        if (!check_log_concavity(points_x, points_y)) {\n          stop("Non-log-concave density detected during sampling.")\n        }\n      } else {\n        points_x <- c(points_x, candidate_x)\n        points_y <- c(points_y, actual_log_dens)\n        ord <- order(points_x)\n        points_x <- points_x[ord]\n        points_y <- points_y[ord]\n      }\n    }\n  }\n  return(samples)\n}\n\ntest <- function() {\n  results <- list()\n  \n  cat("Running TEST_NORMAL...\\n")\n  target_log_dens <- function(x) dnorm(x, mean = 0, sd = 1, log = TRUE)\n  n_samples <- 200\n  tryCatch({\n    samples <- ars(n_samples, target_log_dens)\n    mean_val <- mean(samples)\n    sd_val <- sd(samples)\n    if (abs(mean_val - 0) < 0.3 && abs(sd_val - 1) < 0.3) {\n      cat("TEST_NORMAL: PASS (mean =", mean_val, ", sd =", sd_val, ")\\n")\n      results$normal <- TRUE\n      write.table(samples, "/app/normal_samples.txt", row.names = FALSE, col.names = FALSE)\n    } else {\n      cat("TEST_NORMAL: FAIL (mean =", mean_val, ", sd =", sd_val, ")\\n")\n      results$normal <- FALSE\n    }\n  }, error = function(e) {\n    cat("TEST_NORMAL: FAIL (Error:", e$message, ")\\n")\n    results$normal <- FALSE\n  })\n\n  cat("Running TEST_EXPONENTIAL...\\n")\n  target_log_dens_exp <- function(x) {\n    if (x < 0) return(-Inf)\n    dexp(x, rate = 1, log = TRUE)\n  }\n  n_samples <- 200\n  tryCatch({\n    samples <- ars(n_samples, target_log_dens_exp, lower = 0)\n    mean_val <- mean(samples)\n    sd_val <- sd(samples)\n    if (abs(mean_val - 1) < 0.3 && abs(sd_val - 1) < 0.3) {\n      cat("TEST_EXPONENTIAL: PASS (mean =", mean_val, ", sd =", sd_val, ")\\n")\n      results$exponential <- TRUE\n      write.table(samples, "/app/exponential_samples.txt", row.names = FALSE, col.names = FALSE)\n    } else {\n      cat("TEST_EXPONENTIAL: FAIL (mean =", mean_val, ", sd =", sd_val, ")\\n")\n      results$exponential <- FALSE\n    }\n  }, error = function(e) {\n    cat("TEST_EXPONENTIAL: FAIL (Error:", e$message, ")\\n")\n    results$exponential <- FALSE\n  })\n\n  cat("Running TEST_INVALID_INPUT...\\n")\n  tryCatch({\n    ars(-1, target_log_dens)\n    cat("TEST_INVALID_INPUT: FAIL (Should have errored)\\n")\n    results$invalid_input <- FALSE\n  }, error = function(e) {\n    cat("TEST_INVALID_INPUT: PASS\\n")\n    results$invalid_input <- TRUE\n  })\n\n  cat("\\n--- TEST SUMMARY ---\\n")\n  for (name in names(results)) {\n    status <- if (results[[name]]) "PASS" else "FAIL"\n    cat(paste0(toupper(name), ": ", status, "\\n"))\n  }\n  \n  if (all(unlist(results))) {\n    cat("ALL TESTS PASSED\\n")\n  } else {\n    cat("SOME TESTS FAILED\\n")\n    quit(status = 1)\n  }\n}\n\nif (!interactive()) {\n  test()\n}\nEOF\n'})
