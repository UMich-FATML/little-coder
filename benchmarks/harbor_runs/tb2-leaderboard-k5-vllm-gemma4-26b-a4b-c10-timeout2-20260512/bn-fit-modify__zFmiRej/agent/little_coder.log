a constant 0.0.\n\n# Since we are dealing with continuous variables, we can\'t easily use pgmpy\'s discrete CPDs.\n# Let\'s use a simpler way to sample from the intervened model.\n# The sampling process for a DAG:\n# For each node in topological order:\n#   If node is Y: sample Y = 0.0\n#   Else: sample node from its conditional distribution given its parents.\n\n# We can estimate the conditional distributions using Linear Regression.\n# For each node, we\'ll fit a model: node = intercept + sum(beta_i * parent_i) + epsilon\n\n# Let\'s build the intervened sampler.\n\nimport statsmodels.api as sm\n\nclass IntervenedSampler:\n    def __init__(self, df, model, intervened_node, intervention_value):\n        self.df = df\n        self.model = model\n        self.intervened_node = intervened_node\n        self.intervention_value = intervention_value\n        self.regressions = {}\n        \n        # Topological order\n        self.topo_order = list(model.topological_sort())\n        \n        for node in self.topo_order:\n            parents = list(model.predecessors(node))\n            if node == intervened_node:\n                # No parents needed for the intervened node, it\'s constant\n                self.regressions[node] = None\n            elif not parents:\n                # Root node (not the intervened one)\n                X = np.ones((len(df), 1))\n                self.regressions[node] = sm.OLS(df[node], X).fit()\n            else:\n                # Node with parents\n                X = sm.add_constant(df[parents])\n                self.regressions[node] = sm.OLS(df[node], X).fit()\n\n    def sample(self, n_samples):\n        samples = pd.DataFrame(index=range(n_samples))\n        \n        for node in self.topo_order:\n            if node == self.intervened_node:\n                samples[node] = self.intervention_value\n            else:\n                parents = list(self.model.predecessors(node))\n                if not parents:\n                    # Root node\n                    reg = self.regressions[node]\n                    # Sample from the distribution: intercept + epsilon\n                    # where epsilon ~ N(0, sigma^2)\n                    sigma = np.sqrt(reg.mse_resid)\n                    samples[node] = reg.params[0] + np.random.normal(0, sigma, n_samples)\n                else:\n                    # Node with parents\n                    reg = self.regressions[node]\n                    # Get the parent values from the samples already generated\n                    # We need to handle the case where a parent is the intervened node\n                    X_vals = np.ones((n_samples, 1))\n                    for p in parents:\n                        X_vals = np.column_stack([X_vals, samples[p].values])\n                    \n                    # Predict mean\n                    means = reg.predict(X_vals)\n                    sigma = np.sqrt(reg.mse_resid)\n                    samples[node] = means + np.random.normal(0, sigma, n_samples)\n        return samples\n\n# Let\'s use the sampler.\nsampler = IntervenedSampler(df, model, \'Y\', 0.0)\nintervened_samples = sampler.sample(10000)\n\n# 6. Save the intervened samples\nintervened_samples.to_csv("/app/final_bn_sample.csv", index=False)\n\n# 7. Save the edges of the intervened BN.\n# The edges of the intervened BN are the same as the original, \n# but with edges into Y removed.\nintervened_edges = []\nfor u, v in model.edges():\n    if v != \'Y\':\n        intervened_edges.append((v, u)) # to, from\n\nedges_intervened_df = pd.DataFrame(intervened_edges, columns=[\'to\', \'from\'])\nedges_intervened_df.to_csv("/app/intervened_dag.csv", index=False)\n\nprint("Task completed successfully.")\nEOF\npython3 solve_task.py'})
