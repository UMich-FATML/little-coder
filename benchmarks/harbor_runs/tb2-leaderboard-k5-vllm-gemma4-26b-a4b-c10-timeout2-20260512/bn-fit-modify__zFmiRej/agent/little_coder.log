hey are independent given U and one other.\nfor i in range(len(cols)):\n    for j in range(i + 1, len(cols)):\n        x = cols[i]\n        y = cols[j]\n        if x == \'U\' or y == \'U\': continue\n        \n        # Check if x,y are independent given U\n        p_u = abs(get_partial_corr(df, x, y, [\'U\']))\n        if p_u > 0.05:\n            print(f"{x}-{y} is NOT independent given U (p={p_u:.4f})")\n        else:\n            print(f"{x}-{y} IS independent given U (p={p_u:.4f})")\n\nEOF\npython3 analyze_bn_v3.py'})
