The script `jump_analyzer.py` has been created and tested with the example video. It uses motion detection (frame differencing with Gaussian blurring) to identify the period of significant movement, which corresponds to the jump. The takeoff frame is identified as the first frame of significant motion, and the landing frame is identified as the frame following the last frame of significant motion.

```python
import cv2
import numpy as np
import sys

def analyze_video(video_path):
    cap = cv2.VideoCapture(video_path)
    if not cap.isOpened():
        return None

    prev_gray = None
    motion_scores = []
    frame_idx = 0

    while cap.isOpened():
        ret, frame = cap.read()
        if not ret:
            break
        
        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)
        gray = cv2.GaussianBlur(gray, (21, 21), 0)

        if prev_gray is not None:
            frame_delta = cv2.absdiff(prev_gray, gray)
            thresh = cv2.threshold(frame_delta, 25, 255, cv2.THRESH_BINARY)[1]
            motion_score = np.sum(thresh) / 255
            motion_scores.append(motion_score)
        else:
            motion_scores.append(0.0)
            
        prev_gray = gray
        frame_idx += 1
    
    cap.release()

    if not motion_scores:
        return None

    # Threshold for significant motion
    threshold = 500 
    active_frames = [i for i, score in enumerate(motion_scores) if score > threshold]

    if not active_frames:
        return {"jump_takeoff_frame_number": 0, "jump_land_frame_number": 0}

    takeoff_idx = active_frames[0]
    land_idx = active_frames[-1]

    # takeoff_idx is the first frame where motion is detected.
    # land_idx is the last frame where motion is detected.
    # Since motion_scores[i] is motion between frame i and i+1:
    # takeoff_frame = takeoff_idx
    # land_frame = land_idx + 1
    
    return {
        "jump_takeoff_frame_number": int(takeoff_idx),
        "jump_land_frame_number": int(land_idx + 1)
    }

if __name__ == "__main__":
    if len(sys.argv) < 2:
        sys.exit(1)
    
    video_file = sys.argv[1]
    results = analyze_video(video_file)
    
    if results:
        with open('/app/output.toml', 'w') as f:
            f.write(f"jump_takeoff_frame_number = {results['jump_takeoff_frame_number']}\n")
            f.write(f"jump_land_frame_number = {results['jump_land_frame_number']}\n")
```

