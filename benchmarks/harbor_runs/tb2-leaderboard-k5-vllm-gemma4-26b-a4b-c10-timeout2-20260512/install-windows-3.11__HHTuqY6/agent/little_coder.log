>> ShellSession({'command': 'cat <<EOF > /usr/local/bin/start_win311.sh\n#!/bin/bash\n# Start noVNC (assuming it\'s available or we can use a simple proxy)\n# Since I don\'t know if noVNC is installed, I\'ll just start QEMU with VNC first.\n# To satisfy "web interface (nginx) on port 80 for remote access", \n# I\'ll use a simple approach: if noVNC is not there, I\'ll just ensure \n# the VNC is running and nginx is ready. \n# Actually, a better way to provide a web interface for VNC is to use noVNC.\n\n# Check if novnc is installed, if not, install it.\nif ! command -v websockify &> /dev/null; then\n    apt-get install -y novnc\nfi\n\n# Start QEMU in the background\n# -vnc :1 means port 5901\n# -snapshot keeps the image immutable\n# -device usb-tablet for better mouse/keyboard integration\n# -device usb-kbd for programmatic keyboard input via USB\nqemu-system-i386 -m 512 -drive file=/app/isos/win311.img,format=raw,if=ide -vnc :1 -snapshot -device usb-tablet -device usb-kbd &\n\n# Wait for QEMU to start\nsleep 10\n\n# Start websockify to bridge VNC to a web-friendly port (e.g., 6080)\n# noVNC usually comes with a websockify or uses it.\n# We\'ll use websockify to proxy 5901 to 6080\nwebsockify --web /usr/share/novnc/ 6080 localhost:5901 &\n\nEOF\nchmod +x /usr/local/bin/start_win311.sh\n/usr/local/bin/start_win311.sh &'})
