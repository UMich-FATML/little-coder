ultiheadAttention to be safe or just use the standard one.\n        # Standard nn.MultiheadAttention(embed_dim, num_heads, batch_first=True)\n        pass\n\n# Since I need to reconstruct the exact architecture, I\'ll use the standard components \n# but I need to be careful about the order of operations (Pre-norm vs Post-norm).\n# Looking at the weights: norm1, linear1, linear2, norm2.\n# This looks like:\n# x = x + self_attn(norm1(x))\n# x = x + linear2(dropout(linear1(norm2(x))))\n# Wait, the order in the state dict is:\n# transformer_encoder.layers.0.self_attn.in_proj_weight\n# transformer_encoder.layers.0.self_attn.out_proj.weight\n# transformer_encoder.layers.0.linear1.weight\n# transformer_encoder.layers.0.linear1.bias\n# transformer_encoder.layers.0.linear2.weight\n# transformer_encoder.layers.0.linear2.bias\n# transformer_encoder.layers.0.norm1.weight\n# transformer_encoder.layers.0.norm1.bias\n# transformer_encoder.layers.0.norm2.weight\n# transformer_encoder.layers.0.norm2.bias\n\n# This order suggests:\n# x = norm1(x) -> self_attn -> x = x + attn_out\n# x = norm2(x) -> linear1 -> linear2 -> x = x + ff_out\n# This is Pre-Norm.\n\nclass TransformerEncoderLayerCustom(nn.Module):\n    def __init__(self, d_model, nhead, dim_feedforward):\n        super().__init__()\n        self.self_attn = nn.MultiheadAttention(d_model, nhead, batch_first=True)\n        self.linear1 = nn.Linear(d_model, dim_feedforward)\n        self.linear2 = nn.Linear(dim_feedforward, d_model)\n        self.norm1 = nn.LayerNorm(d_model)\n        self.norm2 = nn.LayerNorm(d_model)\n\n    def forward(self, x):\n        # Pre-norm architecture\n        # 1. Self-attention\n        residual = x\n        x = self.norm1(x)\n        attn_output, _ = self.self_attn(x, x, x)\n        x = residual + attn_output\n        \n        # 2. Feed-forward\n        residual = x\n        x = self.norm2(x)\n        x = self.linear1(x)\n        x = self.linear2(x)\n        x = residual + x\n        return x\n\nclass TransformerDecoderLayerCustom(nn.Module):\n    def __init__(self, d_model, nhead, dim_feedforward):\n        super().__init__()\n        self.self_attn = nn.MultiheadAttention(d_model, nhead, batch_first=True)\n        self.multihead_attn = nn.MultiheadAttention(d_model, nhead, batch_first=True)\n        self.linear1 = nn.Linear(d_model, dim_feedforward)\n        self.linear2 = nn.Linear(dim_feedforward, d_model)\n        self.norm1 = nn.LayerNorm(d_model)\n        self.norm2 = nn.LayerNorm(d_model)\n        self.norm3 = nn.LayerNorm(d_model)\n\n    def forward(self, x, memory):\n        # Pre-norm architecture\n        # 1. Self-attention\n        residual = x\n        x = self.norm1(x)\n        attn_output, _ = self.self_attn(x, x, x)\n        x = residual + attn_output\n\n        # 2. Cross-attention\n        residual = x\n        x = self.norm2(x)\n        attn_output, _ = self.multihead_attn(x, memory, memory)\n        x = residual + attn_output\n\n        # 3. Feed-forward\n        residual = x\n        x = self.norm3(x)\n        x = self.linear1(x)\n        x = self.linear2(x)\n        x = residual + x\n        return x\n\nclass RecoveredModel(nn.Module):\n    def __init__(self, vocab_size, d_model, nhead, num_layers_enc, num_layers_dec, dim_feedforward, output_dim, max_len=5000):\n        super().__init__()\n        self.embedding = nn.Embedding(vocab_size, d_model)\n        self.embedding.bias = nn.Parameter(torch.zeros(d_model))\n        self.pos_encoder = nn.Module()\n        self.pos_encoder.register_buffer(\'pe\', torch.zeros(1, max_len, d_model))\n        # We\'ll manually set pe in the loading part or here\n        \n        self.transformer_encoder = nn.ModuleList([\n            TransformerEncoderLayerCustom(d_model, nhead, dim_feedforward) for _ in range(num_layers_enc)\n        ])\n        \n        self.transformer_decoder = nn.ModuleList([\n            TransformerDecoderLayerCustom(d_model, nhead, dim_feedforward) for _ in range(num_layers_d