>> ShellSession({'command': 'cat << \'EOF\' > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return 0, 0\n\n    num_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    \n    # We\'ll use a more robust approach to find the athlete.\n    # Instead of just the first frame, we\'ll use a running background subtraction.\n    \n    y_coords = []\n    \n    # Initialize background with the first frame\n    ret, first_frame = cap.read()\n    if not ret:\n        return 0, 0\n    background = cv2.cvtColor(first_frame, cv2.COLOR_BGR2GRAY).astype(np.float32)\n    \n    # We\'ll process frames and track the top-most point of the moving object\n    frame_idx = 0\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        \n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY).astype(np.float32)\n        \n        # Simple background subtraction\n        diff = cv2.absdiff(gray, background)\n        _, thresh = cv2.threshold(diff, 30, 255, cv2.THRESH_BINARY)\n        \n        coords = np.column_stack(np.where(thresh > 0))\n        if len(coords) > 0:\n            # We want the top-most part of the athlete. \n            # In many videos, the athlete is the most significant moving object.\n            # We\'ll take the minimum y-coordinate of the detected moving pixels.\n            y_coords.append(np.min(coords[:, 0]))\n        else:\n            y_coords.append(None)\n            \n        # Slowly update background to handle lighting changes, but keep it stable\n        alpha = 0.95\n        cv2.accumulateWeighted(gray, background, 1 - alpha)\n        \n        frame_idx += 1\n        if frame_idx >= num_frames:\n            break\n    cap.release()\n\n    if not y_coords:\n        return 0, 0\n\n    # Smoothing\n    smoothed_y = []\n    window_size = 5\n    for i in range(len(y_coords)):\n        window = []\n        for j in range(max(0, i - window_size), min(len(y_coords), i + window_size + 1)):\n            if y_coords[j] is not None:\n                window.append(y_coords[j])\n        if window:\n            smoothed_y.append(np.median(window))\n        else:\n            smoothed_y.append(None)\n\n    valid_smoothed = [(i, y) for i, y in enumerate(smoothed_y) if y is not None]\n    if not valid_smoothed:\n        return 0, 0\n\n    # Find the peak (minimum y)\n    peak_idx = min(valid_smoothed, key=lambda x: x[1])[0]\n\n    # Takeoff: the frame where y starts to decrease (moving up)\n    # We look for the first frame before the peak where the trend is downward.\n    takeoff_idx = peak_idx\n    for i in range(peak_idx, 0, -1):\n        if smoothed_y[i-1] is not None and smoothed_y[i] is not None:\n            if smoothed_y[i-1] > smoothed_y[i]: # y is decreasing\n                takeoff_idx = i - 1\n            else:\n                break\n\n    # Landing: the frame where y starts to increase (moving down)\n    landing_idx = peak_idx\n    for i in range(peak_idx, len(smoothed_y) - 1):\n        if smoothed_y[i] is not None and smoothed_y[i+1] is not None:\n            if smoothed_y[i+1] > smoothed_y[i]: # y is increasing\n                landing_idx = i + 1\n                break\n\n    return int(takeoff_idx), int(landing_idx)\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    takeoff, landing = analyze_video(video_path)\n    \n    with open(\'/app/output.toml\', \'w\') as f:\n        f.write(f"jump_takeoff_frame_number = {takeoff}\\n")\n        f.write(f"jump_land_frame_number = {landing}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4 && cat /app/output.toml'})
