 # number of "active" pixels (pixels that differ from the background).\n    \n    active_pixels = []\n    for i in range(num_frames):\n        diff = cv2.absdiff(frames[i], frames[0])\n        _, thresh = cv2.threshold(diff, 30, 255, cv2.THRESH_BINARY)\n        active_pixels.append(np.sum(thresh > 0))\n    \n    # The jump usually involves the athlete being in the air.\n    # Let\'s find the window where active_pixels is highest or where the athlete is "most" present.\n    # Or better: takeoff is when the athlete\'s vertical position changes significantly.\n    # But we only have monocular.\n    \n    # Let\'s look at the active_pixels trend.\n    # In the example:\n    # 0 459883 (Wait, this was the first debug run, which was just thresholding the frame itself)\n    # Let\'s use the diff_sums from the second debug run.\n    \n    # Let\'s try to find the takeoff and landing by looking at the "center of mass" of the difference.\n    # Or simply, the takeoff is when the athlete\'s vertical position (y) increases.\n    \n    # Let\'s try to find the bounding box of the difference.\n    \n    diff_frames = []\n    for i in range(num_frames):\n        diff = cv2.absdiff(frames[i], frames[0])\n        _, thresh = cv2.threshold(diff, 30, 255, cv2.THRESH_BINARY)\n        diff_frames.append(thresh)\n\n    # Find the frame where the athlete is highest.\n    # We can estimate the "height" of the athlete by the y-coordinate of the top of the bounding box.\n    \n    y_coords = []\n    for i in range(num_frames):\n        coords = np.column_stack(np.where(diff_frames[i] > 0))\n        if len(coords) > 0:\n            y_coords.append(np.min(coords[:, 0])) # Min y is the top\n        else:\n            y_coords.append(None)\n            \n    # Filter out None and find the minimum y (highest point)\n    valid_y = [(i, y) for i, y in enumerate(y_coords) if y is not None]\n    \n    if not valid_y:\n        return 0, 0\n\n    # The jump starts when the athlete starts ascending and ends when they land.\n    # Let\'s find the period where the athlete is "in the air".\n    # A simple heuristic: takeoff is when the y-coordinate starts decreasing (moving up)\n    # and landing is when it starts increasing again (moving down) or stabilizes.\n    \n    # Actually, let\'s look at the y_coords.\n    # The athlete runs, then jumps (y decreases), then lands (y increases).\n    \n    # Let\'s find the minimum y (highest point)\n    min_y_val = min(y for i, y in valid_y)\n    peak_frame = next(i for i, y in valid_y if y == min_y_val)\n    \n    # Takeoff: the frame before the y starts decreasing significantly.\n    # Landing: the frame after the y starts increasing significantly.\n    \n    # Let\'s use a more robust way:\n    # Takeoff is the frame where the athlete\'s vertical position starts to change from the running phase.\n    # Landing is the frame where the vertical position returns to the running phase.\n    \n    # Let\'s find the running phase y-level.\n    # The first few frames might be empty, so we look at the first stable y.\n    \n    # For the example:\n    # Let\'s just find the frame where the athlete is highest and look around it.\n    # But we need to be precise.\n    \n    # Let\'s find the takeoff: the frame where y starts to decrease.\n    # Let\'s find the landing: the frame where y stops decreasing and starts increasing.\n    \n    # We need to handle noise.\n    \n    takeoff_frame = 0\n    landing_frame = 0\n    \n    # Let\'s find the frame where the athlete is at the highest point.\n    # Then takeoff is the frame where they first start to move up.\n    # Landing is the frame where they first hit the ground.\n    \n    # Let\'s try this:\n    # 1. Find the frame with the minimum y (highest point).\n    # 2. Takeoff is the frame where y starts to decrease before the peak.\n    # 3. Landing is the frame where y starts to increase after the peak.\n    \n    # To handle noise, we can smooth the y_coords.\n    \n    smoothed_y = []\n    for i in range(len(y_coords)):\n        window = []\n        for j in range(max(0, i-2), min(len(y_coords), i+3)):\n            if y_coords[j] is not None:\n                window.append(y_coords[j])\n        if window:\n            smoothed_y.append(np.median(window))\n        else:\n            smoothed_y.append(None)\n\n    # Find the peak in smoothed_y\n    valid_smoothed = [(i, y) for i, y in enumerate(smoothed_y) if y is not None]\n    if not valid_smoothed:\n        return 0, 0\n        \n    peak_idx = min(valid_smoothed, key=lambda x: x[1])[0]\n    \n    # Takeoff: the frame where smoothed_y starts to decrease.\n    # We look backwards from peak_idx.\n    takeoff_idx = peak_idx\n    for i in range(peak_idx, 0, -1):\n        if smoothed_y[i-1] is not None and smoothed_y[i] is not None:\n            if smoothed_y[i-1] > smoothed_y[i]: # Moving up\n                takeoff_idx = i - 1\n            else:\n                break\n    # Wait, if smoothed_y[i-1] > smoothed_y[i], it means the previous frame was lower.\n    # So it\'s moving up.\n    \n    # Let\'s re-evaluate:\n    # y decreases -> moving up.\n    # y increases -> moving down.\n    \n    # Peak is min y.\n    # Before peak: y is decreasing.\n    # After peak: y is increasing.\n    \n    # Takeoff: the frame where y starts to decrease.\n    takeoff_idx = peak_idx\n    for i in range(peak_idx, 0, -1):\n        if smoothed_y[i-1] is not None and smoothed_y[i] is not None:\n            if smoothed_y[i-1] > smoothed_y[i]: # y is decreasing\n                takeoff_idx = i - 1\n            else:\n                # y was increasing or stable, so takeoff must be earlier\n                # but we are going backwards from peak.\n                # If we hit a point where y is not decreasing, that\'s the takeoff.\n                break\n    \n    # Landing: the frame where y starts to increase.\n    landing_idx = peak_idx\n    for i in range(peak_idx, len(smoothed_y) - 1):\n        if smoothed_y[i] is not None and smoothed_y[i+1] is not None:\n            if smoothed_y[i+1] > smoothed_y[i]: # y is increasing\n                landing_idx = i + 1\n                break\n                \n    return takeoff_idx, landing_idx\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        print("Usage: python jump_analyzer.py <video_path>")\n        sys.exit(1)\n        \n    video_path = sys.argv[1]\n    takeoff, landing = analyze_video(video_path)\n    \n    output = {\n        "jump_takeoff_frame_number": int(takeoff),\n        "jump_land_frame_number": int(landing)\n    }\n    \n    with open(\'/app/output.toml\', \'w\') as f:\n        toml.dump(output, f)\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4 && cat /app/output.toml'})
