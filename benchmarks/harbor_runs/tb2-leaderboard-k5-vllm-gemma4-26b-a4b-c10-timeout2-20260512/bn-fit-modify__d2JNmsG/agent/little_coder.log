'from\']].to_csv(\'/app/intervened_dag.csv\', index=False)\n\n# 4. Sample 10k points from the intervened BN\n# We use the learned models, but for Y, we force it to 0.0.\n# For nodes that depend on Y, they will use the 0.0 value.\n\nn_samples = 10000\nsampled_df = pd.DataFrame(index=range(n_samples), columns=cols)\n\n# Topological sort for sampling: U, Y, R, D, M (or similar)\n# U is root.\n# Y depends on U.\n# R depends on U.\n# D depends on U, Y.\n# M depends on U, R.\n\n# Sampling order:\n# 1. U (root)\n# 2. Y (depends on U)\n# 3. R (depends on U)\n# 4. D (depends on U, Y)\n# 5. M (depends on U, R)\n\n# Sample U\nu_mean = models[\'U\'][\'mean\']\nu_std = models[\'U\'][\'std\']\nsampled_df[\'U\'] = np.random.normal(u_mean, u_std, n_samples)\n\n# Sample Y (Intervened to 0.0)\nsampled_df[\'Y\'] = 0.0\n\n# Sample R (depends on U)\nX_r = sampled_df[[\'U\']]\nsampled_df[\'R\'] = models[\'R\'].predict(X_r)\n\n# Sample D (depends on U, Y)\nX_d = sampled_df[[\'U\', \'Y\']]\nsampled_df[\'D\'] = models[\'D\'].predict(X_d)\n\n# Sample M (depends on U, R)\nX_m = sampled_df[[\'U\', \'R\']]\nsampled_df[\'M\'] = models[\'M\'].predict(X_m)\n\n# Save result\nsampled_df.to_csv(\'/app/final_bn_sample.csv\', index=False)\nprint("Done")\nEOF\npython3 solve_task.py'})
