odel.config, 'hidden_size'):\n                hidden_size = model.model.config.hidden_size\n            else:\n                hidden_size = 4096\n        shape_tensor[0] = microbatch\n        shape_tensor[1] = seq_len\n        shape_tensor[2] = hidden_size\n    \n    dist.broadcast(shape_tensor, src=0)\n    microbatch, seq_len, hidden_size = shape_tensor[0].item(), shape_tensor[1].item(), shape_tensor[2].item()\n\n    # 3. Forward Pass (AFAB: All Forward first)\n    inputs_to_my_layers = [None] * num_microbatches\n    activations_out = [None] * num_microbatches\n    \n    if rank == 0:\n        for m in range(num_microbatches):\n            x = inputs[m].to(device=device, dtype=dtype)\n            if embed_layer is not None:\n                x = embed_layer(x)\n            inputs_to_my_layers[m] = x\n            for layer in my_layers:\n                x = layer(x)\n            activations_out[m] = x\n        if world_size > 1:\n            for m in range(num_microbatches):\n                dist.send(tensor=activations_out[m], dst=1)\n    else:\n        for m in range(num_microbatches):\n            x = torch.empty((microbatch, seq_len, hidden_size), device=device, dtype=dtype)\n            dist.recv(tensor=x, src=rank - 1)\n            inputs_to_my_layers[m] = x\n            for layer in my_layers:\n                x = layer(x)\n            activations_out[m] = x\n        if rank < world_size - 1:\n            for m in range(num_microbatches):\n                dist.send(tensor=activations_out[m], dst=rank + 1)\n\n    # 4. Backward Pass (AFAB: All Backward)\n    if rank == world_size - 1:\n        grads_to_send = [None] * num_microbatches\n        for m in range(num_microbatches):\n            x_out = activations_out[m]\n            if head_layer is not None:\n                logits = head_layer(x_out)\n            else:\n                logits = x_out\n            \n            loss = F.cross_entropy(logits.view(-1, logits.size(-1)), targets[m].view(-1), reduction='mean')\n            loss = loss / num_microbatches\n            \n            inputs_to_my_layers[m].retain_grad()\n            loss.backward()\n            grads_to_send[m] = inputs_to_my_layers[m].grad\n        \n        if world_size > 1:\n            for m in range(num_microbatches):\n                dist.send(tensor=grads_to_send[m], dst=rank - 1)\n    elif rank < world_size - 1:\n        grads_to_send = [None] * num_microbatches\n        for m in range(num_microbatches):\n            grad_in = torch.empty((microbatch, seq_len, hidden_size), device=device, dtype=dtype)\n            dist.recv(tensor=grad_in, src=rank + 1)\n            \n            inputs_to_my_layers[m].retain_grad()\n            activations_out[m].backward(grad_in)\n            grads_to_send[m] = inputs_to_my_layers[m].grad\n            \n        if rank > 0:\n            for m in range(num_microbatches):\n                dist.send(tensor=grads_to_send[m], dst=rank - 1)\n    else:\n        # Rank 0\n        if world_size > 1:\n            for m in range(num_microbatches):\n                grad_in = torch.empty((microbatch, seq_len, hidden_size), device=device, dtype=dtype)\n                dist.recv(tensor=grad_in, src=1)\nEOF\n"})
