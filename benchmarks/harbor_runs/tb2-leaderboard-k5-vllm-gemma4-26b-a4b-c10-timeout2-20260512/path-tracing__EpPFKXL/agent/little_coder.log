>> ShellSession({'command': 'python3 -c "\ndef get_ppm_data(filename):\n    with open(filename, \'r\') as f:\n        lines = f.readlines()\n    header = lines[0].strip()\n    dims = lines[1].strip().split()\n    width, height = int(dims[0]), int(dims[1])\n    max_val = int(lines[2].strip())\n    pixels = []\n    for line in lines[3:]:\n        parts = line.split()\n        if not parts: continue\n        pixels.extend(map(int, parts))\n    return width, height, max_val, pixels\n\nwidth, height, max_val, pixels = get_ppm_data(\'/app/image.ppm\')\nr_vals = pixels[0::3]\ng_vals = pixels[1::3]\nb_vals = pixels[2::3]\n\n# Check for correlation with x, y\nimport math\n\ndef get_stats(vals, w, h):\n    n = len(vals)\n    sum_v = sum(vals)\n    sum_x = 0\n    sum_y = 0\n    sum_xy = 0\n    sum_x2 = 0\n    sum_y2 = 0\n    for i in range(n):\n        x = i % w\n        y = i // w\n        v = vals[i]\n        sum_x += x\n        sum_y += y\n        sum_xy += x * y\n        sum_x2 += x * x\n        sum_y2 += y * y\n    \n    # Covariance\n    mean_x = (w - 1) / 2.0\n    mean_y = (h - 1) / 2.0\n    mean_v = sum_v / n\n    \n    cov_xy = 0\n    cov_xv = 0\n    cov_yv = 0\n    for i in range(n):\n        x = i % w\n        y = i // w\n        v = vals[i]\n        cov_xy += (x - mean_x) * (y - mean_y)\n        cov_xv += (x - mean_x) * (v - mean_v)\n        cov_yv += (y - mean_y) * (v - mean_v)\n        \n    return cov_xv, cov_yv, cov_xy\n\nfor name, vals in zip([\'R\', \'G\', \'B\'], [r_vals, g_vals, b_vals]):\n    cv, cy, cxy = get_stats(vals, width, height)\n    print(f\'{name}: cv={cv:.2e}, cy={cy:.2e}, cxy={cxy:.2e}\')\n"'})
