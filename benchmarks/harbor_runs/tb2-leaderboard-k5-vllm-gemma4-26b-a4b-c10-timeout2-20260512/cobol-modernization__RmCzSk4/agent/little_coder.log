>> ShellSession({'command': 'cat << \'EOF\' > /app/program.py\nimport os\n\ndef main():\n    # File paths\n    input_file_path = "/app/src/INPUT.DAT"\n    accounts_file_path = "/app/data/ACCOUNTS.DAT"\n    books_file_path = "/app/data/BOOKS.DAT"\n    transactions_file_path = "/app/data/TRANSACTIONS.DAT"\n\n    # 1. Read Input\n    try:\n        with open(input_file_path, \'r\') as f:\n            input_data = f.read().strip()\n    except FileNotFoundError:\n        print("Error: Input file not found")\n        return\n\n    if not input_data:\n        print("Error: Input file is empty")\n        return\n\n    # INPUT-RECORD:\n    # 05 INPUT-BUYER-ID   PIC X(4).\n    # 05 INPUT-SELLER-ID  PIC X(4).\n    # 05 INPUT-BOOK-ID    PIC X(4).\n    # 05 INPUT-AMOUNT     PIC 9(10).\n    # Note: The COBOL code uses WS-AMOUNT PIC 9(10)V99, but the input is PIC 9(10).\n    # Looking at the input: U001 U002 B007 200\n    # Wait, the input is U001 U002 B007 200. \n    # Let\'s check the length: 4 + 4 + 4 + 10 = 22? \n    # Input file content: U001U002B007200 (length 16)\n    # U001 (4) + U002 (4) + B007 (4) + 200 (3) = 15?\n    # Let\'s re-examine the input: U001 U002 B007 200.\n    # U001 (4)\n    # U002 (4)\n    # B007 (4)\n    # 200 (3)\n    # Total 15.\n    # The COBOL code says PIC 9(10) for INPUT-AMOUNT.\n    # If the input is "200", it might be padded or just read.\n    \n    buyer_id = input_data[0:4]\n    seller_id = input_data[4:8]\n    book_id = input_data[8:12]\n    amount_str = input_data[12:]\n    amount = int(amount_str)\n\n    # 2. Validate Users and Book\n    buyer_found = False\n    seller_found = False\n    book_found = False\n    valid_owner = False\n\n    # Read Accounts\n    with open(accounts_file_path, \'r\') as f:\n        accounts_content = f.read()\n    \n    # ACCOUNT-RECORD:\n    # 05 ACCOUNT-ID        PIC X(4).\n    # 05 ACCOUNT-NAME      PIC X(20).\n    # 05 ACCOUNT-BALANCE   PIC 9(10).\n    # Total 4 + 20 + 10 = 34 bytes per record.\n    \n    accounts = []\n    for i in range(0, len(accounts_content), 34):\n        rec = accounts_content[i:i+34]\n        if len(rec) < 34: break\n        acc_id = rec[0:4]\n        acc_name = rec[4:24]\n        acc_balance = int(rec[24:34])\n        accounts.append({\'id\': acc_id, \'name\': acc_name, \'balance\': acc_balance, \'raw\': rec})\n        \n        if acc_id == buyer_id:\n            buyer_found = True\n        if acc_id == seller_id:\n            seller_found = True\n\n    # Read Books\n    with open(books_file_path, \'r\') as f:\n        books_content = f.read()\n    \n    # BOOK-RECORD:\n    # 05 BOOK-ID          PIC X(4).\n    # 05 BOOK-TITLE       PIC X(20).\n    # 05 BOOK-OWNER       PIC X(4).\n    # Total 4 + 20 + 4 = 28 bytes per record.\n    \n    books = []\n    for i in range(0, len(books_content), 28):\n        rec = books_content[i:i+28]\n        if len(rec) < 28: break\n        b_id = rec[0:4]\n        b_title = rec[4:24]\n        b_owner = rec[24:28]\n        books.append({\'id\': b_id, \'title\': b_title, \'owner\': b_owner, \'raw\': rec})\n        \n        if b_id == book_id:\n            book_found = True\n            if b_owner == seller_id:\n                valid_owner = True\n\n    # 3. Process Transaction\n    if buyer_found and seller_found and book_found and valid_owner:\n        # Update Accounts\n        new_accounts_content = ""\n        for acc in accounts:\n            if acc[\'id\'] == buyer_id:\n                acc[\'balance\'] -= amount\n            elif acc[\'id\'] == seller_id:\n                acc[\'balance\'] += amount\n            \n            # Reconstruct raw record: ID(4) + Name(20) + Balance(10)\n            # Balance must be PIC 9(10) - zero padded\n            new_rec = acc[\'id\'] + acc[\'name\'] + f"{acc[\'balance\']:010d}"\n            new_accounts_content += new_rec\n        \n        with open(accounts_file_path, \'w\') as f:\n            f.write(new_accounts_content)\n\n        # Update Books\n        new_books_content = ""\n        for book in books:\n            if book[\'id\'] == book_id:\n                book[\'owner\'] = buyer_id\n            \n            # Reconstruct raw record: ID(4) + Title(20) + Owner(4)\n            new_rec = book[\'id\'] + book[\'title\'] + book[\'owner\']\n            new_books_content += new_rec\n            \n        with open(books_file_path, \'w\') as f:\n            f.write(new_books_content)\n\n        # Append Transaction\n        # TRANSACTION-RECORD:\n        # 05 TRANS-BOOK       PIC X(4).\n        # 05 TRANS-AMOUNT     PIC 9(10).\n        # 05 TRANS-SELLER     PIC X(4).\n        # 05 TRANS-BUYER      PIC X(4).\n        # Total 4 + 10 + 4 + 4 = 22 bytes.\n        # Wait, the COBOL code says:\n        # 05 TRANS-BOOK       PIC X(4).\n        # 05 TRANS-AMOUNT     PIC 9(10).\n        # 05 TRANS-SELLER     PIC X(4).\n        # 05 TRANS-BUYER      PIC X(4).\n        # But the order in PROCESS-TRANSACTION is:\n        # MOVE WS-BUYER-ID TO TRANS-BUYER\n        # MOVE WS-SELLER-ID TO TRANS-SELLER\n        # MOVE WS-BOOK-ID TO TRANS-BOOK\n        # MOVE WS-AMOUNT TO TRANS-AMOUNT\n        # WRITE TRANSACTION-RECORD\n        # Let\'s check the order in the DATA DIVISION:\n        # 05 TRANS-BOOK       PIC X(4).\n        # 05 TRANS-AMOUNT     PIC 9(10).\n        # 05 TRANS-SELLER     PIC X(4).\n        # 05 TRANS-BUYER      PIC X(4).\n        # So the record is: BOOK(4) + AMOUNT(10) + SELLER(4) + BUYER(4)\n        \n        with open(transactions_file_path, \'a\') as f:\n            trans_rec = f"{book_id}{amount:010d}{seller_id}{buyer_id}"\n            f.write(trans_rec)\n            \n        print("Transaction completed successfully")\n    else:\n        print("Transaction failed due to validation errors")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/program.py\n'})
