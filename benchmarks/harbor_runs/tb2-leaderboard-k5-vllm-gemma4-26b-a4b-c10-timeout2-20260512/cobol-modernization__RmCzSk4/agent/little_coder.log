ID          PIC X(4).\n    # 05 BOOK-TITLE       PIC X(20).\n    # 05 BOOK-OWNER       PIC X(4).\n    # Total 28 bytes per record.\n    \n    books = []\n    for i in range(0, len(books_content), 28):\n        rec = books_content[i:i+28]\n        if len(rec) < 28: break\n        b_id = rec[0:4]\n        b_title = rec[4:24]\n        b_owner = rec[24:28]\n        books.append({\'id\': b_id, \'title\': b_title, \'owner\': b_owner, \'raw\': rec})\n        \n        if b_id == book_id:\n            book_found = True\n            if b_owner == seller_id:\n                valid_owner = True\n\n    # 3. Process Transaction\n    if buyer_found and seller_found and book_found and valid_owner:\n        # Update Accounts\n        new_accounts_content = ""\n        for acc in accounts:\n            if acc[\'id\'] == buyer_id:\n                acc[\'balance\'] -= amount\n            elif acc[\'id\'] == seller_id:\n                acc[\'balance\'] += amount\n            \n            # Reconstruct raw record: ID(4) + Name(20) + Balance(10)\n            # Balance must be PIC 9(10) - zero padded\n            new_rec = acc[\'id\'] + acc[\'name\'] + f"{acc[\'balance\']:010d}"\n            new_accounts_content += new_rec\n        \n        with open(accounts_file_path, \'w\') as f:\n            f.write(new_accounts_content)\n\n        # Update Books\n        new_books_content = ""\n        for book in books:\n            if book[\'id\'] == book_id:\n                book[\'owner\'] = buyer_id\n            \n            # Reconstruct raw record: ID(4) + Title(20) + Owner(4)\n            new_rec = book[\'id\'] + book[\'title\'] + book[\'owner\']\n            new_books_content += new_rec\n            \n        with open(books_file_path, \'w\') as f:\n            f.write(new_books_content)\n\n        # Append Transaction\n        # TRANSACTION-RECORD:\n        # 05 TRANS-BOOK       PIC X(4).\n        # 05 TRANS-AMOUNT     PIC 9(10).\n        # 05 TRANS-SELLER     PIC X(4).\n        # 05 TRANS-BUYER      PIC X(4).\n        # Total 22 bytes.\n        \n        with open(transactions_file_path, \'a\') as f:\n            trans_rec = f"{book_id}{amount:010d}{seller_id}{buyer_id}"\n            f.write(trans_rec)\n            \n        print("Transaction completed successfully")\n    else:\n        print("Transaction failed due to validation errors")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/program.py\n'})
