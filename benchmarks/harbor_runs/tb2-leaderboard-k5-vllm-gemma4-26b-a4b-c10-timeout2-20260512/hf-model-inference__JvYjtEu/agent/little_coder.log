n        # Map the labels to the requested lowercase format\n        # and extract scores\n        \n        # We\'ll use the index of the max probability for the main sentiment\n        max_idx = torch.argmax(probabilities, dim=-1).item()\n        sentiment_label = labels[max_idx].lower()\n        \n        # The task asks for "positive" or "negative"\n        # If the model returns "LABEL_0" or something, we handle it.\n        if sentiment_label not in ["positive", "negative"]:\n            # Fallback/heuristic for SST-2\n            if max_idx == 1:\n                sentiment_label = "positive"\n            elif max_idx == 0:\n                sentiment_label = "negative"\n            else:\n                sentiment_label = sentiment_label # keep as is if unknown\n        \n        # Construct response\n        # We need to return confidence for both\n        # The task asks for:\n        # "confidence": { "positive": float, "negative": float }\n        \n        # We\'ll assume index 0 is negative and 1 is positive based on SST-2 convention\n        # and the model\'s id2label.\n        \n        # Let\'s find which index is positive and which is negative\n        pos_idx = -1\n        neg_idx = -1\n        for idx, label in labels.items():\n            if label.lower() == "positive":\n                pos_idx = idx\n            elif label.lower() == "negative":\n                neg_idx = idx\n        \n        # If we couldn\'t find them by name, fallback to SST-2 defaults\n        if pos_idx == -1: pos_idx = 1\n        if neg_idx == -1: neg_idx = 0\n        \n        res = {\n            "sentiment": sentiment_label,\n            "confidence": {\n                "positive": float(probs[pos_idx]),\n                "negative": float(probs[neg_idx])\n            }\n        }\n        return jsonify(res)\n\n    except Exception as e:\n        return jsonify({"error": str(e)}), 400\n\nif __name__ == \'__main__\':\n    app.run(host=\'0.0.0.0\', port=5000)\nEOF\n\npython3 /app/app.py &\n', 'timeout': 300})
