_c[\'status\'].map({True: \'active\', False: \'inactive\'})\n    df_c = df_c[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\n    df_c[\'source\'] = \'source_c\'\n\n    # Ensure types\n    for df in [df_a, df_b, df_c]:\n        df[\'user_id\'] = df[\'user_id\'].astype(int)\n        df[\'created_date\'] = pd.to_datetime(df[\'created_date\']).dt.strftime(\'%Y-%m-%d\')\n\n    # 2. Merge and handle conflicts\n    # We want to collect all values for each user_id and field to detect conflicts.\n    \n    all_dfs = [df_a, df_b, df_c]\n    sources = [\'source_a\', \'source_b\', \'source_c\']\n    \n    # Get all unique user_ids\n    all_user_ids = pd.concat([df_a[\'user_id\'], df_b[\'user_id\'], df_c[\'user_id\']]).unique()\n    \n    merged_data = []\n    conflicts_list = []\n    \n    target_fields = [\'name\', \'email\', \'created_date\', \'status\']\n\n    for uid in all_user_ids:\n        user_values = {field: {} for field in target_fields}\n        user_exists_in_source = {s: False for s in sources}\n        \n        # Collect values from each source\n        for i, df in enumerate(all_dfs):\n            s_name = sources[i]\n            row = df[df[\'user_id\'] == uid]\n            if not row.empty:\n                user_exists_in_source[s_name] = True\n                for field in target_fields:\n                    if field in row.columns:\n                        val = row.iloc[0][field]\n                        # Handle NaN\n                        if pd.isna(val):\n                            val = None\n                        else:\n                            val = str(val)\n                        user_values[field][s_name] = val\n\n        # Determine selected values based on priority\n        selected_row = {\'user_id\': int(uid)}\n        \n        for field in target_fields:\n            # Find the highest priority source that has a value for this field\n            selected_val = None\n            for s_name in sources:\n                if s_name in user_values[field] and user_values[field][s_name] is not None:\n                    selected_val = user_values[field][s_name]\n                    break\n            \n            selected_row[field] = selected_val\n            \n            # Check for conflicts\n            # A conflict occurs if multiple sources provide DIFFERENT non-null values for the same field\n            vals_for_field = [v for v in user_values[field].values() if v is not None]\n            if len(set(vals_for_field)) > 1:\n                # Conflict detected\n                conflict_entry = {\n                    "user_id": int(uid),\n                    "field": field,\n                    "values": user_values[field],\n                    "selected": selected_val\n                }\n                # Clean up None values in the report for the specific field\n                # The requirement shows: "values": { "source_a": <value if exists>, ... }\n                # We should only include sources that actually had a value for this field.\n                # Actually, the example shows "source_a": <value if exists>. \n                # Let\'s refine the values dict to only include non-None.\n                clean_values = {k: v for k, v in user_values[field].items() if v is not None}\n                conflict_entry["values"] = clean_values\n                conflicts_list.append(conflict_entry)\n\n        merged_data.append(selected_row)\n\n    # 3. Generate outputs\n    # Merged Parquet\n    final_df = pd.DataFrame(merged_data)\n    # Ensure column order and types\n    final_df = final_df[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\n    final_df[\'user_id\'] = final_df[\'user_id\'].astype(int)\n    final_df.to_parquet(\'/app/merged_users.parquet\')\n\n    # Conflict Report\n    report = {\n        "total_conflicts": len(conflicts_list),\n        "conflicts": conflicts_list\n    }\n    with open(\'/app/conflicts.json\', \'w\') as f:\n        json.dump(re