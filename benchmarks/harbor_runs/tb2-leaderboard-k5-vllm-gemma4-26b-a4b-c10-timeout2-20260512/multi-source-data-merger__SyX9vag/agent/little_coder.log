>> ShellSession({'command': 'cat <<\'EOF\' > /app/merge_users.py\nimport pandas as pd\nimport json\nfrom datetime import datetime\n\ndef solve():\n    # 1. Load data\n    # Source A: JSON\n    df_a = pd.read_json(\'/data/source_a/users.json\')\n    # Mapping A: id -> user_id, full_name -> name, email -> email, registration_date -> created_date\n    df_a = df_a.rename(columns={\n        \'id\': \'user_id\',\n        \'full_name\': \'name\',\n        \'email\': \'email\',\n        \'registration_date\': \'created_date\'\n    })\n    # Ensure types\n    df_a[\'user_id\'] = df_a[\'user_id\'].astype(int)\n    df_a[\'created_date\'] = pd.to_datetime(df_a[\'created_date\']).dt.strftime(\'%Y-%m-%d\')\n    # Keep only relevant columns\n    df_a = df_a[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\n\n    # Source B: CSV\n    df_b = pd.read_csv(\'/data/source_b/users.csv\')\n    # Mapping B: user_id -> user_id, name -> name, email_address -> email, created_at -> created_date\n    # Note: \'is_active\' might be \'status\'\n    df_b = df_b.rename(columns={\n        \'user_id\': \'user_id\',\n        \'name\': \'name\',\n        \'email_address\': \'email\',\n        \'created_at\': \'created_date\'\n    })\n    df_b[\'user_id\'] = df_b[\'user_id\'].astype(int)\n    df_b[\'created_date\'] = pd.to_datetime(df_b[\'created_date\']).dt.strftime(\'%Y-%m-%d\')\n    # Map \'is_active\' to \'status\'\n    if \'is_active\' in df_b.columns:\n        df_b[\'status\'] = df_b[\'is_active\'].map({True: \'active\', False: \'inactive\'})\n    else:\n        df_b[\'status\'] = None\n    df_b = df_b[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\n\n    # Source C: Parquet\n    df_c = pd.read_parquet(\'/data/source_c/users.parquet\')\n    # Mapping C: userId -> user_id, userName -> name, email -> email, joined -> created_date\n    df_c = df_c.rename(columns={\n        \'userId\': \'user_id\',\n        \'userName\': \'name\',\n        \'email\': \'email\',\n        \'joined\': \'created_date\'\n    })\n    df_c[\'user_id\'] = df_c[\'user_id\'].astype(int)\n    df_c[\'created_date\'] = pd.to_datetime(df_c[\'created_date\']).dt.strftime(\'%Y-%m-%d\')\n    # Map \'active\' to \'status\'\n    if \'active\' in df_c.columns:\n        df_c[\'status\'] = df_c[\'active\'].map({True: \'active\', False: \'inactive\'})\n    else:\n        df_c[\'status\'] = None\n    df_c = df_c[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\n\n    # 2. Merge and handle conflicts\n    # We\'ll build a master dictionary of users\n    # master_users[user_id] = {field: (value, source_priority)}\n    \n    sources = [\n        (\'source_a\', df_a, 1),\n        (\'source_b\', df_b, 2),\n        (\'source_c\', df_c, 3)\n    ]\n    \n    master_data = {} # user_id -> {field: {source_name: value}}\n    \n    for source_name, df, priority in sources:\n        for _, row in df.iterrows():\n            uid = int(row[\'user_id\'])\n            if uid not in master_data:\n                master_data[uid] = {}\n            \n            for field in [\'name\', \'email\', \'created_date\', \'status\']:\n                val = row[field]\n                # Handle NaN/None\n                if pd.isna(val):\n                    val = None\n                \n                if field not in master_data[uid]:\n                    master_data[uid][field] = {}\n                \n                # Only store if it\'s not None (or if we want to track None as a value, but usually we want the best available)\n                # The requirement says "use values from the highest priority source".\n                # If a field is missing in source_a but present in source_b, we use source_b.\n                if val is not None:\n                    master_data[uid][field][source_name] = val\n\n    # 3. Build final dataset and conflict report\n    final_rows = []\n    conflicts = []\n    \n    for uid, fields in master_data.items():\n        merged_row = {\'user_id\': uid}\n        \n        for field in [\'name\', \'email\', \'created_date\', \'status\']:\n            field_values = fields.get(field, {})\n            \n            # Determine selected value based on priority\n            # Priority: source_a (1) > source_b (2) > source_c (3)\n            selected_val = None\n            if \'source_a\' in field_values:\n                selected_val = field_values[\'source_a\']\n            elif \'source_b\' in field_values:\n                selected_val = field_values[\'source_b\']\n            elif \'source_c\' in field_values:\n                selected_val = field_values[\'source_c\']\n            \n            merged_row[field] = selected_val\n            \n            # Check for conflicts\n            # A conflict exists if multiple sources have different non-None values for the same field\n            vals_to_compare = {k: v for k, v in field_values.items() if v is not None}\n            if len(vals_to_compare) > 1:\n                # Check if they are actually different\n                unique_vals = set(vals_to_compare.values())\n                if len(unique_vals) > 1:\n                    conflicts.append({\n                        "user_id": uid,\n                        "field": field,\n                        "values": vals_to_compare,\n                        "selected": selected_val\n                    })\n        \n        final_rows.append(merged_row)\n\n    # 4. Output files\n    # Merged Parquet\n    final_df = pd.DataFrame(final_rows)\n    # Ensure correct types\n    final_df[\'user_id\'] = final_df[\'user_id\'].astype(int)\n    # Reorder columns to match requirement\n    cols = [\'user_id\', \'name\', \'email\', \'created_date\', \'status\']\n    # Filter cols to only those present in final_df\n    cols = [c for c in cols if c in final_df.columns]\n    final_df = final_df[cols]\n    final_df.to_parquet(\'/app/merged_users.parquet\')\n    \n    # Conflict Report\n    report = {\n        "total_conflicts": len(conflicts),\n        "conflicts": conflicts\n    }\n    with open(\'/app/conflicts.json\', \'w\') as f:\n        json.dump(report, f, indent=2)\n\nif __name__ == "__main__":\n    solve()\nEOF\npython3 /app/merge_users.py'})
