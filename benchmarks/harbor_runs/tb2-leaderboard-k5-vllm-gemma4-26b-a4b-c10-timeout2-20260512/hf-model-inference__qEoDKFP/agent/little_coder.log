0: NEGATIVE\n        # label 1: POSITIVE\n        \n        # We\'ll extract scores for both\n        # We\'ll assume index 0 is negative and index 1 is positive for this specific model\n        # but we\'ll try to use id2label if it exists.\n        \n        # Let\'s find the indices\n        pos_idx = None\n        neg_idx = None\n        \n        for idx, label in id2label.items():\n            if label.lower() == "positive":\n                pos_idx = idx\n            elif label.lower() == "negative":\n                neg_idx = idx\n        \n        if pos_idx is None or neg_idx is None:\n            # Fallback to standard SST-2\n            pos_idx = 1\n            neg_idx = 0\n            \n        pos_score = probs[pos_idx]\n        neg_score = probs[neg_idx]\n        \n        # Determine the primary sentiment\n        if pos_score > neg_score:\n            sentiment = "positive"\n        else:\n            sentiment = "negative"\n            \n        return jsonify({\n            "sentiment": sentiment,\n            "confidence": {\n                "positive": pos_score,\n                "negative": neg_score\n            }\n        })\n    except Exception as e:\n        return jsonify({"error": str(e)}), 400\n\nif __name__ == "__main__":\n    app.run(host="0.0.0.0", port=5000)\nEOF\n\npython3 /app/app.py &', 'timeout': 300})
