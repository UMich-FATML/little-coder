>> ShellSession({'command': 'cat << \'EOF\' > /app/process_documents.sh\n#!/bin/bash\n\n# Directories\nDOCS_DIR="/app/documents"\nINVOICES_DIR="/app/invoices"\nOTHER_DIR="/app/other"\n\nmkdir -p "$INVOICES_DIR" "$OTHER_DIR"\n\n# Initialize summary file\necho "filename,total_amount,vat_amount" > "$INVOICES_DIR/summary.csv"\n\nTOTAL_SUM_AMOUNT=0\nTOTAL_SUM_VAT=0\n\n# Function to extract text from PDF or JPG\nget_text() {\n    local file="$1"\n    local ext="${file##*.}"\n    if [[ "$ext" == "pdf" ]]; then\n        pdftotext "$file" - 2>/dev/null\n    elif [[ "$ext" == "jpg" ]]; then\n        tesseract "$file" stdout 2>/dev/null\n    fi\n}\n\n# Process files\nfor file_path in "$DOCS_DIR"/*; do\n    [ -e "$file_path" ] || continue\n    filename=$(basename "$file_path")\n    \n    text=$(get_text "$file_path")\n    \n    # Classification\n    is_invoice=false\n    if echo "$text" | grep -iqE "invoice|bill|receipt|amount due|total"; then\n        is_invoice=true\n    fi\n\n    if [ "$is_invoice" = true ]; then\n        # Extraction\n        # Total amount\n        # Look for "Total", "Amount Due", "Grand Total"\n        # We\'ll use grep and sed to find the first occurrence of a number after these terms\n        \n        # Try to find Total first\n        total_amount=$(echo "$text" | grep -iE "Total|Grand Total" | grep -oE "[0-9]+\\.[0-9]{2}" | head -n 1)\n        \n        # If not found, try Amount Due\n        if [ -z "$total_amount" ]; then\n            total_amount=$(echo "$text" | grep -iE "Amount Due" | grep -oE "[0-9]+\\.[0-9]{2}" | head -n 1)\n        fi\n\n        # If still not found, we might not have a valid invoice or parsing failed\n        if [ -z "$total_amount" ]; then\n            is_invoice=false\n        fi\n\n        if [ "$is_invoice" = true ]; then\n            # VAT amount\n            vat_amount=$(echo "$text" | grep -iE "VAT|Tax|GST" | grep -oE "[0-9]+\\.[0-9]{2}" | head -n 1)\n            if [ -z "$vat_amount" ]; then\n                vat_amount="0.00"\n            fi\n            \n            # Move to invoices\n            mv "$file_path" "$INVOICES_DIR/"\n            \n            # Add to summary\n            echo "$filename,$total_amount,$vat_amount" >> "$INVOICES_DIR/summary.csv"\n            \n            # Update totals (using bc for float math)\n            TOTAL_SUM_AMOUNT=$(echo "$TOTAL_SUM_AMOUNT + $total_amount" | bc)\n            TOTAL_SUM_VAT=$(echo "$TOTAL_SUM_VAT + $vat_amount" | bc)\n        fi\n    fi\n\n    if [ "$is_invoice" = false ]; then\n        mv "$file_path" "$OTHER_DIR/"\n    fi\ndone\n\n# Add final total row\necho "total,$TOTAL_SUM_AMOUNT,$TOTAL_SUM_VAT" >> "$INVOICES_DIR/summary.csv"\nEOF\n\nchmod +x /app/process_documents.sh\n/app/process_documents.sh\n'})
