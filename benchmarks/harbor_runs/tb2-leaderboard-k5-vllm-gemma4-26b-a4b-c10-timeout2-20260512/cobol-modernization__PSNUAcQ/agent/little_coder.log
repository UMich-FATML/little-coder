ts in 000000020000 (if it\'s decimal)\n    # or 0000000200 (if it\'s integer).\n    # Actually, PIC 9(10)V99 means 10 digits before decimal, 2 after.\n    # If we move 200 (PIC 9(10)) to WS-AMOUNT (PIC 9(10)V99), \n    # it\'s usually treated as 200.00 or 0.0200 depending on alignment.\n    # But standard COBOL: MOVE 200 to 9(10)V99 -> 000000020000.\n    # Let\'s look at the TRANSACTION record: 05 TRANS-AMOUNT PIC 9(10).\n    # And the output: B003000000020U003U001B003000000050U001U002\n    # B003 (4) + 0000000200 (10) + U003 (4) + U001 (4) ... wait.\n    # Let\'s re-examine the TRANSACTION record:\n    # 05 TRANS-BOOK       PIC X(4).\n    # 05 TRANS-AMOUNT     PIC 9(10).\n    # 05 TRANS-SELLER     PIC X(4).\n    # 05 TRANS-BUYER      PIC X(4).\n    # Total: 4 + 10 + 4 + 4 = 22.\n    # The output "B003000000020U003U001" is 4 + 10 + 4 + 4 = 22.\n    # Wait, "B003" (4) + "0000000200" (10) + "U003" (4) + "U001" (4) = 22.\n    # My manual count was wrong. 4+10+4+4 = 22.\n    # The input "U001U002B007200" is 16 chars.\n    # 4 (U001) + 4 (U002) + 4 (B007) + 4 (200) = 16.\n    # So INPUT-AMOUNT is 4 digits in this case? But PIC is 9(10).\n    # COBOL will pad it with leading zeros.\n    \n    # Let\'s re-calculate amount.\n    # If input is "200", and PIC is 9(10), it\'s 0000000200.\n    # WS-AMOUNT is 9(10)V99. \n    # MOVE 200 to WS-AMOUNT -> 000000020000.\n    # Wait, if WS-AMOUNT is 9(10)V99, it has 12 digits.\n    # If we move 200 to it, it becomes 000000020000.\n    # Then when we SUBTRACT WS-AMOUNT from ACCOUNT-BALANCE (PIC 9(10))...\n    # This is getting confusing. Let\'s look at the ACCOUNT-BALANCE PIC.\n    # 05 ACCOUNT-BALANCE   PIC 9(10).\n    # If we subtract 200.00 from a PIC 9(10), it\'s 200.\n    # Let\'s check the transaction output again.\n    # B003 0000000200 U003 U001\n    # This means TRANS-AMOUNT is 0000000200.\n    # This matches the input "200" padded to 10 digits.\n    # So WS-AMOUNT is used for the subtraction, but the amount written to \n    # TRANSACTIONS is the original 10-digit integer.\n    # Wait, the COBOL says:\n    # MOVE WS-AMOUNT TO TRANS-AMOUNT\n    # WS-AMOUNT is 9(10)V99. TRANS-AMOUNT is 9(10).\n    # If WS-AMOUNT is 000000020000, moving it to 9(10) will truncate it to 0000000200.\n    # This makes sense!\n    \n    # Let\'s refine the amount logic:\n    # amount_val = int(amount_str)\n    # ws_amount = amount_val * 100 (to simulate 9(10)V99)\n    # But wait, if I subtract ws_amount from account_balance, \n    # and account_balance is 9(10), I need to be careful.\n    # If account_balance is 1180 and I subtract 200.00, it should be 980.\n    # In COBOL, if you move 200 to 9(10)V99, it\'s 200.00.\n    # If you subtract 200.00 from 1180 (9(10)), it\'s 980.\n    # So WS-AMOUNT is effectively amount_val * 100, but we must divide by 100 \n    # when applying to the integer balance.\n    \n    # Let\'s try a simpler approach:\n    # WS-AMOUNT = amount_val (as a float/decimal)\n    # ACCOUNT-BALANCE = ACCOUNT-BALANCE - amount_val\n    # TRANS-AMOUNT = amount_val (padded to 10 digits)\n\n    # 2. Validate\n    buyer_found = False\n    seller_found = False\n    book_found = False\n    valid_owner = False\n\n    # Read Accounts\n    with open(accounts_file, \'r\') as f:\n        accounts_data = f.read()\n    \n    # Account record: ID(4), Name(20), Balance(10) = 34 bytes\n    for i in range(0, len(accounts_data), 34):\n        rec = accounts_data[i:i+34]\n        if len(rec) < 34: continue\n        acc_id = rec[0:4]\n        if acc_id == buyer_id:\n            buyer_found = True\n        if acc_id == seller_id:\n            seller_found = True\n\n    # Read Books\n    with open(books_file, \'r\') as f:\n        books_data = f.read()\n    \n    # Book record: ID(4), Title(20), Owner(4) = 28 bytes\n    for i in range(0, len(books_data), 28):\n        rec = books_data[i:i+28]\n        if len(rec) < 28: continue\n        bk_id = rec[0:4]\n        bk_owner = rec[24:28]\n        if bk_id == book_id:\n            book_found = True\n            if bk_owner == seller_id:\n                valid_owner = True\n\n    if buyer_found and seller_found and book_found and valid_owner:\n        # 3. Process Transaction\n        \n        # Update Accounts\n        new_accounts = []\n        with open(accounts_file, \'r\') as f:\n            accounts_data = f.read()\n        \n        for i in range(0, len(accounts_data), 34):\n            rec = accounts_data[i:i+34]\n            if len(rec) < 34: continue\n            acc_id = rec[0:4]\n            acc_name = rec[4:24]\n            acc_balance_str = rec[24:34]\n            acc_balance = int(acc_balance_str)\n            \n            if acc_id == buyer_id:\n                acc_balance -= amount\n            elif acc_id == seller_id:\n                acc_balance += amount\n            \n            new_rec = f"{acc_id}{acc_name}{acc_balance:010d}"\n            new_accounts.append(new_rec)\n        \n        with open(accounts_file, \'w\') as f:\n            f.write("".join(new_accounts))\n\n        # Update Books\n        new_books = []\n        with open(books_file, \'r\') as f:\n            books_data = f.read()\n            \n        for i in range(0, len(books_data), 28):\n            rec = books_data[i:i+28]\n            if len(rec) < 28: continue\n            bk_id = rec[0:4]\n            bk_title = rec[4:24]\n            bk_owner = rec[24:28]\n            \n            if bk_id == book_id:\n                bk_owner = buyer_id\n            \n            new_rec = f"{bk_id}{bk_title}{bk_owner}"\n            new_books.append(new_rec)\n            \n        with open(books_file, \'w\') as f:\n            f.write("".join(new_books))\n\n        # Append Transactions\n        with open(transactions_file, \'a\') as f:\n            # TRANS-BOOK(4), TRANS-AMOUNT(10), TRANS-SELLER(4), TRANS-BUYER(4)\n            trans_rec = f"{book_id}{amount:010d}{seller_id}{buyer_id}"\n            f.write(trans_rec)\n            \n        print("Tran