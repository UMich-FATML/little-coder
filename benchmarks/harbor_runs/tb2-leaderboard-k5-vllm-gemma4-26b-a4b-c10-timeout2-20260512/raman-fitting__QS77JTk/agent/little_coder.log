>> ShellSession({'command': 'python3 -c "\nimport numpy as np\nimport json\nfrom scipy.optimize import curve_fit\n\ndef lorentzian(x, x0, gamma, amplitude, offset):\n    return amplitude * (gamma**2 / ((x - x0)**2 + gamma**2)) + offset\n\nall_x = []\nall_y = []\nwith open(\'/app/graphene.dat\', \'r\') as f:\n    for line in f:\n        line = line.strip()\n        if not line: continue\n        parts = line.split()\n        for p in parts:\n            if \',\' in p:\n                coords = p.split(\',\')\n                if len(coords) == 2:\n                    all_x.append(float(coords[0]))\n                    all_y.append(float(coords[1]))\n\nx = np.array(all_x)\ny = np.array(all_y)\nidx = np.argsort(x)\nx = x[idx]\ny = y[idx]\n\n# G peak is around 1580 cm-1\n# 2D peak is around 2700 cm-1\n\n# Let\'s find the actual peaks in the data to improve initial guesses\n# G peak\ng_mask = (x > 1400) & (x < 1700)\nx_g, y_g = x[g_mask], y[g_mask]\nif len(x_g) > 0:\n    g_idx = np.argmax(y_g)\n    g_x0 = x_g[g_idx]\n    g_amp = y_g[g_idx] - np.min(y_g)\n    g_offset = np.min(y_g)\n    p0_g = [g_x0, 10, g_amp, g_offset]\nelse:\n    p0_g = [1580, 10, 1000, 0]\n\ntry:\n    popt_g, _ = curve_fit(lorentzian, x_g, y_g, p0=p0_g, maxfev=20000)\nexcept Exception as e:\n    print(f\'G fit failed: {e}\')\n    popt_g = [1580, 10, 0, 0]\n\n# 2D peak\nd2_mask = (x > 2600) & (x < 2900)\nx_d2, y_d2 = x[d2_mask], y[d2_mask]\nif len(x_d2) > 0:\n    d2_idx = np.argmax(y_d2)\n    d2_x0 = x_d2[d2_idx]\n    d2_amp = y_d2[d2_idx] - np.min(y_d2)\n    d2_offset = np.min(y_d2)\n    p0_d2 = [d2_x0, 20, d2_amp, d2_offset]\nelse:\n    p0_d2 = [2700, 20, 1000, 0]\n\ntry:\n    popt_d2, _ = curve_fit(lorentzian, x_d2, y_d2, p0=p0_d2, maxfev=20000)\nexcept Exception as e:\n    print(f\'2D fit failed: {e}\')\n    popt_d2 = [2700, 20, 0, 0]\n\nresults = {\n    \'G\': {\n        \'x0\': float(popt_g[0]),\n        \'gamma\': abs(float(popt_g[1])),\n        \'amplitude\': float(popt_g[2]),\n        \'offset\