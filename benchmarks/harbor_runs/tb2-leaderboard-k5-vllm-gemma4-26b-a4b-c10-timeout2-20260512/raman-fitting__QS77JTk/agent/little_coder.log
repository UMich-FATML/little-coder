>> ShellSession({'command': 'cat <<EOF > /app/fit_peaks.py\nimport numpy as np\nimport pandas as pd\nfrom scipy.optimize import curve_fit\nimport json\n\ndef lorentzian(x, x0, gamma, amplitude, offset):\n    return amplitude * (gamma**2 / ((x - x0)**2 + gamma**2)) + offset\n\ndef main():\n    # Load data\n    # The file format seems to be: x,y <tab> x,y or something similar?\n    # Looking at head: 47183,554644\t19261,547207\n    # It looks like two columns of (x,y) pairs? \n    # Wait, let\'s re-examine the head output.\n    # 47183,554644\t19261,547207\n    # This looks like: x1,y1 <tab> x2,y2\n    # But Raman spectra are usually a single sequence of x and y.\n    # Let\'s check the number of columns.\n    \n    data = []\n    with open(\'/app/graphene.dat\', \'r\') as f:\n        for line in f:\n            if not line.strip():\n                continue\n            # Split by whitespace\n            parts = line.split()\n            if len(parts) == 2:\n                # Each part is x,y\n                p1 = parts[0].split(\',\')\n                p2 = parts[1].split(\',\')\n                data.append([float(p1[0]), float(p1[1]), float(p2[0]), float(p2[1])])\n            elif len(parts) == 1:\n                p1 = parts[0].split(\',\')\n                data.append([float(p1[0]), float(p1[1])])\n    \n    # Actually, let\'s just try to read it as a single stream of x,y\n    # If the file is x,y <tab> x,y, it might be two spectra or just a weird format.\n    # Let\'s try to parse it more robustly.\n    \n    all_x = []\n    all_y = []\n    \n    with open(\'/app/graphene.dat\', \'r\') as f:\n        for line in f:\n            line = line.strip()\n            if not line: continue\n            # Replace tabs with spaces to simplify\n            line = line.replace(\'\\t\', \' \')\n            # Split by space or comma\n            # But the format is x,y <space> x,y\n            # Let\'s try splitting by whitespace first\n            parts = line.split()\n            for p in parts:\n                if \',\' in p:\n                    coords = p.split(\',\')\n                    if len(coords) == 2:\n                        all_x.append(float(coords[0]))\n                        all_y.append(float(coords[1]))\n    \n    x = np.array(all_x)\n    y = np.array(all_y)\n    \n    # Sort by x just in case\n    idx = np.argsort(x)\n    x = x[idx]\n    y = y[idx]\n\n    # G peak is around 1580 cm-1\n    # 2D peak is around 2700 cm-1\n    \n    # Find G peak\n    g_mask = (x > 1400) & (x < 1700)\n    x_g = x[g_mask]\n    y_g = y[g_mask]\n    \n    # Find 2D peak\n    d2_mask = (x > 2600) & (x < 2900)\n    x_d2 = x[d2_mask]\n    y_d2 = y[d2_mask]\n\n    # Initial guesses\n    # Lorentzian: x0, gamma, amplitude, offset\n    \n    # Fit G\n    p0_g = [1580, 10, np.max(y_g) - np.min(y_g), np.min(y_g)]\n    try:\n        popt_g, _ = curve_fit(lorentzian, x_g, y_g, p0=p0_g)\n    except Exception as e:\n        print(f"G fit failed: {e}")\n        popt_g = [1580, 10, 0, 0]\n\n    # Fit 2D\n    p0_d2 = [2700, 20, np.max(y_d2) - np.min(y_d2), np.min(y_d2)]\n    try:\n        popt_d2, _ = curve_fit(lorentzian, x_d2, y_d2, p0=p0_d2)\n    except Exception as e:\n        print(f"2D fit failed: {e}")\n        popt_d2 = [2700, 20, 0, 0]\n\n    results = {\n        "G": {\n            "x0": float(popt_g[0]),\n            "gamma": float(popt_g[1]),\n            "amplitude": float(popt_g[2]),\n            "offset": float(popt_g[3])\n        },\n        "2D": {\n            "x0": float(popt_d2[0]),\n            "gamma": float(popt_d2[1]),\n            "amplitude": float(popt_d2[2]),\n            "offset": float(popt_d2[3])\n        }\n    }\n\n    with open(\'/app/results.json\', \'w\') as f:\n        json.dump(results, f, indent=2)\n    \n    print("Results written to /app/results.json")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/fit_peaks.py'})
