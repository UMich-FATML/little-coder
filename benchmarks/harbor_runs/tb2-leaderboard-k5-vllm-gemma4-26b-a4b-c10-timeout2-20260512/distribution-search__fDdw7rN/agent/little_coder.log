eed to be huge.\n    \n    def get_error(k_val, V, target):\n        # k is the number of elements with probability p\n        # p is the probability of those k elements\n        # q = (1 - k*p) / (V - k)\n        # We need to find p that minimizes error.\n        \n        def error_func(p):\n            if p <= 0 or p >= 1/k: return 1e9\n            q = (1.0 - k_val * p) / (V - k_val)\n            if q <= 0: return 1e9\n            \n            # KL_fwd = - [k*p*log(p) + (V-k)*q*log(q)] + log(V)\n            # KL_bwd = log(V) - 1/V * [k*log(p) + (V-k)*log(q)]\n            \n            h_p = k_val * p * np.log(p) + (V - k_val) * q * np.log(q)\n            kl_fwd = -h_p + np.log(V)\n            \n            sum_log_p = k_val * np.log(p) + (V - k_val) * np.log(q)\n            kl_bwd = np.log(V) - (1.0/V) * sum_log_p\n            \n            return (kl_fwd - target)**2 + (kl_bwd - target)**2\n\n        from scipy.optimize import minimize_scalar\n        res = minimize_scalar(error_func, bounds=(1e-12, 1.0/k_val - 1e-12), method=\'bounded\')\n        return res.fun, res.x\n\n    # Try different values of k\n    for k in [1, 2, 5, 10, 20, 50, 100, 500, 1000]:\n        err, p = get_error(k, V, target)\n        if err < best_error:\n            best_error = err\n            q = (1.0 - k * p) / (V - k)\n            dist = np.full(V, q)\n            dist[:k] = p\n            best_dist = dist\n\n    if best_dist is not None:\n        f, b = calculate_kls(best_dist, V)\n        print(f"Best error: {best_error}")\n        print(f"KL_fwd: {f}")\n        print(f"KL_bwd: {b}")\n        if abs(f - target) <= 0.001 and abs(b - target) <= 0.001:\n            np.save(\'/app/dist.npy\', best_dist)\n            print("Saved dist.npy")\n        else:\n            print("Failed tolerance check")\n    else:\n        print("No distribution found")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/solve.py\n'})
