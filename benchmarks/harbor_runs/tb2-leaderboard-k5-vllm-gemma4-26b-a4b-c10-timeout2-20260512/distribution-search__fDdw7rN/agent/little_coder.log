      \n        best_err = float(\'inf\')\n        best_p = None\n        best_k = None\n        \n        for k_cand in [int(np.floor(k_float)), int(np.ceil(k_float))]:\n            if k_cand < 1 or k_cand >= V: continue\n            \n            def error_func(p_cand):\n                if p_cand <= 0 or k_cand * p_cand >= 1: return 1e18\n                q_cand = (1.0 - k_cand * p_cand) / (V - k_cand)\n                if q_cand <= 0: return 1e18\n                eq1 = k_cand * p_cand * np.log(p_cand) + (V - k_cand) * q_cand * np.log(q_cand) - (np.log(V) - 10.0)\n                eq2 = k_cand * np.log(p_cand) + (V - k_cand) * np.log(q_cand) - V * (np.log(V) - 10.0)\n                return eq1**2 + eq2**2\n            \n            from scipy.optimize import minimize_scalar\n            res_p = minimize_scalar(error_func, bounds=(1e-15, 1.0/k_cand - 1e-15), method=\'bounded\')\n            if res_p.fun < best_err:\n                best_err = res_p.fun\n                best_p = res_p.x\n                best_k = k_cand\n        \n        if best_p is not None:\n            p = best_p\n            k = best_k\n            q = (1.0 - k * p) / (V - k)\n            dist = np.full(V, q)\n            dist[:k] = p\n            \n            U = np.full(V, 1.0/V)\n            kl_fwd = np.sum(dist * np.log(dist / U))\n            kl_bwd = np.sum(U * np.log(U / dist))\n            \n            print(f"k: {k}, p: {p}, q: {q}")\n            print(f"KL_fwd: {kl_fwd}, KL_bwd: {kl_bwd}")\n            \n            if abs(kl_fwd - 10.0) <= 0.001 and abs(kl_bwd - 10.0) <= 0.001:\n                np.save(\'/app/dist.npy\', dist)\n                print("SUCCESS")\n            else:\n                print("FAILED TOLERANCE")\n    else:\n        print("OPTIMIZATION FAILED")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/solve.py\n'})
