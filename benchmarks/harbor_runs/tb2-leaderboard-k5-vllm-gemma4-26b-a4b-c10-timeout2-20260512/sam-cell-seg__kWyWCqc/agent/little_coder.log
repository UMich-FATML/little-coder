e(np.uint8)\\n            mask = cv2.subtract(mask, occupied_mask)\\n            \\n            if np.sum(mask) > 0:\\n                contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\\n                if contours:\\n                    contour = max(contours, key=cv2.contourArea)\\n                    contour = contour.reshape(-1, 2)\\n                    coords_x = contour[:, 0].tolist()\\n                    coords_y = contour[:, 1].tolist()\\n                    xmin, xmax = float(np.min(coords_x)), float(np.max(coords_x))\\n                    ymin, ymax = float(np.min(coords_y)), float(np.max(coords_y))\\n                    \\n                    new_mask = np.zeros_like(mask)\\n                    cv2.drawContours(new_mask, [contour], -1, 1, thickness=cv2.FILLED)\\n                    occupied_mask = cv2.bitwise_or(occupied_mask, new_mask)\\n                    \\n                    new_row = row.copy()\\n                    new_row[\'xmin\'], new_row[\'xmax\'] = xmin, xmax\\n                    new_row[\'ymin\'], new_row[\'ymax\'] = ymin, ymax\\n                    new_row[\'coords_x\'] = \',\'.join(map(str, coords_x))\\n                    new_row[\'coords_y\'] = \',\'.join(map(str, coords_y))\\n                    new_rows.append(new_row)\\n                else:\\n                    new_rows.append(row)\\n            else:\\n                new_rows.append(row)\\n        except Exception:\\n            new_rows.append(row)\\n\\n    output_df = pd.DataFrame(new_rows)\\n    output_csv_path = os.path.join(args.output_path, os.path.basename(args.csv_path))\\n    output_df.to_csv(output_csv_path, index=False)\\n\\nif __name__ == \'__main__\':\\n    main()\\n" > /app/convert_masks.py'})
