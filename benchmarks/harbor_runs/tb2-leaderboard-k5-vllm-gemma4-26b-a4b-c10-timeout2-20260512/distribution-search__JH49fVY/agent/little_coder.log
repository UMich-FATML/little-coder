pha, K, V)\n        return (kf - 10.0)**2 + (kb - 10.0)**2\n\n    # Refine K and alpha\n    res = minimize(objective_final, [best_alpha, float(best_K)], \n                   bounds=[(1e-12, 1 - 1e-12), (1, V)], method=\'L-BFGS-B\')\n    \n    final_alpha = res.x[0]\n    final_K = int(round(res.x[1]))\n    \n    # Final check with integer K\n    # Since K must be an integer, we check K-1, K, K+1\n    best_err = float(\'inf\')\n    final_alpha = 0\n    final_K = 0\n    \n    for k_cand in [final_K - 1, final_K, final_K + 1]:\n        if k_cand < 1 or k_cand > V: continue\n        def alpha_obj(a):\n            kf, kb = get_kls(a, k_cand, V)\n            return (kf - 10.0)**2 + (kb - 10.0)**2\n        res_a = minimize(alpha_obj, [final_alpha], bounds=[(1e-12, 1 - 1e-12)], method=\'L-BFGS-B\')\n        err = res_a.fun\n        if err < best_err:\n            best_err = err\n            final_alpha = res_a.x[0]\n            final_K = k_cand\n\n    kf, kb = get_kls(final_alpha, final_K, V)\n    print(f"Final K: {final_K}, alpha: {final_alpha}")\n    print(f"KL_fwd: {kf}, KL_back: {kb}")\n    print(f"Error: {best_err}")\n\n    if abs(kf - 10.0) <= tol and abs(kb - 10.0) <= tol:\n        print("SUCCESS")\n        dist = np.full(V, (1 - final_alpha) / V)\n        P_high = (1 - final_alpha) / V + final_alpha / final_K\n        dist[:final_K] = P_high\n        np.save(\'/app/dist.npy\', dist)\n    else:\n        print("FAILED")\n\nsolve()\nEOF\npython3 /app/solve.py\n'})
