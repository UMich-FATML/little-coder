 finder.\n    \n    # Sample K to find the range\n    K_samples = np.linspace(1, V, 100).astype(int)\n    errors = []\n    for k in K_samples:\n        errors.append(error_func(k))\n    \n    # Find where the sign changes\n    found_K = -1\n    for i in range(len(errors)-1):\n        if errors[i] * errors[i+1] <= 0:\n            # Root is between K_samples[i] and K_samples[i+1]\n            # Use bisection on K\n            low_k = float(K_samples[i])\n            high_k = float(K_samples[i+1])\n            for _ in range(40):\n                mid_k = (low_k + high_k) / 2\n                if error_func(mid_k) < 0:\n                    low_k = mid_k\n                else:\n                    high_k = mid_k\n            found_K = int(round(mid_k))\n            break\n            \n    if found_K != -1:\n        # Check integer neighbors\n        best_K = found_K\n        best_err = float(\'inf\')\n        final_alpha = 0\n        \n        for k_cand in [found_K - 1, found_K, found_K + 1]:\n            if k_cand < 1 or k_cand > V: continue\n            alpha = find_alpha_for_fwd(k_cand)\n            kf, kb = get_kls(alpha, k_cand, V)\n            err = abs(kf - target_kl) + abs(kb - target_kl)\n            if err < best_err:\n                best_err = err\n                best_K = k_cand\n                final_alpha = alpha\n        \n        kf, kb = get_kls(final_alpha, best_K, V)\n        print(f"Final K: {best_K}, alpha: {final_alpha}")\n        print(f"KL_fwd: {kf}, KL_back: {kb}")\n        print(f"Error: {best_err}")\n\n        if abs(kf - target_kl) <= tol and abs(kb - target_kl) <= tol:\n            print("SUCCESS")\n            dist = np.full(V, (1 - final_alpha) / V)\n            P_high = (1 - final_alpha) / V + final_alpha / best_K\n            dist[:best_K] = P_high\n            np.save(\'/app/dist.npy\', dist)\n        else:\n            print("FAILED")\n    else:\n        print("FAILED to find K range")\n\nsolve()\nEOF\npython3 /app/solve.py\n'})
