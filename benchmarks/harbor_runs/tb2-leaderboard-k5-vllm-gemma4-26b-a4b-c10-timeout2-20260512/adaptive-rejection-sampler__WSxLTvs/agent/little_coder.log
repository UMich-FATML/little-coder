>> ShellSession({'command': 'cat << \'EOF\' > /app/ars.R\n# Adaptive Rejection Sampling (ARS) implementation\n# Based on Gilks and Wild (1992)\n\n#\' Adaptive Rejection Sampler\n#\'\n#\' @param n Number of samples to generate.\n#\' @param target_log_density A function that returns the log-density of the target distribution.\n#\'                           It should be vectorized.\n#\' @param lower Lower bound of the support (can be -Inf).\n#\' @param upper Upper bound of the support (can be Inf).\n#\' @return A vector of samples.\nars <- function(n, target_log_density, lower = -Inf, upper = Inf) {\n  # 1. Input Validation\n  if (!is.function(target_log_density)) {\n    stop("target_log_density must be a function.")\n  }\n  if (n <= 0) {\n    stop("Number of samples n must be positive.")\n  }\n  if (is.finite(lower) && is.finite(upper) && lower >= upper) {\n    stop("Lower bound must be less than upper bound.")\n  }\n\n  # Internal state for the adaptive envelope\n  pts_x <- c()\n  pts_y <- c()\n\n  # Helper to add a point and maintain sorted order\n  add_point <- function(x, y) {\n    # Check if x is within bounds\n    if (!is.na(x) && !is.infinite(x) && x >= lower && x <= upper) {\n      # Check if x is already in pts_x to avoid duplicates\n      if (!(x %in% pts_x)) {\n        pts_x <<- c(pts_x, x)\n        pts_y <<- c(pts_y, y)\n        ord <- order(pts_x)\n        pts_x <<- pts_x[ord]\n        pts_y <<- pts_y[ord]\n      }\n    }\n  }\n\n  # Initialization: Find the mode and some points around it\n  # We use optimize to find the mode of the log-density.\n  # We need a search interval.\n  search_lower <- if (is.finite(lower)) lower else -1e5\n  search_upper <- if (is.finite(upper)) upper else 1e5\n  \n  mode_res <- try(optimize(function(x) -target_log_density(x), \n                            interval = c(search_lower, search_upper)), \n                  silent = TRUE)\n  \n  if (inherits(mode_res, "try-error")) {\n    stop("Could not find the mode of the density. Check bounds or function.")\n  }\n  \n  mode_val <- mode_res$minimum\n  \n  # Add mode and some points around it to initialize the envelope\n  # We\'ll try to find points where the log-density is not too low.\n  add_point(mode_val, target_log_density(mode_val))\n  \n  # Try to find points to the left and right\n  for (step in c(0.1, 1, 10, 100, 1000, 10000)) {\n    # Try left\n    val_l <- mode_val - step\n    if (val_l >= lower) {\n      add_point(val_l, target_log_density(val_l))\n    }\n    # Try right\n    val_r <- mode_val + step\n    if (val_r <= upper) {\n      add_point(val_r, target_log_density(val_r))\n    }\n  }\n  \n  # Ensure we have at least 2 points\n  if (length(pts_x) < 2) {\n    # If we still have < 2 points, try to find any valid points\n    # This is a fallback.\n    stop("Failed to initialize enough points for the envelope.")\n  }\n\n  samples <- numeric(n)\n  count <- 0\n  \n  # Main loop\n  while (count < n) {\n    # 1. Construct the envelope (piecewise linear in log-density space)\n    num_segments <- length(pts_x) - 1\n    log_segment_integrals <- numeric(num_segments)\n    \n    for (i in 1:num_segments) {\n      xi <- pts_x[i]\n      xi1 <- pts_x[i+1]\n      yi <- pts_y[i]\n      yi1 <- pts_y[i+1]\n      m <- (yi1 - yi) / (xi1 - xi)\n      \n      # Integral of exp(yi + m*(x-xi)) from xi to xi1\n      # = (exp(yi1) - exp(yi)) / m\n      # To avoid overflow, use log-space:\n      # log_integral = log(abs(exp(yi1) - exp(yi))) - log(abs(m))\n      # Better: log_integral = yi + log(abs(exp(m*(xi1-xi)) - 1)) - log(abs(m))\n      \n      u <- m * (xi1 - xi)\n      if (abs(u) < 1e-10) {\n        log_segment_integrals[i] <- yi + log(xi1 - xi)\n      } else if (u > 50) {\n        log_segment_integrals[i] <- yi + u - log(m)\n      } else if (u < -50) {\n        # u is very negative, exp(u) is near 0.\n        # (exp(yi1) - exp(yi)) / m = (exp(yi) * (exp(u) - 1)) / m\n        # log(...) = yi + log(abs(exp(u) - 1)) - log(abs(m))\n        # Since u is very negative, exp(u)-1 is approx -1.\n        log_segment_integrals[i] <- yi + log(1) - log(abs(m))\n      } else {\n        log_segment_integrals[i] <- yi + log(abs(exp(u) - 1)) - log(abs(m))\n      }\n    }\n    \n    # 2. Sample a segment\n    max_log_int <- max(log_segment_integrals)\n    probs <- exp(log_segment_integrals - max_log_int)\n    segment_idx <- sample(1:num_segments, size = 1, prob = probs)\n    \n    # 3. Sample x from the chosen segment\n    xi <- pts_x[segment_idx]\n    xi1 <- pts_x[segment_idx + 1]\n    yi <- pts_y[segment_idx]\n    yi1 <- pts_y[segment_idx + 1]\n    m <- (yi1 - yi) / (xi1 - xi)\n    u_val <- runif(1)\n    \n    if (abs(m) < 1e-12) {\n      x_sample <- xi + u_val * (xi1 - xi)\n    } else {\n      u_term <- exp(m * (xi1 - xi)) - 1\n      # To avoid issues with u_term being 0 or negative\n      if (u_term <= 0) {\n        # This happens if m is very negative and u_term is tiny\n        # Use a small epsilon or handle it\n        x_sample <- xi + (log(1 + 1e-15 * u_val) / m) # fallback\n      } else {\n        x_sample <- xi + log(1 + u_val * u_term) / m\n      }\n    }\n    \n    # 4. Acceptance/Rejection step\n    # The envelope log-density at x_sample\n    env_log_density <- yi + m * (x_sample - xi)\n    target_log_density_val <- target_log_density(x_sample)\n    \n    # Check for log-concavity: if target_log_density_val < env_log_density, \n    # it means the density is not log-concave at this point.\n    # However, the ARS algorithm says we should add the point if it\'s NOT accepted.\n    # The condition for acceptance is target_log_density(x) >= env_log_density(x).\n    # But wait, the envelope is constructed to be BELOW the target density.\n    # So target_log_density(x) should ALWAYS be >= env_log_density(x).\n    # If it\'s not, then the density is not log-concave.\n    \n    if (target_log_density_val < env_log_density - 1e-9) {\n      # This is a violation of log-concavity!\n      # In a strict ARS, we\'d stop or handle it.\n      # For this task, we\'ll add the point and continue, but we should report it.\n      # Actually, the requirement says "include checks that catch cases of non-log-concave densities".\n      stop(paste("Non-log-concave density detected at x =", x_sample))\n    }\n    \n    # In ARS, we don\'t "reject" in the traditional sense if we sample from the envelope.\n    # We sample from the envelope, and if it\'s not accepted, we update the envelope.\n    # But if we sample from the envelope, the only way it\'s not "accepted" is if \n    # the target density is actually higher than the envelope.\n    # Wait, the standard ARS:\n    # 1. Sample x from the envelope.\n    # 2. If target_log_density(x) >= envelope_log_density(x), accept.\n    # 3. Else, add x to the points and update the envelope.\n    \n    # But if we sample from the envelope, the envelope log-density is exactly what we used.\n    # The only way target_log_density(x) < env_log_density(x) is if the density is not log-concave.\n    \n    # Let\'s re-read Gilks (1992).\n    # The envelope is a piecewise linear function in log-density space.\n    # The density is f(x) = exp(L(x)).\n    # We sample x from f_env(x).\n    # If target_log_density(x) > L(x), we accept.\n    # If target_log_density(x) < L(x), we add x to the points and update.\n    # BUT, if the density is log-concave, then target_log_density(x) >= L(x) is ALWAYS true\n    # for any x between the points used to construct L(x).\n    # So if target_log_density(x) < L(x), it\'s a sign of non-log-concavity.\n    \n    # Wait, if we sample from the envelope, we are essentially doing rejection sampling\n    # where the proposal is the envelope.\n    # The acceptance probability is target_density(x) / envelope_density(x).\n    # Since we sample from the envelope, we accept with probability:\n    # P(accept | x) = target_density(x) / envelope_density(x)\n    \n    # Let\'s implement this.\n    \n    accept_prob <- exp(target_log_density_val - env_log_density)\n    # Due to numerical precision, cap it at 1\n    if (accept_prob > 1) accept_prob <- 1\n    \n    if (runif(1) <= accept_prob) {\n      samples[count + 1] <- x_sample\n      count <- count + 1\n    } else {\n      # Not accepted, add the point to the envelope and update\n      add_point(x_sample, target_log_density_val)\n    }\n  }\n  \n  return(samples)\n}\n\n#\' Test function for ARS\n#\'\n#\' @return Prints test results.\ntest <- function() {\n  cat("Starting tests...\\n")\n  \n  # Test 1: Normal Distribution\n  cat("TEST_NORMAL: Running...\\n")\n  target_norm <- function(x) dnorm(x, mean = 2, sd = 1, log = TRUE)\n  # Expected mean = 2, sd = 1\n  tryCatch({\n    set.seed(42)\n    s_norm <- ars(500, target_norm)\n    m_norm <- mean(s_norm)\n    sd_norm <- sd(s_norm)\n    \n    # Check if mean and sd are within reasonable range\n    # Using a loose tolerance for stochasticity\n    if (abs(m_norm - 2) < 0.2 && abs(sd_norm - 1) < 0.2) {\n      cat(sprintf("TEST_NORMAL: PASS (mean=%.3f, sd=%.3f)\\n", m_norm, sd_norm))\n      writeLines(as.character(s_norm), "/app/normal_samples.txt")\n    } else {\n      cat(sprintf("TEST_NORMAL: FAIL (mean=%.3f, sd=%.3f)\\n", m_norm, sd_norm))\n    }\n  }, error = function(e) {\n    cat(sprintf("TEST_NORMAL: FAIL (Error: %s)\\n", e$message))\n  })\n\n  # Test 2: Exponential Distribution\n  cat("TEST_EXPONENTIAL: Running...\\n")\n  target_exp <- function(x) {\n    # Exponential is defined for x > 0\n    res <- dexp(x, rate = 1, log = TRUE)\n    res[x <= 0] <- -Inf\n    res\n  }\n  # Expected mean = 1, sd = 1\n  tryCatch({\n    set.seed(42)\n    s_exp <- ars(500, target_exp, lower = 0)\n    m_exp <- mean(s_exp)\n    sd_exp <- sd(s_exp)\n    \n    if (abs(m_exp - 1) < 0.2 && abs(sd_exp - 1) < 0.2) {\n      cat(sprintf("TEST_EXPONENTIAL: PASS (mean=%.3f, sd=%.3f)\\n", m_exp, sd_exp))\n      writeLines(as.character(s_exp), "/app/exponential_samples.txt")\n    } else {\n      cat(sprintf("TEST_EXPONENTIAL: FAIL (mean=%.3f, sd=%.3f)\\n", m_exp, sd_exp))\n    }\n  }, error = function(e) {\n    cat(sprintf("TEST_EXPONENTIAL: FAIL (Error: %s)\\n", e$message))\n  })\n\n  # Test 3: Non-log-concave distribution (should fail/error)\n  cat("TEST_NON_LOG_CONCAVE: Running...\\n")\n  # A mixture of two normals is not log-concave\n  target_mixture <- function(x) {\n    log(0.5 * dnorm(x, 0, 1) + 0.5 * dnorm(x, 5, 1))\n  }\n  tryCatch({\n    set.seed(42)\n    ars(100, target_mixture)\n    cat("TEST_NON_LOG_CONCAVE: FAIL (Should have detected non-log-concavity)\\n")\n  }, error = function(e) {\n    if (grepl("Non-log-concave", e$message)) {\n      cat("TEST_NON_LOG_CONCAVE: PASS (Detected non-log-concavity)\\n")\n    } else {\n      cat(sprintf("TEST_NON_LOG_CONCAVE: FAIL (Unexpected error: %s)\\n", e$message))\n    }\n  })\n}\n\n# If run as a script, execute test\nif (!interactive()) {\n  test()\n}\nEOF\n'})
