>> ShellSession({'command': 'cat << \'EOF\' > /app/ars.R\n# Adaptive Rejection Sampling (ARS) implementation\n# Based on Gilks and Wild (1992)\n\n#\' Adaptive Rejection Sampler\n#\'\n#\' @param n Number of samples to generate.\n#\' @param target_log_density A function that returns the log-density of the target distribution.\n#\'                           It should be vectorized.\n#\' @param lower Lower bound of the support (can be -Inf).\n#\' @param upper Upper bound of the support (can be Inf).\n#\' @return A vector of samples.\nars <- function(n, target_log_density, lower = -Inf, upper = Inf) {\n  # 1. Input Validation\n  if (!is.function(target_log_density)) {\n    stop("target_log_density must be a function.")\n  }\n  if (n <= 0) {\n    stop("Number of samples n must be positive.")\n  }\n  if (is.finite(lower) && is.finite(upper) && lower >= upper) {\n    stop("Lower bound must be less than upper bound.")\n  }\n\n  # Internal state for the adaptive envelope\n  # We maintain a set of points (x, log_density(x)) to construct the piecewise linear envelope\n  # in the log-density space.\n  \n  # Initial points to start the process\n  # If bounds are infinite, we need some initial points.\n  # For simplicity, let\'s try to find some points if bounds are infinite.\n  \n  # Helper to check log-concavity (simplified: check if the envelope is always below the function)\n  # In practice, ARS relies on the log-density being concave.\n  \n  # Initialize points\n  # We\'ll use a small set of points to start. \n  # If bounds are infinite, we might need to find them.\n  \n  # For this implementation, we\'ll assume the user provides reasonable bounds or \n  # we\'ll attempt to find them if they are infinite.\n  \n  # Let\'s use a more robust approach for initialization.\n  # We\'ll maintain a list of points (x, y) where y = log_density(x).\n  \n  points_x <- c()\n  points_y <- c()\n  \n  # Function to add a point and check log-concavity\n  add_point <- function(x, y) {\n    # Ch