n    # Let\'s use log-integrals.\n    # log_integral_i = log(segment_integrals[i])\n    \n    # Wait, segment_integrals can be very small or very large.\n    # Let\'s use log_integrals.\n    log_segment_integrals <- numeric(num_segments)\n    for (i in 1:num_segments) {\n      xi <- pts_x[i]\n      xi1 <- pts_x[i+1]\n      yi <- pts_y[i]\n      yi1 <- pts_y[i+1]\n      m <- (yi1 - yi) / (xi1 - xi)\n      \n      if (abs(m) < 1e-12) {\n        log_segment_integrals[i] <- yi + log(xi1 - xi)\n      } else {\n        # (exp(yi1) - exp(yi)) / m = exp(yi) * (exp(m*(xi1-xi)) - 1) / m\n        # log(...) = yi + log(exp(m*(xi1-xi)) - 1) - log(m)\n        # To avoid overflow in exp(m*(xi1-xi)), use log1p:\n        # log(exp(u) - 1) = log(exp(u) * (1 - exp(-u))) = u + log(1 - exp(-u))\n        # Wait, if u is large, exp(u) is huge.\n        # If u is small, log(exp(u)-1) approx log(u).\n        # Let\'s use: log(exp(u)-1) = log(exp(u)(1-exp(-u))) = u + log(1-exp(-u))\n        # But if u is very large, 1-exp(-u) is 1.\n        # If u is very small, log(exp(u)-1) is log(u).\n        \n        u <- m * (xi1 - xi)\n        if (u > 50) {\n          log_segment_integrals[i] <- yi + u - log(m)\n        } else if (u < -50) {\n          # exp(u) is very small, so exp(u)-1 approx -1. \n          # But m can be negative.\n          # If m is negative, u is negative.\n          # (exp(yi1) - exp(yi)) / m = (exp(yi) - exp(yi1)) / (-m)\n          # Let\'s just use the formula and be careful.\n          log_segment_integrals[i] <- yi + log(abs(exp(u) - 1)) - log(abs(m))\n        } else {\n          log_segment_integrals[i] <- yi + log(abs(exp(u) - 1)) - log(abs(m))\n        }\n      }\n    }\n    \n    # Sample segment i with probability proportional to exp(log_segment_integrals[i])\n    # Use log-sum-exp to sample\n    max_log_int <- max(log_segment_integrals)\n    probs <- exp(log_segment_integrals - max_log_int)\n    segment_idx <- sample(1:num_segments, size = 1, prob = probs)\n    \n    # 2. Sample x from the chosen segment\n    # The density on the segment is f(x) = exp(yi + m * (x - xi))\n    # We want to sample x from this.\n    # Let U ~ Uniform(0, 1).\n    # The CDF of the segment is F(x) = (exp(m*(x-xi)) - 1) / (exp(m*(xi1-xi)) - 1)\n    # We want F(x) = U => exp(m*(x-xi)) - 1 = U * (exp(m*(xi1-xi)) - 1)\n    # exp(m*(x-xi)) = 1 + U * (exp(m*(xi1-xi)) - 1)\n    # m*(x-xi) = log(1 + U * (exp(m*(xi1-xi)) - 1))\n    # x = xi + log(1 + U * (exp(m*(xi1-xi)) - 1)) / m\n    \n    xi <- pts_x[segment_idx]\n    xi1 <- pts_x[segment_idx + 1]\n    yi <- pts_y[segment_idx]\n    yi1 <- pts_y[segment_idx + 1]\n    m <- (yi1 - yi) / (xi1 - xi)\n    u_val <- runif(1)\n    \n    if (abs(m) < 1e-12) {\n      x_sample <- xi + u_val * (xi1 - xi)\n    } else {\n      # To avoid numerical issues with exp(m*(xi1-xi))\n      # Use the same logic as before\n      u_term <- exp(m * (xi1 - xi)) - 1\n      x_sample <- xi + log(1 + u_val * u_term) / m\n    }\n    \n    # 3. Acceptance/Rejection step\n    # Check if x_sample is within the current envelope.\n    # Actually, the envelope is constructed such that it is always below the target density.\n    # So we just need to check if the target density at x_sample is >= the envelope density at x_sample.\n    \n    # The envelope density at x_sample is:\n    # L(x_sample) = exp(yi + m * (x_sample - xi))\n    # But we sampled x_sample from this density, so it\'s always true?\n    # No, the envelope is piecewise linear in log-density.\n    # The density we sampled from is the envelope density.\n    # We need to check if target_log_density(x_sample) >= L(x_sample).\n    \n    # Wait, the ARS algorithm says:\n    # 1. Sample x from the envelope.\n    # 2. If target_log_density(x) >= envelope_log_density(x), accept.\n    # 3. Otherwise, add x to the points and update the envelope.\n    \n    # Let\'s calculate the envelope log-density at x_sample.\n    # Since x_sample was sampled from the segment, the envelope log-density is:\