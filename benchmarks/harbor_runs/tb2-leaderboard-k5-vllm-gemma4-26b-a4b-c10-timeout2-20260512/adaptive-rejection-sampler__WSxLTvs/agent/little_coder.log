mple search if optimize fails.\n  \n  # Let\'s define the core sampling loop.\n  \n  samples <- numeric(n)\n  count <- 0\n  \n  # We need to maintain the points for the envelope.\n  # The envelope is the piecewise linear function connecting (x_i, y_i).\n  \n  # To handle infinite bounds, we can use "virtual" points at +/- Inf.\n  # But the log-density at +/- Inf is -Inf.\n  \n  # Let\'s use a list of points.\n  pts_x <- c()\n  pts_y <- c()\n  \n  # Initial points:\n  # We need at least 2 points to form a line.\n  # Let\'s try to find the mode and two points around it.\n  \n  # For simplicity, let\'s use a small set of points to start.\n  # If bounds are infinite, we\'ll use a wide range.\n  \n  # Let\'s try to find the mode.\n  mode_val <- try(optimize(function(x) -target_log_density(x), \n                            interval = c(if(is.finite(lower)) lower else -1e5, \n                                         if(is.finite(upper)) upper else 1e5)), \n                   silent = TRUE)\n  \n  if (inherits(mode_res, "try-error")) {\n    # Fallback\n    mode_val <- 0\n  } else {\n    mode_val <- mode_res$minimum\n  }\n  \n  # Add mode and some points around it\n  pts_x <- c(mode_val - 1, mode_val, mode_val + 1)\n  # Ensure they are within bounds\n  pts_x <- pts_x[pts_x >= lower & pts_x <= upper]\n  if (length(pts_x) < 2) {\n    # If we can\'t get 2 points, we might need to search more.\n    # This is a simplified version.\n    pts_x <- c(lower, upper) # This might not work if bounds are infinite\n    # Let\'s try to find some points if bounds are infinite\n    if (is.infinite(lower)) pts_x <- c(-1e5, mode_val, mode_val + 1)\n    if (is.infinite(upper)) pts_x <- c(mode_val - 1, mode_val, 1e5)\n    # Filter again\n    pts_x <- pts_x[pts_x >= lower & pts_x <= upper]\n  }\n  \n  # Re-calculate pts_x to be safe\n  pts_x <- unique(pts_x)\n  pts_y <- target_log_density(pts_x)\n  \n  # Sort points by x\n  ord <- order(pts_x)\n  pts_x <- pts_x[ord]\n  pts_y <- pts_y[ord]\n\n  # M