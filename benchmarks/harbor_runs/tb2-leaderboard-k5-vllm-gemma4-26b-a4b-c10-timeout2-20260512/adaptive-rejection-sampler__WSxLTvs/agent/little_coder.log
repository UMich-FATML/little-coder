 in c(0.1, 1, 10, 100, 1000, 10000)) {\n    val_l <- mode_val - step\n    if (val_l >= lower) add_point(val_l, target_log_density(val_l))\n    val_r <- mode_val + step\n    if (val_r <= upper) add_point(val_r, target_log_density(val_r))\n  }\n  \n  if (length(pts_x) < 2) {\n    stop("Failed to initialize enough points for the envelope.")\n  }\n\n  samples <- numeric(n)\n  count <- 0\n  \n  while (count < n) {\n    num_segments <- length(pts_x) - 1\n    log_segment_integrals <- numeric(num_segments)\n    \n    for (i in 1:num_segments) {\n      xi <- pts_x[i]\n      xi1 <- pts_x[i+1]\n      yi <- pts_y[i]\n      yi1 <- pts_y[i+1]\n      m <- (yi1 - yi) / (xi1 - xi)\n      u <- m * (xi1 - xi)\n      \n      if (abs(u) < 1e-10) {\n        log_segment_integrals[i] <- yi + log(xi1 - xi)\n      } else if (u > 50) {\n        log_segment_integrals[i] <- yi + u - log(m)\n      } else if (u < -50) {\n        log_segment_integrals[i] <- yi + log(1) - log(abs(m))\n      } else {\n        log_segment_integrals[i] <- yi + log(abs(exp(u) - 1)) - log(abs(m))\n      }\n    }\n    \n    max_log_int <- max(log_segment_integrals)\n    probs <- exp(log_segment_integrals - max_log_int)\n    segment_idx <- sample(1:num_segments, size = 1, prob = probs)\n    \n    xi <- pts_x[segment_idx]\n    xi1 <- pts_x[segment_idx + 1]\n    yi <- pts_y[segment_idx]\n    yi1 <- pts_y[segment_idx + 1]\n    m <- (yi1 - yi) / (xi1 - xi)\n    u_val <- runif(1)\n    \n    if (abs(m) < 1e-12) {\n      x_sample <- xi + u_val * (xi1 - xi)\n    } else {\n      u_term <- exp(m * (xi1 - xi)) - 1\n      if (u_term <= 0) {\n        x_sample <- xi + (log(1 + 1e-15 * u_val) / m)\n      } else {\n        x_sample <- xi + log(1 + u_val * u_term) / m\n      }\n    }\n    \n    env_log_density <- yi + m * (x_sample - xi)\n    target_log_density_val <- target_log_density(x_sample)\n    \n    if (target_log_density_val < env_log_density - 1e-9) {\n      stop(paste("Non-log-concave density detected at x =", x_sample))\n    }\n    \n    accept_prob <- exp(target_log_density_val - env_log_density)\n    if (accept_prob > 1) accept_prob <- 1\n    \n    if (runif(1) <= accept_prob) {\n      count <- count + 1\n      samples[count] <- x_sample\n    } else {\n      add_point(x_sample, target_log_density_val)\n    }\n  }\n  \n  return(samples)\n}\n\ntest <- function() {\n  cat("Starting tests...\\n")\n  \n  cat("TEST_NORMAL: Running...\\n")\n  target_norm <- function(x) dnorm(x, mean = 2, sd = 1, log = TRUE)\n  tryCatch({\n    set.seed(42)\n    s_norm <- ars(500, target_norm)\n    m_norm <- mean(s_norm)\n    sd_norm <- sd(s_norm)\n    if (abs(m_norm - 2) < 0.2 && abs(sd_norm - 1) < 0.2) {\n      cat(sprintf("TEST_NORMAL: PASS (mean=%.3f, sd=%.3f)\\n", m_norm, sd_norm))\n      writeLines(as.character(s_norm), "/app/normal_samples.txt")\n    } else {\n      cat(sprintf("TEST_NORMAL: FAIL (mean=%.3f, sd=%.3f)\\n", m_norm, sd_norm))\n    }\n  }, error = function(e) {\n    cat(sprintf("TEST_NORMAL: FAIL (Error: %s)\\n", e$message))\n  })\n\n  cat("TEST_EXPONENTIAL: Running...\\n")\n  target_exp <- function(x) {\n    res <- dexp(x, rate = 1, log = TRUE)\n    res[x <= 0] <- -Inf\n    res\n  }\n  tryCatch({\n    set.seed(42)\n    s_exp <- ars(500, target_exp, lower = 0)\n    m_exp <- mean(s_exp)\n    sd_exp <- sd(s_exp)\n    if (abs(m_exp - 1) < 0.2 && abs(sd_exp - 1) < 0.2) {\n      cat(sprintf("TEST_EXPONENTIAL: PASS (mean=%.3f, sd=%.3f)\\n", m_exp, sd_exp))\n      writeLines(as.character(s_exp), "/app/exponential_samples.txt")\n    } else {\n      cat(sprintf("TEST_EXPONENTIAL: FAIL (mean=%.3f, sd=%.3f)\\n", m_exp, sd_exp))\n    }\n  }, error = function(e) {\n    cat(sprintf("TEST_EXPONENTIAL: FAIL (Error: %s)\\n", e$message))\n  })\n\n  cat("TEST_NON_LOG_CONCAVE: Running...\\n")\n  target_mixture <- function(x) {\n    log(0.5 * dnorm(x, 0, 1) + 0.5 * dnorm(x, 5, 1))\n  }\n  tryCatch({\n    set.seed(42)\n    ars(100, target_mixture)\n    cat("TEST_NON_LOG_CONCAVE: FAIL (Should have detected non-log-concavity)\\n")\n  }, error = function(e) {\n    if (grepl("Non-log-concave", e$message)) {\n      cat("TEST_NON_LOG_CONCAVE: PASS (Detected non-log-concavity)\\n")\n    } else {\n      cat(sprintf("TEST_NON_LOG_CONCAVE: FAIL (Unexpected error: %s)\\n", e$message))\n    }\n  })\n}\n\nif (!interactive()) {\n  test()\n}\nEOF\n'})
