sum(Y)\n    s_yd2 = sum(Y[i] * X[i][1] for i in range(len(X)))\n    \n    det = s1 * s_d4 - s_d2**2\n    if abs(det) < 1e-9:\n        return 0, 0, 0\n    \n    r0 = (s_d4 * s_y - s_d2 * s_yd2) / det\n    r1 = (-s_d2 * s_y + s1 * s_yd2) / det\n    \n    # Check error\n    errors = []\n    for idx in sample_indices:\n        y = idx // width\n        x = idx % width\n        dist_sq = (x - center_x)**2 + (y - center_y)**2\n        actual = channel_pixels[idx]\n        expected = r0 + r1 * dist_sq\n        errors.append(abs(actual - expected))\n    \n    return r0, r1, sum(errors)/len(errors)\n\nfor c in range(3):\n    r0, r1, err = check_radial(c)\n    print(f"Channel {c}: r0={r0:.2f}, r1={r1:.2f}, avg_err={err:.2f}")\n\nEOF\npython3 analyze_ppm.py\n'})
