>> ShellSession({'command': 'cat << \'EOF\' > analyze_ppm.py\nimport sys\nimport math\n\ndef read_ppm(filename):\n    with open(filename, \'r\') as f:\n        line = f.readline()\n        while line and not line.strip() == \'P3\':\n            line = f.readline()\n        if not line: return None\n        \n        dims = f.readline().split()\n        width, height = int(dims[0]), int(dims[1])\n        max_val = int(f.readline().strip())\n        \n        pixels = []\n        for line in f:\n            pixels.extend(map(int, line.split()))\n        return width, height, max_val, pixels\n\ndata = read_ppm(\'/app/image.ppm\')\nif not data:\n    print("Failed to read")\n    sys.exit(1)\n\nwidth, height, max_val, pixels = data\nprint(f"W: {width}, H: {height}, Max: {max_val}, Pixels: {len(pixels)}")\n\n# Let\'s check if it\'s a function of distance from center\ncenter_x, center_y = width/2, height/2\n\ndef check_radial_v3(c_idx):\n    channel_pixels = pixels[c_idx::3]\n    \n    # Try R(x,y) = r0 + r1 * dist(x,y, cx, cy) + r2 * dist(x,y, cx, cy)^2\n    # R = r0 + r1 * d + r2 * d^2\n    \n    # Sample points\n    sample_indices = []\n    for i in range(0, len(channel_pixels), width*height//1000):\n        sample_indices.append(i)\n    \n    X = []\n    Y = []\n    for idx in sample_indices:\n        y = idx // width\n        x = idx % width\n        dist = math.sqrt((x - center_x)**2 + (y - center_y)**2)\n        X.append([1.0, dist, dist**2])\n        Y.append(float(channel_pixels[idx]))\n    \n    # Solve X^T X beta = X^T Y using Gaussian elimination\n    # X^T X is 3x3\n    n = 3\n    XTX = [[0.0]*n for _ in range(n)]\n    XTY = [0.0]*n\n    \n    for i in range(len(X)):\n        for r in range(n):\n            for c in range(n):\n                XTX[r][c] += X[i][r] * X[i][c]\n            XTY[r] += X[i][r] * Y[i]\n            \n    # Gaussian elimination\n    for i in range(n):\n        pivot = XTX[i][i]\n        for j in range(i+1, n):\n            factor = XTX[j][i] / pivot\n            for k in range(i, n):\n                XTX[j][k] -= factor * XTX[i][k]\n            XTY[j] -= factor * XTY[i]\n            \n    beta = [0.0]*n\n    for i in range(n-1, -1, -1):\n        sum_val = sum(XTX[i][j] * beta[j] for j in range(i+1, n))\n        beta[i] = (XTY[i] - sum_val) / XTX[i][i]\n        \n    r0, r1, r2 = beta\n    \n    # Check error\n    errors = []\n    for idx in sample_indices:\n        y = idx // width\n        x = idx % width\n        dist = math.sqrt((x - center_x)**2 + (y - center_y)**2)\n        actual = channel_pixels[idx]\n        expected = r0 + r1 * dist + r2 * dist**2\n        errors.append(abs(actual - expected))\n    \n    return r0, r1, r2, sum(errors)/len(errors)\n\nfor c in range(3):\n    r0, r1, r2, err = check_radial_v3(c)\n    print(f"Channel {c}: r0={r0:.2f}, r1={r1:.2f}, r2={r2:.2f}, avg_err={err:.2f}")\n\nEOF\npython3 analyze_ppm.py\n'})
