 # r1 = (R(1, 0) - R(0, 0))\n    # r2 = (R(0, 1) - R(0, 0))\n    # But it might be noisy. Let\'s use averages.\n    \n    r1_samples = []\n    for _ in range(500):\n        x = (len(channel_pixels) // 500) * _\n        y = 0\n        if x < width - 1:\n            r1_samples.append(channel_pixels[y*width + x + 1] - channel_pixels[y*width + x])\n    \n    r2_samples = []\n    for _ in range(500):\n        x = 0\n        y = (len(channel_pixels) // (width * height)) * _\n        if y < height - 1:\n            r2_samples.append(channel_pixels[(y+1)*width + x] - channel_pixels[y*width + x])\n            \n    r1 = sum(r1_samples)/len(r1_samples) if r1_samples else 0\n    r2 = sum(r2_samples)/len(r2_samples) if r2_samples else 0\n    r0 = channel_pixels[0]\n    \n    # Check error\n    errors = []\n    for i in range(0, len(channel_pixels), width*height//100):\n        y = i // width\n        x = i % width\n        if x < width and y < height:\n            actual = channel_pixels[y*width + x]\n            expected = r0 + r1*x + r2*y\n            errors.append(abs(actual - expected))\n    \n    return r0, r1, r2, sum(errors)/len(errors) if errors else 0\n\nfor c in range(3):\n    r0, r1, r2, err = analyze_channel(c)\n    print(f"Channel {c}: r0={r0:.2f}, r1={r1:.2f}, r2={r2:.2f}, avg_err={err:.2f}")\n\nEOF\npython3 analyze_ppm.py\n'})
