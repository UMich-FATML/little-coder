>> ShellSession({'command': 'cat << \'EOF\' > /app/process_documents.py\nimport os\nimport shutil\nimport re\nimport csv\nimport subprocess\n\n# Note: Since we are in a terminal environment, we might not have OCR tools like Tesseract installed.\n# However, for PDF files, we can try to extract text using pdftotext if available.\n# For JPG files, we would normally need OCR. \n# Let\'s check what tools are available.\n\ndef get_text(filepath):\n    ext = os.path.splitext(filepath)[1].lower()\n    text = ""\n    if ext == \'.pdf\':\n        try:\n            # Try pdftotext\n            result = subprocess.run([\'pdftotext\', filepath, \'-\'], capture_output=True, text=True)\n            text = result.stdout\n        except FileNotFoundError:\n            try:\n                # Try python library if available (unlikely to be pre-installed without knowing)\n                import pypdf\n                from io import StringIO\n                reader = pypdf.PdfReader(filepath)\n                for page in reader.pages:\n                    text += page.extract_text() + "\\n"\n            except Exception:\n                pass\n    elif ext == \'.jpg\' or ext == \'.jpeg\':\n        # For JPG, we\'d need OCR. Let\'s see if tesseract is available.\n        try:\n            # Using tesseract via subprocess\n            # tesseract <image> <stdout>\n            result = subprocess.run([\'tesseract\', filepath, \'stdout\'], capture_output=True, text=True)\n            text = result.stdout\n        except FileNotFoundError:\n            pass\n    return text\n\ndef classify_and_extract(text):\n    # Simple classification: look for invoice-related keywords\n    invoice_keywords = [\'invoice\', \'bill\', \'receipt\', \'amount due\', \'total\', \'tax\', \'vat\']\n    text_lower = text.lower()\n    \n    is_invoice = any(kw in text_lower for kw in invoice_keywords)\n    \n    if not is_invoice:\n        return \'other\', None, None\n\n    # Extraction logic\n    # Total amount\n    # Look for "Total", "Amount Due", "Grand Total"\n    # Special case: If both "Total" and "Amount Due" are present with different values, use only the "Total" amount\n    \n    total_amount = None\n    amount_due = None\n    \n    # Regex for currency/numbers\n    # Matches patterns like $1,234.56 or 1234.56\n    money_pattern = r\'(?:[\\$\\£\\€]\\s?)?(\\d{1,3}(?:,\\d{3})*(?:\\.\\d{2})?|\\d+(?:\\.\\d{2})?)\'\n\n    # Find "Total"\n    total_match = re.search(r\'(?:Total|Grand Total)[:\\s]*\' + money_pattern, text, re.IGNORECASE)\n    if total_match:\n        total_amount = total_match.group(1).replace(\',\', \'\')\n\n    # Find "Amount Due"\n    due_match = re.search(r\'(?:Amount Due)[:\\s]*\' + money_pattern, text, re.IGNORECASE)\n    if due_match:\n        amount_due = due_match.group(1).replace(\',\', \'\')\n\n    # Apply special rule\n    if total_amount and amount_due and total_amount != amount_due:\n        final_total = total_amount\n    elif total_amount:\n        final_total = total_amount\n    elif amount_due:\n        final_total = amount_due\n    else:\n        final_total = "0.00"\n\n    # VAT amount\n    vat_amount = "0.00"\n    vat_match = re.search(r\'(?:VAT|Tax|GST)[:\\s]*\' + money_pattern, text, re.IGNORECASE)\n    if vat_match:\n        vat_amount = vat_match.group(1).replace(\',\', \'\')\n\n    return \'invoice\', final_total, vat_amount\n\ndef main():\n    docs_dir = \'/app/documents/\'\n    invoices_dir = \'/app/invoices/\'\n    other_dir = \'/app/other/\'\n    \n    files = os.listdir(docs_dir)\n    results = []\n\n    for filename in files:\n        filepath = os.path.join(docs_dir, filename)\n        if not os.path.isfile(filepath):\n            continue\n            \n        text = get_text(filepath)\n        category, total, vat = classify_and_extract(text)\n        \n        if category == \'invoice\':\n            dest = os.path.join(invoices_dir, filename)\n            shutil.move(filepath, dest)\n            results.append({\n                \'filename\': filename,\n                \'total_amount\': float(total) if total and total != "" else 0.0,\n                \'vat_amount\': float(vat) if vat and vat != "" else 0.0\n            })\n        else:\n            dest = os.path.join(other_dir, filename)\n            shutil.move(filepath, dest)\n\n    # Create CSV\n    csv_path = os.path.join(invoices_dir, \'summary.csv\')\n    \n    grand_total_amount = 0.0\n    grand_total_vat = 0.0\n    \n    with open(csv_path, \'w\', newline=\'\') as csvfile:\n        fieldnames = [\'filename\', \'total_amount\', \'vat_amount\']\n        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)\n        writer.writeheader()\n        for res in results:\n            writer.writerow(res)\n            grand_total_amount += res[\'total_amount\']\n            grand_total_vat += res[\'vat_amount\']\n        \n        writer.writerow({\n            \'filename\': \'total\',\n            \'total_amount\': grand_total_amount,\n            \'vat_amount\': grand_total_vat\n        })\n\nif __name__ == "__main__":\n    main()\nEOF\n'})
