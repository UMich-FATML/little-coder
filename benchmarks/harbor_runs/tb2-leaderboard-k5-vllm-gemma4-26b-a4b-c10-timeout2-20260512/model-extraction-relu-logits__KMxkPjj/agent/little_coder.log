s a small optimization problem.\n        # Since we only have a few v_i, we can use a simple greedy approach.\n        \n        residual = g.copy()\n        # This is not quite right because we don\'t know which v_i are in the sum.\n        # But we can try to subtract v_i from the residual.\n        \n        # Let\'s try a different way:\n        # The set of all g(x) is a zonotope. The vertices of the zonotope are \n        # the sums of all v_i (or subsets).\n        # The difference between two "adjacent" vertices is a v_i.\n        \n        # Let\'s use the "jump" method but with a much larger step to ensure we cross a boundary.\n        # And we\'ll use many different steps.\n        pass\n\n    # Let\'s try the "jump" method again, but more systematically.\n    # We\'ll sample x, and for each x, we\'ll try to find a direction that causes a jump.\n    \n    v_candidates = []\n    for i in range(num_samples):\n        x = samples_x[i]\n        g_x = gradients[i]\n        # Try to find a jump by moving in each dimension\n        for k in range(input_dim):\n            # Try a few different step sizes to cross the boundary\n            for step in [1e-3, 0.1, 1.0]:\n                x_eps = x.copy()\n                x_eps[k] += step\n                g_x_eps = get_gradient(x_eps)\n                diff = g_x_eps - g_x\n                if np.linalg.norm(diff) > 1e-4:\n                    v_candidates.append(diff)\n                \n                x_eps = x.copy()\n                x_eps[k] -= step\n                g_x_eps = get_gradient(x_eps)\n                diff = g_x_eps - g_x\n                if np.linalg.norm(diff) > 1e-4:\n                    v_candidates.append(diff)\n\n    # Now we have a lot of candidate v_i.\n    # We need to find the unique ones.\n    # Since v_i = A2_i * A1_i, and A2_i can be anything, we can\'t just normalize.\n    # BUT, the task says "up to scaling". This means we can just find the directions.\n    # Wait, if we find the directions