g(x).\n    # These diffs are sums of some v_i.\n    # If we use a very small step, diff will be a single v_i.\n    \n    v_list = []\n    for i in range(num_samples):\n        x = samples_x[i]\n        g_x = gradients[i]\n        for k in range(input_dim):\n            x_eps = x.copy()\n            x_eps[k] += 1e-4 # Very small step\n            g_x_eps = get_gradient(x_eps)\n            diff = g_x_eps - g_x\n            if np.linalg.norm(diff) > 1e-4:\n                # This diff is likely a single v_i or a sum of v_i.\n                # If it\'s a single v_i, it\'s a good candidate.\n                v_list.append(diff)\n                \n    # Now we have a list of candidate v_i.\n    # We need to find the unique ones.\n    # Since v_i can have different magnitudes, we can\'t just normalize.\n    # But we can use the fact that if two vectors are the same v_i, they will be very close.\n    \n    unique_v = []\n    for v in v_list:\n        is_new = True\n        for uv in unique_v:\n            if np.allclose(v, uv, atol=1e-2):\n                is_new = False\n                break\n        if is_new:\n            unique_v.append(v)\n            \n    # Let\'s try to see if this works.\n    A1_stolen = np.array(unique_v)\n    # If we have too many, we\'ll just take the first 20.\n    if A1_stolen.shape[0] > 20:\n        A1_stolen = A1_stolen[:20]\n        \n    np.save(\'/app/stolen_A1.npy\', A1_stolen)\n    print(f"Saved {A1_stolen.shape[0]} neurons.")\n\nif __name__ == "__main__":\n    solve()\nEOF\npython3 /app/steal.py\n'})
