>> ShellSession({'command': 'cat <<\'EOF\' > /app/headless_terminal.py\nimport os\nimport pty\nimport select\nimport time\nimport threading\nimport queue\nimport pyte\nfrom base_terminal import BaseTerminal\n\nclass HeadlessTerminal(BaseTerminal):\n    def __init__(self, shell="/bin/bash"):\n        self.shell = shell\n        self.read_queue = queue.Queue()\n        self.screen = pyte.Screen(80, 24)\n        self.stream = pyte.Stream(self.screen)\n        self.running = True\n        \n        # pty.fork() returns (pid, fd)\n        # pid is the child process pid, fd is the master file descriptor\n        self.pid, self.fd = pty.fork()\n        \n        if self.pid == 0:\n            # Child process: execute the shell\n            # We use -i for interactive mode\n            os.execvpe(self.shell, [self.shell, "-i"], os.environ.copy())\n        else:\n            # Parent process\n            self.thread = threading.Thread(target=self._read_loop, daemon=True)\n            self.thread.start()\n\n    def _read_loop(self):\n        while self.running:\n            try:\n                # Use select to wait for data on the master fd\n                r, _, _ = select.select([self.fd], [], [], 0.1)\n                if r:\n                    data = os.read(self.fd, 4096)\n                    if not data:\n                        break\n                    # Feed data to pyte stream to maintain screen state\n                    try:\n                        self.stream.feed(data.decode(\'utf-8\', errors=\'replace\'))\n                    except Exception:\n                        pass\n                    self.read_queue.put(data)\n            except (OSError, select.error):\n                break\n        self.running = False\n\n    def send_keystrokes(self, keystrokes: str, wait_sec: float = 0.0) -> None:\n        if not self.running:\n            return\n        \n        # keystrokes can contain escape sequences like \\x03\n        # If it\'s a string, we encode it.\n        if isinstance(keystrokes, str):\n            data = keystrokes.encode(\'utf-8\')\n        else:\n            data = keystrokes\n            \n        try:\n            os.write(self.fd, data)\n        except OSError:\n            pass\n        \n        if wait_sec > 0:\n            time.sleep(wait_sec)\n\n    def get_screen_content(self) -> str:\n        """Helper to get the current screen content from pyte."""\n        return self.screen.display\n\n    def close(self):\n        self.running = False\n        try:\n            os.close(self.fd)\n        except OSError:\n            pass\n\nEOF\n'})
