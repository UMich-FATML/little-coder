>> ShellSession({'command': 'cat <<EOF > /app/headless_terminal.py\nimport os\nimport pty\nimport select\nimport time\nimport threading\nimport queue\nimport subprocess\nimport pyte\nfrom base_terminal import BaseTerminal\n\nclass HeadlessTerminal(BaseTerminal):\n    def __init__(self, shell="/bin/bash"):\n        self.shell = shell\n        self.read_queue = queue.Queue()\n        self.screen = pyte.Screen(80, 24)\n        self.stream = pyte.Stream(self.screen)\n        \n        # Use subprocess to start the shell in a pty\n        # We use a pipe to communicate with the process\n        self.process = subprocess.Popen(\n            [self.shell, "-i"],\n            stdin=subprocess.PIPE,\n            stdout=subprocess.PIPE,\n            stderr=subprocess.STDOUT,\n            text=False,\n            bufsize=0,\n            preexec_fn=os.setsid\n        )\n        \n        # We need a real PTY for interactive programs to work correctly.\n        # subprocess.Popen with stdin=PIPE doesn\'t create a PTY.\n        # Let\'s use pty.fork() instead.\n        \n    def __init__(self, shell="/bin/bash"):\n        self.shell = shell\n        self.read_queue = queue.Queue()\n        self.screen = pyte.Screen(80, 24)\n        self.stream = pyte.Stream(self.screen)\n        \n        self.pid, self.fd = pty.fork()\n        \n        if self.pid == 0:\n            # Child process: execute the shell\n            os.execvpe(self.shell, [self.shell, "-i"], os.environ.copy())\n        else:\n            # Parent process\n            self.running = True\n            self.thread = threading.Thread(target=self._read_loop, daemon=True)\n            self.thread.start()\n\n    def _read_loop(self):\n        while self.running:\n            try:\n                r, _, _ = select.select([self.fd], [], [], 0.1)\n                if r:\n                    data = os.read(self.fd, 1024)\n                    if not data:\n                        break\n                    # Feed data to pyte stream\n                    self.stream.feed(data.decode(\'utf-8\', errors=\'replace\'))\n                    self.read_queue.put(data)\n            except Exception:\n                break\n        self.running = False\n\n    def send_keystrokes(self, keystrokes: str, wait_sec: float = 0.0) -> None:\n        if not self.running:\n            return\n        \n        # Convert string to bytes (handling escape sequences correctly)\n        # Note: keystrokes might contain raw bytes like \\x03\n        # If keystrokes is a string, we encode it.\n        # If it\'s already bytes, we use it directly.\n        if isinstance(keystrokes, str):\n            data = keystrokes.encode(\'utf-8\')\n        else:\n            data = keystrokes\n            \n        os.write(self.fd, data)\n        \n        if wait_sec > 0:\n            time.sleep(wait_sec)\n\n    def close(self):\n        self.running = False\n        os.close(self.fd)\n\nEOF\n'})
