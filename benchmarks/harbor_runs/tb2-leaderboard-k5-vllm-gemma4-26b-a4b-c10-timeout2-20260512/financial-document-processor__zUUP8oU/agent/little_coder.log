>> ShellSession({'command': 'cat << \'EOF\' > /app/process_documents.py\nimport os\nimport shutil\nimport re\nimport csv\nimport subprocess\n\n# Since we can\'t use OCR tools easily in a standard shell without knowing what\'s installed,\n# and the task implies we can "read" content, I\'ll check if there\'s a way to extract text.\n# For PDFs, \'pdftotext\' is common. For JPGs, we\'d need OCR (tesseract).\n# However, in these environments, often the "files" are actually text files with fake extensions\n# or we can use a simple approach. Let\'s check if pdftotext is available.\n\ndef get_text(filepath):\n    ext = os.path.splitext(filepath)[1].lower()\n    if ext == \'.pdf\':\n        try:\n            # Try pdftotext\n            result = subprocess.run([\'pdftotext\', filepath, \'-\'], capture_output=True, text=True)\n            return result.stdout\n        except FileNotFoundError:\n            # Fallback: maybe it\'s just a text file renamed?\n            try:\n                with open(filepath, \'r\', errors=\'ignore\') as f:\n                    return f.read()\n            except:\n                return ""\n    elif ext == \'.jpg\':\n        # For JPG, we\'d normally need OCR. Let\'s try to see if it\'s actually text.\n        try:\n            with open(filepath, \'r\', errors=\'ignore\') as f:\n                return f.read()\n        except:\n            return ""\n    else:\n        try:\n            with open(filepath, \'r\', errors=\'ignore\') as f:\n                return f.read()\n        except:\n            return ""\n\ndef classify_and_extract(text):\n    # Simple classification: look for invoice-related keywords\n    invoice_keywords = [\'invoice\', \'bill\', \'receipt\', \'amount due\', \'total\']\n    is_invoice = any(kw in text.lower() for kw in invoice_keywords)\n    \n    if not is_invoice:\n        return \'other\', None, None\n\n    # Extraction\n    # Total amount\n    # Look for "Total", "Amount Due", "Grand Total"\n    # Special case: If both "Total" and "Amount Due" are present with different values, use only the "Total" amount\n    \n    total_val = None\n    amount_due_val = None\n    \n    # Regex for amounts: e.g., $1,234.56 or 1234.56\n    amount_pattern = r\'(?:Total|Amount Due|Grand Total)[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\'\n    \n    # We need to be careful with the "Total" vs "Amount Due" rule.\n    # Let\'s find all occurrences.\n    \n    total_matches = re.findall(r\'(?:Total|Grand Total)[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    amount_due_matches = re.findall(r\'Amount Due[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    \n    if total_matches:\n        total_val = float(total_matches[0].replace(\',\', \'\'))\n    \n    if amount_due_matches:\n        amount_due_val = float(amount_due_matches[0].replace(\',\', \'\'))\n        \n    if total_val is not None and amount_due_val is not None and total_val != amount_due_val:\n        # Use only Total\n        final_total = total_val\n    elif total_val is not None:\n        final_total = total_val\n    elif amount_due_val is not None:\n        final_total = amount_due_val\n    else:\n        final_total = 0.0\n\n    # VAT amount\n    # Look for "VAT", "Tax", "GST"\n    vat_val = 0.0\n    vat_matches = re.findall(r\'(?:VAT|Tax|GST)[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    if vat_matches:\n        vat_val = float(vat_matches[0].replace(\',\', \'\'))\n        \n    return \'invoice\', final_total, vat_val\n\ndef main():\n    docs_dir = \'/app/documents/\'\n    invoices_dir = \'/app/invoices/\'\n    other_dir = \'/app/other/\'\n    summary_file = \'/app/invoices/summary.csv\'\n    \n    files = os.listdir(docs_dir)\n    invoice_data = []\n    \n    for filename in files:\n        filepath = os.path.join(docs_dir, filename)\n        if not os.path.isfile(filepath):\n            continue\n            \n        text = get_text(filepath)\n        category, total, vat = classify_and_extract(text)\n        \n        if category == \'invoice\':\n            dest = os.path.join(invoices_dir, filename)\n            shutil.move(filepath, dest)\n            invoice_data.append({\n                \'filename\': filename,\n                \'total_amount\': total,\n                \'vat_amount\': vat\n            })\n        else:\n            dest = os.path.join(other_dir, filename)\n            shutil.move(filepath, dest)\n            \n    # Create summary.csv\n    with open(summary_file, \'w\', newline=\'\') as csvfile:\n        fieldnames = [\'filename\', \'total_amount\', \'vat_amount\']\n        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)\n        writer.writeheader()\n        \n        sum_total = 0.0\n        sum_vat = 0.0\n        \n        for data in invoice_data:\n            writer.writerow(data)\n            sum_total += data[\'total_amount\']\n            sum_vat += data[\'vat_amount\']\n            \n        writer.writerow({\n            \'filename\': \'total\',\n            \'total_amount\': f"{sum_total:.2f}",\n            \'vat_amount\': f"{sum_vat:.2f}"\n        })\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/process_documents.py'})
