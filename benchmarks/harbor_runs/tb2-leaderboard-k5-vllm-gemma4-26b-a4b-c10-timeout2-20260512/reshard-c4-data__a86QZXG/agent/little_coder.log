_chunk\'] else ""\n            path_hash = hashlib.sha256(str(item[\'rel_path\']).encode()).hexdigest()[:16]\n            dest_name = f"{path_hash}{suffix}_{item[\'rel_path\'].name}"\n            dest_path = shard_dir / dest_name\n            \n            with open(item[\'src\'], \'rb\') as f_in:\n                f_in.seek(item[\'offset\'])\n                with open(dest_path, \'wb\') as f_out:\n                    remaining = item[\'length\']\n                    while remaining > 0:\n                        to_read = min(remaining, 1024*1024)\n                        chunk = f_in.read(to_read)\n                        if not chunk:\n                            break\n                        f_out.write(chunk)\n                        remaining -= len(chunk)\n            \n            manifest[f"{shard_name}/{dest_name}"] = (\n                str(item[\'rel_path\']),\n                item[\'offset\'],\n                item[\'length\'],\n                item[\'is_chunk\'],\n                item[\'chunk_idx\']\n            )\n        \n        shard_idx += 1\n\n    with open(output_path / "manifest.json", "w") as f:\n        json.dump(manifest, f)\n\nif __name__ == "__main__":\n    if len(sys.argv) != 3:\n        print("Usage: python compress.py <input_dir> <output_dir>")\n        sys.exit(1)\n    compress(sys.argv[1], sys.argv[2])\nEOF\n'})
