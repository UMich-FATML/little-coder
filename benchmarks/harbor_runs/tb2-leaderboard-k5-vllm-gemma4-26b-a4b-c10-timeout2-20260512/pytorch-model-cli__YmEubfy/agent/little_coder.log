5.0\n    \n    # MNIST images are often inverted (white digit on black background)\n    if np.mean(img_array) > 0.5:\n        img_array = 1.0 - img_array\n\n    img_tensor = torch.from_numpy(img_array).view(1, 784)\n\n    with torch.no_grad():\n        output = model(img_tensor)\n        prediction = torch.argmax(output, dim=1).item()\n\n    print(prediction)\n\nif __name__ == "__main__":\n    main()\nEOF\nchmod +x cli_tool\n./cli_tool weights.json image.png > prediction.txt\ncat prediction.txt'})
