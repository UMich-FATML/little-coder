>> ShellSession({'command': 'cat <<EOF > cli_tool.py\nimport sys\nimport json\nimport torch\nimport torch.nn as nn\nfrom PIL import Image\nimport numpy as np\n\nclass MnistModel(nn.Module):\n    def __init__(\n        self,\n        input_dim: int,\n        hidden_dim: int,\n        num_classes: int,\n    ) -> torch.nn.Module:\n        super().__init__()\n\n        self.input_layer = nn.Linear(input_dim, hidden_dim)\n        self.hidden_layer = nn.Linear(hidden_dim, hidden_dim)\n        self.output_layer = nn.Linear(hidden_dim, num_classes)\n        self.activation = nn.ReLU()\n\n    def forward(self, x):\n        x = self.input_layer(x)\n        x = self.activation(x)\n\n        x = self.hidden_layer(x)\n        x = self.activation(x)\n\n        x = self.output_layer(x)\n        return x\n\ndef load_weights_from_json(weights_json, model):\n    with open(weights_json, \'r\') as f:\n        weights = json.load(f)\n    \n    with torch.no_grad():\n        model.input_layer.weight.copy_(torch.tensor(weights[\'input_layer.weight\']))\n        model.input_layer.bias.copy_(torch.tensor(weights[\'input_layer.bias\']))\n        model.hidden_layer.weight.copy_(torch.tensor(weights[\'hidden_layer.weight\']))\n        model.hidden_layer.bias.copy_(torch.tensor(weights[\'hidden_layer.bias\']))\n        model.output_layer.weight.copy_(torch.tensor(weights[\'output_layer.weight\']))\n        model.output_layer.bias.copy_(torch.tensor(weights[\'output_layer.bias\']))\n\ndef main():\n    if len(sys.argv) != 3:\n        sys.exit(1)\n\n    weights_path = sys.argv[1]\n    image_path = sys.argv[2]\n\n    # Model dimensions based on weights.json\n    # input_dim=784, hidden_dim=16, num_classes=10\n    model = MnistModel(784, 16, 10)\n    load_weights_from_json(weights_path, model)\n    model.eval()\n\n    # Load and preprocess image\n    img = Image.open(image_path).convert(\'L\')\n    img = img.resize((28, 28))\n    img_array = np.array(img).astype(np.float32) / 255.0\n    \n    # MNIST images are often inverted (white digit on black background)\n    # But let\'s check if we need to invert. \n    # If the image is black digit on white background, we might need to invert.\n    # Standard MNIST is white on black.\n    \n    # Let\'s assume the input image is already in the correct format or \n    # we might need to handle it.\n    # A common trick is to check if the mean is high and invert if so.\n    if np.mean(img_array) > 0.5:\n        img_array = 1.0 - img_array\n\n    img_tensor = torch.from_numpy(img_array).view(1, 1, 28, 28)\n    # The model expects input_dim=784, so we flatten it.\n    img_tensor = img_tensor.view(1, 784)\n\n    with torch.no_grad():\n        output = model(img_tensor)\n        prediction = torch.argmax(output, dim=1).item()\n\n    print(prediction)\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 cli_tool.py weights.json image.png'})
