o match the keys.\n        pass\n\n# Re-evaluating the structure based on keys:\n# transformer_encoder.layers.0.self_attn.in_proj_weight: [384, 128]\n# transformer_encoder.layers.0.self_attn.out_proj.weight: [128, 128]\n# This is exactly what nn.MultiheadAttention uses internally, but we need to define it \n# so that the keys match.\n\nclass CustomMultiheadAttention(nn.Module):\n    def __init__(self, d_model, nhead):\n        super().__init__()\n        self.d_model = d_model\n        self.nhead = nhead\n        self.in_proj_weight = nn.Parameter(torch.empty(3 * d_model, d_model))\n        self.in_proj_bias = nn.Parameter(torch.empty(3 * d_model))\n        self.out_proj = nn.Linear(d_model, d_model)\n\n    def forward(self, q, k, v):\n        # Simplified forward for reconstruction\n        # In a real scenario, we'd implement the full scaled dot-product attention.\n        # But for reconstruction, we just need the structure to match.\n        # Since we are loading weights, the forward pass must be correct for the loss calculation.\n        \n        # Standard MultiheadAttention forward:\n        # 1. Linear projection\n        # 2. Split into heads\n        # 3. Scaled dot-product attention\n        # 4. Concatenate heads\n        # 5. Output projection\n        \n        batch_size, seq_len, _ = q.size()\n        \n        # Project q, k, v\n        qkv = F.linear(q, self.in_proj_weight, self.in_proj_bias)\n        # This is a bit tricky because q, k, v are usually projected separately if they are different.\n        # But in_proj_weight is 3*d_model, so it's a combined projection.\n        \n        # For simplicity, let's assume q=k=v (self-attention)\n        # qkv shape: [batch, seq_len, 3 * d_model]\n        qkv = qkv.reshape(batch_size, seq_len, 3, self.d_model // self.nhead, self.nhead)\n        q, k, v = qkv.unbind(2) # [batch, seq_len, d_model // nhead, nhead]\n\n        # Transpose for attention: [batch, nhead, seq_len, d_model // nhead]\n        q =