layers)\n        self.transformer_decoder = Decoder(d_model, nhead, dim_feedforward, num_decoder_layers)\n        self.output_layer = nn.Linear(d_model, output_dim)\n\n    def forward(self, src, tgt):\n        src_emb = self.embedding(src) + self.pos_encoder.pe[:, :src.size(1), :]\n        tgt_emb = self.embedding(tgt) + self.pos_encoder.pe[:, :tgt.size(1), :]\n        memory = self.transformer_encoder(src_emb)\n        out = self.transformer_decoder(tgt_emb, memory)\n        out = self.output_layer(out)\n        return out\n\ndef main():\n    device = torch.device(\'cpu\')\n    weights = torch.load(\'/app/weights.pt\', map_location=device)\n    dataset = torch.load(\'/app/dataset.pt\', map_location=device)\n    \n    model = RecoveredModel(d_model=128, nhead=8, dim_feedforward=256, max_len=5000, num_encoder_layers=3, num_decoder_layers=1, vocab_size=64, output_dim=64)\n    model.load_state_dict(weights)\n    \n    src_data = dataset[\'src_sequences\']\n    tgt_data = dataset[\'tgt_sequences\']\n    \n    # Original MSE\n    model.eval()\n    with torch.no_grad():\n        preds = model(src_data, tgt_data)\n        mse_loss = F.mse_loss(preds, tgt_data)\n        print(f"Original MSE: {mse_loss.item()}")\n\n    # Tuning\n    model.train()\n    for name, param in model.named_parameters():\n        if "output_layer" in name:\n            param.requires_grad = True\n        else:\n            param.requires_grad = False\n            \n    optimizer = torch.optim.Adam(model.output_layer.parameters(), lr=0.01)\n    criterion = nn.MSELoss()\n    \n    for epoch in range(200):\n        optimizer.zero_grad()\n        preds = model(src_data, tgt_data)\n        loss = criterion(preds, tgt_data)\n        loss.backward()\n        optimizer.step()\n        if epoch % 50 == 0:\n            print(f"Epoch {epoch}, Loss: {loss.item()}")\n\n    # New MSE\n    model.eval()\n    with torch.no_grad():\n        preds = model(src_data, tgt_data)\n        new_mse_loss = F.mse_loss(preds, tgt_data)\n        print(f"New MSE: {new_mse_loss.item()}")\n        \n    if new_mse_loss < mse_loss:\n        print("Success: New MSE is lower.")\n    else:\n        print("Failure: New MSE is not lower.")\n\n    # Save as TorchScript\n    model.eval()\n    scripted_model = torch.jit.script(model)\n    scripted_model.save(\'/app/model.pt\')\n    print("Model saved to /app/model.pt")\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 solve.py'})
