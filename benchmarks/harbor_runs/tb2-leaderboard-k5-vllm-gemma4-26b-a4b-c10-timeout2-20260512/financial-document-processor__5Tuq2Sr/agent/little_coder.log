>> ShellSession({'command': 'cat << \'EOF\' > /app/process_documents.py\nimport os\nimport shutil\nimport re\nimport csv\nimport subprocess\n\n# Note: Since we are in a terminal environment, we might not have OCR tools like Tesseract installed.\n# However, for PDF files, we can try to extract text using pdftotext if available.\n# For JPG files, we\'d normally need OCR. Let\'s check what tools are available.\n\ndef get_text(filepath):\n    ext = os.path.splitext(filepath)[1].lower()\n    text = ""\n    if ext == \'.pdf\':\n        try:\n            # Try pdftotext\n            result = subprocess.run([\'pdftotext\', filepath, \'-\'], capture_output=True, text=True)\n            text = result.stdout\n        except FileNotFoundError:\n            # Fallback to something else if pdftotext is missing? \n            # Let\'s check if we can use python libraries.\n            pass\n    elif ext == \'.jpg\':\n        # For JPG, we\'d need OCR. Let\'s see if tesseract is available.\n        try:\n            result = subprocess.run([\'tesseract\', filepath, \'stdout\'], capture_output=True, text=True)\n            text = result.stdout\n        except FileNotFoundError:\n            pass\n    return text\n\ndef classify_and_extract(filepath):\n    text = get_text(filepath)\n    # If text is empty, we might need to try harder or it\'s just not an invoice.\n    # But for this task, let\'s assume we can get text.\n    \n    # Simple classification: look for invoice-related keywords\n    invoice_keywords = [\'invoice\', \'bill\', \'receipt\', \'amount due\', \'total\']\n    is_invoice = any(kw in text.lower() for kw in invoice_keywords)\n    \n    if not is_invoice:\n        return \'other\', None, None\n\n    # Extraction\n    # Total amount\n    # Look for "Total", "Amount Due", "Grand Total"\n    # Special case: If both "Total" and "Amount Due" are present with different values, use only the "Total" amount\n    \n    total_amount = None\n    amount_due = None\n    \n    # Regex for amounts: e.g., $123.45, 123.45, Total: 123.45\n    # We\'ll look for patterns like "Total: 123.45" or "Total 123.45"\n    \n    def find_amount(pattern, text):\n        matches = re.findall(pattern, text, re.IGNORECASE)\n        amounts = []\n        for m in matches:\n            # m might be a group or the whole match\n            # We want the numeric part. Let\'s refine the regex.\n            pass\n        return amounts\n\n    # Let\'s try a more direct approach for extraction\n    # Find "Total" followed by some characters and then a number\n    total_match = re.search(r\'(?:Total|Grand Total)[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    if total_match:\n        total_amount = float(total_match.group(1).replace(\',\', \'\'))\n    \n    amount_due_match = re.search(r\'(?:Amount Due)[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    if amount_due_match:\n        amount_due = float(amount_due_match.group(1).replace(\',\', \'\'))\n\n    # Apply special rule\n    if total_amount is not None and amount_due is not None and total_amount != amount_due:\n        final_total = total_amount\n    elif total_amount is not None:\n        final_total = total_amount\n    elif amount_due is not None:\n        final_total = amount_due\n    else:\n        # Try a generic search if specific ones failed\n        generic_match = re.search(r\'(?:Total|Amount)[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n        if generic_match:\n            final_total = float(generic_match.group(1).replace(\',\', \'\'))\n        else:\n            final_total = None\n\n    # VAT amount\n    vat_amount = 0.0\n    vat_match = re.search(r\'(?:VAT|Tax|GST)[:\\s]*\\$?\\s*([\\d,]+\\.\\d{2})\', text, re.IGNORECASE)\n    if vat_match:\n        vat_amount = float(vat_match.group(1).replace(\',\', \'\'))\n    \n    return \'invoice\', final_total, vat_amount\n\ndef main():\n    docs_dir = \'/app/documents/\'\n    invoices_dir = \'/app/invoices/\'\n    other_dir = \'/app/other/\'\n    \n    files = os.listdir(docs_dir)\n    invoice_data = []\n    \n    for filename in files:\n        filepath = os.path.join(docs_dir, filename)\n        if os.path.isdir(filepath):\n            continue\n            \n        label, total, vat = classify_and_extract(filepath)\n        \n        if label == \'invoice\':\n            dest = os.path.join(invoices_dir, filename)\n            shutil.move(filepath, dest)\n            if total is not None:\n                invoice_data.append({\n                    \'filename\': filename,\n                    \'total_amount\': total,\n                    \'vat_amount\': vat\n                })\n            else:\n                # If it\'s an invoice but we couldn\'t find total, \n                # the prompt implies we should still move it.\n                # But the CSV requires total_amount. Let\'s assume it\'s 0.0 if not found?\n                # Actually, let\'s just skip adding to CSV if total is None, \n                # or use 0.0. The prompt says "Extract total_amount...".\n                # Let\'s use 0.0 to be safe for the CSV.\n                invoice_data.append({\n                    \'filename\': filename,\n                    \'total_amount\': 0.0,\n                    \'vat_amount\': vat\n                })\n        else:\n            dest = os.path.join(other_dir, filename)\n            shutil.move(filepath, dest)\n\n    # Create CSV\n    csv_path = os.path.join(invoices_dir, \'summary.csv\')\n    with open(csv_path, \'w\', newline=\'\') as csvfile:\n        fieldnames = [\'filename\', \'total_amount\', \'vat_amount\']\n        writer = csv.DictWriter(csvfile, fieldnames=fieldnames)\n        writer.writeheader()\n        \n        sum_total = 0.0\n        sum_vat = 0.0\n        for data in invoice_data:\n            writer.writerow(data)\n            sum_total += data[\'total_amount\']\n            sum_vat += data[\'vat_amount\']\n            \n        writer.writerow({\n            \'filename\': \'total\',\n            \'total_amount\': sum_total,\n            \'vat_amount\': sum_vat\n        })\n\nif __name__ == "__main__":\n    main()\nEOF\npython3 /app/process_documents.py'})
