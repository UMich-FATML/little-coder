>> ShellSession({'command': 'cat << \'EOF\' > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport toml\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return None\n\n    frames = []\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        # Convert to grayscale and maybe resize for speed if needed, \n        # but let\'s keep original for now.\n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        frames.append(gray)\n    cap.release()\n\n    if not frames:\n        return None\n\n    num_frames = len(frames)\n    motion_scores = np.zeros(num_frames)\n\n    # Calculate motion scores using frame differencing\n    for i in range(1, num_frames):\n        diff = cv2.absdiff(frames[i], frames[i-1])\n        motion_scores[i] = np.mean(diff)\n\n    # The jump is characterized by a period of high motion.\n    # We need to find the start and end of this period.\n    # However, the task asks for takeoff and landing.\n    # Takeoff: when the runner starts to jump (motion increases significantly)\n    # Landing: when the runner lands (motion decreases significantly)\n    \n    # Let\'s refine the motion score. A runner jumping will cause motion \n    # in the middle of the frame.\n    h, w = frames[0].shape\n    roi_h_start, roi_h_end = int(h * 0.3), int(h * 0.7)\n    roi_w_start, roi_w_end = int(w * 0.2), int(w * 0.8)\n\n    refined_motion = np.zeros(num_frames)\n    for i in range(1, num_frames):\n        diff = cv2.absdiff(frames[i], frames[i-1])\n        roi_diff = diff[roi_h_start:roi_h_end, roi_w_start:roi_w_end]\n        refined_motion[i] = np.mean(roi_diff)\n\n    # Find the window of high motion\n    # We can use a threshold. Let\'s find the peak motion.\n    if len(refined_motion) == 0:\n        return None\n        \n    # Thresholding: find frames where motion is above a certain percentile or absolute value\n    # Since we don\'t know the scale, let\'s use a relative threshold.\n    threshold = np.mean(refined_motion) + 2 * np.std(refined_motion)\n    \n    high_motion_indices = np.where(refined_motion > threshold)[0]\n    \n    if len(high_motion_indices) == 0:\n        # Fallback: just use the max motion if no threshold met\n        max_idx = np.argmax(refined_motion)\n        return {"jump_takeoff_frame_number": max_idx, "jump_land_frame_number": max_idx}\n\n    # The jump starts at the beginning of the high motion period and ends at the end.\n    # But takeoff is specifically the moment they leave the ground.\n    # Landing is when they hit the ground.\n    \n    # Let\'s try to find the first and last frame of the "event"\n    start_event = high_motion_indices[0]\n    end_event = high_motion_indices[-1]\n\n    # Refine takeoff: it\'s usually the frame just before the motion spikes\n    # Refine landing: it\'s usually the frame just after the motion spikes\n    # Actually, the motion spike *is* the jump.\n    # Let\'s look at the motion profile.\n    \n    # In many cases, takeoff is the first frame of significant motion.\n    # Landing is the last frame of significant motion.\n    # Let\'s adjust based on the example.\n    \n    # For the example, the motion was high around 109-119.\n    # Let\'s see if we can find a better way.\n    \n    # Let\'s try to find the peak and look around it.\n    peak_idx = np.argmax(refined_motion)\n    \n    # A simple heuristic: takeoff is the start of the high motion cluster,\n    # landing is the end.\n    \n    # Let\'s try to find the start of the cluster that contains the peak.\n    # We\'ll look for the first frame where motion > threshold before the peak.\n    takeoff = start_event\n    landing = end_event\n    \n    # Let\'s refine takeoff: the moment the runner\'s vertical motion starts.\n    # Since we only have grayscale, we\'ll stick to the motion cluster.\n    # However, the prompt says "detect when the jump happens".\n    # Takeoff is the start, landing is the end.\n    \n    return {\n        "jump_takeoff_frame_number": int(takeoff),\n        "jump_land_frame_number": int(landing)\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        print("Usage: python jump_analyzer.py <video_file>")\n        sys.exit(1)\n    \n    video_file = sys.argv[1]\n    results = analyze_video(video_file)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            toml.dump(results, f)\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml\n'})
