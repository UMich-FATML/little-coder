:\n        end_event += 1\n    if end_event < num_frames - 1 and refined_motion[end_event] <= threshold:\n        end_event -= 1\n\n    # Refine takeoff/landing based on the motion profile.\n    # The takeoff is often the frame where motion starts to rise sharply.\n    # The landing is often the frame where motion drops sharply.\n    # For this task, the start and end of the high-motion cluster is a robust estimate.\n    \n    return {\n        "jump_takeoff_frame_number": int(start_event),\n        "jump_land_frame_number": int(end_event)\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n    \n    video_file = sys.argv[1]\n    results = analyze_video(video_file)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml\n'})
