>> ShellSession({'command': 'cat << \'EOF\' > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return None\n\n    frames = []\n    while True:\n        ret, frame = cap.read()\n        if not ret:\n            break\n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        frames.append(gray)\n    cap.release()\n\n    if not frames:\n        return None\n\n    num_frames = len(frames)\n    h, w = frames[0].shape\n    \n    # ROI for the runner (middle of the frame)\n    roi_h_start, roi_h_end = int(h * 0.3), int(h * 0.7)\n    roi_w_start, roi_w_end = int(w * 0.2), int(w * 0.8)\n\n    refined_motion = np.zeros(num_frames)\n    for i in range(1, num_frames):\n        diff = cv2.absdiff(frames[i], frames[i-1])\n        roi_diff = diff[roi_h_start:roi_h_end, roi_w_start:roi_w_end]\n        refined_motion[i] = np.mean(roi_diff)\n\n    # Find the window of high motion\n    mean_motion = np.mean(refined_motion)\n    std_motion = np.std(refined_motion)\n    \n    # Use a threshold based on the mean and std of the motion\n    # We\'ll try a few thresholds to find the best one\n    thresholds = [mean_motion + 2 * std_motion, mean_motion + 1 * std_motion, mean_motion + 0.5 * std_motion]\n    \n    best_start = 0\n    best_end = 0\n    max_cluster_size = -1\n\n    for threshold in thresholds:\n        # Find the peak motion\n        peak_idx = np.argmax(refined_motion)\n        \n        # If the peak is not above threshold, we skip this threshold\n        if refined_motion[peak_idx] <= threshold:\n            continue\n\n        # Find the start and end of the continuous block containing peak_idx\n        start_event = peak_idx\n        while start_event > 0 and refined_motion[start_event] > threshold:\n            start_event -= 1\n        if start_event > 0 and refined_motion[start_event] <= threshold:\n            start_event += 1\n            \n        end_event = peak_idx\n        while end_event < num_frames - 1 and refined_motion[end_event] > threshold:\n            end_event += 1\n        if end_event < num_frames - 1 and refined_motion[end_event] <= threshold:\n            end_event -= 1\n            \n        cluster_size = end_event - start_event + 1\n        if cluster_size > max_cluster_size:\n            max_cluster_size = cluster_size\n            best_start = start_event\n            best_end = end_event\n\n    if max_cluster_size <= 0:\n        peak_idx = np.argmax(refined_motion)\n        return {\n            "jump_takeoff_frame_number": int(peak_idx),\n            "jump_land_frame_number": int(peak_idx)\n        }\n\n    return {\n        "jump_takeoff_frame_number": int(best_start),\n        "jump_land_frame_number": int(best_end)\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n    \n    video_file = sys.argv[1]\n    results = analyze_video(video_file)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml\n'})
