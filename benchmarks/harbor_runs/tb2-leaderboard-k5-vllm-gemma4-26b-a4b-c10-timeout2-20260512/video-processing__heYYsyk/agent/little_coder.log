>> ShellSession({'command': 'cat << \'EOF\' > /app/jump_analyzer.py\nimport cv2\nimport numpy as np\nimport sys\n\ndef analyze_video(video_path):\n    cap = cv2.VideoCapture(video_path)\n    if not cap.isOpened():\n        return None\n\n    num_frames = int(cap.get(cv2.CAP_PROP_FRAME_COUNT))\n    h = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))\n    w = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))\n    \n    # ROI for the runner (middle of the frame)\n    roi_h_start, roi_h_end = int(h * 0.3), int(h * 0.7)\n    roi_w_start, roi_w_end = int(w * 0.2), int(w * 0.8)\n\n    # We\'ll track the vertical center of mass in the ROI\n    # to detect the jump.\n    y_centers = []\n    \n    for i in range(num_frames):\n        ret, frame = cap.read()\n        if not ret:\n            break\n        \n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        roi = gray[roi_h_start:roi_h_end, roi_w_start:roi_w_end]\n        \n        # Use thresholding to find the runner in the ROI\n        # Since we don\'t know the exact color, we\'ll use Otsu\'s or just a simple threshold\n        _, thresh = cv2.threshold(roi, 0, 255, cv2.THRESH_BINARY + cv2.THRESH_OTSU)\n        \n        # Find moments to get the center of mass\n        M = cv2.moments(thresh)\n        if M["m00"] != 0:\n            cy = int(M["m01"] / M["m00"])\n            # Convert ROI y back to global y\n            y_centers.append(cy + roi_h_start)\n        else:\n            y_centers.append(None)\n\n    cap.release()\n\n    # Filter out None values and find the jump\n    # A jump is a period where the y_center increases and then decreases.\n    # However, the runner is moving across the screen.\n    # Let\'s look at the vertical velocity or the change in y.\n    \n    # Actually, let\'s use the motion score again but with a much more sensitive approach.\n    # The previous motion score was too sensitive to the peak.\n    # Let\'s try to find the start and end of the motion spike.\n    \n    # Re-calculating motion scores more carefully\n    cap = cv2.VideoCapture(video_path)\n    motion_scores = []\n    prev_gray = None\n    for i in range(num_frames):\n        ret, frame = cap.read()\n        if not ret: break\n        gray = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)\n        if prev_gray is not None:\n            diff = cv2.absdiff(gray, prev_gray)\n            motion_scores.append(np.mean(diff))\n        else:\n            motion_scores.append(0)\n        prev_gray = gray\n    cap.release()\n    motion_scores = np.array(motion_scores)\n\n    # Find the peak\n    peak_idx = np.argmax(motion_scores)\n    \n    # Let\'s find the window where motion is above a certain fraction of the peak\n    # This is a common way to find an event.\n    threshold = motion_scores[peak_idx] * 0.5\n    \n    # Find the continuous block around the peak\n    start_event = peak_idx\n    while start_event > 0 and motion_scores[start_event] > threshold:\n        start_event -= 1\n    if start_event > 0 and motion_scores[start_event] <= threshold:\n        start_event += 1\n        \n    end_event = peak_idx\n    while end_event < num_frames - 1 and motion_scores[end_event] > threshold:\n        end_event += 1\n    if end_event < num_frames - 1 and motion_scores[end_event] <= threshold:\n        end_event -= 1\n\n    return {\n        "jump_takeoff_frame_number": int(start_event),\n        "jump_land_frame_number": int(end_event)\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n    \n    video_file = sys.argv[1]\n    results = analyze_video(video_file)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml\n'})
