\n    \n    if len(high_motion_indices) == 0:\n        # Fallback to peak\n        return {"jump_takeoff_frame_number": int(peak_idx), "jump_land_frame_number": int(peak_idx)}\n\n    # Find the cluster containing the peak\n    start_event = high_motion_indices[0]\n    end_event = high_motion_indices[-1]\n    \n    # Refine: takeoff is often the frame where motion first spikes\n    # Landing is often the frame where motion last spikes\n    \n    # Let\'s try to find the first frame where motion is > threshold\n    # and the last frame where motion is > threshold.\n    # But we want to be careful about noise.\n    \n    # Let\'s find the continuous block around the peak.\n    peak_cluster_start = peak_idx\n    while peak_cluster_start > 0 and motion_scores[peak_cluster_start] > threshold:\n        peak_cluster_start -= 1\n    if peak_cluster_start > 0 and motion_scores[peak_cluster_start] <= threshold:\n        peak_cluster_start += 1\n        \n    peak_cluster_end = peak_idx\n    while peak_cluster_end < num_frames - 1 and motion_scores[peak_cluster_end] > threshold:\n        peak_cluster_end += 1\n    if peak_cluster_end < num_frames - 1 and motion_scores[peak_cluster_end] <= threshold:\n        peak_cluster_end -= 1\n\n    return {\n        "jump_takeoff_frame_number": int(peak_cluster_start),\n        "jump_land_frame_number": int(peak_cluster_end)\n    }\n\nif __name__ == "__main__":\n    if len(sys.argv) < 2:\n        sys.exit(1)\n    \n    video_file = sys.argv[1]\n    results = analyze_video(video_file)\n    \n    if results:\n        with open(\'/app/output.toml\', \'w\') as f:\n            f.write(f"jump_takeoff_frame_number = {results[\'jump_takeoff_frame_number\']}\\n")\n            f.write(f"jump_land_frame_number = {results[\'jump_land_frame_number\']}\\n")\nEOF\npython3 /app/jump_analyzer.py /app/example_video.mp4\ncat /app/output.toml\n'})
