_k] = best_p\n                    np.save(\'/app/dist.npy\', dist)\n                    print("Saved dist.npy")\n                else:\n                    print("Failed tolerance check")\n    else:\n        print("No solution found")\n\nsolve()\nEOF\npython3 /app/solve.py\n'})
