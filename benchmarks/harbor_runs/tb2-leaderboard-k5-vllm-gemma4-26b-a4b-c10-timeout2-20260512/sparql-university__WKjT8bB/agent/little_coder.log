>> ShellSession({'command': 'cat <<\'EOF\' > /app/solution.sparql\nPREFIX uni: <http://university.org/ontology/>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema#>\n\nSELECT ?professorName (GROUP_CONCAT(DISTINCT ?country; separator=", ") AS ?countries)\nWHERE {\n  # 1. They are full professors.\n  # Based on the data, role is a string like "Professor of Computer Science"\n  ?professor uni:hasName ?professorName ;\n             uni:role ?role ;\n             uni:worksIn ?dept .\n  FILTER(CONTAINS(?role, "Professor") && !CONTAINS(?role, "Assistant Professor") && !CONTAINS(?role, "Associate Professor"))\n\n  # 2. They work in at least one department of a university located in an EU country.\n  ?dept uni:belongsTo ?university .\n  ?university uni:locatedInCountry ?country .\n  \n  # EU Member States as of 2025-08-16 (ISO 3166-1 alpha-2)\n  # AT, BE, BG, CY, CZ, DE, DK, EE, ES, FI, FR, GR, HR, HU, IE, IT, LT, LU, LV, MT, NL, PL, PT, RO, SE, SI, SK\n  # Note: The prompt says "assume that \'European Union countries\' refers to the official EU member states as of 2025-08-16".\n  # I will list them.\n  FILTER(?country IN ("AT", "BE", "BG", "CY", "CZ", "DE", "DK", "EE", "ES", "FI", "FR", "GR", "HR", "HU", "IE", "IT", "LT", "LU", "LV", "MT", "NL", "PL", "PT", "RO", "SE", "SI", "SK"))\n\n  # 3. Among all departments they work in, at least one has more than 10 students currently enrolled in any classes taught in that department.\n  # This condition must be met by AT LEAST ONE department the professor works in.\n  # The professor might work in multiple departments.\n  \n  {\n    SELECT ?professor\n    WHERE {\n      ?professor uni:worksIn ?dept .\n      ?dept uni:hasStudentCount ?count . # Wait, is there a hasStudentCount? No, I need to count from enrollment.\n      # Let\'s re-read the requirement: "at least one [department] has more than 10 students currently enrolled in any classes taught in that department."\n      # "Currently enrolled" implies we should check the enrollment date or graduation date.\n      # The reference date is 2025-08-16.\n      # A student is "currently enrolled" if they have an enrollment date and no graduation date OR graduation date is in the future.\n      # Actually, the prompt says "currently enrolled in any classes taught in that department".\n      # Let\'s look at the data: uni:Student1 uni:isEnrolledIn uni:CS101 ...\n      # A student is enrolled in a class. A class is taught in a department.\n      \n      ?dept uni:hasClass ?class . # Wait, is it uni:hasClass or uni:isTaughtIn?\n      # Looking at data: uni:CS101 uni:isTaughtIn uni:ComputerScience_NTUA .\n      # So: ?class uni:isTaughtIn ?dept .\n      \n      ?student uni:isEnrolledIn ?class ;\n               uni:hasEnrollmentDate ?enrollDate ;\n               uni:hasGraduationDate ?gradDate .\n      \n      # Filter for "currently enrolled" as of 2025-08-16\n      FILTER(?enrollDate <= "2025-08-16"^^xsd:date)\n      FILTER(!BOUND(?gradDate) || ?gradDate > "2025-08-16"^^xsd:date)\n      \n      # We need to count students per department.\n      # But the condition is "at least one [department] has more than 10 students...".\n      # This means we group by department and check the count.\n    }\n    GROUP BY ?professor ?dept\n    HAVING (COUNT(DISTINCT ?student) > 10)\n  }\n\n  # For the final output, we need ALL countries where the professor works.\n  ?professor uni:worksIn ?anyDept .\n  ?anyDept uni:belongsTo ?anyUni .\n  ?anyUni uni:locatedInCountry ?country .\n}\nGROUP BY ?professorName\nEOF\n'})
