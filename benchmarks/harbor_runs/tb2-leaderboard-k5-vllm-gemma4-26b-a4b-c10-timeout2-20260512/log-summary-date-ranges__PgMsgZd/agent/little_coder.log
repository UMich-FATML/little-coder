>> ShellSession({'command': 'cat << \'EOF\' > /app/analyze_logs.py\nimport os\nimport csv\nfrom datetime import datetime, timedelta\n\ndef analyze():\n    log_dir = \'/app/logs\'\n    reference_date = datetime(2025, 8, 12)\n    \n    # Define periods\n    periods = {\n        \'today\': (reference_date, reference_date),\n        \'last_7_days\': (reference_date - timedelta(days=6), reference_date),\n        \'last_30_days\': (reference_date - timedelta(days=29), reference_date),\n        \'month_to_date\': (datetime(reference_date.year, reference_date.month, 1), reference_date),\n    }\n    \n    severities = [\'ERROR\', \'WARNING\', \'INFO\']\n    \n    # Initialize counts\n    # counts[period][severity]\n    counts = {p: {s: 0 for s in severities} for p in periods}\n    counts[\'total\'] = {s: 0 for s in severities}\n\n    # Get all log files\n    log_files = [f for f in os.listdir(log_dir) if f.endswith(\'.log\')]\n    \n    for log_file in log_files:\n        # Parse date from filename: YYYY-MM-DD_<source>.log\n        try:\n            date_str = log_file.split(\'_\')[0]\n            file_date = datetime.strptime(date_str, \'%Y-%m-%d\')\n        except (ValueError, IndexError):\n            continue\n\n        file_path = os.path.join(log_dir, log_file)\n        \n        with open(file_path, \'r\') as f:\n            for line in f:\n                # Check for severities in the line\n                for s in severities:\n                    if f\'[{s}]\' in line:\n                        # Increment total\n                        counts[\'total\'][s] += 1\n                        \n                        # Increment period counts if file_date is in range\n                        for p, (start, end) in periods.items():\n                            if start <= file_date <= end:\n                                counts[p][s] += 1\n                        break # Found the severity for this line\n\n    # Write to CSV\n    with open(\'/app/summary.csv\', \'w\', newline=\'\') as csvfile:\n        writer = csv.writer(csvfile)\n        writer.writerow([\'period\', \'severity\', \'count\'])\n        \n        # Order of periods in output: today, last_7_days, last_30_days, month_to_date, total\n        ordered_periods = [\'today\', \'last_7_days\', \'last_30_days\', \'month_to_date\', \'total\']\n        for p in ordered_periods:\n            for s in severities:\n                writer.writerow([p, s, counts[p][s]])\n\nif __name__ == "__main__":\n    analyze()\nEOF\npython3 /app/analyze_logs.py\n'})
