tart, today):\n                counts[\'last_30_days\'][sev] += 1\n            \n            # month to date\n            if in_range(d, month_start, today):\n                counts[\'month_to_date\'][sev] += 1\n\n# Write CSV\nperiods = [\'today\', \'last_7_days\', \'last_30_days\', \'month_to_date\', \'total\']\nsevs = [\'ERROR\', \'WARNING\', \'INFO\']\n\nwith open(\'/app/summary.csv\', \'w\') as f:\n    f.write(\'period,severity,count\\n\')\n    for p in periods:\n        for s in sevs:\n            f.write(f\'{p},{s},{counts[p][s]}\\n\')\n\nprint("Done. CSV written to /app/summary.csv")\nPYEOF\npython3 /app/analyze_logs.py'})
