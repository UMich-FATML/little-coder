low)\n                    err = (fwd-10)**2 + (bwd-10)**2\n                    if err < best_err:\n                        best_err = err\n                        best_result = (k, ph, p_low, fwd, bwd)\n        except:\n            pass\n\nif best_result:\n    k, ph, pl, fwd, bwd = best_result\n    print(f"k={k:.6f}, p_high={ph:.15f}, p_low={pl:.15e}")\n    print(f"fwd={fwd:.15f}, bwd={bwd:.15f}")\n    print(f"err_fwd={abs(fwd-10):.2e}, err_bwd={abs(bwd-10):.2e}")\nelse:\n    print("No solution found")\n\nEOF\npython3 solve.py'})
