<< /* config.h for UNIX/Linux build of POV-Ray 2.2 */

#define PARAMS(x) x

#define STARTUP_POVRAY unix_init_POVRAY();
#define TIME_ELAPSED (tstop - tstart);

#define EPSILON 1.0e-5

#define READ_ENV_VAR_BEFORE
#define READ_ENV_VAR_AFTER if ((Option_String_Ptr = getenv("POVRAYOPT")) != NULL) read_options(Option_String_Ptr);

#define CONFIG_MATH

#define DBL double
#define ACOS acos
#define SQRT sqrt

