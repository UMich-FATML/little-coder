0; j < input_dim; j++) {\n            sum += w1[i * input_dim + j] * input[j];\n        }\n        // ReLU\n        hidden[i] = std::max(0.0, sum);\n    }\n    \n    // Layer 2: hidden -> output (no activation on output)\n    std::vector<double> output(output_dim, 0.0);\n    for (int i = 0; i < output_dim; i++) {\n        double sum = b3[i];\n        for (int j = 0; j < hidden_dim; j++) {\n            sum += w3[i * hidden_dim + j] * hidden[j];\n        }\n        output[i] = sum;\n    }\n    \n    return output;\n}\n\nint main(int argc, char* argv[]) {\n    if (argc != 3) {\n        fprintf(stderr, "Usage: %s weights.json image.png\\n", argv[0]);\n        return 1;\n    }\n    \n    // Load weights from JSON\n    FILE* f = fopen(argv[1], "r");\n    if (!f) {\n        fprintf(stderr, "Cannot open weights file: %s\\n", argv[1]);\n        return 1;\n    }\n    fseek(f, 0, SEEK_END);\n    long fsize = ftell(f);\n    fseek(f, 0, SEEK_SET);\n    char* json_str = (char*)malloc(fsize + 1);\n    fread(json_str, 1, fsize, f);\n    fclose(f);\n    json_str[fsize] = \'\\0\';\n    \n    cJSON* root = cJSON_Parse(json_str);\n    free(json_str);\n    if (!root) {\n        fprintf(stderr, "Failed to parse JSON\\n");\n        return 1;\n    }\n    \n    auto get_array = [&](const char* key) -> std::vector<double> {\n        cJSON* arr = cJSON_GetObjectItem(root, key);\n        int len = cJSON_GetArraySize(arr);\n        std::vector<double> result(len);\n        for (int i = 0; i < len; i++) {\n            result[i] = cJSON_GetArrayItem(arr, i)->valuedouble;\n        }\n        return result;\n    };\n    \n    std::vector<double> w1 = get_array("input_layer.weight");\n    std::vector<double> b1 = get_array("input_layer.bias");\n    std::vector<double> w2 = get_array("hidden_layer.weight");\n    std::vector<double> b2 = get_array("hidden_layer.bias");\n    std::vector<double> w3 = get_array("output_layer.weight");\n    std::vector<double> b3 = get_array("output_layer.bias");\n    \n    // Model dimensions\n    int hidden_dim = b1.size();  // 16\n    int input_dim = w1.size() / hidden_dim;  // 784\n    int output_dim = b3.size();  // 10\n    \n    // Load image\n    std::vector<double> pixels = load_png(argv[2]);\n    \n    // Forward pass\n    std::vector<double> output = forward(pixels, w1, b1, w2, b2, w3, b3, input_dim, hidden_dim, output_dim);\n    \n    // Find argmax\n    int best = 0;\n    for (int i = 1; i < output_dim; i++) {\n        if (output[i] > output[best]) {\n            best = i;\n        }\n    }\n    \n    printf("%d\\n", best);\n    \n    cJSON_Delete(root);\n    return 0;\n}\nCPPEOF\necho "Source written"'})
