ast_7_days\', \'last_30_days\', \'month_to_date\', \'total\']:\n        for severity in [\'ERROR\', \'WARNING\', \'INFO\']:\n            f.write(f\'{period},{severity},{counts[period][severity]}\\n\')\n\nprint("Done. CSV written to /app/summary.csv")\nPYEOF\npython3 /app/analyze.py'})
