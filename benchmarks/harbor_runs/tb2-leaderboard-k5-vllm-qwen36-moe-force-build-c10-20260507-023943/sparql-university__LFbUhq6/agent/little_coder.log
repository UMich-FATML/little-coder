WHERE {
  ?professor a uni:Person ;
             uni:hasName ?professorName ;
             uni:role ?role .

  FILTER(CONTAINS(?role, "Professor") && !CONTAINS(?role, "Assistant"))

  ?professor uni:worksIn ?dept .
  ?d
