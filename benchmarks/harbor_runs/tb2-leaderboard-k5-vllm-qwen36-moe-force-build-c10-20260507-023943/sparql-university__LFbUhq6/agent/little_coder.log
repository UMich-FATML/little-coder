>> ShellSession({'command': 'cat > /app/solution.sparql << \'EOF\'\nPREFIX uni: <http://university.org/ontology/>\nPREFIX xsd: <http://www.w3.org/2001/XMLSchema/>\n\nSELECT ?professorName (GROUP_CONCAT(DISTINCT ?country; separator=", ") AS ?countries)\nWHERE {\n  # Get the professor and their name\n  ?professor a uni:Person ;\n             uni:hasName ?professorName ;\n             uni:role ?role .\n\n  # Criterion 1: They are full professors (role starts with "Professor" but not "Assistant Professor")\n  FILTER(CONTAINS(?role, "Professor") && !CONTAINS(?role, "Assistant"))\n\n  # Get departments the professor works in\n  ?professor uni:worksIn ?dept .\n\n  # Get the university the department belongs to\n  ?dept uni:belongsTo ?university .\n\n  # Get the country of the university\n  ?university uni:locatedInCountry ?country .\n\n  # Criterion 2: University must be in an EU country\n  FILTER(?country IN ("AT", "BE", "BG", "HR", "CY", "CZ", "DK", "EE", "FI", "FR", "DE", "GR", "IE", "IT", "LV", "LT", "LU", "MT", "NL", "PL", "PT", "RO", "SK", "SI", "ES", "SE"))\n\n  # Criterion 3: At least one department they work in has >10 currently enrolled students\n  # A student is currently enrolled if they are enrolled in a course and either:\n  # - they have no graduation date, OR\n  # - their graduation date is after 2025-08-16\n  {\n    SELECT ?professor\n    WHERE {\n      ?professor uni:worksIn ?dept .\n      ?course uni:isTaughtIn ?dept .\n      ?student uni:isEnrolledIn ?course ;\n               uni:hasEnrollmentDate ?enrollDate .\n      OPTIONAL { ?student uni:hasGraduationDate ?gradDate }\n\n      # Student is currently enrolled: no graduation date or graduation after reference date\n      FILTER(!BOUND(?gradDate) || ?gradDate > "2025-08-16"^^xsd:date)\n\n      # Count students per professor-department pair\n      BIND(COUNT(DISTINCT ?student) AS ?studentCount)\n    }\n    GROUP BY ?professor ?dept\n    HAVING (COUNT(DISTINCT ?student) > 10)\n  }\n}\nGROUP BY ?professorName\nEOF', 'timeout': 10})
