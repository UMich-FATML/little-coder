>> ShellSession({'command': 'cat > /app/analysis.R << \'REOF\'\nlibrary(rstan)\n\n# Load data\ndata <- read.csv("/app/data.csv")\nN <- nrow(data)\ny <- data$y\nn <- data$n\n\n# Stan model\nstan_model <- stan_model(file = "/app/hierarchical_model.stan")\n\n# Sampling\nfit <- sampling(\n  stan_model,\n  data = list(N = N, y = y, n = n),\n  chains = 4,\n  iter = 100000,\n  seed = 1,\n  refresh = 1000\n)\n\n# Extract posterior means\nalpha_mean <- mean(fit, pars = "alpha")\nbeta_mean <- mean(fit, pars = "beta")\n\n# Save results\nwrite(as.numeric(alpha_mean), file = "/app/posterior_alpha_mean.txt")\nwrite(as.numeric(beta_mean), file = "/app/posterior_beta_mean.txt")\n\ncat("Posterior mean of alpha:", as.numeric(alpha_mean), "\\n")\ncat("Posterior mean of beta:", as.numeric(beta_mean), "\\n")\nREOF\necho "R script created"'})
