>> ShellSession({'command': 'cat > /app/parallel_linear.py << \'EOF\'\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport torch.distributed as dist\n\n\nclass ColumnParallelLinear(nn.Module):\n    """\n    Splits the weight matrix by columns across ranks.\n    Each rank holds a shard of the weight matrix with shape (out_features // world_size, in_features).\n    Output is computed locally, then all-gathered along the output dimension.\n    Bias is also sharded in the same way as the output dimension.\n    """\n\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.use_bias = bias\n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n\n        # Split master_weight by columns (last dimension is in_features, first is out_features)\n        # master_weight shape: (out_features, in_features)\n        # We split along dim=0 (out_features dimension)\n        chunk_size = master_weight.shape[0] // self.world_size\n        self.weight = master_weight[self.rank * chunk_size : (self.rank + 1) * chunk_size].clone()\n\n        if self.use_bias:\n            self.bias = nn.Parameter(torch.zeros(chunk_size))\n        else:\n            self.register_parameter(\'bias\', None)\n\n        self.register_buffer(\'_out_features_per_rank\', torch.tensor(chunk_size))\n\n    def forward(self, x):\n        # x shape: (*, in_features)\n        output = F.linear(x, self.weight, self.bias)\n        # output shape: (*, out_features // world_size)\n\n        if self.world_size > 1:\n            # All-gather outputs from all ranks and concatenate along the last dimension\n            gathered = [torch.empty_like(output) for _ in range(self.world_size)]\n            dist.all_gather(gathered, output)\n            output = torch.cat(gathered, dim=-1)\n\n        return output\n\n\nclass RowParallelLinear(nn.Module):\n    """\n    Splits the weight matrix by rows across ranks.\n    Each rank holds a shard of the weight matrix with shape (out_features // world_size, in_features).\n    Partial outputs are computed locally, then summed together (all-reduce).\n    Bias remains full on each rank.\n    """\n\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.use_bias = bias\n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n\n        # Split master_weight by rows (dim=0)\n        # master_weight shape: (out_features, in_features)\n        chunk_size = master_weight.shape[0] // self.world_size\n        self.weight = master_weight[self.rank * chunk_size : (self.rank + 1) * chunk_size].clone()\n\n        if self.use_bias:\n            # Full bias on each rank\n            self.bias = nn.Parameter(torch.zeros(out_features))\n        else:\n            self.register_parameter(\'bias\', None)\n\n    def forward(self, x):\n        # x shape: (*, in_features)\n        # self.weight shape: (out_features // world_size, in_features)\n        output = F.linear(x, self.weight, self.bias)\n        # output shape: (*, out_features // world_size)\n\n        if self.world_size > 1:\n            # All-reduce: sum partial outputs across all ranks\n            dist.all_reduce(output, op=dist.ReduceOp.SUM)\n\n        return output\nEOF'})
