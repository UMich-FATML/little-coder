>> ShellSession({'command': 'cat > /app/merge.py << \'PYEOF\'\nimport json\nimport pandas as pd\nimport pyarrow as pa\nimport pyarrow.parquet as pq\n\n# --- Source A: JSON ---\nwith open(\'/data/source_a/users.json\') as f:\n    source_a_list = json.load(f)\n\nsource_a = []\nfor u in source_a_list:\n    source_a.append({\n        \'user_id\': int(u[\'id\']),\n        \'name\': u[\'full_name\'],\n        \'email\': u[\'email\'],\n        \'created_date\': u[\'registration_date\'],\n        \'status\': u.get(\'status\', \'\'),\n        \'_source\': \'a\'\n    })\ndf_a = pd.DataFrame(source_a)\n\n# --- Source B: CSV ---\ndf_b_raw = pd.read_csv(\'/data/source_b/users.csv\')\nsource_b = []\nfor _, row in df_b_raw.iterrows():\n    source_b.append({\n        \'user_id\': int(row[\'user_id\']),\n        \'name\': row[\'name\'],\n        \'email\': row[\'email_address\'],\n        \'created_date\': row[\'created_at\'],\n        \'status\': \'active\' if str(row.get(\'is_active\', \'\')).lower() == \'true\' else \'inactive\',\n        \'_source\': \'b\'\n    })\ndf_b = pd.DataFrame(source_b)\n\n# --- Source C: Parquet ---\ndf_c_raw = pd.read_parquet(\'/data/source_c/users.parquet\')\nsource_c = []\nfor _, row in df_c_raw.iterrows():\n    source_c.append({\n        \'user_id\': int(row[\'userId\']),\n        \'name\': row[\'userName\'],\n        \'email\': row[\'email\'],\n        \'created_date\': row[\'joined\'],\n        \'status\': \'active\' if str(row.get(\'active\', \'\')).lower() == \'true\' else \'inactive\',\n        \'_source\': \'c\'\n    })\ndf_c = pd.DataFrame(source_c)\n\n# Collect all unique user_ids\nall_user_ids = sorted(set(df_a[\'user_id\'].tolist() + df_b[\'user_id\'].tolist() + df_c[\'user_id\'].tolist()))\n\n# Build per-source lookup dicts\nlookup_a = {r[\'user_id\']: r for r in source_a}\nlookup_b = {r[\'user_id\']: r for r in source_b}\nlookup_c = {r[\'user_id\']: r for r in source_c}\n\n# Fields to check for conflicts\nfields = [\'name\', \'email\', \'created_date\', \'status\']\n\nconflicts = []\nmerged_rows = []\n\nfor uid in all_user_ids:\n    row_a = lookup_a.get(uid)\n    row_b = lookup_b.get(uid)\n    row_c = lookup_c.get(uid)\n    \n    merged = {}\n    for field in fields:\n        val_a = row_a[field] if row_a else None\n        val_b = row_b[field] if row_b else None\n        val_c = row_c[field] if row_c else None\n        \n        # Determine selected value by priority\n        if val_a is not None:\n            selected = val_a\n        elif val_b is not None:\n            selected = val_b\n        elif val_c is not None:\n            selected = val_c\n        else:\n            selected = None\n        \n        merged[field] = selected\n        \n        # Check if there\'s a conflict (same field, different values across sources)\n        present = {}\n        if val_a is not None:\n            present[\'source_a\'] = val_a\n        if val_b is not None:\n            present[\'source_b\'] = val_b\n        if val_c is not None:\n            present[\'source_c\'] = val_c\n        \n        if len(present) > 1:\n            # Check if values differ\n            unique_vals = set(present.values())\n            if len(unique_vals) > 1:\n                conflicts.append({\n                    \'user_id\': uid,\n                    \'field\': field,\n                    \'values\': present,\n                    \'selected\': selected\n                })\n    \n    merged[\'user_id\'] = uid\n    merged_rows.append(merged)\n\n# Build output DataFrame\noutput_df = pd.DataFrame(merged_rows)\noutput_df = output_df[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\noutput_df[\'user_id\'] = output_df[\'user_id\'].astype(int)\n\n# Write parquet\noutput_df.to_parquet(\'/app/merged_users.parquet\', index=False)\n\n# Write conflict report\nreport = {\n    \'total_conflicts\': len(conflicts),\n    \'conflicts\': conflicts\n}\nwith open(\'/app/conflicts.json\', \'w\') as f:\n    json.dump(report, f, indent=2)\n\nprint("=== Merged users ===")\nprint(output_df.to_string())\nprint(f"\\n=== Conflicts: {len(conflicts)} ===")\nprint(json.dumps(report, indent=2))\nPYEOF\npython3 /app/merge.py', 'timeout': 30})
