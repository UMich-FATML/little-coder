ificate: {cert_path}")\n    print(f"Subject: {subject}")\n    print(f"Common Name: {cn}")\n    print(f"Expiration Date: {exp_formatted}")\n    print("Certificate verification successful")\n\nif __name__ == "__main__":\n    main()\nPYEOF'})
