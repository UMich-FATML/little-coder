>> ShellSession({'command': 'cat > /tmp/extract_text.py << \'PYEOF\'\nimport re\nimport sys\n\n# Read gcode\nwith open(\'/app/text.gcode\', \'r\') as f:\n    lines = f.readlines()\n\n# Extract G1 moves with Z values\nmoves = []\nfor line in lines:\n    line = line.strip()\n    if line.startswith(\'G1 \'):\n        parts = line.split()\n        x = y = z = None\n        for p in parts:\n            if p.startswith(\'X\'):\n                x = float(p[1:])\n            elif p.startswith(\'Y\'):\n                y = float(p[1:])\n            elif p.startswith(\'Z\'):\n                z = float(p[1:])\n        if x is not None and y is not None and z is not None:\n            moves.append((x, y, z))\n\n# Find the text region - look for Z values that are not the base layer\n# The base layer seems to be around Z=0.2, and embossed text goes higher\n# Let\'s find the min/max Z in the text area\nz_values = [m[2] for m in moves]\nprint(f"Total moves: {len(moves)}")\nprint(f"Z range: {min(z_values):.3f} to {max(z_values):.3f}")\n\n# The text area seems to be around X=100, Y=100 based on earlier analysis\n# Let\'s look at the Z values in that region\ntext_moves = [m for m in moves if 95 <= m[0] <= 105 and 95 <= m[1] <= 110]\nprint(f"Text region moves: {len(text_moves)}")\n\nif text_moves:\n    text_z = [m[2] for m in text_moves]\n    print(f"Text Z range: {min(text_z):.3f} to {max(text_z):.3f}")\n    \n    # Find the base Z (most common low Z value)\n    from collections import Counter\n    z_counts = Counter([round(z, 1) for z in text_z])\n    print(f"Most common Z values: {z_counts.most_common(10)}")\n    \n    # Find the highest Z values - these are the raised letters\n    high_z = [m for m in text_moves if m[2] > 1.0]\n    print(f"High Z moves (>1.0): {len(high_z)}")\n    \n    # Let\'s look at the X,Y positions of high Z moves\n    if high_z:\n        high_x = [m[0] for m in high_z]\n        high_y = [m[1] for m in high_z]\n        print(f"High Z X range: {min(high_x):.3f} to {max(high_x):.3f}")\n        print(f"High Z Y range: {min(high_y):.3f} to {max(high_y):.3f}")\n\n# Let\'s look at the overall bounding box\nall_x = [m[0] for m in moves]\nall_y = [m[1] for m in moves]\nprint(f"Overall X range: {min(all_x):.3f} to {max(all_x):.3f}")\nprint(f"Overall Y range: {min(all_y):.3f} to {max(all_y):.3f}")\n\nPYEOF\npython3 /tmp/extract_text.py', 'timeout': 60})
