\', \'Y\', \'R\', \'D\'], 2):\n    pc = partial_corr(df, x, y, [\'M\'])\n    print(f"  PC({x},{y}|M) = {pc:.4f}")\n\nprint("\\nPartial correlations (given Y):")\nfor x, y in permutations([\'U\', \'R\', \'D\', \'M\'], 2):\n    pc = partial_corr(df, x, y, [\'Y\'])\n    print(f"  PC({x},{y}|Y) = {pc:.4f}")\nPYEOF', 'timeout': 60})
