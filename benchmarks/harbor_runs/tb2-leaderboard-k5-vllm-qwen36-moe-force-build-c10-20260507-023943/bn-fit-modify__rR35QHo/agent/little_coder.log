independent of Y|U\n# Actually let\'s just check the regression model\n\n# Model: D = beta0 + beta1*U + beta2*Y + noise\nfrom sklearn.linear_model import LinearRegression\nX = df[[\'U\', \'Y\']].values\ny = df[\'D\'].values\nlr = LinearRegression().fit(X, y)\nprint(f"D = {lr.coef_[0]:.4f}*U + {lr.coef_[1]:.4f}*Y + {lr.intercept_:.4f}")\nprint(f"R² = {lr.score(X,y):.4f}")\n\n# Model: M = beta0 + beta1*U + beta2*R + noise\nX = df[[\'U\', \'R\']].values\ny = df[\'M\'].values\nlr = LinearRegression().fit(X, y)\nprint(f"\\nM = {lr.coef_[0]:.4f}*U + {lr.coef_[1]:.4f}*R + {lr.intercept_:.4f}")\nprint(f"R² = {lr.score(X,y):.4f}")\n\n# Model: R = beta0 + beta1*U + noise\nX = df[[\'U\']].values\ny = df[\'R\'].values\nlr = LinearRegression().fit(X, y)\nprint(f"\\nR = {lr.coef_[0]:.4f}*U + {lr.intercept_:.4f}")\nprint(f"R² = {lr.score(X,y):.4f}")\n\n# Model: Y = beta0 + beta1*U + noise\nX = df[[\'U\']].values\ny = df[\'Y\'].values\nlr = LinearRegression().fit(X, y)\nprint(f"\\nY = {lr.coef_[0]:.4f}*U + {lr.intercept_:.4f}")\nprint(f"R² = {lr.score(X,y):.4f}")\n\n# Model: M = beta0 + beta1*U + beta2*R + noise\n# Check residuals independence\nX = df[[\'U\', \'R\']].values\ny = df[\'M\'].values\nlr = LinearRegression().fit(X, y)\nres = y - X @ lr.coef_ - lr.intercept_\nprint(f"\\nM residuals mean={res.mean():.4f}, std={res.std():.4f}")\n\n# Check if D residuals (given U,Y) are independent of Y residuals (given U)\nX = df[[\'U\', \'Y\']].values\ny = df[\'D\'].values\nlr = LinearRegression().fit(X, y)\nres_D = y - X @ lr.coef_ - lr.intercept_\n\nX = df[[\'U\']].values\ny = df[\'Y\'].values\nlr = LinearRegression().fit(X, y)\nres_Y = y - X @ lr.coef_ - lr.intercept_\n\ncorr, _ = stats.pearsonr(res_D, res_Y)\nprint(f"Correlation(D_resid, Y_resid) = {corr:.4f}")\n\n# Check if M residuals (given U,R) are independent of R residuals (given U)\nX = df[[\'U\', \'R\']].values\ny = df[\'M\'].values\nlr = LinearRegression().fit(X, y)\nres_M = y - X @ lr.coef_ - lr.intercept_\n\nX = df[[\'U\']]