>> ShellSession({'command': 'cat > /app/merge.py << \'PYEOF\'\nimport json\nimport pandas as pd\nimport pyarrow as pa\nimport pyarrow.parquet as pq\n\n# --- Source A: JSON ---\nwith open(\'/data/source_a/users.json\') as f:\n    source_a_raw = json.load(f)\n\nsource_a = []\nfor row in source_a_raw:\n    source_a.append({\n        \'user_id\': int(row[\'id\']),\n        \'name\': row[\'full_name\'],\n        \'email\': row[\'email\'],\n        \'created_date\': row[\'registration_date\'],\n        \'status\': row.get(\'status\', \'\'),\n        \'_source\': \'a\'\n    })\ndf_a = pd.DataFrame(source_a)\n\n# --- Source B: CSV ---\ndf_b_raw = pd.read_csv(\'/data/source_b/users.csv\')\nsource_b = []\nfor _, row in df_b_raw.iterrows():\n    source_b.append({\n        \'user_id\': int(row[\'user_id\']),\n        \'name\': row[\'name\'],\n        \'email\': row[\'email_address\'],\n        \'created_date\': row[\'created_at\'],\n        \'status\': \'active\' if row.get(\'is_active\', False) else \'inactive\',\n        \'_source\': \'b\'\n    })\ndf_b = pd.DataFrame(source_b)\n\n# --- Source C: Parquet ---\ndf_c_raw = pq.read_table(\'/data/source_c/users.parquet\').to_pandas()\nsource_c = []\nfor _, row in df_c_raw.iterrows():\n    source_c.append({\n        \'user_id\': int(row[\'userId\']),\n        \'name\': row[\'userName\'],\n        \'email\': row[\'email\'],\n        \'created_date\': row[\'joined\'],\n        \'status\': \'active\' if row.get(\'active\', False) else \'inactive\',\n        \'_source\': \'c\'\n    })\ndf_c = pd.DataFrame(source_c)\n\n# --- Merge ---\nall_users = set(df_a[\'user_id\'].tolist() + df_b[\'user_id\'].tolist() + df_c[\'user_id\'].tolist())\nall_users = sorted(all_users)\n\nconflicts = []\nmerged_rows = []\n\nfor uid in all_users:\n    a_row = df_a[df_a[\'user_id\'] == uid]\n    b_row = df_b[df_b[\'user_id\'] == uid]\n    c_row = df_c[df_c[\'user_id\'] == uid]\n    \n    a_val = a_row.iloc[0].to_dict() if not a_row.empty else None\n    b_val = b_row.iloc[0].to_dict() if not b_row.empty else None\n    c_val = c_row.iloc[0].to_dict() if not c_row.empty else None\n    \n    # Determine values per field from each source\n    fields = [\'user_id\', \'name\', \'email\', \'created_date\', \'status\']\n    row_dict = {}\n    \n    for field in fields:\n        val_a = a_val[field] if a_val and field in a_val else None\n        val_b = b_val[field] if b_val and field in b_val else None\n        val_c = c_val[field] if c_val and field in c_val else None\n        \n        # Pick highest priority non-null value\n        if val_a is not None:\n            selected = val_a\n        elif val_b is not None:\n            selected = val_b\n        elif val_c is not None:\n            selected = val_c\n        else:\n            selected = None\n        \n        row_dict[field] = selected\n        \n        # Check for conflicts (different non-null values across sources)\n        non_null_values = {k: v for k, v in [(\'a\', val_a), (\'b\', val_b), (\'c\', val_c)] if v is not None}\n        if len(non_null_values) > 1:\n            unique_vals = set(str(v) for v in non_null_values.values())\n            if len(unique_vals) > 1:\n                conflict_entry = {\n                    \'user_id\': uid,\n                    \'field\': field,\n                    \'values\': {},\n                    \'selected\': selected\n                }\n                if val_a is not None:\n                    conflict_entry[\'values\'][\'source_a\'] = val_a\n                if val_b is not None:\n                    conflict_entry[\'values\'][\'source_b\'] = val_b\n                if val_c is not None:\n                    conflict_entry[\'values\'][\'source_c\'] = val_c\n                conflicts.append(conflict_entry)\n    \n    merged_rows.append(row_dict)\n\n# --- Write merged parquet ---\nmerged_df = pd.DataFrame(merged_rows)\nmerged_df[\'user_id\'] = merged_df[\'user_id\'].astype(int)\n\n# Ensure columns in correct order\nmerged_df = merged_df[[\'user_id\', \'name\', \'email\', \'created_date\', \'status\']]\n\ntable = pa.Table.from_pandas(merged_df)\npq.write_table(table, \'/app/merged_users.parquet\')\n\n# --- Write conflict report ---\nreport = {\n    \'total_conflicts\': len(conflicts),\n    \'conflicts\': conflicts\n}\n\nwith open(\'/app/conflicts.json\', \'w\') as f:\n    json.dump(report, f, indent=2)\n\nprint("=== Merged Data ===")\nprint(merged_df.to_string(index=False))\nprint(f"\\n=== Conflicts: {len(conflicts)} ===")\nfor c in conflicts:\n    print(c)\nprint("\\nDone!")\nPYEOF\npython3 /app/merge.py', 'timeout': 60})
