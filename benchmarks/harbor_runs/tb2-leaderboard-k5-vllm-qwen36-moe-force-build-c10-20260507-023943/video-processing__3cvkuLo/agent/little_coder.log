>> ShellSession({'command': 'cd /app && python3 -c "\nimport cv2\nimport numpy as np\n\ncap = cv2.VideoCapture(\'example_video.mp4\')\nframes = []\nfor i in range(120):\n    ret, frame = cap.read()\n    if ret:\n        frames.append(frame)\ncap.release()\n\ngray0 = cv2.cvtColor(frames[0], cv2.COLOR_BGR2GRAY)\n\n# Let\'s look at the full frame diff with a lower threshold\n# The runner is moving across the frame, so the diff from frame 0 will show\n# the runner\'s position at each frame\n# Let\'s look at the y-coordinate of the runner\'s feet (lowest point of the runner)\n\nfor i in range(120):\n    gray = cv2.cvtColor(frames[i], cv2.COLOR_BGR2GRAY)\n    diff = cv2.absdiff(gray, gray0)\n    _, thresh = cv2.threshold(diff, 25, 255, cv2.THRESH_BINARY)\n    \n    # Find contours\n    contours, _ = cv2.findContours(thresh, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    \n    # Find the largest contour (the runner)\n    largest_area = 0\n    largest_cnt = None\n    for cnt in contours:\n        area = cv2.contourArea(cnt)\n        if area > largest_area:\n            largest_area = area\n            largest_cnt = cnt\n    \n    if largest_cnt is not None and largest_area > 500:\n        x, y, w, h_rect = cv2.boundingRect(largest_cnt)\n        # The bottom of the bounding box is the lowest point of the runner\n        bottom = y + h_rect\n        # The center of the bounding box\n        cx = x + w // 2\n        cy = y + h_rect // 2\n        print(f\'Frame {i:3d}: area={int(largest_area):6d}, bbox=({x},{y},{w},{h_rect}), bottom={bottom}, center=({cx},{cy})\')\n    else:\n        print(f\'Frame {i:3d}: no runner detected\')\n"', 'timeout': 30})
