>> ShellSession({'command': '# Create document root and files\nmkdir -p /var/www/html\necho "Welcome to the benchmark webserver" > /var/www/html/index.html\necho "Page not found - Please check your URL" > /var/www/html/404.html\n\n# Remove default site\nrm -f /etc/nginx/sites-enabled/default\n\n# Create the site config\ncat > /etc/nginx/conf.d/benchmark-site.conf << \'EOF\'\nserver {\n    listen 8080;\n    server_name _;\n    root /var/www/html;\n    index index.html;\n\n    # Rate limiting\n    limit_req zone=one burst=10;\n\n    # Custom access log\n    access_log /var/log/nginx/benchmark-access.log benchmark_log;\n\n    # Error log\n    error_log /var/log/nginx/benchmark-error.log;\n\n    location / {\n        try_files $uri $uri/ =404;\n    }\n\n    error_page 404 /404.html;\n    location = /404.html {\n        internal;\n    }\n}\nEOF\n\n# Update nginx.conf to add custom log format and rate limit zone\ncat > /etc/nginx/nginx.conf << \'EOF\'\nuser www-data;\nworker_processes auto;\npid /run/nginx.pid;\ninclude /etc/nginx/modules-enabled/*.conf;\n\nevents {\n    worker_connections 768;\n}\n\nhttp {\n    sendfile on;\n    tcp_nopush on;\n    types_hash_max_size 2048;\n\n    include /etc/nginx/mime.types;\n    default_type application/octet-stream;\n\n    # Custom log format\n    log_format benchmark_log \'$time_local $request_method $status "$http_user_agent"\';\n\n    # Rate limiting zone\n    limit_req_zone $binary_remote_addr zone=one:10m rate=10r/s;\n\n    access_log /var/log/nginx/access.log;\n\n    include /etc/nginx/conf.d/*.conf;\n    include /etc/nginx/sites-enabled/*;\n}\nEOF\n\necho "Config files created"', 'timeout': 10})
