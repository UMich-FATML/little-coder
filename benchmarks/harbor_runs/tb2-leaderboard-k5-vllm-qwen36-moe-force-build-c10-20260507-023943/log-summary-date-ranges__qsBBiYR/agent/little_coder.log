>> ShellSession({'command': 'cat > /app/analyze.py << \'PYEOF\'\nimport os\nimport re\nimport csv\nfrom datetime import date, timedelta\n\ncurrent_date = date(2025, 8, 12)\nlog_dir = "/app/logs"\n\n# Date ranges\ntoday = current_date\nlast_7_start = current_date - timedelta(days=6)  # 7 days including today\nlast_30_start = current_date - timedelta(days=29)  # 30 days including today\nmonth_start = date(current_date.year, current_date.month, 1)\n\nseverities = ["ERROR", "WARNING", "INFO"]\n\n# Pattern to extract date from filename: YYYY-MM-DD_<source>.log\nfile_date_pattern = re.compile(r\'^(\\d{4}-\\d{2}-\\d{2})_\')\n\n# Pattern to extract severity from log line\nseverity_pattern = re.compile(r\'\\[(ERROR|WARNING|INFO)\\]\')\n\n# Initialize counters\ncounts = {\n    "today": {s: 0 for s in severities},\n    "last_7_days": {s: 0 for s in severities},\n    "last_30_days": {s: 0 for s in severities},\n    "month_to_date": {s: 0 for s in severities},\n    "total": {s: 0 for s in severities},\n}\n\nfor fname in os.listdir(log_dir):\n    m = file_date_pattern.match(fname)\n    if not m:\n        continue\n    file_date_str = m.group(1)\n    parts = file_date_str.split("-")\n    file_date = date(int(parts[0]), int(parts[1]), int(parts[2]))\n    \n    filepath = os.path.join(log_dir, fname)\n    with open(filepath, \'r\') as f:\n        for line in f:\n            sev_match = severity_pattern.search(line)\n            if not sev_match:\n                continue\n            sev = sev_match.group(1)\n            \n            # total\n            counts["total"][sev] += 1\n            \n            # today\n            if file_date == today:\n                counts["today"][sev] += 1\n            \n            # last 7 days\n            if last_7_start <= file_date <= today:\n                counts["last_7_days"][sev] += 1\n            \n            # last 30 days\n            if last_30_start <= file_date <= today:\n                counts["last_30_days"][sev] += 1\n            \n            # month to date\n            if month_start <= file_date <= today:\n                counts["month_to_date"][sev] += 1\n\n# Write CSV\nwith open("/app/summary.csv", "w", newline="") as f:\n    writer = csv.writer(f)\n    writer.writerow(["period", "severity", "count"])\n    for period in ["today", "last_7_days", "last_30_days", "month_to_date", "total"]:\n        for sev in severities:\n            writer.writerow([period, sev, counts[period][sev]])\n\nprint("Done. CSV written to /app/summary.csv")\nPYEOF\npython3 /app/analyze.py'})
