>> ShellSession({'command': 'python3 -c "\ncontent = \'\'\'#!/usr/bin/env python3\n\\"\\"\\"Decompress/revert a resharded directory back to its original flat structure.\\"\\"\\"\nimport sys\nimport os\nimport shutil\nimport json\n\n\ndef decompress(resharded_dir):\n    \\"\\"\\"Reconstruct the original file structure from a resharded directory.\\"\\"\\"\n    if not os.path.isdir(resharded_dir):\n        print(f\\"Error: {resharded_dir} is not a valid directory.\\")\n        sys.exit(1)\n\n    # Find all shard directories (directories containing .manifest.json)\n    entries = sorted(os.listdir(resharded_dir))\n    shard_dirs = []\n    for entry in entries:\n        entry_path = os.path.join(resharded_dir, entry)\n        if os.path.isdir(entry_path):\n            manifest_path = os.path.join(entry_path, \\".manifest.json\\")\n            if os.path.isfile(manifest_path):\n                shard_dirs.append(entry_path)\n\n    if not shard_dirs:\n        print(\\"No shard directories found.\\")\n        sys.exit(1)\n\n    print(f\\"Found {len(shard_dirs)} shard directories.\\")\n\n    # Collect all files and their original names\n    all_files = []\n    for shard_dir in shard_dirs:\n        manifest_path = os.path.join(shard_dir, \\".manifest.json\\")\n        with open(manifest_path, \\"r\\") as f:\n            manifest = json.load(f)\n\n        for filename in manifest:\n            src = os.path.join(shard_dir, filename)\n            if os.path.isfile(src):\n                all_files.append((filename, src))\n            else:\n                print(f\\"Warning: {src} not found, skipping.\\")\n\n    # Sort by original filename to reconstruct the original order\n    all_files.sort(key=lambda x: x[0])\n\n    # Determine output directory (parent of the resharded dir)\n    output_dir = os.path.dirname(os.path.abspath(resharded_dir))\n    if not output_dir:\n        output_dir = \\".\\"\n\n    # Create output directory if needed\n    os.makedirs(output_dir, exist_ok=True)\n\n    # Copy files back to the original flat structure\n    for filename, src in all_files:\n        dst = os.path.join(output_dir, filename)\n        shutil.copy2(src, dst)\n\n    print(f\\"Reconstructed {len(all_files)} files in {output_dir}\\")\n\n\nif __name__ == \\"__main__\\":\n    if len(sys.argv) != 2:\n        print(\\"Usage: python decompress.py <resharded_dir>\\")\n        sys.exit(1)\n\n    resharded_dir = sys.argv[1]\n    decompress(resharded_dir)\n\'\'\'\nwith open(\'/app/decompress.py\', \'w\') as f:\n    f.write(content)\nprint(\'decompress.py written\')\n"'})
