<< library(rstan)

# Load data
data <- read.csv("/app/data.csv")
N <- nrow(data)
y <- data$y
n <- data$n

# Stan model
stan_model <- stan_model(file = "/app/hierarchical_model.stan")

# Sampling
fit <- sampling(
  stan_model,
  data = list(N = N, y = y, n = n),
  chains = 4,
  iter = 100000,
  seed = 1,
  refresh = 1000
)

# Extract posterior means
alpha_mean <- mean(as.array(fit, pars = "alpha"))
