end(f.readlines())\n\n    print(f\\"Total lines read: {len(all_lines)}\\")\n\n    # Reconstruct original files from the line stream\n    # Each original file has a known line count from the manifest\n    line_offset = 0\n    for i, filename in enumerate(original_files):\n        num_lines = file_line_counts[i]\n        output_path = os.path.join(resharded_dir, filename)\n        with open(output_path, \\"w\\", encoding=\\"utf-8\\") as f:\n            f.writelines(all_lines[line_offset:line_offset + num_lines])\n        line_offset += num_lines\n\n    # Verify\n    if line_offset != len(all_lines):\n        print(f\\"Warning: line mismatch. Expected {len(all_lines)}, got {line_offset}\\")\n        sys.exit(1)\n\n    # Clean up chunk files and manifest\n    for chunk_path in chunk_files:\n        os.remove(chunk_path)\n    os.remove(manifest_path)\n\n    # Clean up empty subdirectories\n    for root, dirs, files in os.walk(resharded_dir, topdown=False):\n        for d in dirs:\n            dir_path = os.path.join(root, d)\n            if not os.listdir(dir_path):\n                os.rmdir(dir_path)\n\n    print(f\\"Restored {num_files} files to {resharded_dir}\\")\n    print(\\"Chunk files and manifest cleaned up.\\")\n\n\nif __name__ == \\"__main__\\":\n    if len(sys.argv) != 2:\n        print(f\\"Usage: python {sys.argv[0]} <resharded_dir>\\")\n        sys.exit(1)\n\n    resharded_dir = sys.argv[1]\n\n    if not os.path.isdir(resharded_dir):\n        print(f\\"Error: {resharded_dir} is not a directory\\")\n        sys.exit(1)\n\n    decompress(resharded_dir)\n\'\'\'\nwith open(\'/app/decompress.py\', \'w\') as f:\n    f.write(code)\nprint(\'decompress.py written\')\n"'})
