>> ShellSession({'command': 'cat > /app/check_cert.py << \'PYEOF\'\nimport subprocess\nimport sys\nfrom datetime import datetime\n\ndef main():\n    cert_path = "/app/ssl/server.crt"\n\n    # Verify the certificate exists and can be loaded\n    try:\n        result = subprocess.run(\n            ["openssl", "x509", "-in", cert_path, "-noout", "-text"],\n            capture_output=True, text=True\n        )\n        if result.returncode != 0:\n            print("Error: Could not load certificate")\n            sys.exit(1)\n    except Exception as e:\n        print(f"Error: {e}")\n        sys.exit(1)\n\n    # Get the subject and extract Common Name\n    result = subprocess.run(\n        ["openssl", "x509", "-in", cert_path, "-noout", "-subject"],\n        capture_output=True, text=True\n    )\n    subject = result.stdout.strip()\n    print(f"Subject: {subject}")\n\n    # Extract Common Name\n    cn = ""\n    for part in subject.split(","):\n        part = part.strip()\n        if part.startswith("CN"):\n            cn = part.split("=", 1)[1].strip()\n    print(f"Common Name: {cn}")\n\n    # Get validity dates\n    result = subprocess.run(\n        ["openssl", "x509", "-in", cert_path, "-noout", "-startdate", "-enddate"],\n        capture_output=True, text=True\n    )\n    dates = result.stdout.strip()\n    print(f"Validity:\\n{dates}")\n\n    # Parse and print expiration date in YYYY-MM-DD format\n    for line in dates.split("\\n"):\n        if line.startswith("notAfter="):\n            date_str = line.split("=", 1)[1].strip()\n            # Parse OpenSSL date format like "May  7 15:35:04 2027 GMT"\n            exp_date = datetime.strptime(date_str, "%b %d %H:%M:%S %Y %Z")\n            print(f"Expiration Date: {exp_date.strftime(\'%Y-%m-%d\')}")\n\n    print("Certificate verification successful")\n\nif __name__ == "__main__":\n    main()\nPYEOF'})
