>> ShellSession({'command': 'cd /app && python3 -c "\nimport numpy as np\n\nN = 150000\n\n# The problem is clear: with 2-3 level distributions, backward KL is always much smaller.\n# We need a fundamentally different approach.\n#\n# Let me think about this more carefully.\n# \n# Forward KL = log(N) - H(P) = 10 => H(P) = log(N) - 10 ≈ 1.918\n# Backward KL = -log(N) - mean(log(P)) = 10 => mean(log(P)) = -log(N) - 10 ≈ -21.918\n#\n# So we need a distribution with entropy ~1.918 and mean log-prob ~ -21.918.\n#\n# With a 2-level distribution (k tokens at p, rest at q):\n# H(P) = -k*p*log(p) - (N-k)*q*log(q)\n# mean(log(P)) = (k/N)*log(p) + ((N-k)/N)*log(q)\n#\n# The issue is that when q is very small (to make mean(log(P)) very negative),\n# the entropy contribution from q is small (since q*log(q) → 0 as q→0).\n# So H(P) ≈ -k*p*log(p), which is limited.\n#\n# Let\'s try: many tokens with moderate probability, few with very high probability.\n# \n# Or: use a power-law / Zipf-like distribution.\n\n# Let\'s try: P(i) = C / (i+1)^alpha for i=0..N-1\n# This gives a smooth distribution.\n\ndef compute_kls_powerlaw(alpha, N=N):\n    i = np.arange(N)\n    probs = 1.0 / (i + 1)**alpha\n    probs = probs / probs.sum()\n    \n    U = 1.0 / N\n    fwd = np.sum(probs * np.log(probs / U))\n    bwd = np.sum((1.0/N) * np.log(U / probs))\n    \n    return fwd, bwd\n\n# Search for alpha\nfor alpha in [0.1, 0.5, 1.0, 1.5, 2.0, 2.5, 3.0]:\n    fwd, bwd = compute_kls_powerlaw(alpha)\n    print(f\'alpha={alpha}: fwd={fwd:.4f}, bwd={bwd:.4f}\')\n"\n'})
