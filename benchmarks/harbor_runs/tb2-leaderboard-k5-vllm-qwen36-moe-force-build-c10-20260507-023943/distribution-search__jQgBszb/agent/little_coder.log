mbinations\nbest = 1e10\nbest_params = None\nfor k1 in [1, 2, 3, 5, 10]:\n    for k2 in [1, 2, 3, 5, 10, 50, 100, 500, 1000, 5000, 10000]:\n        if k1 + k2 >= N:\n            continue\n        res = minimize(objective_3level, [k1, np.log(0.1/k1), k2, np.log(0.01/k2)], \n                       method=\'Nelder-Mead\', options={\'xatol\': 1e-10, \'fatol\': 1e-12, \'maxiter\': 10000})\n        if res.fun < best:\n            best = res.fun\n            best_params = res.x\n            k1r, p1r, k2r, p2r = int(round(res.x[0])), np.exp(res.x[1]), int(round(res.x[2])), np.exp(res.x[3])\n            p3r = (1 - k1r*p1r - k2r*p2r) / (N - k1r - k2r)\n            fwd = k1r*p1r*np.log(p1r*N) + k2r*p2r*np.log(p2r*N) + (N-k1r-k2r)*p3r*np.log(p3r*N)\n            bwd = (k1r/N)*np.log(1/(k1r*p1r)) + (k2r/N)*np.log(1/(k2r*p2r)) + ((N-k1r-k2r)/N)*np.log(1/((N-k1r-k2r)*p3r))\n            if best < 0.01:\n                print(f\'k1={k1r}, p1={p1r:.6f}, k2={k2r}, p2={p2r:.6f}, p3={p3r:.10f}\')\n                print(f\'  fwd={fwd:.6f}, bwd={bwd:.6f}, obj={best:.10f}\')\n"\n'})
