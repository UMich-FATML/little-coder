>> ShellSession({'command': 'cat > /app/parallel_linear.py << \'PYEOF\'\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport torch.distributed as dist\n\n\nclass ColumnParallelLinear(nn.Module):\n    """\n    Splits the weight matrix by columns across ranks.\n    Each rank holds a shard of the output features.\n    - weight: (out_features, in_features) -> each rank gets (out_features/world_size, in_features)\n    - bias: sharded same way as output dimension\n    - forward: compute local matmul, then all_gather and concatenate along last dim\n    """\n\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.bias = bias\n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n\n        # Split master_weight by columns (output dimension = rows of weight matrix)\n        # master_weight shape: (out_features, in_features)\n        # Each rank gets out_features // world_size rows\n        chunk_size = out_features // self.world_size\n        start = self.rank * chunk_size\n        end = start + chunk_size\n        self.weight = master_weight[start:end].clone()\n\n        if bias:\n            self.bias = nn.Parameter(torch.zeros(chunk_size))\n        else:\n            self.register_parameter("bias", None)\n\n    def forward(self, x):\n        # x: (*, in_features)\n        output = F.linear(x, self.weight, self.bias)\n        # output: (*, out_features // world_size)\n\n        if self.world_size > 1:\n            # All-gather outputs from all ranks and concatenate along last dim\n            gathered = [torch.empty_like(output) for _ in range(self.world_size)]\n            dist.all_gather(gathered, output)\n            output = torch.cat(gathered, dim=-1)\n\n        return output\n\n\nclass RowParallelLinear(nn.Module):\n    """\n    Splits the weight matrix by rows across ranks.\n    Each rank holds a shard of the input features.\n    - weight: (out_features, in_features) -> each rank gets (out_features, in_features/world_size)\n    - bias: full on each rank (out_features,)\n    - forward: compute local matmul, then all_reduce (sum) the partial outputs\n    """\n\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.bias = bias\n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n\n        # Split master_weight by rows (input dimension = cols of weight matrix)\n        # master_weight shape: (out_features, in_features)\n        # Each rank gets in_features // world_size columns\n        chunk_size = in_features // self.world_size\n        start = self.rank * chunk_size\n        end = start + chunk_size\n        self.weight = master_weight[:, start:end].clone()\n\n        if bias:\n            self.bias = nn.Parameter(torch.zeros(out_features))\n        else:\n            self.register_parameter("bias", None)\n\n    def forward(self, x):\n        # x: (*, in_features)\n        output = F.linear(x, self.weight, self.bias)\n        # output: (*, out_features)\n\n        if self.world_size > 1:\n            # All-reduce: sum partial outputs across ranks\n            dist.all_reduce(output, op=dist.ReduceOp.SUM)\n\n        return output\nPYEOF'})
