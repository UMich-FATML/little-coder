>> ShellSession({'command': 'python3 -c "\nimport numpy as np\nimport time\n\ndef power_iteration(A, max_iter=1000, tol=1e-12):\n    n = A.shape[0]\n    np.random.seed(42)\n    b = np.random.rand(n)\n    b = b / np.linalg.norm(b)\n    \n    eigenvalue = 0.0\n    for _ in range(max_iter):\n        Ab = A @ b\n        eigenvalue_new = np.dot(b, Ab)\n        b_new = Ab / np.linalg.norm(Ab)\n        if abs(eigenvalue_new - eigenvalue) < tol:\n            b = b_new\n            return eigenvalue_new, b_new\n        eigenvalue = eigenvalue_new\n        b = b_new\n    return eigenvalue, b\n\n# Test correctness\nfor size in [2, 4, 6, 8, 10]:\n    A = np.random.normal(size=(size, size)).astype(np.float64)\n    # Reference\n    w, v = np.linalg.eig(A)\n    idx = np.argmax(np.abs(w))\n    ref_w, ref_v = w[idx], v[:, idx]\n    \n    # Power iteration\n    pw, pv = power_iteration(A)\n    \n    # Check if they match (accounting for sign/phase)\n    print(f\'{size}x{size}: ref_w={ref_w:.6f}, pow_w={pw:.6f}, match={np.allclose(A @ pv, pw * pv)}\')\n"', 'timeout': 30})
