 (argc != 3) {\n        fprintf(stderr, "Usage: %s weights.json image.png\\n", argv[0]);\n        return 1;\n    }\n\n    const char* weights_file = argv[1];\n    const char* image_file = argv[2];\n\n    // Load weights JSON\n    FILE* f = fopen(weights_file, "r");\n    if (!f) {\n        fprintf(stderr, "Cannot open weights file: %s\\n", weights_file);\n        return 1;\n    }\n    fseek(f, 0, SEEK_END);\n    long fsize = ftell(f);\n    fseek(f, 0, SEEK_SET);\n    char* json_buf = (char*)malloc(fsize + 1);\n    fread(json_buf, 1, fsize, f);\n    fclose(f);\n    json_buf[fsize] = \'\\0\';\n\n    cJSON* root = cJSON_Parse(json_buf);\n    free(json_buf);\n    if (!root) {\n        fprintf(stderr, "Failed to parse JSON\\n");\n        return 1;\n    }\n\n    // Read architecture\n    cJSON* arch = cJSON_GetObjectItem(root, "architecture");\n    int input_dim = (int)cJSON_GetObjectItem(arch, "input_dim")->valuedouble;\n    int hidden_dim = (int)cJSON_GetObjectItem(arch, "hidden_dim")->valuedouble;\n    int num_classes = (int)cJSON_GetObjectItem(arch, "num_classes")->valuedouble;\n\n    // Read weights\n    cJSON* weights_obj = cJSON_GetObjectItem(root, "weights");\n\n    // input_layer.weight: [hidden_dim, input_dim]\n    cJSON* iw = cJSON_GetObjectItem(weights_obj, "input_layer.weight");\n    int iw_len;\n    float* input_weight = read_float_array(iw, &iw_len);\n    // input_layer.bias: [hidden_dim]\n    cJSON* ib = cJSON_GetObjectItem(weights_obj, "input_layer.bias");\n    int ib_len;\n    float* input_bias = read_float_array(ib, &ib_len);\n\n    // hidden_layer.weight: [hidden_dim, hidden_dim]\n    cJSON* hw = cJSON_GetObjectItem(weights_obj, "hidden_layer.weight");\n    int hw_len;\n    float* hidden_weight = read_float_array(hw, &hw_len);\n    // hidden_layer.bias: [hidden_dim]\n    cJSON* hb = cJSON_GetObjectItem(weights_obj, "hidden_layer.bias");\n    int hb_len;\n    float* hidden_bias = read_float_array(hb, &hb_len);\n\n    // output_layer.weight: [num_classes, hidden_dim]\n    cJSON* ow = cJSON_GetObjectItem(weights_obj, "output_layer.weight");\n    int ow_len;\n    float* output_weight = read_float_array(ow, &ow_len);\n    // output_layer.bias: [num_classes]\n    cJSON* ob = cJSON_GetObjectItem(weights_obj, "output_layer.bias");\n    int ob_len;\n    float* output_bias = read_float_array(ob, &ob_len);\n\n    cJSON_Delete(root);\n\n    // Load image using lodepng\n    unsigned char* image_data = NULL;\n    unsigned img_w, img_h;\n    unsigned err = lodepng_decode32_file(&image_data, &img_w, &img_h, image_file);\n    if (err) {\n        fprintf(stderr, "Error loading image: %s\\n", lodepng_error_text(err));\n        return 1;\n    }\n\n    // Convert to grayscale and normalize to [0, 1]\n    // Image is 28x28, 32-bit (RGBA)\n    float* input = (float*)malloc(input_dim * sizeof(float));\n    for (int i = 0; i < 28; i++) {\n        for (int j = 0; j < 28; j++) {\n            int idx = i * 28 + j;\n            int px = (i * 28 + j) * 4;\n            // Convert RGBA to grayscale\n            float pixel = (0.299f * image_data[px] + 0.587f * image_data[px+1] + 0.114f * image_data[px+2]) / 255.0f;\n            // Invert: background is white (255), digit is black (0)\n            // The model expects dark digits on light background, so we want dark = high value\n            // Actually, let\'s just use the grayscale directly\n            input[idx] = 1.0f - pixel; // invert so dark digits become high values\n        }\n    }\n    free(image_data);\n\n    // Forward pass\n    float* h1 = (float*)malloc(hidden_dim * sizeof(float));\n    float* h2 = (float*)malloc(hidden_dim * sizeof(float));\n    float* output = (float*)malloc(num_classes * sizeof(float));\n\n    // Layer 1: input -> hidden\n    linear_forward(input, input_dim, input_weight, hidden_dim, input_dim, input_bias, h1);\n    relu(h1, hidden_dim);\n\n    // Layer 2: hidden -> hidden\n    linear_forward(h1, hidden_dim, hidden_weight, hidden_dim, hidden_dim, hidden_bias, h2);\n    relu(h2, hidden_dim);\n\n    // Layer 3: hidden -> output\n    linear_forward(h2, hidden_dim, output_weight, num_classes, hidden_dim, output_bias, output);\n\n    // Find argmax\n    int pred = 0;\n    float max_val = output[0];\n    for (int i = 1; i < num_classes; i++) {\n        if (output[i] > max_val) {\n            max_val = output[i];\n            pred = i;\n        }\n    }\n\n    // Write prediction\n    FILE* pf = fopen("/app/prediction.txt", "w");\n    fprintf(pf, "%d", pred);\n    fclose(pf);\n\n    printf("%d\\n", pred);\n\n    // Cleanup\n    free(input);\n    free(h1);\n    free(h2);\n    free(output);\n    free(input_weight);\n    free(input_bias);\n    free(hidden_weight);\n    free(hidden_bias);\n    free(output_weight);\n    free(output_bias);\n\n    return 0;\n}\nCPPEOF\necho "cli_tool.cpp written"', 'timeout': 15})
