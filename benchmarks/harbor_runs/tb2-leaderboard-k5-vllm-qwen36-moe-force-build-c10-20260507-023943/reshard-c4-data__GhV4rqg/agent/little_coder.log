>> ShellSession({'command': 'cat > /app/compress.py << \'PYEOF\'\n#!/usr/bin/env python3\n"""\nReshard a directory of files into a tree structure with at most 30 files/folders\nper directory and at most 15MB per file.\n\nUsage: python compress.py <input_dir> <output_dir>\n"""\nimport sys\nimport os\nimport shutil\nimport hashlib\n\n\ndef get_sorted_files(input_dir):\n    """Get all files in the input directory, sorted by name."""\n    files = []\n    for f in sorted(os.listdir(input_dir)):\n        full_path = os.path.join(input_dir, f)\n        if os.path.isfile(full_path):\n            files.append(full_path)\n    return files\n\n\ndef split_file_if_needed(filepath, max_size):\n    """\n    If a file exceeds max_size, split it into chunks.\n    Returns a list of (chunk_name, chunk_path) tuples.\n    """\n    file_size = os.path.getsize(filepath)\n    if file_size <= max_size:\n        return [(os.path.basename(filepath), filepath)]\n\n    base_name = os.path.basename(filepath)\n    name, ext = os.path.splitext(base_name)\n    chunks = []\n    chunk_index = 0\n    offset = 0\n\n    with open(filepath, \'rb\') as f:\n        while offset < file_size:\n            chunk_name = f"{name}.part{chunk_index:04d}{ext}"\n            chunk_path = filepath + f".tmp.{chunk_index}"\n            with open(chunk_path, \'wb\') as chunk_f:\n                remaining = file_size - offset\n                to_read = min(max_size, remaining)\n                # Read in chunks to avoid loading entire file into memory\n                bytes_written = 0\n                while bytes_written < to_read:\n                    read_size = min(1024 * 1024, to_read - bytes_written)\n                    data = f.read(read_size)\n                    if not data:\n                        break\n                    chunk_f.write(data)\n                    bytes_written += len(data)\n            chunks.append((chunk_name, chunk_path))\n            offset += to_read\n            chunk_index += 1\n\n    return chunks\n\n\ndef compress(input_dir, output_dir):\n    max_files_per_dir = 30\n    max_file_size = 15 * 1024 * 1024  # 15MB\n\n    os.makedirs(output_dir, exist_ok=True)\n\n    files = get_sorted_files(input_dir)\n    total_files = len(files)\n    print(f"Found {total_files} files in {input_dir}")\n\n    # Phase 1: Split any files that exceed max_file_size\n    # We\'ll process files and track how many "items" we have\n    items = []  # list of (original_name, temp_path_or_none, size)\n    for filepath in files:\n        basename = os.path.basename(filepath)\n        file_size = os.path.getsize(filepath)\n        if file_size > max_file_size:\n            chunks = split_file_if_needed(filepath, max_file_size)\n            for chunk_name, chunk_path in chunks:\n                items.append((chunk_name, chunk_path, os.path.getsize(chunk_path)))\n        else:\n            items.append((basename, None, file_size))\n\n    print(f"After splitting: {len(items)} items total")\n\n    # Phase 2: Create directory structure\n    # Each directory can hold at most max_files_per_dir files\n    # We create a flat structure of subdirectories\n    dir_index = 0\n    file_index_in_dir = 0\n    current_dir = None\n\n    for item_name, temp_path, item_size in items:\n        if file_index_in_dir >= max_files_per_dir:\n            dir_index += 1\n            file_index_in_dir = 0\n            current_dir = os.path.join(output_dir, f"shard_{dir_index:04d}")\n            os.makedirs(current_dir, exist_ok=True)\n\n        dest_path = os.path.join(current_dir, item_name)\n\n        if temp_path is not None:\n            # Move the temp chunk to destination\n            shutil.move(temp_path, dest_path)\n        else:\n            # Copy the original file\n            src = os.path.join(input_dir, item_name)\n            shutil.copy2(src, dest_path)\n\n        file_index_in_dir += 1\n\n    # Count final structure\n    total_dirs = 0\n    total_files = 0\n    for root, dirs, files_list in os.walk(output_dir):\n        total_dirs += 1\n        total_files += len(files_list)\n\n    print(f"Resharded into {total_dirs - 1} directories with {total_files} files")\n    print(f"Output: {output_dir}")\n\n\nif __name__ == "__main__":\n    if len(sys.argv) != 3:\n        print("Usage: python compress.py <input_dir> <output_dir>")\n        sys.exit(1)\n\n    input_dir = sys.argv[1]\n    output_dir = sys.argv[2]\n\n    if not os.path.isdir(input_dir):\n        print(f"Error: {input_dir} is not a directory")\n        sys.exit(1)\n\n    compress(input_dir, output_dir)\nPYEOF'})
