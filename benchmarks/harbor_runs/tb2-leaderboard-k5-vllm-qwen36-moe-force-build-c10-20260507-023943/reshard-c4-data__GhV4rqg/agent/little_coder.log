dest_path = os.path.join(output_dir, original_name)\n        with open(dest_path, \\"wb\\") as out_f:\n            for basename, full_path in parts:\n                with open(full_path, \\"rb\\") as in_f:\n                    shutil.copyfileobj(in_f, out_f)\n                os.remove(full_path)\n        print(f\\"Reconstructed: {original_name}\\")\n\n    # Remove empty shard directories\n    for root, dirs, files in os.walk(resharded_dir, topdown=False):\n        for d in dirs:\n            dir_path = os.path.join(root, d)\n            if not os.listdir(dir_path):\n                os.rmdir(dir_path)\n                print(f\\"Removed empty dir: {dir_path}\\")\n\n    # Remove the resharded directory itself\n    os.rmdir(resharded_dir)\n    print(f\\"Removed resharded directory: {resharded_dir}\\")\n    print(f\\"Output: {output_dir}\\")\n\n\nif __name__ == \\"__main__\\":\n    if len(sys.argv) != 2:\n        print(\\"Usage: python decompress.py <resharded_dir>\\")\n        sys.exit(1)\n    resharded_dir = sys.argv[1]\n    if not os.path.isdir(resharded_dir):\n        print(f\\"Error: {resharded_dir} is not a directory\\")\n        sys.exit(1)\n    decompress(resharded_dir)\n\'\'\'\nwith open(\'/app/decompress.py\', \'w\') as f:\n    f.write(content)\nprint(\'decompress.py written\')\n"'})
