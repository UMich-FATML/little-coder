<< data {
  int<lower=0> N;
  int<lower=0> y[N];
  int<lower=0> n[N];
}
parameters {
  real<lower=0> alpha;
  real<lower=0> beta;
  real<lower=0,upper=1> theta[N];
}
model {
  // Prior: (alpha + beta)^(-5/2)
  target += -2.5 * log(alpha + beta);
  
  // Likelihood
  for (i in 1:N) {
    y[i] ~ binomial(n[i], theta[i]);
    theta[i] ~ beta(alpha, beta);
  }
}
