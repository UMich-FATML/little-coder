                vl = variables[l]\n                        corr3, p3 = partial_corr(df, vi, vj, [vk, vl])\n                        print(f"    {vi} -- {vj} | {vk},{vl}: corr={corr3:.4f}, p={p3:.6f}")\nEOF\npython3 /app/learn_dag.py 2>&1 | grep -v "FutureWarning" | grep -v "pearsonr" | grep -v "deprecated"', 'timeout': 60})
