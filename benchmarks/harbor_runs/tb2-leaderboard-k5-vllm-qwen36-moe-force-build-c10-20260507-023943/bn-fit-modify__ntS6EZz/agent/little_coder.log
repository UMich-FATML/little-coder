eck if maybe there\'s a different structure.\n# What if the DAG is:\n# U -> Y, U -> R, U -> D, U -> M, Y -> D, M -> R\n# That\'s 6 edges.\n\n# In this DAG:\n# - Y has parent U\n# - R has parent U\n# - D has parents U, Y\n# - M has parents U, R\n\n# Check Y -- M | U:\n# Path Y -> D <- U -> M: blocked by U (collider at D, but U is conditioned)\n# Actually, Y -> D <- U is a collider, and U is conditioned, so this path is OPEN.\n# Y -> D <- U -> M: Y -> D, D <- U, U -> M\n# This path is: Y -> D <- U -> M. D is a collider, U is conditioned.\n# When a collider is conditioned on, the path opens. But U is also conditioned on.\n# Actually, the path is Y -> D <- U -> M. D is a collider.\n# For a collider, the path is blocked unless we condition on D or its descendants.\n# We\'re not conditioning on D, so this path is BLOCKED.\n# Path Y <- U -> M: blocked by U.\n# So Y -- M | U should be independent. ✓\n\n# But wait, we got p=0.017. Let me check more carefully.\n# Actually, maybe the p=0.017 is just a statistical fluctuation.\n# With 10k samples, even small correlations can be significant.\n# The partial correlation is only -0.024, which is very small.\n\n# Let me check the BIC for different DAGs\nfrom sklearn.linear_model import LinearRegression\n\n# DAG 1: U->Y, U->R, U->D, U->M, D->Y, M->R\n# DAG 2: U->Y, U->R, U->D, U->M, D->Y, R->M\n\n# For DAG 1:\n# Y ~ U + M\n# R ~ U + M\n# D ~ U\n# M ~ U\n\n# For DAG 2:\n# Y ~ U + D\n# R ~ U\n# D ~ U\n# M ~ U + R\n\nfrom sklearn.linear_model import LinearRegression\n\ndef compute_bic(data, parent_map):\n    """Compute BIC score for a DAG."""\n    n = len(data)\n    k = 0  # number of parameters\n    log_likelihood = 0\n    for node in data.columns:\n        parents = parent_map.get(node, [])\n        if parents:\n            X = data[parents].values\n        else:\n            X = np.ones((n, 1))\n        y = data[node].values\n        model = LinearRegression().fit(X, y)\n        residuals = y - model.predict(X)\n        sigma2 = np.s