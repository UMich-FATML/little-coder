 58-72\n\n# Reverse primer design:\n# 5\' end: part of the reverse complement of the insertion sequence  \n# 3\' end: anneals to the input template ending at position 215 (complementary)\n# The annealing part should be 15-45 nt, TM 58-72\n\n# Strategy: split the insertion between forward and reverse primers\n# Forward primer: [insertion part][annealing to input starting at pos 215]\n# Reverse primer: [insertion part (RC)][annealing to input ending at pos 215]\n\n# Let\'s try different split points and annealing lengths\nbest_pairs = []\n\nfor fwd_anneal_len in range(15, 46):  # annealing part length\n    for rev_anneal_len in range(15, 46):\n        # Forward primer annealing region: input[215:215+fwd_anneal_len]\n        fwd_anneal = input_seq[215:215+fwd_anneal_len]\n        \n        # Reverse primer annealing region: input[215-rev_anneal_len:215]\n        rev_anneal = input_seq[215-rev_anneal_len:215]\n        rev_anneal_rc = reverse_complement(rev_anneal)\n        \n        # Calculate TM for annealing parts\n        fwd_anneal_tm = get_tm(fwd_anneal)\n        rev_anneal_tm = get_tm(rev_anneal_rc)\n        \n        if not (58 <= fwd_anneal_tm <= 72):\n            continue\n        if not (58 <= rev_anneal_tm <= 72):\n            continue\n        if abs(fwd_anneal_tm - rev_anneal_tm) > 5:\n            continue\n        \n        # Now distribute the 39bp insertion between fwd and rev primers\n        # Forward gets first X bp of insertion, reverse gets last (39-X) bp (as RC)\n        for ins_fwd_len in range(0, insertion_len + 1):\n            ins_rev_len = insertion_len - ins_fwd_len\n            \n            # Forward primer\n            fwd_ins = insertion_seq[:ins_fwd_len]\n            fwd_primer = fwd_ins + fwd_anneal\n            \n            # Reverse primer\n            rev_ins = reverse_complement(insertion_seq[ins_rev_len:])\n            rev_primer = rev_ins + rev_anneal_rc\n            \n            # Check total primer lengths (should be reasonable, typically 30-60)\n            if len(fwd_primer) < 30 or len(fwd_primer) > 80:\n                continue\n            if len(rev_primer) < 30 or len(rev_primer) > 80:\n                continue\n            \n            # Calculate total TM (annealing part only, per rules)\n            # Actually the rule says TM should be computed with respect to only the annealing part\n            # So we already checked that. But let\'s verify the full primer TMs too for sanity.\n            fwd_total_tm = get_tm(fwd_primer)\n            rev_total_tm = get_tm(rev_primer)\n            \n            best_pairs.append((\n                abs(fwd_anneal_tm - rev_anneal_tm),\n                fwd_anneal_tm + rev_anneal_tm,\n                len(fwd_primer) + len(rev_primer),\n                fwd_primer, rev_primer,\n                fwd_anneal_tm, rev_anneal_tm,\n                ins_fwd_len, ins_rev_len,\n                fwd_anneal, rev_anneal\n            ))\n\n# Sort by: minimum TM difference, then minimum total length\nbest_pairs.sort(key=lambda x: (x[0], x[2]))\n\nprint(f"\\nFound {len(best_pairs)} valid primer pairs")\nif best_pairs:\n    best = best_pairs[0]\n    print(f"\\nBest pair:")\n    print(f"Forward: {best[3]}")\n    print(f"  Annealing part: {best[8]} (TM={best[4]:.1f})")\n    print(f"  Insertion part: {best[3][:best[6]]} (len={best[6]})")\n    print(f"Reverse: {best[4]}")\n    print(f"  Annealing part: {best[9]} (TM={best[5]:.1f})")\n    print(f"  Insertion part: {best[4][:best[7]]} (len={best[7]})")\n    print(f"TM difference: {best[0]:.1f}")\n    print(f"Total length: {best[2]}")\nPYEOF', 'timeout': 120})
