<< library(rstan)
rstan_options(auto_write = TRUE)
options(mc.cores = parallel::detectCores())

# Load data
data <- read.csv("/app/data.csv")
N <- nrow(data)
y <- data$y
n <- data$n

# Stan data list
stan_data <- list(N = N, y = y, n = n)

# Compile and sample
fit <- sampling(
  object = hierarchical_model,
  data = stan_data,
  chains = 4,
  iter = 100000,
  seed = 1
)

# Extract posterior means
alp
