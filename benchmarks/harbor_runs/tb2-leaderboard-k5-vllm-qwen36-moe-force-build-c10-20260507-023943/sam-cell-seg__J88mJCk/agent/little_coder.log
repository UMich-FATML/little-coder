>> ShellSession({'command': 'cat > /app/convert_masks.py << \'PYEOF\'\nimport argparse\nimport os\nimport numpy as np\nimport pandas as pd\nimport cv2\nfrom PIL import Image\nimport torch\nfrom mobile_sam import build_sam_vit_t\nfrom mobile_sam.predictor import SamPredictor\n\n\ndef get_mask_contour(mask):\n    """Extract the outer contour from a binary mask."""\n    contours, _ = cv2.findContours(mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    if not contours:\n        return None\n    # Get the largest contour\n    largest = max(contours, key=cv2.contourArea)\n    return largest\n\n\ndef simplify_contour(contour, epsilon_factor=0.005):\n    """Simplify a contour using Ramer-Douglas-Peucker, keeping it as a polyline."""\n    if contour is None:\n        return None\n    contour = contour.reshape(-1, 2)\n    perimeter = cv2.arcLength(contour, True)\n    epsilon = epsilon_factor * perimeter\n    simplified = cv2.approxPolyDP(contour, epsilon, True)\n    return simplified\n\n\ndef extract_polyline_coords(contour):\n    """Extract x and y coordinate lists from a contour."""\n    if contour is None:\n        return [], []\n    pts = contour.reshape(-1, 2)\n    coords_x = pts[:, 0].tolist()\n    coords_y = pts[:, 1].tolist()\n    return coords_x, coords_y\n\n\ndef mask_to_bbox(mask):\n    """Get bounding box from a binary mask."""\n    coords = np.column_stack(np.where(mask > 0))\n    if len(coords) == 0:\n        return 0, 0, 0, 0\n    y_min, x_min = coords.min(axis=0)\n    y_max, x_max = coords.max(axis=0)\n    return int(x_min), int(y_min), int(x_max), int(y_max)\n\n\ndef get_largest_contour_from_mask(mask):\n    """Get the largest contour from a binary mask, ensuring single contiguous region."""\n    # Morphological operations to clean noise\n    kernel = np.ones((3, 3), np.uint8)\n    mask = cv2.morphologyEx(mask.astype(np.uint8), cv2.MORPH_CLOSE, kernel, iterations=2)\n    mask = cv2.morphologyEx(mask, cv2.MORPH_OPEN, kernel, iterations=1)\n    \n    # Get the largest connected component\n    num_labels, labels, stats, centroids = cv2.connectedComponentsWithStats(mask, connectivity=8)\n    if num_labels > 1:\n        # Find the largest component (excluding background)\n        largest_label = 1 + np.argmax(stats[1:, cv2.CC_STAT_AREA])\n        mask = (labels == largest_label).astype(np.uint8)\n    \n    # Extract contour\n    contours, _ = cv2.findContours(mask, cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE)\n    if not contours:\n        return None, mask\n    largest = max(contours, key=cv2.contourArea)\n    return largest, mask\n\n\ndef remove_overlaps_from_mask(mask, occupied):\n    """Remove pixels from mask that overlap with already-occupied regions."""\n    mask = mask.copy()\n    overlap = (mask > 0) & (occupied > 0)\n    if overlap.any():\n        mask[overlap] = 0\n    return mask\n\n\ndef main():\n    parser = argparse.ArgumentParser(description="Convert masks to polylines using MobileSAM")\n    parser.add_argument("--weights_path", type=str, required=True, help="Path to MobileSAM weights")\n    parser.add_argument("--output_path", type=str, required=True, help="Path to output CSV")\n    parser.add_argument("--rgb_path", type=str, required=True, help="Path to RGB image")\n    parser.add_argument("--csv_path", type=str, required=True, help="Path to input metadata CSV")\n    args = parser.parse_args()\n\n    # Load image\n    image = np.array(Image.open(args.rgb_path).convert("RGB"))\n    original_h, original_w = image.shape[:2]\n\n    # Load MobileSAM model\n    print("Loading MobileSAM model...")\n    model = build_sam_vit_t(checkpoint=args.weights_path)\n    model = model.to("cpu")\n    model.eval()\n    predictor = SamPredictor(model)\n    predictor.set_image(image, image_format="RGB")\n    print("Model loaded.")\n\n    # Load metadata\n    df = pd.read_csv(args.csv_path)\n    print(f"Processing {len(df)} masks...")\n\n    # Track occupied pixels to avoid overlaps\n    occupied = np.zeros((original_h, original_w), dtype=np.uint8)\n\n    # Process each mask\n    results = []\n    for idx, row in df.iterrows():\n        xmin = int(row["xmin"])\n        ymin = int(row["ymin"])\n        xmax = int(row["xmax"])\n        ymax = int(row["ymax"])\n\n        # Create a box prompt for MobileSAM\n        box = np.array([xmin, ymin, xmax, ymax])\n\n        # Get mask from MobileSAM\n        masks, iou_preds, low_res_masks = predictor.predict(\n            box=box,\n            multimask_output=True,\n        )\n\n        # Select the best mask based on IoU prediction\n        best_idx = np.argmax(iou_preds)\n        best_mask = masks[best_idx]\n\n        # Get the largest contour and mask\n        contour, best_mask = get_largest_contour_from_mask(best_mask)\n\n        # Remove overlapping pixels\n        best_mask = remove_overlaps_from_mask(best_mask, occupied)\n\n        # Update occupied mask\n        occupied[best_mask > 0] = 1\n\n        # Re-extract contour from the cleaned mask\n        contour, best_mask = get_largest_contour_from_mask(best_mask)\n\n        if contour is None:\n            # Fallback: use original bounding box as polyline\n            coords_x = [xmin, xmax, xmax, xmin, xmin]\n            coords_y = [ymin, ymin, ymax, ymax, ymin]\n        else:\n            # Simplify the contour to get a polyline\n            simplified = simplify_contour(contour, epsilon_factor=0.003)\n            coords_x, coords_y = extract_polyline_coords(simplified)\n\n        # Compute new bounding box\n        new_xmin, new_ymin, new_xmax, new_ymax = mask_to_bbox(best_mask)\n\n        results.append({\n            "xmin": new_xmin,\n            "ymin": new_ymin,\n            "xmax": new_xmax,\n            "ymax": new_ymax,\n            "coords_x": coords_x,\n            "coords_y": coords_y,\n        })\n\n        if (idx + 1) % 10 == 0 or idx == len(df) - 1:\n            print(f"  Processed {idx + 1}/{len(df)} masks")\n\n    # Build output dataframe preserving original columns\n    out_df = df.copy()\n    out_df["xmin"] = [r["xmin"] for r in results]\n    out_df["ymin"] = [r["ymin"] for r in results]\n    out_df["xmax"] = [r["xmax"] for r in results]\n    out_df["ymax"] = [r["ymax"] for r in results]\n    out_df["coords_x"] = [",".join(map(str, r["coords_x"])) for r in results]\n    out_df["coords_y"] = [",".join(map(str, r["coords_y"])) for r in results]\n    out_df["type"] = "polyline"\n\n    # Ensure output directory exists\n    out_dir = os.path.dirname(args.output_path)\n    if out_dir:\n        os.makedirs(out_dir, exist_ok=True)\n\n    out_df.to_csv(args.output_path, index=False)\n    print(f"Saved output to {args.output_path}")\n\n\nif __name__ == "__main__":\n    main()\nPYEOF\necho "Script updated."'})
