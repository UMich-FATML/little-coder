th prob p1, 1 token with prob p2, (V-2) tokens with prob p3\n# where p1 >> p2 >> p3\n\n# From S2: log(p1) + log(p2) + (V-2)*log(p3) = S2\n# From S1: p1*log(p1) + p2*log(p2) + (V-2)*p3*log(p3) = -1.9184\n# From norm: p1 + p2 + (V-2)*p3 = 1\n\n# Let\'s parameterize by p1 and p2, compute p3, and check both constraints.\n\nS1_target = 10 - log_V  # -1.9184\nS2_target = -V * (10 + log_V)  # -3287758.59\n\n# From S2: (V-2)*log(p3) = S2 - log(p1) - log(p2)\n# log(p3) = (S2 - log(p1) - log(p2)) / (V-2)\n# p3 = exp((S2 - log(p1) - log(p2)) / (V-2))\n\n# Then from norm: p1 + p2 + (V-2)*p3 = 1\n# This gives us a constraint on p1, p2.\n\n# Let\'s search over p1, p2\nbest_err = float(\'inf\')\nbest = None\n\nfor p1 in np.linspace(0.5, 0.99999, 100):\n    for p2 in np.linspace(1e-10, 1-p1-1e-10, 100):\n        log_p3 = (S2_target - np.log(p1) - np.log(p2)) / (V-2)\n        p3 = np.exp(log_p3)\n        if p3 <= 0 or p3 > 1:\n            continue\n        norm = p1 + p2 + (V-2)*p3\n        if norm < 0 or norm > 2:\n            continue\n        # Scale to make it sum to 1\n        scale = 1.0 / norm\n        p1s, p2s, p3s = p1*scale, p2*scale, p3*scale\n        if p1s <= 0 or p2s <= 0 or p3s <= 0:\n            continue\n        \n        s1 = p1s*np.log(p1s) + p2s*np.log(p2s) + (V-2)*p3s*np.log(p3s)\n        s2 = np.log(p1s) + np.log(p2s) + (V-2)*np.log(p3s)\n        fk = s1 + log_V\n        bk = -log_V - s2/V\n        \n        err = (fk-10)**2 + (bk-10)**2\n        if err < best_err:\n            best_err = err\n            best = (p1s, p2s, p3s, fk, bk)\n\nif best:\n    p1, p2, p3, fk, bk = best\n    print(f\'Best: p1={p1:.6f}, p2={p2:.6f}, p3={p3:.2e}\')\n    print(f\'FK={fk:.4f}, BK={bk:.4f}, err={best_err:.6f}\')\n"\n', 'timeout': 300})
