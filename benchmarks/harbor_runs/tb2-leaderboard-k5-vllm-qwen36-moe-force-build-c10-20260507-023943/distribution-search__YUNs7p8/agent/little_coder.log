l = sol\n            if ph > 0 and pl > 0 and k*ph < 1 and ier == 1:\n                fk = k*ph*(np.log(ph) + log_V) + (V-k)*pl*(np.log(pl) + log_V)\n                bk = -log_V - (1/V)*(k*np.log(ph) + (V-k)*np.log(pl))\n                return ph, pl, fk, bk\n        except:\n            pass\n    return None\n\n# Try various k values\nfor k in [1, 2, 3, 5, 10, 20, 50, 100, 500, 1000, 5000, 10000]:\n    result = solve_for_k(k)\n    if result:\n        ph, pl, fk, bk = result\n        print(f\'k={k}: ph={ph:.6f}, pl={pl:.2e}, FK={fk:.4f}, BK={bk:.4f}\')\n    else:\n        print(f\'k={k}: no solution found\')\n"\n', 'timeout': 120})
