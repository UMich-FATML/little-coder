(np.log(p_high) + log_V) + (V-k)*p_low*(np.log(p_low) + log_V)\n    bk = -log_V - (1/V)*(k*np.log(p_high) + (V-k)*np.log(p_low))\n    return fk, bk\n\n# Let\'s try k=2 with a wider search\nfor k in [2, 3, 5, 10, 20, 50, 100]:\n    # For each k, we have 2 constraints and 1 free param (p_high)\n    # So generally we can\'t satisfy both unless k is chosen right\n    # Let\'s see the relationship between forward and backward KL as p_high varies\n    \n    results = []\n    for p_high in np.linspace(0.001, 1.0/k - 0.001, 50):\n        fk, bk = check(k, p_high)\n        if fk is not None and bk is not None:\n            results.append((p_high, fk, bk))\n    \n    if results:\n        p_min, fk_min, bk_min = results[0]\n        p_max, fk_max, bk_max = results[-1]\n        print(f\'k={k}: p_high in [{p_min:.4f}, {p_max:.4f}], FK in [{fk_min:.2f}, {fk_max:.2f}], BK in [{bk_min:.2f}, {bk_max:.2f}]\')\n"\n', 'timeout': 30})
