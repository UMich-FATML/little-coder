>> ShellSession({'command': 'cat > /app/merge.py << \'PYEOF\'\nimport json\nimport pandas as pd\nfrom datetime import datetime\n\n# --- Source A: JSON ---\nwith open(\'/data/source_a/users.json\') as f:\n    source_a_list = json.load(f)\n\nsource_a = pd.DataFrame(source_a_list)\nsource_a = source_a.rename(columns={\n    \'id\': \'user_id\',\n    \'full_name\': \'name\',\n    \'email\': \'email\',\n    \'registration_date\': \'created_date\'\n})\nsource_a[\'source\'] = \'source_a\'\nsource_a[\'created_date\'] = pd.to_datetime(source_a[\'created_date\']).dt.strftime(\'%Y-%m-%d\')\n\n# --- Source B: CSV ---\nsource_b = pd.read_csv(\'/data/source_b/users.csv\')\nsource_b = source_b.rename(columns={\n    \'user_id\': \'user_id\',\n    \'name\': \'name\',\n    \'email_address\': \'email\',\n    \'created_at\': \'created_date\'\n})\nsource_b[\'source\'] = \'source_b\'\nsource_b[\'created_date\'] = pd.to_datetime(source_b[\'created_date\']).dt.strftime(\'%Y-%m-%d\')\n\n# --- Source C: Parquet ---\nsource_c = pd.read_parquet(\'/data/source_c/users.parquet\')\nsource_c = source_c.rename(columns={\n    \'userId\': \'user_id\',\n    \'userName\': \'name\',\n    \'email\': \'email\',\n    \'joined\': \'created_date\'\n})\nsource_c[\'source\'] = \'source_c\'\nsource_c[\'created_date\'] = pd.to_datetime(source_c[\'created_date\']).dt.strftime(\'%Y-%m-%d\')\n\n# --- Build conflict report ---\n# Collect all records per source with only the fields we care about\nfields = [\'user_id\', \'name\', \'email\', \'created_date\']\n\nrecords_by_source = {}\nfor src_name, df in [(\'source_a\', source_a), (\'source_b\', source_b), (\'source_c\', source_c)]:\n    records_by_source[src_name] = {}\n    for _, row in df.iterrows():\n        uid = int(row[\'user_id\'])\n        records_by_source[src_name][uid] = {\n            \'user_id\': uid,\n            \'name\': row[\'name\'],\n            \'email\': row[\'email\'],\n            \'created_date\': row[\'created_date\']\n        }\n\nall_user_ids = sorted(set().union(*[set(d.keys()) for d in records_by_source.values()]))\n\nconflicts = []\nmerged_rows = []\n\nfor uid in all_user_ids:\n    merged = {\'user_id\': uid}\n    \n    for field in [\'name\', \'email\', \'created_date\']:\n        values = {}\n        for src_name in [\'source_a\', \'source_b\', \'source_c\']:\n            if uid in records_by_source[src_name]:\n                val = records_by_source[src_name][uid][field]\n                values[src_name] = val\n        \n        # Determine selected value by priority\n        selected = None\n        for src_name in [\'source_a\', \'source_b\', \'source_c\']:\n            if src_name in values:\n                selected = values[src_name]\n                break\n        \n        merged[field] = selected\n        \n        # Check for conflicts: same user, multiple sources, different values\n        present_values = [v for v in values.values()]\n        if len(present_values) > 1 and len(set(present_values)) > 1:\n            conflict_entry = {\n                \'user_id\': uid,\n                \'field\': field,\n                \'values\': {k: v for k, v in values.items()},\n                \'selected\': selected\n            }\n            conflicts.append(conflict_entry)\n    \n    # Handle status field (only in source_a)\n    if uid in records_by_source.get(\'source_a\', {}):\n        merged[\'status\'] = source_a[source_a[\'user_id\'] == uid][\'status\'].values[0]\n    else:\n        merged[\'status\'] = None\n    \n    merged_rows.append(merged)\n\n# --- Write merged parquet ---\nmerged_df = pd.DataFrame(merged_rows)\nmerged_df[\'user_id\'] = merged_df[\'user_id\'].astype(int)\nmerged_df.to_parquet(\'/app/merged_users.parquet\', index=False)\n\n# --- Write conflict report ---\nreport = {\n    \'total_conflicts\': len(conflicts),\n    \'conflicts\': conflicts\n}\n\nwith open(\'/app/conflicts.json\', \'w\') as f:\n    json.dump(report, f, indent=2)\n\nprint("=== Merged users ===")\nprint(merged_df.to_string())\nprint(f"\\n=== Total conflicts: {len(conflicts)} ===")\nprint(json.dumps(report, indent=2))\nPYEOF\npython3 /app/merge.py'})
