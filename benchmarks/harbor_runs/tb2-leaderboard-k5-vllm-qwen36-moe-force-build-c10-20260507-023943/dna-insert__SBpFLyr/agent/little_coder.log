 point)\n# The annealing part should be 15-45 nt, TM 58-72\n\n# Reverse primer design:\n# The reverse primer should have:\n# - 5\' tail: reverse complement of the insertion sequence\n# - 3\' annealing region: reverse complement of sequence from the input template ending at position 215 (right before the insertion point)\n# The annealing part should be 15-45 nt, TM 58-72\n\n# Let\'s find good annealing regions\n# Forward primer anneals to: input_seq[215:]\n# Reverse primer anneals to: reverse_complement(input_seq[:215])\n\nbest_forward = None\nbest_reverse = None\nbest_score = float(\'inf\')\n\n# Try different annealing lengths for forward primer (15-45)\nfor fwd_anneal_len in range(15, 46):\n    if 215 + fwd_anneal_len > len(input_seq):\n        break\n    fwd_anneal = input_seq[215:215+fwd_anneal_len]\n    fwd_tm = get_tm(fwd_anneal)\n    if fwd_tm < 58 or fwd_tm > 72:\n        continue\n    \n    # Try different annealing lengths for reverse primer (15-45)\n    for rev_anneal_len in range(15, 46):\n        if rev_anneal_len > 215:\n            break\n        rev_anneal = reverse_complement(input_seq[215-rev_anneal_len:215])\n        rev_tm = get_tm(rev_anneal)\n        if rev_tm < 58 or rev_tm > 72:\n            continue\n        \n        # Check TM difference\n        tm_diff = abs(fwd_tm - rev_tm)\n        if tm_diff > 5:\n            continue\n        \n        # Score: prefer TMs close to 60 and balanced\n        score = abs(fwd_tm - 60) + abs(rev_tm - 60) + tm_diff\n        \n        if score < best_score:\n            best_score = score\n            best_forward = fwd_anneal\n            best_reverse = rev_anneal\n            best_fwd_tm = fwd_tm\n            best_rev_tm = rev_tm\n\nif best_forward is None:\n    print("No valid primer pair found!")\n    sys.exit(1)\n\n# Build full primers\nfwd_primer = insertion_seq + best_forward\nrev_primer = reverse_complement(insertion_seq) + best_reverse\n\nprint(f"Forward primer: {fwd_primer}")\nprint(f"  Annealing region: {best_forward}")\nprint(f"  Annealing TM: {best_fwd_tm}")\nprint(f"  Full length: {len(fwd_primer)}")\n\nprint(f"Reverse primer: {rev_primer}")\nprint(f"  Annealing region: {best_reverse}")\nprint(f"  Annealing TM: {best_rev_tm}")\nprint(f"  Full length: {len(rev_primer)}")\n\n# Verify TMs\nfwd_full_tm = get_tm(fwd_primer)\nrev_full_tm = get_tm(rev_primer)\nprint(f"\\nFull forward TM: {fwd_full_tm}")\nprint(f"Full reverse TM: {rev_full_tm}")\n\n# Write output\nwith open(\'/app/primers.fasta\', \'w\') as f:\n    f.write(f">forward_primer\\n{fwd_primer}\\n")\n    f.write(f">reverse_primer\\n{rev_primer}\\n")\n\nprint("\\nPrimers written to primers.fasta")\nPYEOF\npython3 /app/design_primers.py'})
