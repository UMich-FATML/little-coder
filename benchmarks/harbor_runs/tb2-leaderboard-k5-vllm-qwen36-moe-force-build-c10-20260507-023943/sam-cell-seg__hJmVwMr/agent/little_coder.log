\n    xmin = int(min(coords_x))\n    xmax = int(max(coords_x))\n    ymin = int(min(coords_y))\n    ymax = int(max(coords_y))\n    \n    return coords_x, coords_y, xmin, xmax, ymin, ymax\n\n\ndef refine_mask_with_sam(sam_model, image, box, device):\n    """Use MobileSAM to refine a mask given a bounding box prompt."""\n    from mobile_sam.predictor import SamPredictor\n    \n    predictor = SamPredictor(sam_model)\n    predictor.set_image(image, image_format="RGB")\n    \n    # Use the bounding box as prompt\n    box_np = np.array([box[0], box[1], box[2], box[3]], dtype=np.float32)\n    \n    masks, iou_predictions, low_res_masks = predictor.predict(\n        box=box_np,\n        multimask_output=True,\n    )\n    \n    # Select the best mask based on IoU prediction\n    best_idx = np.argmax(iou_predictions)\n    best_mask = masks[best_idx]\n    \n    return best_mask\n\n\ndef remove_overlaps(masks_dict, img_h, img_w):\n    """Remove overlaps between masks by giving priority to earlier masks."""\n    # Create a combined mask of all masks\n    combined = np.zeros((img_h, img_w), dtype=np.uint8)\n    \n    # Sort masks by index to maintain order\n    sorted_indices = sorted(masks_dict.keys())\n    \n    for idx in sorted_indices:\n        mask = masks_dict[idx]\n        # Remove pixels that are already covered by other masks\n        mask_clean = mask & (combined == 0)\n        masks_dict[idx] = mask_clean\n        # Update combined mask\n        combined = combined | mask_clean\n    \n    return masks_dict\n\n\ndef main():\n    parser = argparse.ArgumentParser(description="Convert mask annotations to polylines using MobileSAM")\n    parser.add_argument("--weights_path", type=str, required=True, help="Path to MobileSAM weights")\n    parser.add_argument("--output_path", type=str, required=True, help="Path to output CSV")\n    parser.add_argument("--rgb_path", type=str, required=True, help="Path to RGB image")\n    parser.add_argument("--csv_path", type=str, required=True, help="Path to metadata CSV")\n    args = parser.parse_args()\n    \n    # Load model\n    print("Loading MobileSAM model...")\n    sam_model, device = load_model(args.weights_path)\n    \n    # Load image\n    print("Loading image...")\n    image = np.array(Image.open(args.rgb_path).convert("RGB"))\n    img_h, img_w = image.shape[:2]\n    \n    # Load metadata\n    print("Loading metadata...")\n    df = pd.read_csv(args.csv_path, index_col=0)\n    \n    # Set up predictor (compute image embedding once)\n    from mobile_sam.predictor import SamPredictor\n    predictor = SamPredictor(sam_model)\n    predictor.set_image(image, image_format="RGB")\n    \n    # Process each mask\n    print(f"Processing {len(df)} masks...")\n    results = []\n    \n    for idx, row in tqdm(df.iterrows(), total=len(df)):\n        xmin = int(row["xmin"])\n        ymin = int(row["ymin"])\n        xmax = int(row["xmax"])\n        ymax = int(row["ymax"])\n        \n        # Use the bounding box as prompt\n        box_np = np.array([xmin, ymin, xmax, ymax], dtype=np.float32)\n        \n        masks, iou_predictions, low_res_masks = predictor.predict(\n            box=box_np,\n            multimask_output=True,\n        )\n        \n        # Select the best mask based on IoU prediction\n        best_idx = np.argmax(iou_predictions)\n        best_mask = masks[best_idx]\n        \n        # Get polygon from the mask\n        coords_x, coords_y, new_xmin, new_xmax, new_ymin, new_ymax = get_mask_polygon(best_mask)\n        \n        if coords_x is None:\n            # Fallback: use the original bounding box\n            coords_x = [xmin, xmax, xmax, xmin, xmin]\n            coords_y = [ymin, ymin, ymax, ymax, ymin]\n            new_xmin, new_xmax, new_ymin, new_ymax = xmin, xmax, ymin, ymax\n        \n        results.append({\n            "raw_classification": row["raw_classification"],\n            "main_classification": row["main_classification"],\n            "super_classification": row["super_classification"],\n            "type": "polyline",\n            "xmin": new_xmin,\n            "ymin": new_ymin,\n            "xmax": new_xmax,\n            "ymax": new_ymax,\n            "coords_x": ",".join(str(int(x)) for x in coords_x),\n            "coords_y": ",".join(str(int(y)) for y in coords_y),\n        })\n    \n    # Build output dataframe\n    out_df = pd.DataFrame(results)\n    \n    # Remove overlaps between masks\n    print("Removing overlaps between masks...")\n    masks_dict = {}\n    for i, row in out_df.iterrows():\n        coords_x = np.array([int(x) for x in row["coords_x"].split(",")])\n        coords_y = np.array([int(y) for y in row["coords_y"].split(",")])\n        mask = coords_to_mask(coords_x, coords_y, img_h, img_w)\n        masks_dict[i] = mask\n    \n    # Remove overlaps\n    masks_dict = remove_overlaps(masks_dict, img_h, img_w)\n    \n    # Update the dataframe with cleaned masks\n    for i in tqdm(range(len(out_df))):\n        mask = masks_dict[i]\n        coords_x, coords_y, new_xmin, new_xmax, new_ymin, new_ymax = get_mask_polygon(mask)\n        \n        if coords_x is not None:\n            out_df.at[i, "coords_x"] = ",".join(str(int(x)) for x in coords_x)\n            out_df.at[i, "coords_y"] = ",".join(str(int(y)) for y in coords_y)\n            out_df.at[i, "xmin"] = new_xmin\n            out_df.at[i, "ymin"] = new_ymin\n            out_df.at[i, "xmax"] = new_xmax\n            out_df.at[i, "ymax"] = new_ymax\n    \n    # Save output\n    out_df.to_csv(args.output_path)\n    print(f"Saved output to {args.output_path}")\n\n\nif __name__ == "__main__":\n    main()\nPYEOF\necho "Script written successfully"'})
