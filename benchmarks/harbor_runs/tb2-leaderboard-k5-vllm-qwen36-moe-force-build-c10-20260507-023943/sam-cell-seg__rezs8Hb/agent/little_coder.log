>> ShellSession({'command': 'cat > /app/convert_masks.py << \'PYEOF\'\nimport argparse\nimport os\nimport numpy as np\nimport pandas as pd\nimport cv2\nimport torch\nfrom mobile_sam import build_sam_vit_t\nfrom mobile_sam.predictor import SamPredictor\nfrom tqdm import tqdm\n\n\ndef get_contours_as_polyline(mask):\n    """Extract the largest contour from a binary mask and return as polyline."""\n    contours, hierarchy = cv2.findContours(\n        mask.astype(np.uint8), cv2.RETR_EXTERNAL, cv2.CHAIN_APPROX_SIMPLE\n    )\n    if not contours:\n        return None\n    # Find the largest contour by area\n    largest = max(contours, key=cv2.contourArea)\n    if cv2.contourArea(largest) < 1:\n        return None\n    return largest\n\n\ndef get_mask_from_contour(contour, h, w):\n    """Create a binary mask from a contour."""\n    mask = np.zeros((h, w), dtype=np.uint8)\n    cv2.drawContours(mask, [contour], -1, 1, -1)\n    return mask\n\n\ndef get_bbox_from_contour(contour):\n    """Get bounding box from a contour."""\n    x, y, w, h = cv2.boundingRect(contour)\n    return x, y, x + w, y + h\n\n\ndef get_polyline_from_contour(contour):\n    """Get polyline coordinates from a contour."""\n    # Simplify the contour to reduce points while preserving shape\n    epsilon = 1.0\n    simplified = cv2.approxPolyDP(contour, epsilon, True)\n    coords_x = simplified[:, 0, 0].tolist()\n    coords_y = simplified[:, 0, 1].tolist()\n    return coords_x, coords_y\n\n\ndef refine_mask_with_sam(predictor, bbox, mask_input=None):\n    """Use SAM to refine a mask given a bounding box prompt."""\n    box = np.array([bbox[0], bbox[1], bbox[2], bbox[3]], dtype=np.float64)\n    \n    masks, iou_predictions, low_res_masks = predictor.predict(\n        box=box[None, :],\n        mask_input=mask_input[None, None, :, :] if mask_input is not None else None,\n        multimask_output=True,\n    )\n    \n    # Select the best mask based on IoU prediction\n    best_idx = np.argmax(iou_predictions)\n    best_mask = masks[best_idx]\n    return best_mask, iou_predictions, low_res_masks\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument("--weights_path", type=str, required=True)\n    parser.add_argument("--output_path", type=str, required=True)\n    parser.add_argument("--rgb_path", type=str, required=True)\n    parser.add_argument("--csv_path", type=str, required=True)\n    args = parser.parse_args()\n\n    # Load image\n    image = cv2.imread(args.rgb_path)\n    image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB)\n    h, w = image.shape[:2]\n\n    # Load metadata\n    df = pd.read_csv(args.csv_path)\n\n    # Load MobileSAM model\n    print("Loading MobileSAM model...")\n    model = build_sam_vit_t(checkpoint=args.weights_path)\n    model = model.to("cpu")\n    model.eval()\n    predictor = SamPredictor(model)\n    predictor.set_image(image, image_format="RGB")\n    print("Model loaded.")\n\n    # Create output directory\n    os.makedirs(os.path.dirname(args.output_path) if os.path.dirname(args.output_path) else ".", exist_ok=True)\n\n    # Track which pixels have been assigned to prevent overlap\n    assigned_mask = np.zeros((h, w), dtype=np.uint8)\n\n    results = []\n    for idx, row in tqdm(df.iterrows(), total=len(df), desc="Processing masks"):\n        xmin = int(row["xmin"])\n        xmax = int(row["xmax"])\n        ymin = int(row["ymin"])\n        ymax = int(row["ymax"])\n\n        # Ensure bbox is within image bounds\n        xmin = max(0, xmin)\n        ymin = max(0, ymin)\n        xmax = min(w, xmax)\n        ymax = min(h, ymax)\n\n        # Extract the current mask region from the assigned mask to use as mask_input\n        # This helps SAM avoid predicting already-assigned regions\n        current_region = assigned_mask[ymin:ymax, xmin:xmax]\n        \n        # Try to refine with SAM using the bounding box\n        best_mask = None\n        best_iou = -1\n        \n        # Try with mask_input (the already-assigned region)\n        mask_input = None\n        if current_region.size > 0:\n            # Resize to SAM\'s internal mask input size (256x256)\n            mask_input = cv2.resize(current_region.astype(np.float32), (256, 256))\n        \n        try:\n            refined_mask, iou_preds, low_res = refine_mask_with_sam(\n                predictor, (xmin, ymin, xmax, ymax), mask_input\n            )\n            best_mask = refined_mask\n            best_iou = iou_preds[0]\n        except Exception as e:\n            print(f"Error processing row {idx}: {e}")\n            # Fall back to original bbox as rectangle\n            best_mask = np.zeros((h, w), dtype=np.float32)\n            best_mask[ymin:ymax, xmin:xmax] = 1.0\n            best_iou = 0.0\n\n        # Threshold the mask\n        binary_mask = (best_mask > 0.0).astype(np.uint8)\n\n        # Get connected components and keep only the largest one\n        num_labels, labels, stats, centroids = cv2.connectedComponentsWithStats(\n            binary_mask, connectivity=8\n        )\n        if num_labels > 1:\n            # Find the largest component (excluding background)\n            largest_label = 1\n            largest_area = 0\n            for i in range(1, num_labels):\n                area = stats[i, cv2.CC_STAT_AREA]\n                if area > largest_area:\n                    largest_area = area\n                    largest_label = i\n            binary_mask = (labels == largest_label).astype(np.uint8)\n        else:\n            # Only background\n            binary_mask = np.zeros((h, w), dtype=np.uint8)\n\n        # Extract contour from the mask\n        contour = get_contours_as_polyline(binary_mask)\n        \n        if contour is not None and cv2.contourArea(contour) > 0:\n            # Get the mask from contour\n            mask_from_contour = get_mask_from_contour(contour, h, w)\n            \n            # Update assigned mask - only assign pixels that aren\'t already assigned\n            new_pixels = mask_from_contour * (1 - assigned_mask)\n            assigned_mask += new_pixels\n            \n            # Get bounding box and polyline from contour\n            new_xmin, new_ymin, new_w, new_h = cv2.boundingRect(contour)\n            new_xmax = new_xmin + new_w\n            new_ymax = new_ymin + new_h\n            \n            coords_x, coords_y = get_polyline_from_contour(contour)\n            \n            results.append({\n                "xmin": new_xmin,\n                "ymin": new_ymin,\n                "xmax": new_xmax,\n                "ymax": new_ymax,\n                "coords_x": ",".join(map(str, coords_x)),\n                "coords_y": ",".join(map(str, coords_y)),\n            })\n        else:\n            # No valid contour found, use original bbox\n            results.append({\n                "xmin": xmin,\n                "ymin": ymin,\n                "xmax": xmax,\n                "ymax": ymax,\n                "coords_x": ",".join(map(str, [xmin, xmax, xmax, xmin, xmin])),\n                "coords_y": ",".join(map(str, [ymin, ymin, ymax, ymax, ymin])),\n            })\n\n    # Build output dataframe\n    out_df = df.copy()\n    out_df["xmin"] = [r["xmin"] for r in results]\n    out_df["ymin"] = [r["ymin"] for r in results]\n    out_df["xmax"] = [r["xmax"] for r in results]\n    out_df["ymax"] = [r["ymax"] for r in results]\n    out_df["coords_x"] = [r["coords_x"] for r in results]\n    out_df["coords_y"] = [r["coords_y"] for r in results]\n\n    # Save output\n    out_df.to_csv(args.output_path, index=False)\n    print(f"Saved output to {args.output_path}")\n\n\nif __name__ == "__main__":\n    main()\nPYEOF\necho "Script written."'})
