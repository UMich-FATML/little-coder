 end anneals to input template before insertion point\n\n# The annealed part of the forward primer should be downstream of the insertion point\n# The annealed part of the reverse primer should be upstream of the insertion point\n\n# Let\'s design primers where:\n# Forward primer: [insertion_seq][annealing_seq] where annealing_seq is downstream of insertion point\n# Reverse primer: [revcomp(insertion_seq)][annealing_seq] where annealing_seq is upstream of insertion point\n\n# The annealed parts need to be 15-45 nt with TM 58-72°C\n\n# For forward primer: anneal to input_seq starting at insertion_pos\n# For reverse primer: anneal to reverse complement of input_seq ending at insertion_pos\n\nbest_pairs = []\n\n# Try different annealing lengths for forward primer (15-45 nt)\nfor fwd_anneal_len in range(15, 46):\n    fwd_anneal = input_seq[insertion_pos:insertion_pos + fwd_anneal_len]\n    fwd_tm = get_tm(fwd_anneal)\n    \n    if 58 <= fwd_tm <= 72:\n        # Try different annealing lengths for reverse primer (15-45 nt)\n        for rev_anneal_len in range(15, 46):\n            # Reverse primer anneals upstream of insertion point\n            rev_anneal_seq = input_seq[insertion_pos - rev_anneal_len:insertion_pos]\n            rev_anneal = reverse_complement(rev_anneal_seq)\n            rev_tm = get_tm(rev_anneal)\n            \n            if 58 <= rev_tm <= 72:\n                tm_diff = abs(fwd_tm - rev_tm)\n                if tm_diff <= 5:\n                    fwd_primer = insertion_seq + fwd_anneal\n                    rev_primer = reverse_complement(insertion_seq) + rev_anneal\n                    \n                    best_pairs.append({\n                        \'fwd_anneal_len\': fwd_anneal_len,\n                        \'rev_anneal_len\': rev_anneal_len,\n                        \'fwd_tm\': fwd_tm,\n                        \'rev_tm\': rev_tm,\n                        \'tm_diff\': tm_diff,\n                        \'fwd_primer\': fwd_primer,\n                        \'rev_primer\': rev_primer,\n                        \'fwd_anneal\': fwd_anneal,\n                        \'rev_anneal\': rev_anneal,\n                    })\n\nprint(f"\\nFound {len(best_pairs)} valid primer pairs")\n\n# Sort by total annealing length (prefer shorter primers = fewer pairs needed)\n# Actually, we need minimum number of pairs = 1 pair is sufficient for a single insertion\n# Let\'s find the best single pair\nif best_pairs:\n    # Pick the pair with best TM match (smallest tm_diff)\n    best_pairs.sort(key=lambda x: x[\'tm_diff\'])\n    best = best_pairs[0]\n    \n    print(f"\\nBest primer pair:")\n    print(f"Forward primer: {best[\'fwd_primer\']}")\n    print(f"  Annealed part: {best[\'fwd_anneal\']} (len={best[\'fwd_anneal_len\']}, TM={best[\'fwd_tm\']:.2f})")\n    print(f"Reverse primer: {best[\'rev_primer\']}")\n    print(f"  Annealed part: {best[\'rev_anneal\']} (len={best[\'rev_anneal_len\']}, TM={best[\'rev_tm\']:.2f})")\n    print(f"TM difference: {best[\'tm_diff\']:.2f}")\n    \n    # Write output\n    with open(\'/app/primers.fasta\', \'w\') as f:\n        f.write(f">forward_primer\\n{best[\'fwd_primer\']}\\n")\n        f.write(f">reverse_primer\\n{best[\'rev_primer\']}\\n")\n    \n    print("\\nWrote primers.fasta")\nelse:\n    print("No valid primer pairs found!")\n    # Debug: show some TMs\n    print("\\nDebug - TMs for various annealing lengths:")\n    for fwd_len in [15, 20, 25, 30, 35, 40, 45]:\n        if insertion_pos + fwd_len <= len(input_seq):\n            fwd_anneal = input_seq[insertion_pos:insertion_pos + fwd_len]\n            fwd_tm = get_tm(fwd_anneal)\n            print(f"  Fwd anneal len {fwd_len}: TM={fwd_tm:.2f}")\n    \n    for rev_len in [15, 20, 25, 30, 35, 40, 45]:\n        if insertion_pos - rev_len >= 0:\n            rev_anneal_seq = input_seq[insertion_pos - rev_len:insertion_pos]\n            rev_anneal = reverse_complement(rev_anneal_seq)\n            rev_tm = get_tm(rev_anneal)\n            print(f"  Rev anneal len {rev_len}: TM={rev_tm:.2f}")\n\nPYEOF\npython3 /app/design_primers.py'})
