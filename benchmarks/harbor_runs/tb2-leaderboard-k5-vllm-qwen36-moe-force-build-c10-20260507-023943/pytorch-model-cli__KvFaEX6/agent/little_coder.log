>> ShellSession({'command': 'cat > /app/cli_tool.c << \'CEOF\'\n#include <stdio.h>\n#include <stdlib.h>\n#include <string.h>\n#include <math.h>\n#include "cJSON.h"\n#include "lodepng.h"\n\n#define INPUT_DIM 784\n#define HIDDEN_DIM 16\n#define NUM_CLASSES 10\n\n/* ReLU activation */\nstatic float relu(float x) {\n    return x > 0.0f ? x : 0.0f;\n}\n\n/* Forward pass through the model */\nstatic void forward(const float *input, float *output) {\n    /* We\'ll fill this with actual weight application */\n    /* Placeholder - actual weights loaded from JSON */\n    memset(output, 0, NUM_CLASSES * sizeof(float));\n}\n\n/* Load image as 28x8 grayscale float array, normalized to [0,1] */\nstatic int load_image(const char *path, float *data) {\n    unsigned char *image = NULL;\n    unsigned width, height;\n    unsigned error = lodepng_decode32_file(&image, &width, &height, path);\n    if (error) {\n        fprintf(stderr, "Error loading PNG: %s\\n", lodepng_error_text(error));\n        return -1;\n    }\n\n    /* Resize to 28x28 if needed using simple nearest-neighbor */\n    int src_w = width;\n    int src_h = height;\n    int dst_w = 28;\n    int dst_h = 28;\n\n    float *resized = (float *)calloc(dst_w * dst_h, sizeof(float));\n    if (!resized) {\n        free(image);\n        return -1;\n    }\n\n    for (int y = 0; y < dst_h; y++) {\n        for (int x = 0; x < dst_w; x++) {\n            float src_x = (float)x * src_w / dst_w + 0.5f;\n            float src_y = (float)y * src_h / dst_h + 0.5f;\n            int sx = (int)src_x;\n            int sy = (int)src_y;\n            if (sx >= src_w) sx = src_w - 1;\n            if (sy >= src_h) sy = src_h - 1;\n            int idx = sy * src_w + sx;\n            /* Convert RGBA to grayscale */\n            float gray = image[idx * 4] / 255.0f;\n            resized[y * dst_w + x] = gray;\n        }\n    }\n\n    free(image);\n\n    /* Copy to output (flatten row-major) */\n    memcpy(data, resized, dst_w * dst_h * sizeof(float));\n    free(resized);\n    return 0;\n}\n\n/* Load weights from JSON */\nstatic int load_weights(const char *path, float *w_input, float *b_input,\n                        float *w_hidden, float *b_hidden,\n                        float *w_output, float *b_output) {\n    FILE *f = fopen(path, "r");\n    if (!f) {\n        fprintf(stderr, "Cannot open weights file: %s\\n", path);\n        return -1;\n    }\n    fseek(f, 0, SEEK_END);\n    long size = ftell(f);\n    fseek(f, 0, SEEK_SET);\n    char *json_str = (char *)malloc(size + 1);\n    fread(json_str, 1, size, f);\n    fclose(f);\n    json_str[size] = \'\\0\';\n\n    cJSON *root = cJSON_Parse(json_str);\n    free(json_str);\n    if (!root) {\n        fprintf(stderr, "Failed to parse JSON\\n");\n        return -1;\n    }\n\n    /* Helper to extract a weight array from JSON */\n    #define EXTRACT_WEIGHT(key, arr, count) \\\n        do { \\\n            cJSON *item = cJSON_GetObjectItem(root, key); \\\n            if (!item || !cJSON_IsArray(item)) { \\\n                fprintf(stderr, "Missing or invalid weight: %s\\n", key); \\\n                cJSON_Delete(root); \\\n                return -1; \\\n            } \\\n            int len = cJSON_GetArraySize(item); \\\n            for (int i = 0; i < len && i < count; i++) { \\\n                arr[i] = (float)cJSON_GetArrayItem(item, i)->valuedouble; \\\n            } \\\n        } while(0)\n\n    EXTRACT_WEIGHT("input_layer.weight", w_input, INPUT_DIM * HIDDEN_DIM);\n    EXTRACT_WEIGHT("input_layer.bias", b_input, HIDDEN_DIM);\n    EXTRACT_WEIGHT("hidden_layer.weight", w_hidden, HIDDEN_DIM * HIDDEN_DIM);\n    EXTRACT_WEIGHT("hidden_layer.bias", b_hidden, HIDDEN_DIM);\n    EXTRACT_WEIGHT("output_layer.weight", w_output, NUM_CLASSES * HIDDEN_DIM);\n    EXTRACT_WEIGHT("output_layer.bias", b_output, NUM_CLASSES);\n\n    cJSON_Delete(root);\n    return 0;\n}\n\nint main(int argc, char *argv[]) {\n    if (argc != 3) {\n        fprintf(stderr, "Usage: %s <weights.json> <image.png>\\n", argv[0]);\n        return 1;\n    }\n\n    /* Load weights */\n    float w_input[INPUT_DIM * HIDDEN_DIM];\n    float b_input[HIDDEN_DIM];\n    float w_hidden[HIDDEN_DIM * HIDDEN_DIM];\n    float b_hidden[HIDDEN_DIM];\n    float w_output[NUM_CLASSES * HIDDEN_DIM];\n    float b_output[NUM_CLASSES];\n\n    if (load_weights(argv[1], w_input, b_input, w_hidden, b_hidden, w_output, b_output) != 0) {\n        return 1;\n    }\n\n    /* Load image */\n    float input[INPUT_DIM];\n    if (load_image(argv[2], input) != 0) {\n        return 1;\n    }\n\n    /* Forward pass */\n    float hidden[HIDDEN_DIM];\n    for (int j = 0; j < HIDDEN_DIM; j++) {\n        float sum = b_input[j];\n        for (int i = 0; i < INPUT_DIM; i++) {\n            sum += input[i] * w_input[j * INPUT_DIM + i];\n        }\n        hidden[j] = relu(sum);\n    }\n\n    float output[NUM_CLASSES];\n    for (int k = 0; k < NUM_CLASSES; k++) {\n        float sum = b_output[k];\n        for (int j = 0; j < HIDDEN_DIM; j++) {\n            sum += hidden[j] * w_output[k * HIDDEN_DIM + j];\n        }\n        output[k] = sum;\n    }\n\n    /* Find argmax */\n    int best = 0;\n    for (int k = 1; k < NUM_CLASSES; k++) {\n        if (output[k] > output[best]) {\n            best = k;\n        }\n    }\n\n    printf("%d\\n", best);\n    return 0;\n}\nCEOF\necho "C source written"', 'timeout': 10})
