nts) and p (prob of each)\n# p_low = (1 - k*p) / (n - k)\n\ndef kl_forward_2group(k, p):\n    """KL(P||U) for 2-group distribution"""\n    if p <= 0 or (1 - k*p) <= 0:\n        return float(\'inf\')\n    p_low = (1 - k * p) / (n - k)\n    if p_low <= 0:\n        return float(\'inf\')\n    kl = k * p * np.log(p * n) + (n - k) * p_low * np.log(p_low * n)\n    return kl\n\ndef kl_backward_2group(k, p):\n    """KL(U||P) for 2-group distribution"""\n    if p <= 0 or (1 - k*p) <= 0:\n        return float(\'inf\')\n    p_low = (1 - k * p) / (n - k)\n    if p_low <= 0:\n        return float(\'inf\')\n    kl = k * (1.0/n) * np.log(n / p) + (n - k) * (1.0/n) * np.log(n / p_low)\n    return kl\n\n# For a given k, find p such that KL(P||U) = 10\n# Then check if KL(U||P) = 10\n\n# Let\'s explore\nfor k in [1, 2, 5, 10, 50, 100, 500, 1000, 5000, 10000]:\n    # For KL(P||U) = 10, we need H(P) = log(n) - 10 ≈ 11.914 - 10 = 1.914\n    # With k elements at prob p and (n-k) at prob p_low:\n    # H(P) = -k*p*log(p) - (n-k)*p_low*log(p_low)\n    # \n    # Let\'s just search for p that gives KL(P||U) = 10\n    try:\n        # Find p such that kl_forward_2group(k, p) = 10\n        # kl_forward is decreasing in p (more concentrated = higher KL)\n        # At p = 1/k (uniform over k elements): kl = log(n/k)\n        # At p -> 1: kl -> log(n)\n        \n        # Check bounds\n        p_uniform = 1.0 / k\n        kl_at_uniform = kl_forward_2group(k, p_uniform)\n        \n        # p close to 1\n        kl_at_one = kl_forward_2group(k, 1 - 1e-10)\n        \n        print(f"k={k}: KL at uniform={kl_at_uniform:.4f}, KL at p~1={kl_at_one:.4f}")\n        \n        if kl_at_uniform <= target_kl <= kl_at_one:\n            # Brentq needs f(a)*f(b) < 0\n            def obj(p):\n                return kl_forward_2group(k, p) - target_kl\n            p_sol = brentq(obj, 1e-10, 1 - 1e-10)\n            kb = kl_backward_2group(k, p_sol)\n            print(f"  -> p={p_sol:.10f}, KL(U||P)={kb:.4f}, diff={kb