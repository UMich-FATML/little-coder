2 > 0 and p1 + p2 < 1:\n                kf, kb = kl_forward_3group(1, 1, p1, p2), kl_backward_3group(1, 1, p1, p2)\n                if abs(kf - target_kl) < 0.1 and abs(kb - target_kl) < 0.1:\n                    print(f"Found! p1={p1:.10f}, p2={p2:.10f}, kf={kf:.6f}, kb={kb:.6f}")\n        except:\n            pass\n\n# Try with k1=1, k2=2\ndef equations2(params):\n    p1, p2 = params\n    if p1 <= 0 or p2 <= 0 or p1 + 2*p2 >= 1:\n        return [1e10, 1e10]\n    remaining = 1 - p1 - 2*p2\n    p3 = remaining / (n - 3)\n    if p3 <= 0:\n        return [1e10, 1e10]\n    kf = p1*np.log(p1*n) + 2*p2*np.log(p2*n) + (n-3)*p3*np.log(p3*n)\n    kb = (1/n)*np.log(n/p1) + (2/n)*np.log(n/p2) + ((n-3)/n)*np.log(n/p3)\n    return [kf - target_kl, kb - target_kl]\n\nfor p1_init in [0.5, 0.7, 0.8, 0.9, 0.95]:\n    for p2_init in [0.001, 0.01, 0.1, 0.2]:\n        try:\n            sol = fsolve(equations2, [p1_init, p2_init], full_output=True)\n            p1, p2 = sol[0]\n            if p1 > 0 and p2 > 0 and p1 + 2*p2 < 1:\n                kf, kb = kl_forward_3group(1, 2, p1, p2), kl_backward_3group(1, 2, p1, p2)\n                if abs(kf - target_kl) < 0.1 and abs(kb - target_kl) < 0.1:\n                    print(f"Found! k1=1,k2=2: p1={p1:.10f}, p2={p2:.10f}, kf={kf:.6f}, kb={kb:.6f}")\n        except:\n            pass\n\nprint("Done searching.")\nPYEOF\npython3 /app/solve3.py', 'timeout': 60})
