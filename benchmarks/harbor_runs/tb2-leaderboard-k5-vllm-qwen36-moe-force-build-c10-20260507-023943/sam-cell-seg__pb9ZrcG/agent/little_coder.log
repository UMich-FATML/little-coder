multimask output\n    masks, iou_preds, low_res_masks = predictor.predict(\n        box=box,\n        multimask_output=True,\n    )\n    \n    # Select the best mask based on IoU prediction\n    best_idx = np.argmax(iou_preds)\n    best_mask = masks[best_idx]\n    \n    # Binarize\n    best_mask = best_mask > mask_threshold\n    \n    return best_mask\n\n\ndef remove_overlaps(masks_list, image_shape):\n    """Remove overlaps between masks by processing in order and masking out already-assigned pixels."""\n    h, w = image_shape[:2]\n    result_masks = []\n    assigned = np.zeros((h, w), dtype=np.uint8)\n    \n    for mask in masks_list:\n        # Get the mask as binary\n        binary = mask > 0\n        \n        # Remove pixels already assigned to previous masks\n        unassigned = binary & (assigned == 0)\n        \n        # Find the largest connected component to ensure contiguity\n        num_labels, labels, stats, centroids = cv2.connectedComponentsWithStats(\n            unassigned.astype(np.uint8), connectivity=8\n        )\n        \n        if num_labels <= 1:\n            # No foreground pixels\n            result_masks.append(np.zeros((h, w), dtype=bool))\n            continue\n        \n        # Get the largest component (label 0 is background)\n        areas = stats[1:, 4]  # skip background\n        largest_label = np.argmax(areas) + 1\n        clean_mask = (labels == largest_label)\n        \n        result_masks.append(clean_mask)\n        assigned |= clean_mask\n    \n    return result_masks\n\n\ndef main():\n    parser = argparse.ArgumentParser(description="Convert masks to polylines using MobileSAM")\n    parser.add_argument("--weights_path", type=str, required=True, help="Path to MobileSAM weights")\n    parser.add_argument("--output_path", type=str, required=True, help="Path to output CSV")\n    parser.add_argument("--rgb_path", type=str, required=True, help="Path to RGB image")\n    parser.add_argument("--csv_path", type=str, required=True, help="Path to metadata CSV")\n    args = parser.parse_args()\n\n    # Load image\n    image = np.array(Image.open(args.rgb_path).convert("RGB"))\n    image_shape = image.shape\n\n    # Load metadata\n    df = pd.read_csv(args.csv_path)\n\n    # Load MobileSAM model\n    print("Loading MobileSAM model...")\n    model = build_sam_vit_t(args.weights_path)\n    model = model.to("cpu")\n    model.eval()\n    predictor = SamPredictor(model)\n    predictor.set_image(image, image_format="RGB")\n    print("Model loaded.")\n\n    # Process each mask\n    print(f"Processing {len(df)} masks...")\n    results = []\n\n    for idx, row in tqdm(df.iterrows(), total=len(df)):\n        xmin = int(row["xmin"])\n        ymin = int(row["ymin"])\n        xmax = int(row["xmax"])\n        ymax = int(row["ymax"])\n\n        # Ensure coordinates are within image bounds\n        xmin = max(0, xmin)\n        ymin = max(0, ymin)\n        xmax = min(image_shape[1], xmax)\n        ymax = min(image_shape[0], ymax)\n\n        # Skip if bbox is invalid\n        if xmin >= xmax or ymin >= ymax:\n            results.append(row.to_dict())\n            continue\n\n        # Use SAM to refine the mask\n        refined_mask = process_mask_with_sam(predictor, [xmin, ymin, xmax, ymax], image_shape)\n\n        # Extract contour coordinates from the refined mask\n        coords_x, coords_y = extract_coords_from_mask(refined_mask)\n\n        if coords_x is not None and len(coords_x) > 0:\n            # Compute new bounding box from the refined mask\n            ys, xs = np.where(refined_mask)\n            new_xmin = int(xs.min())\n            new_ymin = int(ys.min())\n            new_xmax = int(xs.max())\n            new_ymax = int(ys.max())\n\n            # Convert coords to comma-separated strings\n            coords_x_str = ",".join(map(str, coords_x))\n            coords_y_str = ",".join(map(str, coords_y))\n\n            new_row = row.to_dict()\n            new_row["xmin"] = new_xmin\n            new_row["ymin"] = new_ymin\n            new_row["xmax"] = new_xmax\n            new_row["ymax"] = new_ymax\n            new_row["coords_x"] = coords_x_str\n            new_row["coords_y"] = coords_y_str\n            new_row["type"] = "polyline"\n            results.append(new_row)\n        else:\n            # If SAM didn\'t produce a valid mask, keep original\n            results.append(row.to_dict())\n\n    # Now handle overlaps: process all masks together\n    print("Removing overlaps...")\n    all_masks = []\n    for row in results:\n        coords_x = [int(x) for x in str(row["coords_x"]).split(",")]\n        coords_y = [int(y) for y in str(row["coords_y"]).split(",")]\n        \n        mask = np.zeros((image_shape[0], image_shape[1]), dtype=np.uint8)\n        if len(coords_x) > 2:\n            pts = np.array(list(zip(coords_x, coords_y)), dtype=np.int32)\n            cv2.fillPoly(mask, [pts], 255)\n        all_masks.append(mask > 0)\n\n    # Remove overlaps\n    clean_masks = remove_overlaps(all_masks, image_shape)\n\n    # Update results with clean masks\n    for idx, clean_mask in enumerate(clean_masks):\n        coords_x, coords_y = extract_coords_from_mask(clean_mask.astype(np.uint8))\n        \n        if coords_x is not None and len(coords_x) > 0:\n            ys, xs = np.where(clean_mask)\n            new_xmin = int(xs.min())\n            new_ymin = int(ys.min())\n            new_xmax = int(xs.max())\n            new_ymax = int(ys.max())\n\n            coords_x_str = ",".join(map(str, coords_x))\n            coords_y_str = ",".join(map(str, coords_y))\n\n            results[idx]["xmin"] = new_xmin\n            results[idx]["ymin"] = new_ymin\n            results[idx]["xmax"] = new_xmax\n            results[idx]["ymax"] = new_ymax\n            results[idx]["coords_x"] = coords_x_str\n            results[idx]["coords_y"] = coords_y_str\n            results[idx]["type"] = "polyline"\n\n    # Save results\n    out_df = pd.DataFrame(results)\n    \n    # Ensure column order matches input\n    input_cols = pd.read_csv(args.csv_path).columns.tolist()\n    # Keep the same columns, in the same order\n    out_cols = [c for c in input_cols if c in out_df.columns]\n    out_df = out_df[out_cols]\n    out_df.to_csv(args.output_path, index=False)\n    print(f"Saved output to {args.output_path}")\n\n\nif __name__ == "__main__":\n    main()\nPYEOF\necho "Script written."'})
