>> ShellSession({'command': 'python3 -c "\ncontent = \'\'\'#!/usr/bin/env python3\n\\"\\"\\"Revert a resharded directory back to its original flat structure.\\"\\"\\"\n\nimport os\nimport sys\nimport shutil\nimport tempfile\n\nMAX_FILES_PER_DIR = 30\n\n\ndef decompress(resharded_dir):\n    # Collect all files from all subdirectories\n    all_files = []\n\n    for entry in sorted(os.listdir(resharded_dir)):\n        entry_path = os.path.join(resharded_dir, entry)\n        if os.path.isdir(entry_path):\n            for fname in os.listdir(entry_path):\n                fpath = os.path.join(entry_path, fname)\n                if os.path.isfile(fpath):\n                    all_files.append((fname, fpath))\n\n    # Sort by original filename for deterministic reconstruction\n    all_files.sort(key=lambda x: x[0])\n\n    # Handle chunked files: group files with the same base name\n    # and merge them back together\n    chunks_by_name = {}\n    regular_files = []\n\n    for fname, fpath in all_files:\n        # Check if this is a chunked file (pattern: originalname_NNNN)\n        parts = fname.rsplit(\\"_\\", 1)\n        if len(parts) == 2 and parts[1].isdigit() and len(parts[1]) == 4:\n            base_name = parts[0]\n            chunk_num = int(parts[1])\n            if base_name not in chunks_by_name:\n                chunks_by_name[base_name] = []\n            chunks_by_name[base_name].append((chunk_num, fpath))\n        else:\n            regular_files.append((fname, fpath))\n\n    # Merge chunked files\n    merged_files = {}\n    for base_name, chunks in chunks_by_name.items():\n        chunks.sort(key=lambda x: x[0])\n        merged_files[base_name] = chunks\n\n    # Create a temp directory to stage the output\n    temp_dir = tempfile.mkdtemp(dir=resharded_dir, prefix=\\".decompress_\\")\n\n    try:\n        # Write regular files\n        for fname, fpath in regular_files:\n            shutil.copy2(fpath, os.path.join(temp_dir, fname))\n\n        # Write merged files\n        for base_name, chunks in merged_files.items():\n            dst_path = os.path.join(temp_dir, base_name)\n            with open(dst_path, \\"wb\\") as f_out:\n                for _, chunk_path in chunks:\n                    with open(chunk_path, \\"rb\\") as f_in:\n                        shutil.copyfileobj(f_in, f_out)\n\n        # Remove all current files and subdirectories from the resharded dir\n        for entry in os.listdir(resharded_dir):\n            entry_path = os.path.join(resharded_dir, entry)\n            if entry.startswith(\\".decompress_\\"):\n                continue\n            if os.path.isdir(entry_path):\n                shutil.rmtree(entry_path)\n            else:\n                os.remove(entry_path)\n\n        # Move all files from temp to the resharded dir\n        for fname in os.listdir(temp_dir):\n            src = os.path.join(temp_dir, fname)\n            dst = os.path.join(resharded_dir, fname)\n            shutil.move(src, dst)\n\n        # Remove temp dir\n        os.rmdir(temp_dir)\n\n        print(f\\"Decompressed {len(regular_files)} regular files + {len(merged_files)} merged files\\")\n    except Exception:\n        # Clean up temp dir on failure\n        shutil.rmtree(temp_dir, ignore_errors=True)\n        raise\n\n\nif __name__ == \\"__main__\\":\n    if len(sys.argv) != 2:\n        print(f\\"Usage: {sys.argv[0]} <resharded_dir>\\")\n        sys.exit(1)\n\n    resharded_dir = sys.argv[1]\n    decompress(resharded_dir)\n\'\'\'\nwith open(\'/app/decompress.py\', \'w\') as f:\n    f.write(content)\nprint(\'decompress.py written\')\n"'})
