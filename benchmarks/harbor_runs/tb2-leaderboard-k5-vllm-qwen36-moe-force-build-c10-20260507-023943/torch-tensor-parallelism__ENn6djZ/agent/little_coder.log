>> ShellSession({'command': 'python3 -c "\ncode = \'\'\'import torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport torch.distributed as dist\n\n\nclass ColumnParallelLinear(nn.Module):\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.bias = bias\n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n\n        # master_weight shape: (out_features, in_features)\n        # ColumnParallelLinear splits by columns (dim=1, the in_features dim)\n        # Each rank gets weight of shape (out_features, in_features/world_size)\n        chunk_size = master_weight.shape[1] // self.world_size\n        self.weight = nn.Parameter(master_weight[:, self.rank * chunk_size:(self.rank + 1) * chunk_size].clone())\n\n        if bias:\n            self.bias_param = nn.Parameter(torch.zeros(out_features))\n        else:\n            self.bias_param = None\n\n    def forward(self, x):\n        # F.linear(x, w) computes x @ w.T\n        # x: (batch, in_features), w: (out_features, in_features/ws)\n        # w.T: (in_features/ws, out_features)\n        # result: (batch, out_features)\n        output = F.linear(x, self.weight, self.bias_param)\n\n        if self.world_size > 1:\n            gathered = [torch.zeros_like(output) for _ in range(self.world_size)]\n            dist.all_gather(gathered, output)\n            output = torch.cat(gathered, dim=-1)\n        return output\n\n\nclass RowParallelLinear(nn.Module):\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.bias = bias\n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n\n        # master_weight shape: (out_features, in_features)\n        # RowParallelLinear splits by rows (dim=0, the out_features dim)\n        # Each rank gets weight of shape (out_features/world_size, in_features)\n        chunk_size = master_weight.shape[0] // self.world_size\n        self.weight = nn.Parameter(master_weight[self.rank * chunk_size:(self.rank + 1) * chunk_size, :].clone())\n\n        if bias:\n            self.bias_param = nn.Parameter(torch.zeros(out_features))\n        else:\n            self.bias_param = None\n\n    def forward(self, x):\n        # F.linear(x, w) computes x @ w.T\n        # x: (batch, in_features), w: (out_features/ws, in_features)\n        # w.T: (in_features, out_features/ws)\n        # result: (batch, out_features/ws)\n        output = F.linear(x, self.weight, self.bias_param)\n\n        if self.world_size > 1:\n            dist.all_reduce(output, op=dist.ReduceOp.SUM)\n        return output\n\'\'\'\nwith open(\'/app/parallel_linear.py\', \'w\') as f:\n    f.write(code)\nprint(\'File written successfully\')\n"'})
