>> ShellSession({'command': "cat > /app/parallel_linear.py << 'EOF'\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nimport torch.distributed as dist\n\n\nclass ColumnParallelLinear(nn.Module):\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.bias = bias\n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n\n        # Split master_weight by columns (along dim=1)\n        chunk_size = master_weight.shape[1] // self.world_size\n        self.weight = nn.Parameter(master_weight[:, self.rank * chunk_size:(self.rank + 1) * chunk_size].clone())\n\n        if bias:\n            self.bias = nn.Parameter(torch.zeros(chunk_size))\n        else:\n            self.bias = None\n\n    def forward(self, x):\n        # x @ local_weight.T gives partial output\n        output = F.linear(x, self.weight, self.bias)\n\n        # All-gather outputs from all ranks and concatenate along last dim\n        if self.world_size > 1:\n            gathered = [torch.zeros_like(output) for _ in range(self.world_size)]\n            dist.all_gather(gathered, output)\n            output = torch.cat(gathered, dim=-1)\n        return output\n\n\nclass RowParallelLinear(nn.Module):\n    def __init__(self, in_features, out_features, bias, master_weight):\n        super().__init__()\n        self.in_features = in_features\n        self.out_features = out_features\n        self.bias = bias\n        self.world_size = dist.get_world_size()\n        self.rank = dist.get_rank()\n\n        # Split master_weight by rows (along dim=0)\n        chunk_size = master_weight.shape[0] // self.world_size\n        self.weight = nn.Parameter(master_weight[self.rank * chunk_size:(self.rank + 1) * chunk_size, :].clone())\n\n        if bias:\n            self.bias = nn.Parameter(torch.zeros(out_features))\n        else:\n            self.bias = None\n\n    def forward(self, x):\n        # x @ local_weight.T gives partial output\n        output = F.linear(x, self.weight, self.bias)\n\n        # All-reduce: sum partial outputs across ranks\n        if self.world_size > 1:\n            dist.all_reduce(output, op=dist.ReduceOp.SUM)\n        return output\nEOF"})
