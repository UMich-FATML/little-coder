hard_path, files[file_idx])\n                shutil.copy2(src_file, dst_file)\n                files_in_shard += 1\n            else:\n                # File exceeds 15MB - split it into chunks\n                # Each chunk file gets a suffix to distinguish them\n                chunk_idx = 0\n                with open(src_file, \'r\', encoding=\'utf-8\') as f:\n                    while True:\n                        chunk_name = f"{files[file_idx]}.part_{chunk_idx:05d}"\n                        chunk_path = os.path.join(shard_path, chunk_name)\n                        with open(chunk_path, \'w\', encoding=\'utf-8\') as out_f:\n                            written = 0\n                            while written < MAX_FILE_SIZE:\n                                line = f.readline()\n                                if not line:\n                                    break\n                                out_f.write(line)\n                                written += len(line.encode(\'utf-8\'))\n\n                        chunk_size = os.path.getsize(chunk_path)\n                        if chunk_size > MAX_FILE_SIZE:\n                            # Last line pushed us over; remove it and retry\n                            os.remove(chunk_path)\n                            with open(chunk_path, \'w\', encoding=\'utf-8\') as out_f:\n                                pass  # empty, will retry\n                            # Actually, let\'s handle this differently\n                            # Read all lines, split by size\n                            pass\n\n                        chunk_idx += 1\n                        files_in_shard += 1\n\n                        if written == 0:\n                            # No more data\n                            break\n\n            file_idx += 1\n\n        shard_idx += 1\n\n    print(f"Resharded {total} files into {shard_idx} shards in {output_dir}")\n\n\nif __name__ == "__main__":\n    if len(sys.argv) != 3:\n        print("Usage: python compress.py <input_dir> <output_dir>")\n        sys.exit(1)\n\n    input_dir = sys.argv[1]\n    output_dir = sys.argv[2]\n\n    if not os.path.isdir(input_dir):\n        print(f"Error: {input_dir} is not a directory")\n        sys.exit(1)\n\n    compress(input_dir, output_dir)\nPYEOF'})
