>> ShellSession({'command': 'cat > /app/extract.js << \'JSEOF\'\nconst fs = require(\'fs\');\n\nconst args = process.argv.slice(2);\nif (args.length < 1) {\n  console.error(\'Usage: node extract.js <binary>\');\n  process.exit(1);\n}\n\nconst buf = fs.readFileSync(args[0]);\n\n// Parse ELF header\nconst is64 = buf[4] === 2; // ELFCLASS64\nconst isLE = buf[5] === 1; // ELFDATA2LSB\n\nif (!is64 || !isLE) {\n  console.error(\'Only 64-bit little-endian ELF supported\');\n  process.exit(1);\n}\n\n// ELF header fields (64-bit)\nconst e_phoff = buf.readBigUInt64LE(32);\nconst e_shoff = buf.readBigUInt64LE(40);\nconst e_phentsize = buf.readUInt16LE(54);\nconst e_phnum = buf.readUInt16LE(56);\nconst e_shentsize = buf.readUInt16LE(58);\nconst e_shnum = buf.readUInt16LE(60);\nconst e_shstrndx = buf.readUInt16LE(62);\n\n// Parse program headers to find loadable segments\nconst segments = [];\nfor (let i = 0; i < e_phnum; i++) {\n  const off = Number(e_phoff) + i * e_phentsize;\n  const p_type = buf.readUInt32LE(off);\n  const p_flags = buf.readUInt32LE(off + 4);\n  const p_offset = buf.readBigUInt64LE(off + 8);\n  const p_vaddr = buf.readBigUInt64LE(off + 16);\n  const p_paddr = buf.readBigUInt64LE(off + 24);\n  const p_filesz = buf.readBigUInt64LE(off + 32);\n  const p_memsz = buf.readBigUInt64LE(off + 40);\n  const p_align = buf.readBigUInt64LE(off + 48);\n\n  // PT_LOAD = 1\n  if (p_type === 1) {\n    segments.push({\n      vaddr: p_vaddr,\n      filesz: p_filesz,\n      memsz: p_memsz,\n      offset: p_offset,\n      flags: p_flags\n    });\n  }\n}\n\n// Collect all memory addresses and their values\nconst memory = {};\n\nfor (const seg of segments) {\n  const startAddr = seg.vaddr;\n  const fileSize = Number(seg.filesz);\n  const memSize = Number(seg.memsz);\n  const fileOffset = Number(seg.offset);\n  \n  // Read file contents for this segment\n  const fileData = buf.slice(fileOffset, fileOffset + fileSize);\n  \n  // Map file bytes to memory addresses\n  for (let i = 0; i < fileSize; i += 4) {\n    const addr = startAddr + BigInt(i);\n    const addrStr = addr.toString();\n    const val = fileData.readUInt32LE(i);\n    memory[addrStr] = val;\n  }\n  \n  // For memsz > filesz, the rest is zero-initialized (BSS)\n  // We still need to include zero pages if they\'re in the range\n  for (let i = fileSize; i < memSize; i += 4) {\n    const addr = startAddr + BigInt(i);\n    const addrStr = addr.toString();\n    memory[addrStr] = 0;\n  }\n}\n\n// Output as JSON\nconsole.log(JSON.stringify(memory));\nJSEOF\necho "Script created"'})
