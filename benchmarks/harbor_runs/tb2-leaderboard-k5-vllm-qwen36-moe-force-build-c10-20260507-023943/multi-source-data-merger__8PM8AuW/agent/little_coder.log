>> ShellSession({'command': 'cat > /app/merge.py << \'PYEOF\'\nimport json\nimport pandas as pd\nimport numpy as np\n\n# --- Parse Source A (JSON) ---\nwith open(\'/data/source_a/users.json\', \'r\') as f:\n    source_a_raw = json.load(f)\n\nsource_a = pd.DataFrame(source_a_raw)\nsource_a = source_a.rename(columns={\n    \'id\': \'user_id\',\n    \'full_name\': \'name\',\n    \'email\': \'email\',\n    \'registration_date\': \'created_date\',\n    \'status\': \'status\'\n})\nsource_a[\'source\'] = \'source_a\'\nsource_a[\'user_id\'] = source_a[\'user_id\'].astype(int)\n\n# --- Parse Source B (CSV) ---\nsource_b = pd.read_csv(\'/data/source_b/users.csv\')\nsource_b = source_b.rename(columns={\n    \'user_id\': \'user_id\',\n    \'name\': \'name\',\n    \'email_address\': \'email\',\n    \'created_at\': \'created_date\',\n    \'is_active\': \'status\'\n})\nsource_b[\'source\'] = \'source_b\'\nsource_b[\'user_id\'] = source_b[\'user_id\'].astype(int)\n# Normalize status values\nsource_b[\'status\'] = source_b[\'status\'].map({True: \'active\', False: \'inactive\', \'true\': \'active\', \'false\': \'inactive\'})\n\n# --- Parse Source C (Parquet) ---\nsource_c = pd.read_parquet(\'/data/source_c/users.parquet\')\nsource_c = source_c.rename(columns={\n    \'userId\': \'user_id\',\n    \'userName\': \'name\',\n    \'email\': \'email\',\n    \'joined\': \'created_date\',\n    \'active\': \'status\'\n})\nsource_c[\'source\'] = \'source_c\'\nsource_c[\'user_id\'] = source_c[\'user_id\'].astype(int)\n# Normalize status values\nsource_c[\'status\'] = source_c[\'status\'].map({True: \'active\', False: \'inactive\'})\n\n# --- Collect all unique user_ids ---\nall_user_ids = sorted(set(source_a[\'user_id\']) | set(source_b[\'user_id\']) | set(source_c[\'user_id\']))\n\n# --- Merge and detect conflicts ---\nfields = [\'name\', \'email\', \'created_date\', \'status\']\nconflicts = []\nmerged_rows = []\n\nfor uid in all_user_ids:\n    row = {\'user_id\': uid}\n    \n    # Get records from each source for this user\n    rec_a = source_a[source_a[\'user_id\'] == uid]\n    rec_b = source_b[source_b[\'user_id\'] == uid]\n    rec_c = source_c[source_c[\'user_id\'] == uid]\n    \n    vals = {}\n    for field in fields:\n        va = rec_a[field].iloc[0] if not rec_a.empty else None\n        vb = rec_b[field].iloc[0] if not rec_b.empty else None\n        vc = rec_c[field].iloc[0] if not rec_c.empty else None\n        vals[field] = {\'source_a\': va, \'source_b\': vb, \'source_c\': vc}\n    \n    # Check for conflicts and select values by priority\n    for field in fields:\n        v = vals[field]\n        # Pick highest priority non-null value\n        selected = None\n        for src in [\'source_a\', \'source_b\', \'source_c\']:\n            if v[src] is not None:\n                selected = v[src]\n                break\n        \n        # Check if there\'s a conflict (different non-null values across sources)\n        non_null_values = set()\n        for src in [\'source_a\', \'source_b\', \'source_c\']:\n            if v[src] is not None:\n                non_null_values.add(str(v[src]))\n        \n        if len(non_null_values) > 1:\n            conflicts.append({\n                \'user_id\': uid,\n                \'field\': field,\n                \'values\': {\n                    \'source_a\': v[\'source_a\'] if v[\'source_a\'] is not None else None,\n                    \'source_b\': v[\'source_b\'] if v[\'source_b\'] is not None else None,\n                    \'source_c\': v[\'source_c\'] if v[\'source_c\'] is not None else None\n                },\n                \'selected\': selected\n            })\n        \n        row[field] = selected\n    \n    merged_rows.append(row)\n\n# --- Build output DataFrame ---\nmerged_df = pd.DataFrame(merged_rows)\nmerged_df[\'user_id\'] = merged_df[\'user_id\'].astype(int)\nmerged_df[\'name\'] = merged_df[\'name\'].astype(str)\nmerged_df[\'email\'] = merged_df[\'email\'].astype(str)\nmerged_df[\'created_date\'] = merged_df[\'created_date\'].astype(str)\nmerged_df[\'status\'] = merged_df[\'status\'].astype(str)\n\n# --- Write output files ---\nmerged_df.to_parquet(\'/app/merged_users.parquet\', index=False)\n\nconflict_report = {\n    \'total_conflicts\': len(conflicts),\n    \'conflicts\': conflicts\n}\n\nwith open(\'/app/conflicts.json\', \'w\') as f:\n    json.dump(conflict_report, f, indent=2)\n\nprint("=== Merged Data ===")\nprint(merged_df.to_string())\nprint()\nprint(f"Total conflicts: {len(conflicts)}")\nprint()\nprint("=== Conflicts ===")\nfor c in conflicts:\n    print(c)\nPYEOF\npython3 /app/merge.py'})
