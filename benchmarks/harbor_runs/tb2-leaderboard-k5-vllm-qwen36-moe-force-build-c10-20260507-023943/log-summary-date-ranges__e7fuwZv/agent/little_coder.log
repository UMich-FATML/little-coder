>> ShellSession({'command': 'cat > /app/analyze.py << \'PYEOF\'\nimport os\nimport re\nfrom datetime import datetime, timedelta\n\nREF_DATE = datetime(2025, 8, 12)\nLOGS_DIR = "/app/logs"\n\n# Date ranges\ntoday = REF_DATE\nlast_7_start = REF_DATE - timedelta(days=6)  # 7 days including today\nlast_30_start = REF_DATE - timedelta(days=29)  # 30 days including today\nmonth_start = datetime(REF_DATE.year, REF_DATE.month, 1)\n\n# Pattern to extract date from filename\nfilename_pattern = re.compile(r\'^(\\d{4}-\\d{2}-\\d{2})_\')\n\n# Pattern to extract severity from log line\nseverity_pattern = re.compile(r\'\\[(ERROR|WARNING|INFO)\\]\')\n\ndef count_severities_in_file(filepath, date_str):\n    counts = {"ERROR": 0, "WARNING": 0, "INFO": 0}\n    file_date = datetime.strptime(date_str, "%Y-%m-%d")\n    with open(filepath, \'r\') as f:\n        for line in f:\n            m = severity_pattern.search(line)\n            if m:\n                sev = m.group(1)\n                counts[sev] += 1\n    return counts, file_date\n\n# Collect all files with their dates\nfiles_by_date = {}\nfor fname in os.listdir(LOGS_DIR):\n    m = filename_pattern.match(fname)\n    if m:\n        date_str = m.group(1)\n        if date_str not in files_by_date:\n            files_by_date[date_str] = []\n        files_by_date[date_str].append(fname)\n\n# Initialize counters\nresults = {\n    "today": {"ERROR": 0, "WARNING": 0, "INFO": 0},\n    "last_7_days": {"ERROR": 0, "WARNING": 0, "INFO": 0},\n    "last_30_days": {"ERROR": 0, "WARNING": 0, "INFO": 0},\n    "month_to_date": {"ERROR": 0, "WARNING": 0, "INFO": 0},\n    "total": {"ERROR": 0, "WARNING": 0, "INFO": 0},\n}\n\nfor date_str, fnames in files_by_date.items():\n    file_date = datetime.strptime(date_str, "%Y-%m-%d")\n    for fname in fnames:\n        filepath = os.path.join(LOGS_DIR, fname)\n        counts, _ = count_severities_in_file(filepath, date_str)\n        \n        # Total\n        for sev in counts:\n            results["total"][sev] += counts[sev]\n        \n        # Today\n        if file_date == today:\n            for sev in counts:\n                results["today"][sev] += counts[sev]\n        \n        # Last 7 days\n        if last_7_start <= file_date <= today:\n            for sev in counts:\n                results["last_7_days"][sev] += counts[sev]\n        \n        # Last 30 days\n        if last_30_start <= file_date <= today:\n            for sev in counts:\n                results["last_30_days"][sev] += counts[sev]\n        \n        # Month to date\n        if month_start <= file_date <= today:\n            for sev in counts:\n                results["month_to_date"][sev] += counts[sev]\n\n# Write CSV\nwith open("/app/summary.csv", "w") as f:\n    f.write("period,severity,count\\n")\n    for period in ["today", "last_7_days", "last_30_days", "month_to_date", "total"]:\n        for sev in ["ERROR", "WARNING", "INFO"]:\n            f.write(f"{period},{sev},{results[period][sev]}\\n")\n\nprint("Done. CSV written to /app/summary.csv")\nPYEOF\npython3 /app/analyze.py'})
